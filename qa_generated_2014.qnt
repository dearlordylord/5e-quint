  // Source: https://rpg.stackexchange.com/q/120280
  
  // Can I ready an action to attack using Spiritual Weapon? (No — bonus actions can't be readied)
  run qa_ready_cannot_trigger_bonus_action = {
    // Ready action expends the action and sets readiedAction, but leaves bonusActionUsed
    // untouched. A bonus action (e.g. Spiritual Weapon attack) is not consumed and
    // cannot be the readied trigger — bonus actions are only usable on your own turn.
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, creature, AReady)
    assert(
      t1.actionUsed      == true  and  // action spent on Ready
      t1.readiedAction   == true  and  // ready flag set
      t1.bonusActionUsed == false      // bonus action untouched; cannot be readied
    )
  }

  // Source: https://rpg.stackexchange.com/q/138361
  
  // Can a spell scroll be upcast using a higher-level spell slot?
  run qa_scroll_cast_no_slot_expended = {
      // Caster has 2 level-1 slots and 1 level-2 slot available
      val slots = FRESH_SPELL_SLOTS
          .with("slotsMax", EMPTY_SLOTS.set(1, 2).set(2, 1))
          .with("slotsCurrent", EMPTY_SLOTS.set(1, 2).set(2, 1))
      // DMG p.141: spells from magic items cast at lowest possible level, no slot expended
      // Scroll of Magic Missile (spell level 1): pExpendSlot is NOT called at any level
      val afterScrollCast = slots
      // A normal level-2 upcast from memory WOULD consume the level-2 slot
      val afterNormalUpcast = pExpendSlot(slots, 2)
      assert(
          // Scroll leaves all slots intact — no slot consumed at any level
          afterScrollCast.slotsCurrent.get(1) == 2 and
          afterScrollCast.slotsCurrent.get(2) == 1 and
          // Normal upcast consumed the level-2 slot
          afterNormalUpcast.slotsCurrent.get(2) == 0 and
          // Scroll cast is strictly distinct from an upcast: level-2 slot untouched
          afterScrollCast.slotsCurrent.get(2) != afterNormalUpcast.slotsCurrent.get(2)
      )
  }

  // Source: https://rpg.stackexchange.com/q/216873
  
  // Can a Pact of the Chain Imp familiar use its Shapechanger on its own?
  // Accepted answer: yes; Shapechanger modifies movement speeds only, all other stats unchanged.
  run qa_imp_shapechanger_speed_not_stats = {
    // Imp familiar: 21 HP, unharmed, no conditions
    val impHp = 21
    val impState = freshCreature(impHp)
    // Imp turn: walk speed 20ft (per Imp stat block), action available
    val impTurn: TurnState = {
      movementRemaining: 20,
      effectiveSpeed: 20,
      actionUsed: false,
      attackActionUsed: false,
      bonusActionUsed: false,
      reactionAvailable: true,
      freeInteractionUsed: false,
      extraAttacksRemaining: 0,
      disengaged: false,
      dodging: false,
      readiedAction: false,
      bonusActionSpellCast: false,
      nonCantripActionSpellCast: false,
      surprised: false,
    }
    // Imp uses its action for Shapechanger (modeled as AUseObject — a creature ability action)
    val afterAction = pUseAction(impTurn, impState, AUseObject)
    // Shapechanger → raven form: fly 60 ft; 0 ft moved before shapchanging this turn
    val afterShapechange = pSwitchSpeedType(afterAction, 60, 0)
    // Key assertions:
    // (1) Action was consumed
    // (2) Fly speed (60ft) is now available — movement type switched
    // (3) Creature stat block (HP, conditions) is entirely unchanged
    assert(
      afterShapechange.actionUsed == true
      and afterShapechange.effectiveSpeed == 60
      and afterShapechange.movementRemaining == 60
      and impState.hp == impHp
      and not(impState.prone)
      and not(impState.blinded)
      and not(impState.paralyzed)
      and not(impState.poisoned)
      and impState.dead == false
    )
  }

  // Source: https://rpg.stackexchange.com/q/184149
  
  // Thief of Five Fates: without warlock pact slots, the invocation cannot be used (useless for non-warlocks)
  run qa_thief_of_five_fates_no_pact_slots_cannot_cast = {
    // Non-warlock: no pact slots at all
    val ss = FRESH_SPELL_SLOTS
    // pCanCastWithPactSlot requires pactSlotsCurrent > 0 AND pactSlotLevel >= spellLevel
    // Bane is a 1st-level spell; neither condition is met
    assert(not(pCanCastWithPactSlot(ss, 1)))
  }
  
  // Thief of Five Fates: regular spell slots do NOT substitute for warlock spell slots
  run qa_thief_of_five_fates_regular_slots_dont_substitute = {
    // Character has a full complement of regular level-1 slots but zero pact slots
    val regularSlots = EMPTY_SLOTS.set(1, 4)
    val ss = FRESH_SPELL_SLOTS
                .with("slotsMax", regularSlots)
                .with("slotsCurrent", regularSlots)
    // Must still fail: pCanCastWithPactSlot only checks pactSlotsCurrent, not slotsCurrent
    assert(not(pCanCastWithPactSlot(ss, 1)))
  }
  
  // Thief of Five Fates: pExpendPactSlot is a no-op when no pact slots exist
  run qa_thief_of_five_fates_expend_pact_noop = {
    val ss = FRESH_SPELL_SLOTS  // pactSlotsCurrent = 0
    val ss1 = pExpendPactSlot(ss)
    assert(ss1 == ss)
  }
  
  // Thief of Five Fates: a warlock with pact slots CAN use the invocation (control case)
  run qa_thief_of_five_fates_warlock_has_slot_can_cast = {
    // Warlock with one pact slot at level 2 (>= bane's required level 1)
    val ss = FRESH_SPELL_SLOTS
                .with("pactSlotsMax", 1)
                .with("pactSlotsCurrent", 1)
                .with("pactSlotLevel", 2)
    assert(pCanCastWithPactSlot(ss, 1))
  }
  
  // Thief of Five Fates: after a warlock expends their only pact slot, the invocation becomes unusable
  run qa_thief_of_five_fates_slot_exhausted_after_use = {
    val ss = FRESH_SPELL_SLOTS
                .with("pactSlotsMax", 1)
                .with("pactSlotsCurrent", 1)
                .with("pactSlotLevel", 1)
    val ssAfter = pExpendPactSlot(ss)
    // Slot was consumed; can no longer cast until a short/long rest
    assert(not(pCanCastWithPactSlot(ssAfter, 1)))
  }
  
  // Thief of Five Fates: short rest restores pact slots, making the invocation available again
  run qa_thief_of_five_fates_short_rest_restores_pact_slot = {
    val ss = FRESH_SPELL_SLOTS
                .with("pactSlotsMax", 1)
                .with("pactSlotsCurrent", 0)
                .with("pactSlotLevel", 1)
    val ssRestored = pRestorePactSlots(ss)
    assert(pCanCastWithPactSlot(ssRestored, 1))
  }

  // Source: https://rpg.stackexchange.com/q/201921
  
  // Can Pact of the Chain Warlocks forgo one of their attacks to not break Invisibility?
  run qa_attack_action_does_not_break_invisibility = {
    // Invisibility ends when a target *attacks*, not when they take the Attack action.
    // Taking AAttack (then forgoing the attack) must not remove CInvisible from the creature.
    val invisibleCreature = freshCreature(20).with("invisible", true)
    val t0 = FRESH_TURN
    // Warlock takes the Attack action but foregos their own attack (e.g. grants familiar)
    val t1 = pUseAction(t0, invisibleCreature, AAttack)
    assert(
      // Attack action was consumed ...
      t1.attackActionUsed
      // ... but the creature's invisible flag is untouched — no attack was made
      and invisibleCreature.invisible
    )
  }

  // Source: https://rpg.stackexchange.com/q/213219
  
  // Could I expend all my spell slots to explode? — No such rule exists in 5e PHB
  // SKIP: The accepted answer is purely negative (no mechanics exist for slot-powered self-destruction); the spec has no self-destruct or "expend all slots for AoE damage" function to assert against.

  // Source: https://rpg.stackexchange.com/q/192434
  
  // Thunder Gauntlets: no Light property blocks TWF by default (Armorer Artificer attack rules)
  run qa_thunder_gauntlets_no_twf_without_light_property = {
    val thunderGauntlet: Weapon = {
      name: "thunder_gauntlet",
      damageDie: 8,
      versatileDie: 0,
      damageType: Thunder,
      properties: Set(),   // simple melee, no Light_
      isMelee: true,
      normalRange: 0,
      longRange: 0,
    }
    // attack action already taken this turn, bonus action still available
    val t = FRESH_TURN.with("attackActionUsed", true)
    val creature = freshCreature(30)
    assert(not(pCanTWFWithWeapons(thunderGauntlet, thunderGauntlet, t, creature)))
  }
  
  // Level 5 Artificer (Extra Attack feature) gets 1 extra attack on the Attack action
  run qa_thunder_gauntlets_level5_extra_attack = {
    val creature = freshCreature(30)
    // TEST_CONFIG is level 5 with FExtraAttack — matches Artificer 5
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    assert(t.extraAttacksRemaining == 1)
  }
  
  // Thunder Gauntlets WITH Light_ property (simulating Dual Wielder feat override) enables TWF
  run qa_thunder_gauntlets_twf_enabled_with_light = {
    val lightGauntlet: Weapon = {
      name: "thunder_gauntlet_light",
      damageDie: 8,
      versatileDie: 0,
      damageType: Thunder,
      properties: Set(Light_),   // Dual Wielder feat effectively grants this path
      isMelee: true,
      normalRange: 0,
      longRange: 0,
    }
    val t = FRESH_TURN.with("attackActionUsed", true)
    val creature = freshCreature(30)
    assert(pCanTWFWithWeapons(lightGauntlet, lightGauntlet, t, creature))
  }
  
  // Off-hand gauntlet hit via TWF: no ability modifier added to damage (unless negative)
  run qa_thunder_gauntlets_twf_offhand_no_ability_mod = {
    // positive STR mod: not added to off-hand damage
    val diceResult = 6   // rolled 6 on d8
    val strMod = 3
    assert(pTWFOffHandDamage(diceResult, strMod) == 6)
  }
  
  // Off-hand gauntlet hit via TWF: negative ability modifier IS subtracted
  run qa_thunder_gauntlets_twf_offhand_negative_mod_applied = {
    val diceResult = 4
    val strMod = -1   // negative penalty applies
    assert(pTWFOffHandDamage(diceResult, strMod) == 3)
  }

  // Source: https://rpg.stackexchange.com/q/171632
  
  // How exactly does a Changeling's shapeshifting work?
  run qa_changeling_medium_size_capacity_unchanged = {
    // Trait: "adjust height and weight, but not so much that your size changes"
    // + "none of your game statistics change" → STR and size category stay Medium
    // A changeling with STR 12 has 180lb carrying capacity in any medium form (dwarf or goliath)
    val strScore = 12
    assert(
      carryingCapacity(strScore, Medium) == 180
      // Going Large would double capacity — demonstrating why the size constraint matters
      and carryingCapacity(strScore, Large) == 360
      and carryingCapacity(strScore, Medium) != carryingCapacity(strScore, Large)
    )
  }
  
  // How exactly does a Changeling's shapeshifting work?
  run qa_changeling_speed_stat_unchanged_by_form = {
    // "none of your game statistics change" — speed lives in CharConfig, not in apparent form
    // A changeling's 30ft walk speed is identical whether appearing as a dwarf or a goliath
    val creature = freshCreature(20)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    assert(t.movementRemaining == 30 and t.effectiveSpeed == 30)
  }
  
  // How exactly does a Changeling's shapeshifting work?
  run qa_changeling_push_drag_lift_medium_unchanged = {
    // Push/drag/lift = 2× carrying capacity; also unchanged because STR and size stay Medium
    // The "muscle-bound goliath" appearance grants no extra lift over the "petite dwarf" appearance
    val strScore = 12
    assert(
      pushDragLift(strScore, Medium) == 360
      and pushDragLift(strScore, Medium) == carryingCapacity(strScore, Medium) * 2
    )
  }

  // Source: https://rpg.stackexchange.com/q/59789
  
  // After level 20 I can still take new feats? — 5e level cap is 20; XP table never returns level > 20
  run qa_level_caps_at_20 = {
      assert(
          pLevelForXp(355000) == 20
          and pLevelForXp(385000) == 20
          and pLevelForXp(999999) == 20
      )
  }
  
  // After level 20 I can still take new feats? — no ASI/feat slots exist at levels 21+
  run qa_no_asi_levels_past_20 = {
      assert(
          not(pIsASILevel(21))
          and not(pIsASILevel(24))
          and not(pIsASILevel(28))
          and not(pIsASILevel(32))
      )
  }

  // Source: https://rpg.stackexchange.com/q/80271
  
  // Does a wizard need to hold a component pouch or focus in one hand in order for it to work?
  run qa_same_hand_somatic_and_material = {
    val creature = freshCreature(20)
    // PHB: must have a hand free to access material components or hold a focus,
    // but it CAN be the same hand used to perform somatic components.
    // Spec encodes this with a single hasFreeHand parameter covering both S and M:
    // one free hand is sufficient even when a spell requires both S and M.
    val canCastSM_oneFreeHand = pCanProvideComponents(creature, false, true, true)
    // Without any free hand, somatic (and material access) both fail.
    val cannotCast_noFreeHand = not(pCanProvideComponents(creature, false, true, false))
    assert(canCastSM_oneFreeHand and cannotCast_noFreeHand)
  }

  // Source: https://rpg.stackexchange.com/q/191742
  
  // Do you gain the benefit of the rogue's Reliable Talent feature if the roll is replaced with Portent?
  // Portent replaces only the d20 roll; Reliable Talent still treats that replaced roll of ≤9 as 10.
  run qa_reliable_talent_applies_to_portent_roll = {
    // Setup: proficient ability check, level 5 rogue (profBonus +3), ability mod +3, DC 15
    val portentRoll = 5          // Portent die came up 5
    val abilityMod = 3
    val profBonus = proficiencyBonus(5)  // (5-1)/4 + 2 = 3
    val dc = 15
  
    // Reliable Talent: treat d20 roll of 9 or lower as 10
    val reliableTalentEffectiveRoll = intMax(portentRoll, 10)
  
    // With Reliable Talent: 10 + 3 + 3 = 16 >= 15 → success
    val withReliableTalent = checkSucceeds(reliableTalentEffectiveRoll, abilityMod, Proficient, profBonus, 0, dc)
  
    // Without Reliable Talent: 5 + 3 + 3 = 11 < 15 → failure
    val withoutReliableTalent = checkSucceeds(portentRoll, abilityMod, Proficient, profBonus, 0, dc)
  
    assert(
      // Portent die of 5 is clamped to 10 by Reliable Talent
      reliableTalentEffectiveRoll == 10
      // Applying Reliable Talent to the Portent roll turns a failure into a success
      and withReliableTalent
      and not(withoutReliableTalent)
      // The clamped Portent roll is equivalent to a natural roll of 10
      and withReliableTalent == checkSucceeds(10, abilityMod, Proficient, profBonus, 0, dc)
    )
  }

  // Source: https://rpg.stackexchange.com/q/164146
  
  // How do Plant Growth and Slow interact with each other?
  run qa_slow_plus_plant_growth_stacks = {
      // Slow halves speed (30 -> 15); Plant Growth costs 4 feet of movement per 1 foot traveled.
      // Combined: creature can move at most 3 feet (15 / 4 = 3), i.e. 1 foot per 8 feet of normal speed.
      val normalSpeed = 30
      val slowedSpeed = normalSpeed / 2       // Slow: speed halved -> 15
      val plantGrowthCost = 4                 // Plant Growth: 4 ft movement per 1 ft moved
  
      val slowedTurn = FRESH_TURN
          .with("movementRemaining", slowedSpeed)
          .with("effectiveSpeed",    slowedSpeed)
  
      // Moving 3 feet costs 3 * 4 = 12 out of 15 -> succeeds
      val afterMove3 = pUseMovement(slowedTurn, 3, plantGrowthCost)
      // Moving 4 feet would cost 4 * 4 = 16 > 15 -> no-op (insufficient movement)
      val afterMove4 = pUseMovement(slowedTurn, 4, plantGrowthCost)
  
      assert(
          // 3-foot move succeeds: 15 - 12 = 3 remaining
          afterMove3.movementRemaining == slowedSpeed - 3 * plantGrowthCost
          // 4-foot move is blocked (no-op)
          and afterMove4.movementRemaining == slowedSpeed
          // After moving 3 feet, remaining (3) is less than one more foot's cost (4) —
          // confirming the creature effectively moves 1 ft per 8 ft of base speed
          and afterMove3.movementRemaining < plantGrowthCost
      )
  }

  // Source: https://rpg.stackexchange.com/q/162750
  
  // SKIP: Spec has no Sneak Attack mechanic and no creature-vs-object target distinction; the rule cannot be encoded with existing functions.

  // How to swap a class level for another class — no RAW swap mechanism; PHB Ch6 multiclassing only adds new class levels, prereqs still apply
  run qa_no_class_level_swap = {
    // PHB Ch6: there is no mechanism to replace already-taken class levels.
    // The only RAW option is to ADD Paladin as a third class, which requires
    // meeting both Sorcerer (CHA >= 13) and Paladin (STR >= 13 AND CHA >= 13) prereqs.
    // A typical CHA-focused Sorcerer/Bard with low STR fails Paladin's prereq entirely.
    val sorc_bard_low_str  = Map(Str -> 10, Dex -> 12, Con -> 12, Int_ -> 10, Wis -> 8, Cha -> 16)
    val sorc_bard_meet_str = Map(Str -> 13, Dex -> 12, Con -> 12, Int_ -> 10, Wis -> 8, Cha -> 16)
    assert(
      not(pCanMulticlass(sorc_bard_low_str,  Sorcerer, Paladin)) and
          pCanMulticlass(sorc_bard_meet_str, Sorcerer, Paladin)
    )
  }

  // Source: https://rpg.stackexchange.com/q/177781
  
  // Can a player controlling an NPC use its Legendary Actions?
  // Accepted answer: Charmed (Dominate Monster) does NOT incapacitate the creature;
  // it retains full action capability — a prerequisite for legendary action access under total control.
  run qa_charmed_not_incapacitated = {
    val creature = freshCreature(50)
    val charmed = pApplyCondition(creature, CCharmed)
    assert(
      charmed.charmed == true
      and not(isIncapacitated(charmed))
      and pCanAct(charmed)
      and charmed.incapacitatedSources.size() == 0
    )
  }

  // Source: https://rpg.stackexchange.com/q/126040
  
  // Can a warlock with Devil's Sight see through Fog Cloud?
  run qa_devils_sight_fog_cloud = {
    // Devil's Sight is modeled as darkvision: pEffectiveObscurement(Dark, true).
    // Fog Cloud is HeavilyObscured independent of light level — it is fog, not darkness.
    // pEffectiveObscurement only reduces darkness-based obscurement; fog is not darkness.
    val devilsSightInDarkness = pEffectiveObscurement(Dark, true)
    // Fog Cloud imposes HeavilyObscured regardless of underlying light or darkvision.
    // Even in a Bright-lit room, Fog Cloud = HeavilyObscured; darkvision does not apply.
    val devilsSightInBrightFog = pEffectiveObscurement(Bright, true)
    val fogCloudObscurement = HeavilyObscured
    assert(
      // Devil's Sight (darkvision) works in darkness → LightlyObscured → NOT blinded
      not(pBlindedByObscurement(devilsSightInDarkness))
      // Fog Cloud (HeavilyObscured, not derived from darkness) still blinds the warlock
      and pBlindedByObscurement(fogCloudObscurement)
      // Darkvision on a bright-lit foggy area also gives no additional benefit — already Unobscured by light,
      // but the fog's HeavilyObscured is orthogonal and persists
      and not(pBlindedByObscurement(devilsSightInBrightFog))
      and fogCloudObscurement == HeavilyObscured
    )
  }

  // Source: https://rpg.stackexchange.com/q/176881
  
  // Would a Sentient weapon be able to save versus spells cast against it?
  run qa_sentient_weapon_save_succeeds_vs_spell_with_save = {
    // Sentient weapon: WIS 14 (mod +2), no class proficiency (it's an object)
    // Spell targets objects and lists a WIS save DC 13; roll 11 → 11+2=13 >= 13 → save succeeds
    val wisMod = abilityModifier(14)
    assert(saveSucceeds(11, wisMod, false, 0, 0, 13))
  }
  
  // Would a Sentient weapon be able to save versus spells cast against it?
  run qa_sentient_weapon_save_fails_vs_spell_with_save = {
    // Same weapon (WIS 14, mod +2); roll 10 → 10+2=12 < 13 → save fails → spell takes effect
    val wisMod = abilityModifier(14)
    assert(not(saveSucceeds(10, wisMod, false, 0, 0, 13)))
  }
  
  // Would a Sentient weapon be able to save versus spells cast against it? (Identify: no save listed)
  run qa_sentient_weapon_identify_no_save = {
    // Identify lists no saving throw; the sentient weapon has no mechanical recourse
    // Even INT 18 (mod +4) is irrelevant — caller never invokes saveSucceeds when spell lists no DC
    // Verify the ability modifier is correctly computed (weapon has real scores; they're just moot here)
    val intMod = abilityModifier(18)
    assert(intMod == 4)
  }

  // Source: https://rpg.stackexchange.com/q/176756
  
  // Does a Tortle's Natural Armor interfere with the Monk's Unarmored Movement ability?
  run qa_tortle_natural_armor_unarmored_movement = {
    val creature = freshCreature(20)
    // Natural armor is not "wearing armor" → ArmorState is Unarmored
    // → Unarmored Movement bonus (+10 ft at level 2) applies; caller passes callerSpeedModifier = 10
    val turnNaturalArmor = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 10, false, false)
    // Wearing actual armor → Unarmored Movement does NOT apply; callerSpeedModifier = 0
    val turnWornArmor = pStartTurn(TEST_CONFIG, creature, WearingArmor(LEATHER), false, 0, false, false)
    assert(
      // Tortle monk with natural armor gets the +10 Unarmored Movement: 30 + 10 = 40
      turnNaturalArmor.movementRemaining == 40
      // Monk wearing actual leather armor loses the bonus: 30 + 0 = 30
      and turnWornArmor.movementRemaining == 30
    )
  }

  // Source: https://rpg.stackexchange.com/q/106953
  
  // Does damage from Armor of Agathys take place before or after a character takes damage from an attack that hits?
  run qa_aoa_triggers_before_attack_damage = {
    // Armor of Agathys: creature has 10 temp HP, 10 max HP.
    // Hit is determined first (tempHp > 0 at that moment → AoA retaliatory damage fires),
    // then the 11 melee damage is applied.
    val creature = freshCreature(10).with("tempHp", 10)
    // Snapshot at hit-determination step: temp HP still present → AoA triggers
    val aoaTriggersAtHit = creature.tempHp > 0
    // Now apply the attacker's 11 damage
    val afterDamage = pTakeDamage(creature, 11, Slashing, Set(), Set(), Set(), false)
    assert(
      aoaTriggersAtHit       and   // AoA retaliatory damage fires: tempHp > 0 when hit was confirmed
      afterDamage.tempHp == 0 and  // all 10 temp HP consumed
      afterDamage.hp == 9    and   // 1 bleed-through damage (11 - 10 = 1)
      not(afterDamage.unconscious) // creature survives
    )
  }

  // Source: https://rpg.stackexchange.com/q/99704
  
  // Is there a limit to the number of Unseen Servants I can have?
  run qa_unseen_servant_no_concentration_limit = {
    // Unseen Servant has no concentration requirement and no explicit "only one" clause.
    // Each casting is independent; the only constraint is available spell slots.
    val level1Slots = EMPTY_SLOTS.set(1, 4)
    val slots0 = {
      slotsMax: level1Slots,
      slotsCurrent: level1Slots,
      pactSlotsMax: 0,
      pactSlotsCurrent: 0,
      pactSlotLevel: 0,
      concentrationSpellId: "",
    }
    // Three castings of Unseen Servant: expend a slot each time, never call pStartConcentration
    val slots1 = pExpendSlot(slots0, 1)
    val slots2 = pExpendSlot(slots1, 1)
    val slots3 = pExpendSlot(slots2, 1)
    assert(
      // No concentration active — all three servants coexist with no mutual exclusion
      not(isConcentrating(slots3))
      // Three slots consumed confirms three independent, simultaneous castings
      and slots3.slotsCurrent.get(1) == 1
    )
  }
  
  // Is there a limit to the number of Unseen Servants I can have? (contrast: concentration spells ARE limited)
  run qa_concentration_spell_limited_to_one = {
    // Spells like Hold Person DO call pStartConcentration — each new casting replaces the old one,
    // enforcing the "only one active effect" constraint that Unseen Servant lacks.
    val level1Slots = EMPTY_SLOTS.set(1, 4)
    val slots0 = {
      slotsMax: level1Slots,
      slotsCurrent: level1Slots,
      pactSlotsMax: 0,
      pactSlotsCurrent: 0,
      pactSlotLevel: 0,
      concentrationSpellId: "",
    }
    // Cast a concentration spell on target A, then on target B
    val slots1 = pExpendSlot(pStartConcentration(slots0, "hold_person_target_A"), 1)
    val slots2 = pExpendSlot(pStartConcentration(slots1, "hold_person_target_B"), 1)
    assert(
      // Second casting overwrote the first — only target B is affected
      slots2.concentrationSpellId == "hold_person_target_B"
      and slots2.slotsCurrent.get(1) == 2
    )
  }

  // Source: https://rpg.stackexchange.com/q/201293
  
  // Can I keep concentration on a spell and an ability that works like concentration?
  run qa_concentration_feature_replaced_by_spell = {
    // Favored Foe uses "as if concentrating on a spell" — occupies the same slot
    val ss0 = FRESH_SPELL_SLOTS
    val ss1 = pStartConcentration(ss0, "favored_foe")
    // Casting hex (a concentration spell) replaces favored_foe concentration
    val ss2 = pStartConcentration(ss1, "hex")
    assert(
      ss1.concentrationSpellId == "favored_foe" and
      ss2.concentrationSpellId == "hex" and
      ss2.concentrationSpellId != "favored_foe"
    )
  }

  // Source: https://rpg.stackexchange.com/q/187928
  
  // Decanter of Endless Water: aiming geyser costs bonus action, not reaction
  run qa_decanter_aim_uses_bonus_not_reaction = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseBonusAction(t0, creature)
    assert(t1.bonusActionUsed == true and t1.reactionAvailable == true)
  }
  
  // Decanter of Endless Water: only one use per turn — second bonus action is blocked
  run qa_decanter_one_use_per_turn = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseBonusAction(t0, creature)
    val t2 = pUseBonusAction(t1, creature)
    // second call is a no-op: state identical to after first use
    assert(t1.bonusActionUsed == true and t2 == t1)
  }
  
  // Decanter of Endless Water: 30 cold damage (30 gallons × 1/5ft susceptibility) applies in full
  run qa_decanter_cold_damage_full = {
    val creature = freshCreature(50)
    val s1 = pTakeDamage(creature, 30, Cold, Set(), Set(), Set(), false)
    assert(s1.hp == 20)
  }

  // Source: https://rpg.stackexchange.com/q/105175
  
  // SKIP: Ring of Spell Storing and Metamagic (Quickened Spell) mechanics are not modeled in the spec; no functions exist for spell storage in items, metamagic application, or bonus-action-vs-action spell origin tracking at the item level.

  // Source: https://rpg.stackexchange.com/q/164051
  
  // Is lighting a Drift Globe a bonus action?
  run qa_drift_globe_command_word_is_free_action = {
    // Speaking a magic item's command word is a free speech action — no action or bonus
    // action is consumed — so the creature retains their full action to attack.
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    // "Activating" the globe via command word is free speech: no spec call,
    // turn state is unchanged. Now use the action for Attack.
    val tAfterAttack = pUseAction(t0, creature, AAttack)
    assert(
      // Before the attack the action economy is fully intact (command word cost nothing)
      t0.actionUsed == false and
      t0.bonusActionUsed == false and
      t0.freeInteractionUsed == false and
      // Attack action is still usable and correctly consumed
      tAfterAttack.actionUsed == true and
      tAfterAttack.attackActionUsed == true and
      // Bonus action was never touched — still free for e.g. off-hand strike
      tAfterAttack.bonusActionUsed == false
    )
  }

  // Source: https://rpg.stackexchange.com/q/211763
  
  // Vecna's Rotten Fate: damage reducing to 0 HP (non-massive) yields unconscious, not instant death
  run qa_rotten_fate_to_zero_hp_yields_unconscious = {
    val creature = freshCreature(20).with("hp", 15)
    // 20 necrotic damage: overflow = 5, maxHp = 20; 5 < 20 → standard unconscious path
    val result = pTakeDamage(creature, 20, Necrotic, Set(), Set(), Set(), false)
    assert(result.hp == 0 and result.unconscious == true and result.dead == false)
  }
  
  // Vecna's Rotten Fate: overflow >= maxHp triggers PHB massive damage instant death (no death saves)
  run qa_rotten_fate_massive_damage_instant_death = {
    val creature = freshCreature(20).with("hp", 15)
    // 80 necrotic damage: overflow = 65, maxHp = 20; 65 >= 20 → instant death, skips unconscious
    val result = pTakeDamage(creature, 80, Necrotic, Set(), Set(), Set(), false)
    assert(result.dead == true and result.hp == 0 and result.unconscious == false)
  }
  
  // Vecna's Rotten Fate: after standard drop to 0 HP, death saving throws proceed as normal
  run qa_rotten_fate_death_saves_proceed_normally = {
    val creature = freshCreature(20).with("hp", 15)
    val atZero = pTakeDamage(creature, 20, Necrotic, Set(), Set(), Set(), false)
    // atZero is unconscious at 0 HP with 0 successes; roll 15 >= 10 → 1 success, still alive
    val afterSave = pDeathSave(atZero, 15)
    assert(
      atZero.unconscious == true
      and afterSave.deathSaves.successes == 1
      and afterSave.dead == false
    )
  }

  // Source: https://rpg.stackexchange.com/q/174191
  
  // SKIP: The accepted answer concerns DMG monster CR calculation mechanics (effective AC adjustment for 3+ saving throw proficiencies; skill proficiencies having no CR impact). The spec models PHB combat/character mechanics but contains no CR calculation, effective AC adjustment for save proficiency counts, or monster-design framework needed to encode this rule.

  // Source: https://rpg.stackexchange.com/q/214084
  
  // Does a touch spell have advantage when delivered by an invisible Familiar?
  // Accepted answer: No — the spellcaster makes the spell attack, so only the
  // spellcaster's (not the familiar's) invisibility is relevant.
  run qa_invisible_familiar_touch_spell_no_advantage = {
    // Familiar is invisible, but the spellcaster (the actual attacker) is visible.
    // Target can see the spellcaster → adv_unseenAttacker = false → no advantage.
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: false,
      targetDodging: false,
      targetCanSeeAttacker: true,  // target sees the spellcaster (the attacker), not the familiar
      attackerCanSeeTarget: true,
      isRangedAttack: false,       // melee spell attack
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(not(mods.hasAdvantage) and not(mods.hasDisadvantage))
  }
  
  // Does a touch spell have advantage when delivered by an invisible Familiar?
  // Contrapositive: if the SPELLCASTER (the attacker) is invisible, advantage IS granted.
  run qa_invisible_spellcaster_touch_spell_has_advantage = {
    // The spellcaster is the one invisible; target cannot see the attacker → advantage.
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: false,
      targetDodging: false,
      targetCanSeeAttacker: false, // target cannot see the invisible spellcaster (the attacker)
      attackerCanSeeTarget: true,
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(mods.hasAdvantage and not(mods.hasDisadvantage))
  }

  // Source: https://rpg.stackexchange.com/q/184124
  
  // Summon Greater Demon: Can I summon a specific demon for which I know the true name?
  // True name known → disadvantage on the demon's Charisma saving throw (PHB spell description).
  // Disadvantage: roll 2d20 and take the lower. Without true name: single straight roll.
  run qa_true_name_disadvantage_on_charisma_save = {
    val dc       = 13  // example caster spell save DC (8 + spellcasting bonus 5)
    val chaMod   = 0   // demon's Charisma modifier
    val profBonus = 2  // demon's proficiency bonus (CR-based)
    // No true name: straight roll of 15 — 15 + 0 >= 13, save succeeds
    val noTrueName = saveSucceeds(15, chaMod, false, profBonus, 0, dc)
    // True name known: disadvantage → take min(15, 8) = 8 — 8 + 0 < 13, save fails
    val withTrueName = saveSucceeds(8, chaMod, false, profBonus, 0, dc)
    assert(noTrueName and not(withTrueName))
  }

  // Source: https://rpg.stackexchange.com/q/135276
  
  // Can you cast a Subtle Spell while under the effects of Hold Person?
  run qa_paralyzed_cannot_cast_spell = {
    val base = freshCreature(20)
    val paralyzed = pApplyCondition(base, CParalyzed)
    // Attempt to use action (spell cast) and bonus action while paralyzed
    val afterAction = pUseAction(FRESH_TURN, paralyzed, ACastSpell)
    val afterBonus = pUseBonusAction(FRESH_TURN, paralyzed)
    assert(and {
      // Paralyzed implies incapacitated — the root cause
      isIncapacitated(paralyzed),
      // Incapacitated blocks all actions, so actionUsed stays false
      not(afterAction.actionUsed),
      // Bonus actions are also blocked when you can't take actions
      not(afterBonus.bonusActionUsed),
    })
  }

  // Source: https://rpg.stackexchange.com/q/69350
  
  // How to randomize spell scrolls — no PHB table exists; scroll content is DM discretion, not a mechanical rule
  // SKIP: The Q&A is about loot/treasure generation (DM discretion, no mechanical rule). The spec models creature/combat/spell mechanics only and has no functions for spell scroll generation, loot tables, or class spell lists.

  // Source: https://rpg.stackexchange.com/q/174536
  
  // When a character with no fly speed ends their turn in the air, when should they start falling?
  run qa_no_fly_speed_creature_falls = {
    // PHB/XGtE: creature with no fly speed (effectiveSpeed=0 for flight) and no hover falls
    val creature = freshCreature(30)
    assert(pFlyingCreatureFalls(creature, 0, false, false) == true)
  }
  
  // When a character with no fly speed ends their turn in the air, when should they start falling?
  run qa_fall_90_feet_is_9d6 = {
    // PHB: 1d6 bludgeoning per 10 feet fallen — Q&A scenario was ~90 feet up → 9 dice
    assert(pFallingDamageDice(90) == 9)
  }
  
  // When a character with no fly speed ends their turn in the air, when should they start falling?
  run qa_fall_damage_capped_at_20d6 = {
    // PHB: fall damage is capped at 20d6 regardless of height (500 ft still = 20d6)
    assert(pFallingDamageDice(200) == 20 and pFallingDamageDice(500) == 20)
  }
  
  // When a character with no fly speed ends their turn in the air, when should they start falling?
  run qa_fall_lands_creature_prone = {
    // PHB: creature lands prone at end of fall unless damage entirely avoided
    val creature = freshCreature(50)
    val result = pApplyFall(creature, 15, Set(), Set(), Set())
    assert(result.prone)
  }
  
  // When a character with no fly speed ends their turn in the air, when should they start falling?
  run qa_unconscious_creature_falls_no_protection = {
    // Q&A scenario: knocked unconscious mid-air then falls full distance — no Slow Fall when unconscious.
    // Creature at 0 HP (knocked out), falls enough to exceed maxHp → instant death.
    val creature = freshCreature(20)
    val knocked = pKnockOut(creature)  // hp=0, unconscious, prone, stable
    val result = pApplyFall(knocked, 40, Set(), Set(), Set())  // 40 > maxHp(20) → dead
    assert(result.dead)
  }

  // Source: https://rpg.stackexchange.com/q/91356
  
  // Melee with AOE-impacted enemy: only creature in Moonbeam AOE takes radiant damage; adjacent melee attacker outside AOE takes none
  run qa_aoe_melee_attacker_outside_takes_no_damage = {
    // Creature inside Moonbeam starts its turn in the AOE - takes radiant damage (failed CON save, 2d10=10)
    val insideCreature = freshCreature(20)
    val insideAfterAoe = pTakeDamage(insideCreature, 10, Radiant, Set(), Set(), Set(), false)
  
    // Creature outside Moonbeam is adjacent but NOT in the AOE area - takes zero radiant damage
    // (AOE triggers on entering/starting turn in the area, not on being adjacent or swinging a weapon in)
    val outsideCreature = freshCreature(20)
    val outsideTurn = FRESH_TURN
    val outsideTurnAfterAttack = pUseAction(outsideTurn, outsideCreature, AAttack)
  
    // Resolve melee attack from outside-AOE attacker against inside-AOE target: d20=15 + STR mod +2 = 17 vs AC 13 → hits
    val attackResult = resolveAttackRoll(15, 2, 13, 0)
  
    assert(
      insideAfterAoe.hp == 10              // Inside creature: 20 - 10 = 10 HP after AOE radiant damage
      and outsideCreature.hp == 20         // Outside attacker: full HP, melee reach into AOE does not trigger damage
      and outsideTurnAfterAttack.attackActionUsed  // Outside attacker can act and attack normally
      and attackResult.hits                // Melee attack against AOE-affected target still resolves normally
    )
  }

  // Source: https://rpg.stackexchange.com/q/206592
  
  // Beast Barbarian Call the Hunt: 5 temp HP per accepting creature, capped at CON mod creatures (min 1)
  run qa_call_the_hunt_temp_hp_three_creatures = {
    val conScore = 16 // CON mod = +3
    val conMod = abilityModifier(conScore) // 3
    val creaturesAccepting = intMax(1, conMod) // 3
    val tempHpGained = creaturesAccepting * 5 // 15
    val s0 = freshCreature(30)
    val s1 = pGrantTempHp(s0, tempHpGained, false)
    assert(s1.tempHp == 15)
  }
  
  // Beast Barbarian Call the Hunt: minimum 1 creature accepted even when CON mod is negative
  run qa_call_the_hunt_min_one_creature = {
    val conScore = 8 // CON mod = -1, but feature says minimum of one creature
    val conMod = abilityModifier(conScore) // -1
    val creaturesAccepting = intMax(1, conMod) // 1
    val tempHpGained = creaturesAccepting * 5 // 5
    val s0 = freshCreature(30)
    val s1 = pGrantTempHp(s0, tempHpGained, false)
    assert(s1.tempHp == 5)
  }
  
  // Beast Barbarian Call the Hunt: CON mod cap means extra willing creatures do not add more temp HP
  run qa_call_the_hunt_cap_at_con_mod = {
    val conScore = 14 // CON mod = +2; suppose 5 willing creatures are present
    val conMod = abilityModifier(conScore) // 2
    val willingCreatures = 5
    // Only CON mod creatures can accept; extra willing ones beyond the cap yield nothing
    val creaturesAccepting = intMin(willingCreatures, intMax(1, conMod)) // 2
    val tempHpGained = creaturesAccepting * 5 // 10, not 25
    val s0 = freshCreature(30)
    val s1 = pGrantTempHp(s0, tempHpGained, false)
    assert(s1.tempHp == 10)
  }
  
  // Beast Barbarian Call the Hunt: maximum possible temp HP at CON 20 is 25 (5 creatures × 5)
  run qa_call_the_hunt_max_temp_hp = {
    val conScore = 20 // CON mod = +5, the typical attainable cap
    val conMod = abilityModifier(conScore) // 5
    val creaturesAccepting = intMax(1, conMod) // 5
    val tempHpGained = creaturesAccepting * 5 // 25
    val s0 = freshCreature(200)
    val s1 = pGrantTempHp(s0, tempHpGained, false)
    assert(s1.tempHp == 25)
  }

  // Source: https://rpg.stackexchange.com/q/94027
  
  // When does a player have to state they are making a passive check?
  // Passive check formula: 10 + abilityMod + profBonus (no roll, no declaration needed)
  run qa_passive_check_proficient_baseline = {
    // TEST_CONFIG: WIS 13 → mod +1, level 5 → profBonus +3, Perception proficient
    val wisMod = abilityModifier(13)
    val profBonus = proficiencyBonus(5)
    val result = passiveCheck(wisMod, Proficient, profBonus, false, false)
    assert(result == 14) // 10 + 1 + 3 = 14
  }
  
  // Passive check with no skill proficiency: only ability mod added, no prof
  run qa_passive_check_no_proficiency = {
    val wisMod = abilityModifier(13)
    val profBonus = proficiencyBonus(5)
    val result = passiveCheck(wisMod, NoneProf, profBonus, false, false)
    assert(result == 11) // 10 + 1 + 0 = 11
  }
  
  // Passive check with advantage (e.g. Observant feat) adds +5, no roll needed
  run qa_passive_check_advantage_adds_five = {
    val wisMod = abilityModifier(13)
    val profBonus = proficiencyBonus(5)
    val result = passiveCheck(wisMod, Proficient, profBonus, true, false)
    assert(result == 19) // 10 + 1 + 3 + 5 = 19
  }
  
  // Passive check with disadvantage subtracts 5 (e.g. Perception while dashing)
  run qa_passive_check_disadvantage_subtracts_five = {
    val wisMod = abilityModifier(13)
    val profBonus = proficiencyBonus(5)
    val result = passiveCheck(wisMod, Proficient, profBonus, false, true)
    assert(result == 9) // 10 + 1 + 3 - 5 = 9
  }
  
  // Advantage and disadvantage on passive checks cancel each other (PHB rule)
  run qa_passive_check_adv_disadv_cancel = {
    val wisMod = abilityModifier(13)
    val profBonus = proficiencyBonus(5)
    val withBoth  = passiveCheck(wisMod, Proficient, profBonus, true, true)
    val withNeither = passiveCheck(wisMod, Proficient, profBonus, false, false)
    assert(withBoth == withNeither) // both = 14
  }
  
  // Passive Perception beats hidden creature's stealth → notice without declaring active search
  run qa_passive_perception_detects_hidden_creature = {
    val wisMod = abilityModifier(13)
    val profBonus = proficiencyBonus(5)
    val passivePerception = passiveCheck(wisMod, Proficient, profBonus, false, false) // 14
    val hiddenCreatureStealth = 12 // creature's stealth check result (the DC)
    assert(passivePerception >= hiddenCreatureStealth) // detected without player declaring intent
  }
  
  // Passive Perception fails vs high stealth → creature not noticed (DM says nothing)
  run qa_passive_perception_fails_high_stealth = {
    val wisMod = abilityModifier(13)
    val profBonus = proficiencyBonus(5)
    val passivePerception = passiveCheck(wisMod, Proficient, profBonus, false, false) // 14
    val hiddenCreatureStealth = 18 // high stealth roll
    assert(passivePerception < hiddenCreatureStealth) // not detected
  }
  
  // Half-proficiency (e.g. Bard Jack of All Trades) still contributes to passive check
  run qa_passive_check_half_proficiency = {
    val wisMod = abilityModifier(13)
    val profBonus = proficiencyBonus(5) // +3, half = +1
    val result = passiveCheck(wisMod, HalfProf, profBonus, false, false)
    assert(result == 12) // 10 + 1 + 1 = 12
  }
  
  // Expertise doubles proficiency bonus on passive check (e.g. Perception rogue)
  run qa_passive_check_expertise = {
    val wisMod = abilityModifier(13)
    val profBonus = proficiencyBonus(5) // +3, expertise = +6
    val result = passiveCheck(wisMod, Expertise, profBonus, false, false)
    assert(result == 17) // 10 + 1 + 6 = 17
  }

  // Source: https://rpg.stackexchange.com/q/192790
  
  // SKIP: spec models spell slots and concentration but has no representation of Pact of the Tome, Book of Shadows as a game object, or magic item substitution rules — the ruling is entirely narrative/DM-discretion with no testable mechanical state

  // Source: https://rpg.stackexchange.com/q/191021
  
  // Which Ability do you use for multiclass casters sharing spells?
  run qa_multiclass_spell_uses_granting_class_ability = {
    // Artificer 5 / Sorcerer 5: Int 18 (mod +4), Cha 16 (mod +3), level 10 → profBonus +4
    val intConfig: CharConfig = {
      abilityScores: Map(Str -> 10, Dex -> 10, Con -> 10, Int_ -> 18, Wis -> 10, Cha -> 16),
      level: 10,
      size: Medium,
      speeds: Map(Walk -> 30, Fly -> 0, Swim -> 0, Climb -> 0, Burrow -> 0),
      saveProficiencies: Set(),
      skillProficiencies: Set(),
      expertiseSkills: Set(),
      armorProficiencies: Set(),
      hitDieType: 8,
      spellcastingAbility: Int_,
      hasSpellcasting: true,
      canRitualCast: false,
      unarmoredDefense: NoUnarmoredDefense,
      features: Set(),
    }
    // Same character, same spell (Catapult), but granted by Sorcerer → use Cha
    val chaConfig = intConfig.with("spellcastingAbility", Cha)
    assert(
      // Catapult granted by Artificer: Int mod +4, profBonus +4 → DC 16, attack +8
      spellSaveDC(intConfig) == 16
      and spellAttackBonus(intConfig) == 8
      // Catapult granted by Sorcerer: Cha mod +3, profBonus +4 → DC 15, attack +7
      and spellSaveDC(chaConfig) == 15
      and spellAttackBonus(chaConfig) == 7
      // Same spell, different granting class → different ability → different bonus
      and spellSaveDC(intConfig) != spellSaveDC(chaConfig)
      and spellAttackBonus(intConfig) != spellAttackBonus(chaConfig)
    )
  }

  // Source: https://rpg.stackexchange.com/q/171650
  
  // DMG Chase Rules: at exhaustion 0, first dash Con check has no disadvantage
  run qa_chase_first_con_check_no_disadvantage = {
    val s0 = freshCreature(20)
    // exhaustion 0 → pCheckModifiers reports no disadvantage
    val mods = pCheckModifiers(s0, false, false, false)
    assert(not(mods.hasDisadvantage))
  }
  
  // DMG Chase Rules: after failing first check (gain exhaustion 1), second check gets disadvantage
  run qa_chase_second_con_check_disadv_from_first_failure = {
    val s0 = freshCreature(20)
    // first extra dash check fails → 1 level of exhaustion
    val s1 = pAddExhaustion(s0, 1)
    // second check on same turn: exhaustion >= 1 → disadvantage on ability checks
    val mods = pCheckModifiers(s1, false, false, false)
    assert(mods.hasDisadvantage and s1.exhaustion == 1)
  }
  
  // DMG Chase Rules: two failed checks in same turn resolve sequentially → exhaustion 2
  run qa_chase_two_failed_checks_two_exhaustion_levels = {
    val s0 = freshCreature(20)
    val s1 = pAddExhaustion(s0, 1) // first check fails
    val s2 = pAddExhaustion(s1, 1) // second check fails (caller uses lower d20 due to disadv)
    assert(s2.exhaustion == 2)
  }
  
  // DMG Chase Rules: action Dash and bonus-action Dash (Step of Wind / Cunning Action) each consume separate turn resources
  run qa_chase_action_and_bonus_dash_consume_separate_slots = {
    val s0 = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, s0, ADash)   // regular Dash action
    val t2 = pUseBonusAction(t1, s0)     // bonus-action Dash (Step of the Wind / Cunning Action)
    assert(t2.actionUsed and t2.bonusActionUsed)
  }
  
  // DMG Chase Rules: failed Con check uses checkSucceeds; DC 10 with no proficiency fails on low roll
  run qa_chase_con_check_dc10_low_roll_fails = {
    // conMod = +2 (CON 14 as in TEST_CONFIG), roll 5: 5 + 2 = 7 < 10 → fail
    val conMod = abilityModifier(14)
    val result = checkSucceeds(5, conMod, NoneProf, proficiencyBonus(5), 0, 10)
    assert(not(result))
  }
  
  // DMG Chase Rules: failed Con check uses checkSucceeds; DC 10 passes on sufficient roll
  run qa_chase_con_check_dc10_high_roll_passes = {
    // conMod = +2, roll 9: 9 + 2 = 11 >= 10 → pass → no exhaustion
    val conMod = abilityModifier(14)
    val result = checkSucceeds(9, conMod, NoneProf, proficiencyBonus(5), 0, 10)
    assert(result)
  }

  // Source: https://rpg.stackexchange.com/q/201781
  
  // Is disadvantage resolved before or after the bonus is applied from the Reborn lineage's Knowledge from a Past Life trait?
  run qa_disadvantage_resolves_before_modifiers = {
    // Two d20s under disadvantage: 11 and 14; d6 bonus (Knowledge from a Past Life): 5; DC 15
    // Correct: pick lower d20 first (11), then add bonus → 11 + 5 = 16 ≥ 15 → succeeds
    // Wrong:   add bonus to lower roll first → {16, 14}, pick lower → 14 < 15 → fails
    val d20a = 11
    val d20b = 14
    val d6Bonus = 5
    val dc = 15
  
    // Spec design: caller resolves advantage/disadvantage before passing d20Roll to checkSucceeds;
    // miscBonus carries the d6 addition applied after roll selection.
    val resolvedRoll = if (d20a < d20b) d20a else d20b   // disadvantage → lower = 11
  
    // Correct method: resolve disadvantage first, then add d6 as miscBonus
    val correctResult = checkSucceeds(resolvedRoll, 0, NoneProf, 0, d6Bonus, dc)  // 11+5=16 ≥ 15
  
    // Wrong method: add d6 to the smaller roll first, then pick lower of the two resulting values
    val wrongLower = if ((d20a + d6Bonus) < d20b) (d20a + d6Bonus) else d20b     // min(16,14) = 14
    val wrongResult = wrongLower >= dc                                              // 14 ≥ 15 → false
  
    assert(correctResult and not(wrongResult))
  }

  // Source: https://rpg.stackexchange.com/q/99321
  
  // Is the target aware of the source of telepathy via Awakened Mind?
  // Accepted answer: origin not immediately known; impersonation resolved as a Deception (Cha) check at DM-set DC.
  run qa_telepathic_deception_uses_cha_check = {
    // Deception is Charisma-based (skillAbility mapping)
    val deceptionAbility = skillAbility(Deception)
    val persuasionAbility = skillAbility(Persuasion)
    // Warlock: CHA 16 (+3), level 5 (prof +3), proficient in Deception
    val chaMod = abilityModifier(16)   // (16-10)/2 = 3
    val prof    = proficiencyBonus(5)  // (5-1)/4 + 2 = 3
    // DC 15 telepathic impersonation check: 12 + 3 + 3 = 18 >= 15 → succeeds
    val withProf    = checkSucceeds(12, chaMod, Proficient, prof, 0, 15)
    // Same roll, no proficiency: 12 + 3 + 0 = 15 < 16 → fails
    val withoutProf = not(checkSucceeds(12, chaMod, NoneProf, prof, 0, 16))
    // Passive Insight of a perceptive NPC (WIS 14, proficient) vs the same DC
    val wisMod = abilityModifier(14)   // (14-10)/2 = 2
    val targetPassiveInsight = passiveCheck(wisMod, Proficient, prof, false, false)  // 10+2+3 = 15
    assert(
      deceptionAbility == Cha
      and persuasionAbility == Cha
      and withProf
      and withoutProf
      and targetPassiveInsight == 15
    )
  }

  // Source: https://rpg.stackexchange.com/q/206420
  
  // How would D&D 5e spellcasters investigate an anonymous attack? — spell save DC for a level-5 divine investigator (WIS 18, for Zone of Truth / Scrying / Detect Thoughts)
  run qa_investigator_spell_save_dc = {
    val investigatorConfig = TEST_CONFIG
      .with("abilityScores", Map(Str -> 10, Dex -> 10, Con -> 10, Int_ -> 10, Wis -> 18, Cha -> 10))
      .with("level", 5)
      .with("spellcastingAbility", Wis)
    // proficiencyBonus(5)=3, abilityModifier(18)=4 → DC = 8+4+3 = 15
    assert(spellSaveDC(investigatorConfig) == 15)
  }
  
  // How would D&D 5e spellcasters investigate an anonymous attack? — Zone of Truth: CHA save fails for a suspect with low Charisma
  run qa_zone_of_truth_cha_save_fails = {
    val suspectChaMod = abilityModifier(8)   // score 8 → mod -1
    val casterDC = 15
    // roll 6: 6 + (-1) = 5 < 15 → save fails, subject is compelled
    assert(not(saveSucceeds(6, suspectChaMod, false, 3, 0, casterDC)))
  }
  
  // How would D&D 5e spellcasters investigate an anonymous attack? — Zone of Truth: CHA save passes for a suspect with high Charisma and proficiency
  run qa_zone_of_truth_cha_save_passes = {
    val suspectChaMod = abilityModifier(14)  // score 14 → mod +2
    val casterDC = 15
    // roll 12: 12 + 2 + 3 (prof) = 17 >= 15 → save succeeds, not compelled
    assert(saveSucceeds(12, suspectChaMod, true, 3, 0, casterDC))
  }
  
  // How would D&D 5e spellcasters investigate an anonymous attack? — Scrying: WIS save fails for an unsuspecting target, spell takes hold
  run qa_scrying_wis_save_fails = {
    val targetWisMod = abilityModifier(12)   // score 12 → mod +1
    val casterDC = 15
    // roll 5: 5 + 1 = 6 < 15 → save fails, caster can observe target
    assert(not(saveSucceeds(5, targetWisMod, false, 3, 0, casterDC)))
  }
  
  // How would D&D 5e spellcasters investigate an anonymous attack? — passive Perception of a nearby witness (plant/animal proxy: WIS 14, Perception proficiency)
  run qa_witness_passive_perception = {
    val wisMod    = abilityModifier(14)    // = 2
    val profBonus = proficiencyBonus(5)    // = 3
    // passive = 10 + 2 + 3 = 15
    assert(passiveCheck(wisMod, Proficient, profBonus, false, false) == 15)
  }

  // Source: https://rpg.stackexchange.com/q/191093
  
  // Scrying: familiarity level adjusts target's Wisdom save (secondhand +5, firsthand +0, familiar -5)
  run qa_scrying_familiarity_save_modifiers = {
    val dc    = 15
    val roll  = 10
    // Secondhand (heard of target): +5 to save → 10+5=15 ≥ 15, target resists scrying
    val secondhandResists = saveSucceeds(roll, 0, false, 0, 5, dc)
    // Firsthand (met the target): +0 → 10+0=10 < 15, target fails save
    val firsthandFails    = saveSucceeds(roll, 0, false, 0, 0, dc)
    // Familiar (know well): −5 → 10−5=5 < 15, target fails save more easily
    val familiarFails     = saveSucceeds(roll, 0, false, 0, -5, dc)
    assert(secondhandResists and not(firsthandFails) and not(familiarFails))
  }
  
  // Scrying: physical connection bonus stacks additively with familiarity modifier
  run qa_scrying_connection_bonus_stacks = {
    val dc   = 15
    val roll = 10
    // Secondhand (+5) alone: 10+5=15, save succeeds (no connection)
    val noConnection   = saveSucceeds(roll, 0, false, 0, 5,  dc)
    // Secondhand (+5) + likeness (−2) = +3 net: 10+3=13 < 15, fails
    val withLikeness   = saveSucceeds(roll, 0, false, 0, 3,  dc)
    // Secondhand (+5) + possession (−4) = +1 net: 10+1=11 < 15, fails
    val withPossession = saveSucceeds(roll, 0, false, 0, 1,  dc)
    // Secondhand (+5) + body part (−10) = −5 net: 10−5=5 < 15, fails
    val withBodyPart   = saveSucceeds(roll, 0, false, 0, -5, dc)
    assert(noConnection and not(withLikeness) and not(withPossession) and not(withBodyPart))
  }
  
  // Scrying: firsthand + body part (−10) makes save far harder than familiar (−5) alone
  run qa_scrying_body_part_beats_familiar_alone = {
    val dc   = 15
    val roll = 14
    // Familiar (−5): 14−5=9 < 15, fails
    val familiarOnly      = saveSucceeds(roll, 0, false, 0, -5,  dc)
    // Firsthand (0) + body part (−10) = −10: 14−10=4 < 15, also fails
    val firsthandBodyPart = saveSucceeds(roll, 0, false, 0, -10, dc)
    // Firsthand (0) alone: 14+0=14 < 15, fails — body part is decisive
    val firsthandOnly     = saveSucceeds(roll, 0, false, 0, 0,   dc)
    // Secondhand (+5) alone: 14+5=19 ≥ 15, succeeds — shows secondhand is hardest to scry
    val secondhandOnly    = saveSucceeds(roll, 0, false, 0, 5,   dc)
    assert(not(familiarOnly) and not(firsthandBodyPart) and not(firsthandOnly) and secondhandOnly)
  }

  // Source: https://rpg.stackexchange.com/q/162796
  
  // Can I use the Dimension Door spell to teleport onto the back of an ancient green dragon?
  run qa_dimension_door_uses_action_no_cling_action_left = {
    // Casting dimension door uses your action; no action remains for the contested cling check
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, creature, ACastSpell)
    // Attempting a second action is a no-op — action already consumed
    val t2 = pUseAction(t1, creature, AAttack)
    assert(t1.actionUsed == true and t2 == t1)
  }
  
  // Can I use the Dimension Door spell to teleport onto the back of an ancient green dragon?
  run qa_dimension_door_quickened_bonus_action_preserves_action = {
    // Quickened Spell: cast dimension door as bonus action; action still free for cling check
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseBonusAction(t0, creature)
    val t2 = pMarkBonusActionSpell(t1)
    assert(t2.bonusActionUsed == true and t2.actionUsed == false)
  }
  
  // Can I use the Dimension Door spell to teleport onto the back of an ancient green dragon?
  run qa_dimension_door_cling_contest_still_required = {
    // Teleporting doesn't bypass the opposed Athletics/Acrobatics vs Acrobatics check
    // Dragon wins the contest → rider fails to cling (BWins = dragon)
    val riderTotal  = 8 + 3   // d20=8, rider Athletics mod+prof
    val dragonTotal = 15 + 5  // d20=15, dragon Acrobatics
    assert(contestWinner(riderTotal, dragonTotal) == BWins)
  }
  
  // Can I use the Dimension Door spell to teleport onto the back of an ancient green dragon?
  run qa_dimension_door_quickened_then_win_contest_succeeds = {
    // With quickened spell: bonus action for door, then action for cling — and rider wins contest
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseBonusAction(t0, creature)
    val t2 = pMarkBonusActionSpell(t1)
    // Action still available; rider rolls higher → contest won → cling succeeds
    val t3 = pUseAction(t2, creature, AAttack)  // action spent on cling attempt
    val riderTotal  = 18 + 4  // d20=18, Athletics
    val dragonTotal = 12 + 5  // d20=12, dragon Acrobatics
    assert(
      t3.actionUsed == true and
      t3.bonusActionUsed == true and
      contestWinner(riderTotal, dragonTotal) == AWins
    )
  }

  // Source: https://rpg.stackexchange.com/q/168379
  
  // What ability check is most appropriate for disarming a weapon from a grappled/prone creature?
  
  // Prone target within 5ft gives attacker advantage on disarm attack roll (DMG p.271 + prone rules)
  run qa_disarm_prone_within5ft_grants_attacker_advantage = {
    val target = freshCreature(20).with("prone", true)
    val defMods = pDefenseModifiers(target, true)
    assert(defMods.attackerAdvantage == true)
  }
  
  // Grappled condition alone grants no advantage/disadvantage to the disarmer's attack roll
  run qa_disarm_grappled_alone_no_attack_modifier = {
    val target = freshCreature(20).with("grappled", true)
    val defMods = pDefenseModifiers(target, true)
    assert(defMods.attackerAdvantage == false and defMods.attackerDisadvantage == false)
  }
  
  // Exact Q&A scenario: prone+grappled within 5ft — advantage from prone, grappled adds nothing
  run qa_disarm_prone_and_grappled_advantage_from_prone_only = {
    val target = freshCreature(20).with("prone", true).with("grappled", true)
    val defMods = pDefenseModifiers(target, true)
    assert(defMods.attackerAdvantage == true and defMods.autoCrit == false)
  }
  
  // DMG p.271 contest: attacker's attack roll beats defender's Str(Athletics) -> disarm succeeds
  run qa_disarm_contest_attack_beats_athletics = {
    val attackTotal = 18   // d20 roll + attack bonus
    val athleticsTotal = 13  // d20 roll + Str mod + prof bonus
    assert(contestWinner(attackTotal, athleticsTotal) == AWins)
  }
  
  // DMG p.271 contest: defender's Dex(Acrobatics) beats attacker's roll -> disarm fails
  run qa_disarm_contest_acrobatics_beats_attack = {
    val attackTotal = 11
    val acrobaticsTotal = 16
    assert(contestWinner(attackTotal, acrobaticsTotal) == BWins)
  }
  
  // DMG p.271 contest: tie = status quo, disarm does not succeed
  run qa_disarm_contest_tie_no_disarm = {
    assert(contestWinner(14, 14) == Tie)
  }

  // Source: https://rpg.stackexchange.com/q/109841
  
  // Is there a better technique to handle the lag between cause and effect?
  // Core mechanic of accepted answer: creature that already used its action can still
  // use its Reaction (pUseReaction only checks reactionAvailable, not actionUsed).
  run qa_reaction_usable_after_own_action = {
    val turnAfterAction = FRESH_TURN.with("actionUsed", true)
    val t2 = pUseReaction(turnAfterAction)
    assert(
      turnAfterAction.reactionAvailable == true
      and t2.reactionAvailable == false
    )
  }
  
  // Is there a better technique to handle the lag between cause and effect?
  // Reaction is consumed on use: can only be spent once per round, preventing
  // double-dipping (creature can't both react AND act on the same turn).
  run qa_reaction_consumed_after_use = {
    val t1 = pUseReaction(FRESH_TURN)
    val t2 = pUseReaction(t1)
    assert(
      t1.reactionAvailable == false
      and t2.reactionAvailable == false
    )
  }
  
  // Is there a better technique to handle the lag between cause and effect?
  // Reaction resets at the start of the creature's own next turn, restoring the
  // option to react to the next round's spell effects.
  run qa_reaction_resets_at_start_of_own_turn_8549f6c0 = {
    val s = freshCreature(20)
    val newTurn = pStartTurn(TEST_CONFIG, s, Unarmored, false, 0, false, false)
    assert(newTurn.reactionAvailable == true)
  }
  
  // Is there a better technique to handle the lag between cause and effect?
  // Releasing a grapple (the Command/"drop him" scenario) requires no action — the
  // grappler can release via pReleaseGrapple, freeing the slot for the Reaction
  // narrative: release triggered immediately by spell failure.
  run qa_release_grapple_no_action_required = {
    val grappled = freshCreature(20).with("grappled", true)
    val freed = pReleaseGrapple(grappled)
    // Release costs no action/bonus/reaction on turn state
    assert(freed.grappled == false and FRESH_TURN.actionUsed == false)
  }

  // Source: https://rpg.stackexchange.com/q/191902
  
  // What are the mechanical effects of odd numbers for ability scores in monster stat blocks?
  // Raw STR score (not modifier) drives carrying capacity: STR 11 > STR 10 despite identical modifier
  run qa_odd_str_carrying_capacity_differs = {
    val mod10 = abilityModifier(10)
    val mod11 = abilityModifier(11)
    val cap10 = carryingCapacity(10, Medium)
    val cap11 = carryingCapacity(11, Medium)
    assert(
      mod10 == mod11        // both +0 modifier
      and cap11 > cap10     // but 165 lbs vs 150 lbs
      and cap10 == 150
      and cap11 == 165
    )
  }
  
  // What are the mechanical effects of odd numbers for ability scores in monster stat blocks?
  // Raw STR score drives long jump distance: STR 11 jumps 1 ft farther than STR 10 despite same modifier
  run qa_odd_str_long_jump_differs = {
    val mod10 = abilityModifier(10)
    val mod11 = abilityModifier(11)
    val jump10 = pLongJumpDistance(10, true)
    val jump11 = pLongJumpDistance(11, true)
    assert(
      mod10 == mod11        // both +0 modifier
      and jump11 > jump10   // but 11 ft vs 10 ft running jump
      and jump10 == 10
      and jump11 == 11
    )
  }
  
  // What are the mechanical effects of odd numbers for ability scores in monster stat blocks?
  // Heavy armor STR requirement uses raw score: STR 12 vs 13 same modifier (+1) but different speed penalty
  run qa_odd_str_armor_requirement_threshold = {
    val mod12 = abilityModifier(12)
    val mod13 = abilityModifier(13)
    val penalty12 = armorSpeedPenalty(WearingArmor(CHAIN_MAIL), 12)
    val penalty13 = armorSpeedPenalty(WearingArmor(CHAIN_MAIL), 13)
    assert(
      mod12 == mod13        // both +1 modifier
      and penalty12 == 10   // STR 12 fails chain mail's requirement of 13 → -10 ft speed
      and penalty13 == 0    // STR 13 meets requirement → no penalty
    )
  }
  
  // What are the mechanical effects of odd numbers for ability scores in monster stat blocks?
  // SPLINT armor (req 15): STR 14 vs 15 share modifier (+2) but differ on speed penalty
  run qa_odd_str_splint_armor_threshold = {
    val mod14 = abilityModifier(14)
    val mod15 = abilityModifier(15)
    val penalty14 = armorSpeedPenalty(WearingArmor(SPLINT), 14)
    val penalty15 = armorSpeedPenalty(WearingArmor(SPLINT), 15)
    assert(
      mod14 == mod15        // both +2 modifier
      and penalty14 == 10   // STR 14 fails splint's requirement of 15 → -10 ft speed
      and penalty15 == 0    // STR 15 meets requirement → no penalty
    )
  }

  // Source: https://rpg.stackexchange.com/q/214536
  
  // Does the 10' speed penalty from the Slasher feat's Hamstring feature stack with the Weapon Mastery Slow?
  run qa_slasher_and_weapon_mastery_speed_reductions_stack = {
    val creature = freshCreature(20)
    // Accepted answer: different sources stack additively — no rule caps them.
    // Slasher Hamstring: -10 ft; Weapon Mastery Slow: -10 ft → combined callerSpeedModifier = -20.
    // TEST_CONFIG base Walk speed = 30.
    val tOneSource  = pStartTurn(TEST_CONFIG, creature, Unarmored, false, -10, false, false)
    val tBothStacked = pStartTurn(TEST_CONFIG, creature, Unarmored, false, -20, false, false)
    assert(
      tOneSource.effectiveSpeed  == 20 and
      tBothStacked.effectiveSpeed == 10
    )
  }

  // Source: https://rpg.stackexchange.com/q/175853
  
  // SKIP: Ether cyclone and planar travel mechanics (Border Ethereal, Astral Plane color pools, cyclone random effects) have no corresponding functions in the spec; the spec covers only PHB combat, conditions, movement, spellcasting, and environmental rules.

  // Source: https://rpg.stackexchange.com/q/88635
  
  // Is the Turn Undead really usable only once a day at level 1 through 5?
  // Model Channel Divinity as a pact-slot pool (1 use, resets on short OR long rest)
  
  // Using Turn Undead consumes the single Channel Divinity use
  run qa_channel_divinity_expend_shared_use = {
    val cdSlots = FRESH_SPELL_SLOTS.with("pactSlotsMax", 1).with("pactSlotsCurrent", 1).with("pactSlotLevel", 1)
    val afterTurnUndead = pExpendPactSlot(cdSlots)
    assert(afterTurnUndead.pactSlotsCurrent == 0)
  }
  
  // Channel Divinity resets on short rest, not only long rest
  run qa_channel_divinity_resets_on_short_rest = {
    val cdSlots = FRESH_SPELL_SLOTS.with("pactSlotsMax", 1).with("pactSlotsCurrent", 1).with("pactSlotLevel", 1)
    val afterUse = pExpendPactSlot(cdSlots)
    val afterShortRest = pRestorePactSlots(afterUse)
    assert(afterShortRest.pactSlotsCurrent == 1)
  }
  
  // Channel Divinity also resets on long rest
  run qa_channel_divinity_resets_on_long_rest = {
    val cdSlots = FRESH_SPELL_SLOTS.with("pactSlotsMax", 1).with("pactSlotsCurrent", 1).with("pactSlotLevel", 1)
    val afterUse = pExpendPactSlot(cdSlots)
    val afterLongRest = pRestoreAllSlots(afterUse)
    assert(afterLongRest.pactSlotsCurrent == 1)
  }
  
  // Turn Undead and domain features (e.g. Preserve Life) share the same pool —
  // using one blocks the other until next rest
  run qa_channel_divinity_no_second_use_same_rest = {
    val cdSlots = FRESH_SPELL_SLOTS.with("pactSlotsMax", 1).with("pactSlotsCurrent", 1).with("pactSlotLevel", 1)
    val afterTurnUndead = pExpendPactSlot(cdSlots)
    // Attempting a second CD use (e.g. Preserve Life) is a no-op — pool already empty
    val afterDomainFeature = pExpendPactSlot(afterTurnUndead)
    assert(afterDomainFeature.pactSlotsCurrent == 0)
  }

  // Source: https://rpg.stackexchange.com/q/98965
  
  // SKIP: Spec models no shapeshifting, polymorph, wild shape, or form-change state; polymorph/true polymorph/shapechange/lycanthropy mechanics are entirely outside the current spec's scope.

  // Source: https://rpg.stackexchange.com/q/154748
  
  // Does the Giant Toad's Swallow also inflict its Bite damage?
  run qa_swallow_bite_damage_applies_on_hit = {
    // Target is already grappled (Swallow prerequisite)
    val target = freshCreature(20).with("grappled", true)
    // Swallow "makes a bite attack": d20=15, +4 attack bonus vs AC 12 → hits, not crit
    val attackResult = resolveAttackRoll(15, 4, 12, 0)
    // Bite damage 1d6+2: roll 4, modifier 2 → 6 piercing
    val damageAmount = normalDamage(4, 2)
    // If the attack hits, bite damage applies before swallow effects
    val afterDamage = if (attackResult.hits)
      pTakeDamage(target, damageAmount, Piercing, Set(), Set(), Set(), attackResult.isCritical)
    else target
    assert(
      attackResult.hits         and
      not(attackResult.isCritical) and
      damageAmount == 6         and
      afterDamage.hp == 14
    )
  }

  // Source: https://rpg.stackexchange.com/q/181109
  
  // Does a clay golem's haste action actually give it more attacks?
  run qa_clay_golem_haste_same_total_attacks = {
    val creature = freshCreature(20)
  
    // Without Haste: 2 turns, each with Attack action + 1 extra attack = 2 attacks/turn
    val t1_nh = pUseExtraAttack(pUseAction(FRESH_TURN, creature, AAttack))
    val attacks_t1_nh = 1 + (FRESH_TURN.extraAttacksRemaining - t1_nh.extraAttacksRemaining)
  
    val t2_nh = pUseExtraAttack(pUseAction(FRESH_TURN, creature, AAttack))
    val attacks_t2_nh = 1 + (FRESH_TURN.extraAttacksRemaining - t2_nh.extraAttacksRemaining)
  
    val total_no_haste = attacks_t1_nh + attacks_t2_nh
  
    // With Haste:
    // Turn 1: action = Haste (AUseObject, no attacks), bonus action = 1 slam
    val attacks_t1_h = 1
  
    // Turn 2: action = 2 slams (attack + extra), bonus action = 1 slam (lingering Haste)
    val t2_h = pUseExtraAttack(pUseAction(FRESH_TURN, creature, AAttack))
    val attacks_t2_h = (1 + (FRESH_TURN.extraAttacksRemaining - t2_h.extraAttacksRemaining)) + 1
  
    val total_haste = attacks_t1_h + attacks_t2_h
  
    assert(total_no_haste == 4 and total_haste == 4 and total_no_haste == total_haste)
  }

  // Source: https://rpg.stackexchange.com/q/171218
  
  // Preventing Counterspell: paralyzed creature cannot speak, blocking verbal component
  run qa_paralyzed_blocks_verbal_for_counterspell = {
    val creature = pApplyCondition(freshCreature(20), CParalyzed)
    // Counterspell has V,S components; paralyzed → pCanSpeak = false → verbal fails
    assert(not(pCanProvideComponents(creature, true, false, true)))
  }
  
  // Preventing Counterspell: petrified creature cannot speak, blocking verbal component
  run qa_petrified_blocks_verbal_for_counterspell = {
    val creature = pApplyCondition(freshCreature(20), CPetrified)
    assert(not(pCanProvideComponents(creature, true, false, true)))
  }
  
  // Preventing Counterspell: unconscious creature cannot speak, blocking verbal component
  run qa_unconscious_blocks_verbal_for_counterspell = {
    val creature = pApplyCondition(freshCreature(20), CUnconscious)
    assert(not(pCanProvideComponents(creature, true, false, true)))
  }
  
  // Preventing Counterspell: both hands occupied removes free hand, blocking somatic component
  run qa_no_free_hand_blocks_somatic_for_counterspell = {
    val creature = freshCreature(20)
    // hasFreeHand = false → somatic cannot be provided
    assert(not(pCanProvideComponents(creature, false, true, false)))
  }
  
  // Preventing Counterspell: surprised creature begins round with no reaction available
  run qa_surprised_no_reaction_for_counterspell = {
    val t = pStartTurn(TEST_CONFIG, freshCreature(20), Unarmored, true, 0, false, false)
    assert(not(t.reactionAvailable))
  }
  
  // Preventing Counterspell: reaction already expended (e.g. OA, readied action) blocks it
  run qa_expended_reaction_blocks_counterspell = {
    val t1 = pUseReaction(FRESH_TURN)
    // reaction is gone; second attempt is a no-op
    assert(not(t1.reactionAvailable) and pUseReaction(t1) == t1)
  }
  
  // Preventing Counterspell: darkness with no darkvision creates heavy obscurement, blinding counterspeller
  run qa_darkness_heavy_obscurement_blinds_counterspeller = {
    val obs = pEffectiveObscurement(Dark, false)
    assert(pBlindedByObscurement(obs))
  }
  
  // Preventing Counterspell: darkvision in darkness yields only lightly obscured, not blinding
  run qa_darkvision_in_dark_not_blinded = {
    val obs = pEffectiveObscurement(Dark, true)
    assert(not(pBlindedByObscurement(obs)))
  }

  // Source: https://rpg.stackexchange.com/q/108695
  
  // In D&D 5e is it possible to add a breastplate to leather armor for an AC bonus?
  run qa_leather_armor_sets_ac_not_bonus = {
    // Leather grants AC 11 — a fixed value, not an additive bonus
    val dexMod = 1
    assert(calculateAC(WearingArmor(LEATHER), dexMod, false, NoUnarmoredDefense, 0, 0) == 12)
  }
  
  // In D&D 5e is it possible to add a breastplate to leather armor for an AC bonus?
  run qa_breastplate_sets_ac_not_bonus = {
    // Breastplate grants AC 14 — a fixed value, dex capped at +2 for medium armor
    val dexMod = 3
    assert(calculateAC(WearingArmor(BREASTPLATE), dexMod, false, NoUnarmoredDefense, 0, 0) == 16)
  }
  
  // In D&D 5e is it possible to add a breastplate to leather armor for an AC bonus?
  run qa_only_one_armor_applies_no_stacking = {
    // ArmorState is a single value; armor pieces cannot be combined for additive AC
    // Breastplate alone (15) beats leather alone (12); they are exclusive choices
    val dexMod = 1
    val leatherAC    = calculateAC(WearingArmor(LEATHER),     dexMod, false, NoUnarmoredDefense, 0, 0)
    val breastplateAC = calculateAC(WearingArmor(BREASTPLATE), dexMod, false, NoUnarmoredDefense, 0, 0)
    assert(
      leatherAC == 12
      and breastplateAC == 15
      // Combined naive sum (11+14+dex) would be 27 — that value is never produced
      and breastplateAC != leatherAC + 15
      and breastplateAC > leatherAC
    )
  }

  // Source: https://rpg.stackexchange.com/q/153571
  
  // SKIP: Thieves' Cant is a narrative/classification question about a rogue language feature; the spec models no language, class-feature text, or proficiency-as-language mechanics — no encodable assertion exists.

  // Source: https://rpg.stackexchange.com/q/154093
  
  // "you can release the target whenever you like (no action required)" — releasing grapple is free
  run qa_release_grapple_no_action_required_8770660c = {
    val grappled = freshCreature(20).with("grappled", true)
    // Exhaust every turn resource: action, bonus action, reaction
    val allSpentTurn = FRESH_TURN
      .with("actionUsed", true)
      .with("bonusActionUsed", true)
      .with("reactionAvailable", false)
    // pReleaseGrapple signature is (CreatureState) -> CreatureState — no TurnState parameter,
    // proving it consumes no action, bonus action, or reaction
    val released = pReleaseGrapple(grappled)
    assert(
      not(released.grappled)
      // allSpentTurn is completely unmodified — release is truly free
      and allSpentTurn.actionUsed == true
      and allSpentTurn.bonusActionUsed == true
      and allSpentTurn.reactionAvailable == false
    )
  }
  
  // Releasing a grapple involves no movement; no opportunity attack is triggered
  run qa_release_grapple_no_oa_no_movement = {
    val grappled = freshCreature(20).with("grappled", true)
    val grapplerTurn = FRESH_TURN  // grappler's turn state before releasing
    val released = pReleaseGrapple(grappled)
    // pReleaseGrapple never calls pUseMovement or pUseAction(_, _, ADisengage),
    // so disengaged remains false on the grappler's turn — no OA trigger conditions met
    assert(
      not(released.grappled)
      and not(grapplerTurn.disengaged)
      and pCanBeOpportunityAttacked(grapplerTurn) == true
    )
  }
  
  // Grapple release removes only the grappled condition; all other creature state is preserved
  run qa_release_grapple_preserves_other_state = {
    val grappled = freshCreature(30)
      .with("grappled", true)
      .with("poisoned", true)
      .with("hp", 15)
    val released = pReleaseGrapple(grappled)
    assert(
      not(released.grappled)
      and released.poisoned == true
      and released.hp == 15
      and released.maxHp == 30
    )
  }

  // Source: https://rpg.stackexchange.com/q/152984
  
  // SKIP: The spec models creature states, combat mechanics, and turn structure, but contains no functions for area-of-effect geometry, grid positioning, or counting creatures within a radius. The Q&A's core question (how many Medium creatures fit in a 5-foot-radius cylinder centered on a creature vs. a grid intersection) requires spatial/grid math that is entirely outside the spec's domain.

  // Source: https://rpg.stackexchange.com/q/127284
  
  // Does a Druid using Wild Shape roll for hit points or take the average?
  // Accepted answer: player's choice — same as PC level-up HP generation (roll or take average).
  // Mechanical claim: either choice yields a valid beast form starting at full HP.
  run qa_wild_shape_hp_player_chooses_roll_or_average = {
    // Brown bear: 4d10+8 — rolled result vs average (30)
    val beastHpRolled = 34   // player rolled 4d10: e.g. 7+8+9+10 + 8 CON
    val beastHpAverage = 30  // average of 4d10+8
  
    val wildShapeRolled  = freshCreature(beastHpRolled)
    val wildShapeAverage = freshCreature(beastHpAverage)
  
    // Both choices: form starts at full HP, HP is positive, and hp == maxHp
    assert(
      wildShapeRolled.hp  == beastHpRolled   and wildShapeRolled.maxHp  == beastHpRolled
      and wildShapeAverage.hp == beastHpAverage and wildShapeAverage.maxHp == beastHpAverage
      and wildShapeRolled.hp  > 0
      and wildShapeAverage.hp > 0
    )
  }
  
  // PHB rule cited by accepted answer: at each level "roll that Hit Die… Alternatively, use the fixed value."
  // pLevelUpHp models this: both rolled and averaged inputs yield valid positive HP.
  run qa_wild_shape_hp_levelup_analogy_roll_and_average_both_valid = {
    val hitDie     = 10   // e.g., Druid uses d8; beast uses its own die type
    val conMod     = 2
    // Path A: player rolls (result 7 on d10)
    val hpRolled   = pLevelUpHp(7, conMod)   // 7 + 2 = 9
    // Path B: player takes average (average of d10 = 5, rounded up) + conMod
    val hpAverage  = pLevelUpHp(6, conMod)   // 6 + 2 = 8  (ceil(10/2)+1 = 6 per PHB)
  
    assert(hpRolled > 0 and hpAverage > 0 and hpRolled >= hpAverage)
  }

  // Source: https://rpg.stackexchange.com/q/100348
  
  // Does using the Paladin Protection Fighting Style move the characters involved?
  run qa_protection_style_no_movement = {
    // Accepted answer: Protection style only consumes a reaction to impose disadvantage;
    // no movement occurs and no movement is deducted from the Paladin.
    val t = FRESH_TURN
    val tAfterReaction = pUseReaction(t)
    assert(
      // Reaction is consumed
      tAfterReaction.reactionAvailable == false
      // Movement budget is completely untouched
      and tAfterReaction.movementRemaining == t.movementRemaining
      and tAfterReaction.effectiveSpeed == t.effectiveSpeed
    )
  }
  
  // Protection Fighting Style imposes disadvantage but no other attack-roll modifier
  run qa_protection_style_disadvantage_only = {
    // The only mechanical effect is disadvantage on the triggering attack roll.
    // Model the attacker's context: target is NOT dodging, attacker has no inherent
    // advantage sources — so the net result after protection is pure disadvantage.
    val ctx: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false, targetParalyzed: false, targetPetrified: false,
      targetStunned: false, targetUnconscious: false, targetRestrained: false,
      targetProne: false, attackerWithin5ft: true,
      targetDodging: false, targetCanSeeAttacker: true,
      attackerCanSeeTarget: true,
      isRangedAttack: false, beyondNormalRange: false, hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false,
      squeezing: false, underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    // Protection imposes disadvantage externally; with no advantage sources present
    // the resolved state has disadvantage and no advantage — and no auto-miss/crit.
    val modsWithProtection = pAggregateAttackMods(ctx.with("targetDodging", false))
    // Simulate protection: inject disadvantage (the *only* mechanical effect)
    val resolvedAdv = resolveAdvantage({ hasAdvantage: false, hasDisadvantage: true })
    assert(
      resolvedAdv.hasAdvantage == false
      and resolvedAdv.hasDisadvantage == true
      and modsWithProtection.autoCrit == false
      and modsWithProtection.autoMiss == false
    )
  }

  // Source: https://rpg.stackexchange.com/q/73177
  
  // Q: "What happens when a PC is attacked while unconscious in 5e?" — attacker gets advantage against unconscious target
  run qa_unconscious_target_grants_attacker_advantage = {
    val creature = freshCreature(20)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
    val defMods = pDefenseModifiers(creature, true)
    assert(defMods.attackerAdvantage)
  }
  
  // Q: "What happens when a PC is attacked while unconscious in 5e?" — hit within 5 ft is automatically a critical
  run qa_unconscious_autocrit_within_5ft = {
    val creature = freshCreature(20)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
    val defMods = pDefenseModifiers(creature, true)
    assert(defMods.autoCrit)
  }
  
  // Q: "What happens when a PC is attacked while unconscious in 5e?" — no autocrit beyond 5 ft
  run qa_unconscious_no_autocrit_beyond_5ft = {
    val creature = freshCreature(20)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
    val defMods = pDefenseModifiers(creature, false)
    assert(not(defMods.autoCrit))
  }
  
  // Q: "What happens when a PC is attacked while unconscious in 5e?" — normal damage at 0 HP adds 1 death save failure
  run qa_damage_at_0hp_adds_one_death_save_failure = {
    val creature = freshCreature(20)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
    val after = pTakeDamage(creature, 5, Slashing, Set(), Set(), Set(), false)
    assert(after.deathSaves.failures == 1)
  }
  
  // Q: "What happens when a PC is attacked while unconscious in 5e?" — critical hit at 0 HP adds 2 death save failures
  run qa_critical_hit_at_0hp_adds_two_death_save_failures = {
    val creature = freshCreature(20)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
    val after = pTakeDamage(creature, 5, Slashing, Set(), Set(), Set(), true)
    assert(after.deathSaves.failures == 2)
  }
  
  // Q: "What happens when a PC is attacked while unconscious in 5e?" — massive damage (>= maxHp) at 0 HP is instant death
  run qa_massive_damage_at_0hp_is_instant_death = {
    val creature = freshCreature(20)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
    val after = pTakeDamage(creature, 20, Slashing, Set(), Set(), Set(), false)
    assert(after.dead)
  }
  
  // Q: "What happens when a PC is attacked while unconscious in 5e?" — advantage from unconscious cancels with disadvantage from prone+beyond5ft
  run qa_unconscious_prone_beyond_5ft_advantage_cancels = {
    val ctx: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false, targetParalyzed: false, targetPetrified: false,
      targetStunned: false, targetUnconscious: true, targetRestrained: false,
      targetProne: true,
      attackerWithin5ft: false,
      targetDodging: false, targetCanSeeAttacker: true, attackerCanSeeTarget: true,
      isRangedAttack: false, beyondNormalRange: false, hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false,
      squeezing: false, underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(not(mods.hasAdvantage) and not(mods.hasDisadvantage))
  }
  
  // Q: "What happens when a PC is attacked while unconscious in 5e?" — full multiattack sequence: first hit drops to 0 (unconscious), second critical causes 2 failures
  run qa_multiattack_second_critical_on_just_downed_creature = {
    val alive = freshCreature(25)
    // First hit drops to 0 HP → creature goes unconscious
    val downed = pTakeDamage(alive, 25, Slashing, Set(), Set(), Set(), false)
    // Verify intermediate state: 0 HP, unconscious, prone
    val downed_ok = downed.hp == 0 and downed.unconscious and downed.prone
    // Second hit: critical (attacker within 5ft → autocrit), causes 2 death save failures
    val after = pTakeDamage(downed, 5, Slashing, Set(), Set(), Set(), true)
    assert(downed_ok and after.deathSaves.failures == 2 and not(after.dead))
  }

  // Source: https://rpg.stackexchange.com/q/162411
  
  // Q&A: "Do Monsters gain Maximum HP when they gain Hit Dice?"
  run qa_gaining_hit_dice_increases_max_hp = {
    // A partially-injured creature (like a Nabassu mid-combat)
    val initial = freshCreature(20).with("hp", 15)
    // Monster gains a hit die; roll result = 10
    val hdRoll = 10
    // Gaining HD increases BOTH maxHp and current HP by the rolled amount
    // (not a heal — it's a permanent increase to the hit point maximum)
    val afterGainHd = initial
      .with("maxHp", initial.maxHp + hdRoll)
      .with("hp", initial.hp + hdRoll)
    // pHeal alone would cap at old maxHp=20, giving hp=20 not 25
    val afterHealOnly = pHeal(initial, hdRoll)
    assert(
      // Max HP increased by the rolled amount
      afterGainHd.maxHp == 30
      // Current HP also increased by the rolled amount (not capped at old max)
      and afterGainHd.hp == 25
      // Contrast: simple healing caps at existing maxHp
      and afterHealOnly.hp == 20
      and afterHealOnly.maxHp == 20
      // Key invariant: after gaining HD, maxHp grew but hp remains within bounds
      and afterGainHd.hp <= afterGainHd.maxHp
    )
  }
  
  // Q&A: "Do Monsters gain Maximum HP when they gain Hit Dice?"
  run qa_gaining_hit_dice_at_full_hp_also_increases_max = {
    // A creature already at full HP gains hit dice (e.g. Nabassu devours a soul)
    val initial = freshCreature(20)
    val hdRoll = 6
    // Even at full HP, gaining HD raises the maximum — it is not capped or wasted
    val afterGainHd = initial
      .with("maxHp", initial.maxHp + hdRoll)
      .with("hp", initial.hp + hdRoll)
    assert(
      afterGainHd.maxHp == 26
      and afterGainHd.hp == 26
      and afterGainHd.hp <= afterGainHd.maxHp
    )
  }
  
  // Q&A: "Do Monsters gain Maximum HP when they gain Hit Dice?"
  run qa_hit_dice_gain_is_not_bounded_by_old_max_hp = {
    // Rule: "increase the nabassu's hit points by the numbers rolled"
    // means irrespective of prior HP loss — the increase is to max, not a heal
    val initial = freshCreature(10).with("hp", 1)  // barely alive
    val hdRoll = 8
    val afterGainHd = initial
      .with("maxHp", initial.maxHp + hdRoll)
      .with("hp", initial.hp + hdRoll)
    // pHeal on a creature with maxHp=10 and hp=1 would give at most hp=10
    val afterHealOnly = pHeal(initial, hdRoll)
    assert(
      // Gaining HD: new max = 18, current = 9
      afterGainHd.maxHp == 18
      and afterGainHd.hp == 9
      // Healing: current capped at old maxHp=10; max unchanged
      and afterHealOnly.maxHp == 10
      and afterHealOnly.hp == 9
      // The decisive difference: gaining HD increased maxHp, healing did not
      and afterGainHd.maxHp > afterHealOnly.maxHp
    )
  }

