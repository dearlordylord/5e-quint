  // Source: https://rpg.stackexchange.com/q/187950
  
  // Is a Dryad able to issue commands to a charmed creature that doesn't understand Sylvan or Elvish?
  run qa_charmed_no_shared_language = {
    val creature = freshCreature(20)
    val charmedCreature = pApplyCondition(creature, CCharmed)
    // Charmed sets only the charmed flag — no psychic bond, no shared language,
    // no incapacitation. Creature retains full cognitive function; communication
    // still requires a common language or nonverbal means.
    assert(
      charmedCreature.charmed == true
      and charmedCreature.incapacitatedSources == Set()
      and not(isIncapacitated(charmedCreature))
      and pCanAct(charmedCreature)
      and pCanSpeak(charmedCreature)
      and charmedCreature.unconscious == false
      and charmedCreature.paralyzed == false
      and charmedCreature.stunned == false
      and charmedCreature.hp == creature.hp
    )
  }

  // Source: https://rpg.stackexchange.com/q/153054
  
  // Sunbeam: failed save deals full radiant damage and applies Blinded condition
  run qa_sunbeam_failed_save_blinds = {
    val creature = freshCreature(50)
    // Con save DC 12; target Con mod +2; d20=5 → total 7, fails
    val saveFailed = not(saveSucceeds(5, 2, false, 0, 0, 12))
    val s1 = pTakeDamage(creature, 30, Radiant, Set(), Set(), Set(), false)
    val s2 = pApplyCondition(s1, CBlinded)
    assert(saveFailed and s2.blinded and s2.hp == 20)
  }
  
  // Sunbeam: successful save deals half radiant damage and does NOT blind
  run qa_sunbeam_passed_save_no_blind = {
    val creature = freshCreature(50)
    // Con save DC 12; target Con mod +2; d20=15 → total 17, succeeds
    val saveSucceeded = saveSucceeds(15, 2, false, 0, 0, 12)
    val s1 = pTakeDamage(creature, 15, Radiant, Set(), Set(), Set(), false)
    // On a successful save creature is NOT blinded — CBlinded not applied
    assert(saveSucceeded and not(s1.blinded) and s1.hp == 35)
  }
  
  // Sunbeam: passing a prior save grants no ongoing protection — a later beam can still blind
  run qa_sunbeam_previous_pass_no_protection = {
    // Turn 1: creature passes save → takes half damage (15), not blinded
    val creature = freshCreature(50)
    val s1 = pTakeDamage(creature, 15, Radiant, Set(), Set(), Set(), false)
    // s1: hp=35, blinded=false (CBlinded not applied on successful save)
    // Turn 2: creature fails save against a new beam → full damage (30) + blinded
    val saveFailedAgain = not(saveSucceeds(4, 2, false, 0, 0, 12))
    val s2 = pTakeDamage(s1, 30, Radiant, Set(), Set(), Set(), false)
    val s3 = pApplyCondition(s2, CBlinded)
    assert(saveFailedAgain and not(s1.blinded) and s3.blinded and s3.hp == 5)
  }

  // Source: https://rpg.stackexchange.com/q/59071
  
  // Does whether a Wizard can maintain Polymorph concentration depend on beast form?
  // Answer: No – concentration persists through non-incapacitating state changes; mental stats are irrelevant.
  run qa_polymorph_concentration_not_broken_by_non_incapacitating_condition = {
    val creature = freshCreature(30)
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "polymorph")
    // Beast form does not incapacitate; CPoisoned models a non-incapacitating restriction
    val s1 = pApplyCondition(creature, CPoisoned)
    // Mirror doApplyCondition logic: break concentration only on newly incapacitated
    val ssAfter = if (isIncapacitated(s1) and not(isIncapacitated(creature)) and isConcentrating(ss))
      pBreakConcentration(ss) else ss
    assert(isConcentrating(ssAfter))
  }
  
  // Concentration does break when the creature becomes incapacitated (the actual listed exception)
  run qa_polymorph_concentration_breaks_when_incapacitated = {
    val creature = freshCreature(30)
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "polymorph")
    val s1 = pApplyCondition(creature, CStunned)
    val ssAfter = if (isIncapacitated(s1) and not(isIncapacitated(creature)) and isConcentrating(ss))
      pBreakConcentration(ss) else ss
    assert(not(isConcentrating(ssAfter)))
  }
  
  // Concentration survives taking damage if the CON save succeeds
  run qa_polymorph_concentration_survives_successful_con_save = {
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "polymorph")
    val ssAfter = pConcentrationCheck(ss, true)
    assert(isConcentrating(ssAfter))
  }
  
  // Concentration breaks if the CON save from damage fails
  run qa_polymorph_concentration_breaks_on_failed_con_save = {
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "polymorph")
    val ssAfter = pConcentrationCheck(ss, false)
    assert(not(isConcentrating(ssAfter)))
  }

