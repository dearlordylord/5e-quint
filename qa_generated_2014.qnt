  // Source: https://rpg.stackexchange.com/q/135926
  
  // Is it possible to increase the AC of a mirror image duplicate?
  run qa_mirror_image_duplicate_ac_base_formula = {
    // Duplicate AC = 10 + DEX modifier — fixed formula, no armor or shield
    val dexMod = abilityModifier(14) // +2
    val duplicateAC = calculateAC(Unarmored, dexMod, false, NoUnarmoredDefense, 0, 0)
    assert(duplicateAC == 12)
  }
  
  // Is it possible to increase the AC of a mirror image duplicate?
  run qa_mirror_image_ac_only_dex_modifier_matters = {
    // High CON/WIS do not contribute to duplicate AC under NoUnarmoredDefense
    val dexMod    = abilityModifier(14) // +2
    val highConMod = abilityModifier(20) // +5, irrelevant
    val highWisMod = abilityModifier(20) // +5, irrelevant
    val duplicateAC = calculateAC(Unarmored, dexMod, false, NoUnarmoredDefense, highConMod, highWisMod)
    assert(duplicateAC == 12)
  }
  
  // Is it possible to increase the AC of a mirror image duplicate?
  run qa_mirror_image_ac_rises_with_dex_asi = {
    // Raising DEX via ASI (14→16) lifts the duplicate's AC by 1
    val acBefore = calculateAC(Unarmored, abilityModifier(14), false, NoUnarmoredDefense, 0, 0) // 12
    val acAfter  = calculateAC(Unarmored, abilityModifier(16), false, NoUnarmoredDefense, 0, 0) // 13
    assert(acAfter == acBefore + 1)
  }
  
  // Is it possible to increase the AC of a mirror image duplicate?
  run qa_mirror_image_duplicate_cover_bonus = {
    // Cover applies to duplicates as targets (PHB p.196); half +2, three-quarters +5
    val dexMod  = abilityModifier(14) // +2
    val baseAC  = calculateAC(Unarmored, dexMod, false, NoUnarmoredDefense, 0, 0) // 12
    val halfCoverEffectiveAC       = baseAC + coverBonus(HalfCover)           // 14
    val threeQtrCoverEffectiveAC   = baseAC + coverBonus(ThreeQuartersCover)  // 17
    assert(halfCoverEffectiveAC == 14 and threeQtrCoverEffectiveAC == 17)
  }

  // Source: https://rpg.stackexchange.com/q/184171
  
  // How are Fireball attacks on Iron Golems resolved? - failed save subjects golem to full fire damage, absorption heals full amount
  run qa_fire_absorption_failed_save_heals_full = {
    val golem = freshCreature(100).with("hp", 50)
    // Failed DEX save: golem is subjected to full 8d6 fire damage
    val fireballRoll = 28  // 8d6 result
    val fullDamage = normalDamage(fireballRoll, 0)  // = 28, no spell modifier
    // Fire Absorption: takes no damage, instead regains HP equal to fire damage dealt
    val result = pHeal(golem, fullDamage)
    assert(result.hp == 78)
  }
  
  // How are Fireball attacks on Iron Golems resolved? - successful save halves the damage *before* absorption, so golem heals less
  run qa_fire_absorption_successful_save_heals_half = {
    val golem = freshCreature(100).with("hp", 50)
    val fireballRoll = 28  // same 8d6 roll
    // Successful DEX save: subjected to half damage only; absorption converts that half to healing
    val halfDamage = normalDamage(fireballRoll, 0) / 2  // = 14
    val result = pHeal(golem, halfDamage)
    assert(result.hp == 64)
  }
  
  // How are Fireball attacks on Iron Golems resolved? - save outcome meaningfully changes healing amount (failed > successful)
  run qa_fire_absorption_save_outcome_affects_healing = {
    val golem = freshCreature(100).with("hp", 50)
    val fireballRoll = 28
    val fullDamage  = normalDamage(fireballRoll, 0)       // 28 — failed save
    val halfDamage  = normalDamage(fireballRoll, 0) / 2   // 14 — successful save
    val healedFull  = pHeal(golem, fullDamage)
    val healedHalf  = pHeal(golem, halfDamage)
    assert(healedFull.hp > healedHalf.hp and healedFull.hp == 78 and healedHalf.hp == 64)
  }
  
  // How are Fireball attacks on Iron Golems resolved? - specific (absorption) beats general (immunity): absorption path heals, immunity-only path does nothing
  run qa_fire_absorption_specific_beats_general_immunity = {
    val golem = freshCreature(100).with("hp", 50)
    val fireballRoll = 28
    val fullDamage = normalDamage(fireballRoll, 0)
    // General rule path: pure fire immunity → no HP change
    val immunityOnly = pTakeDamage(golem, fullDamage, Fire, Set(), Set(), Set(Fire), false)
    // Specific rule path: Fire Absorption → HP increases by damage amount
    val absorption   = pHeal(golem, fullDamage)
    assert(
      immunityOnly.hp == golem.hp              // immunity alone: no change
      and absorption.hp == golem.hp + fullDamage  // absorption: heals equal to damage dealt
    )
  }

  // Source: https://rpg.stackexchange.com/q/159502
  
  // How do Suggestion and Subtle Spell work together?
  // Rule: Subtle Spell removes the V component barrier but NOT the need to speak
  // the suggestion sentence — pCanProvideComponents(V=false) can pass while pCanSpeak fails.
  run qa_subtle_spell_suggestion_still_requires_speech = {
    val conscious = freshCreature(10)
    // pApplyCondition handles incapacitatedSources automatically for CUnconscious
    val unconscious = pApplyCondition(freshCreature(10), CUnconscious)
    // paralyzed also can't speak — same principle applies
    val paralyzed = pApplyCondition(freshCreature(10), CParalyzed)
  
    // Subtle Spell: requiresVerbal=false, requiresSomatic=false
    // Conscious caster: component check passes AND speech for suggestion is available
    val consciousComponentsOk     = pCanProvideComponents(conscious,   false, false, false)
    val consciousCanSpeak          = pCanSpeak(conscious)
  
    // Unconscious caster: Subtle Spell makes component check pass (no V required),
    // but the suggestion sentence itself still requires pCanSpeak — which fails
    val unconsciousComponentsOk   = pCanProvideComponents(unconscious, false, false, false)
    val unconsciousCanSpeak        = pCanSpeak(unconscious)
  
    // Paralyzed caster: same split — components ok with Subtle Spell, speech blocked
    val paralyzedComponentsOk     = pCanProvideComponents(paralyzed,   false, false, false)
    val paralyzedCanSpeak          = pCanSpeak(paralyzed)
  
    // For contrast: without Subtle Spell (requiresVerbal=true), unconscious fails
    // BOTH the component check AND the speech check — Subtle Spell only helps with one.
    val unconsciousNormalV         = pCanProvideComponents(unconscious, true, false, false)
  
    assert(
      // Conscious: can cast and can deliver the suggestion
      consciousComponentsOk and consciousCanSpeak
      // Unconscious: Subtle Spell clears component gate, but speech gate still blocks
      and unconsciousComponentsOk and not(unconsciousCanSpeak)
      // Without Subtle Spell, unconscious fails both gates
      and not(unconsciousNormalV) and not(unconsciousCanSpeak)
      // Paralyzed: same as unconscious — component gate cleared, speech gate blocks
      and paralyzedComponentsOk and not(paralyzedCanSpeak)
    )
  }

  // Source: https://rpg.stackexchange.com/q/195280
  
  // Weapon proficiency is distinct from skill proficiency; expertise doubles prof bonus for ability checks, not attack rolls
  run qa_weapon_vs_skill_proficiency_distinct = {
    val profBonus = proficiencyBonus(5)   // level 5 → +3
    val abilityMod = abilityModifier(14)  // STR 14 → +2
    val dc = 21
    val roll = 15
  
    // Skill check with Proficient: 15 + 2 + 3 = 20 < 21 → fails
    val skillProficient = checkSucceeds(roll, abilityMod, Proficient, profBonus, 0, dc)
    // Skill check with Expertise (doubled prof): 15 + 2 + 6 = 23 >= 21 → succeeds
    val skillExpertise = checkSucceeds(roll, abilityMod, Expertise, profBonus, 0, dc)
  
    // Attack roll: resolveAttackRoll takes a flat int attackBonus — no ProficiencyLevel parameter exists
    // Weapon proficiency contributes a flat profBonus to the roll; there is no doubling mechanism
    val attackBonus = abilityMod + profBonus  // +2 + +3 = +5
    val attack = resolveAttackRoll(roll, attackBonus, 20, 0)  // 15 + 5 = 20 >= AC 20
  
    assert(
      // Expertise matters for skill (ability) checks — it doubles the proficiency contribution
      not(skillProficient) and skillExpertise
      // profMultiplier confirms: Expertise = 2× profBonus, Proficient = 1×, NoneProf = 0
      and profMultiplier(Expertise, profBonus) == profMultiplier(Proficient, profBonus) * 2
      and profMultiplier(NoneProf, profBonus) == 0
      // Attack rolls have no ProficiencyLevel parameter — weapon proficiency is a flat bonus only
      and attack.hits
      and not(attack.isCritical)
    )
  }

  // Source: https://rpg.stackexchange.com/q/120727
  
  // What is the 5e wizard equivalent of the Still Spell and Silent Spell feats from 3.5e?
  // Core RAW: spells require verbal (need speech) and somatic (need free hand) components — no PHB wizard bypass exists.
  
  // Baseline: a conscious, unimpaired caster with a free hand can provide both V and S components.
  run qa_verbal_and_somatic_require_speech_and_free_hand = {
    val creature = freshCreature(20)
    val canCastNormally = pCanProvideComponents(creature, true, true, true)
    assert(canCastNormally)
  }
  
  // Verbal component requires ability to speak; a paralyzed creature cannot speak and thus cannot provide it.
  run qa_paralyzed_cannot_provide_verbal_component = {
    val creature = pApplyCondition(freshCreature(20), CParalyzed)
    // requiresVerbal=true, requiresSomatic=false, hasFreeHand=true
    val canProvide = pCanProvideComponents(creature, true, false, true)
    assert(not(canProvide))
  }
  
  // Somatic component requires a free hand; without one the component cannot be provided.
  run qa_no_free_hand_blocks_somatic_component = {
    val creature = freshCreature(20)
    // requiresVerbal=false, requiresSomatic=true, hasFreeHand=false
    val canProvide = pCanProvideComponents(creature, false, true, false)
    assert(not(canProvide))
  }
  
  // Both components fail when creature is unconscious (can't speak) and has no free hand.
  run qa_unconscious_no_hand_blocks_both_components = {
    val creature = freshCreature(20).with("hp", 0)
                                    .with("unconscious", true)
                                    .with("prone", true)
                                    .with("incapacitatedSources", Set(ISUnconscious))
    val canProvide = pCanProvideComponents(creature, true, true, false)
    assert(not(canProvide))
  }

  // Source: https://rpg.stackexchange.com/q/127373
  
  // Does UA Mystic's Tough Hide (+2 AC) stack with UA Warforged's Composite Plating (+1 AC)?
  run qa_tough_hide_stacks_with_composite_plating = {
    val dexMod = abilityModifier(12) // DEX 12 → +1
    val baseAC = calculateAC(Unarmored, dexMod, false, NoUnarmoredDefense, 0, 0)
    val compositePlating = 1 // Warforged racial trait: +1 AC
    val toughHide = 2        // Mystic Bestial Transformation / Tough Hide: +2 AC
    // RAW accepted ruling: flat AC bonuses from distinct sources add together
    val stackedAC = baseAC + compositePlating + toughHide
    // Rejected alternative: larger bonus replaces smaller (only one applies)
    val replacedAC = baseAC + intMax(compositePlating, toughHide)
    assert(stackedAC == baseAC + 3 and stackedAC > replacedAC)
  }

  // Source: https://rpg.stackexchange.com/q/180391
  
  // What happens if I use the Coiling Grasp Tattoo on the same target multiple times?
  run qa_coiling_grasp_second_use_grapple_persists = {
    // Target is already grappled from the first successful tattoo use
    val alreadyGrappled = freshCreature(20).with("grappled", true)
    // Second use on same target: creature succeeds the save (BWins = target wins contest)
    // Attacker Medium, target Medium, free hand available
    val result = pGrapple(Medium, Medium, alreadyGrappled, BWins, true)
    // Successful save against second use does NOT end the pre-existing grapple
    assert(result.targetState.grappled == true)
  }

  // Source: https://rpg.stackexchange.com/q/207285
  
  // What are the effects of magical sleep for a long rest?
  // Magical sleep (8h, ≥1 HP) qualifies: HP is restored to max, no natural-sleep requirement exists
  run qa_magical_sleep_long_rest_restores_hp = {
    val creature = freshCreature(20).with("hp", 8).with("hitDiceRemaining", 2)
    val afterRest = pLongRest(creature, 5, true)
    assert(afterRest.hp == 20)
  }
  
  // What are the effects of magical sleep for a long rest?
  // PHB p.186: "a character must have at least 1 hit point at the start of the rest to gain its benefits"
  run qa_magical_sleep_long_rest_zero_hp_no_benefit = {
    val creature = freshCreature(20).with("hp", 0)
    val afterRest = pLongRest(creature, 5, true)
    assert(afterRest.hp == 0 and afterRest.hitDiceRemaining == 0)
  }
  
  // What are the effects of magical sleep for a long rest?
  // Sleeping creature with ≥1 HP also recovers hit dice (up to half total)
  run qa_magical_sleep_long_rest_hit_dice_recovery = {
    val creature = freshCreature(20).with("hp", 10).with("hitDiceRemaining", 1)
    // totalHitDice=5, remaining=1 → spent=4, maxRecover=max(1,2)=2, recovery=min(4,2)=2
    val afterRest = pLongRest(creature, 5, true)
    assert(afterRest.hitDiceRemaining == 3)
  }
  
  // What are the effects of magical sleep for a long rest?
  // Long rest without food (hasEaten=false) does not reduce exhaustion
  run qa_magical_sleep_long_rest_no_food_no_exhaustion_reduction = {
    val creature = freshCreature(20).with("hp", 15).with("exhaustion", 2).with("hitDiceRemaining", 5)
    val afterRest = pLongRest(creature, 5, false)
    assert(afterRest.exhaustion == 2)
  }

  // Source: https://rpg.stackexchange.com/q/177700
  
  // Wild Companion: casting find familiar costs one action (not 1 hour) per specific-beats-general rule
  run qa_wild_companion_find_familiar_as_action = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    // Wild Companion says "as an action ... cast find familiar" — one action, resolved in same turn
    val t1 = pUseAction(t0, creature, ACastSpell)
    assert(
      // The spell cast consumes exactly the action — done within the turn
      t1.actionUsed == true
      // Bonus action is NOT consumed (it was just an action, not a bonus action cast)
      and t1.bonusActionUsed == false
      // Movement is unaffected — the action completes immediately, not over hours
      and t1.movementRemaining == t0.movementRemaining
      // No other turn resources are drained
      and t1.reactionAvailable == true
      and t1.extraAttacksRemaining == t0.extraAttacksRemaining
    )
  }

  // Source: https://rpg.stackexchange.com/q/71923
  
  // How to use Silence effectively against spellcasters?
  run qa_grappled_caster_cannot_escape_silence_zone = {
    // Grappled caster has speed 0 and cannot walk out of the Silence area
    val caster = freshCreature(20).with("grappled", true)
    val t = pStartTurn(TEST_CONFIG, caster, Unarmored, false, 0, false, false)
    assert(t.movementRemaining == 0)
  }
  
  // How to use Silence effectively against spellcasters?
  run qa_silence_verbal_component_blocked = {
    // Silence suppresses sound; a creature that cannot speak cannot satisfy Verbal component requirement
    val silencedCaster = pApplyCondition(freshCreature(20), CParalyzed)
    assert(not(pCanProvideComponents(silencedCaster, true, false, true)))
  }

  // Source: https://rpg.stackexchange.com/q/159800
  
  // Does a cantrip fired with the Ready Action require concentration?
  run qa_ready_cantrip_requires_concentration = {
    // Readying any spell (including a 0th-level cantrip) requires concentration per PHB Ready action rules
    val s0 = freshCreature(20)
    val t0 = FRESH_TURN
    val ss0 = FRESH_SPELL_SLOTS
    // Caster declares Ready action with a cantrip; holding the energy requires concentration
    val t1 = pUseAction(t0, s0, AReady)
    val ss1 = pStartConcentration(ss0, "firebolt_cantrip")
    assert(t1.readiedAction and isConcentrating(ss1))
  }
  
  // Readied cantrip concentration check DC = max(10, half damage taken)
  run qa_ready_cantrip_concentration_dc = {
    // PHB: concentration check DC = max(10, floor(damage/2)); javelin deals 8 → DC 10
    val dc = pConcentrationDC(8)
    assert(dc == 10)
  }
  
  // Failing concentration check while holding a readied cantrip loses the spell
  run qa_ready_cantrip_failed_concentration_breaks_spell = {
    // Merlin readies Firebolt, ogre javelin hits for 8 damage, Merlin fails CON save → loses readied spell
    val s0 = freshCreature(20)
    val ss0 = pStartConcentration(FRESH_SPELL_SLOTS, "firebolt_cantrip")
    // 8 damage taken, DC = 10; roll 3 + CON mod 2 + prof 3 (CON proficient, level 5) = 8 < 10 → fail
    val dc = pConcentrationDC(8)
    val savePassed = saveSucceeds(3, 2, true, proficiencyBonus(5), 0, dc)
    val ss1 = pConcentrationCheck(ss0, savePassed)
    assert(not(isConcentrating(ss1)))
  }
  
  // Passing concentration check while holding a readied cantrip maintains it
  run qa_ready_cantrip_passed_concentration_maintains_spell = {
    // Merlin readies Firebolt, ogre javelin hits for 8 damage, Merlin passes CON save → spell still held
    val ss0 = pStartConcentration(FRESH_SPELL_SLOTS, "firebolt_cantrip")
    // roll 5 + CON mod 2 + prof 3 = 10 >= DC 10 → succeeds
    val dc = pConcentrationDC(8)
    val savePassed = saveSucceeds(5, 2, true, proficiencyBonus(5), 0, dc)
    val ss1 = pConcentrationCheck(ss0, savePassed)
    assert(isConcentrating(ss1) and ss1.concentrationSpellId == "firebolt_cantrip")
  }

  // Source: https://rpg.stackexchange.com/q/180205
  
  // Mending has instantaneous duration — no ongoing magic; Detect Magic finds nothing
  run qa_instantaneous_spell_no_ongoing_magic = {
    val ss = FRESH_SPELL_SLOTS
    // Instantaneous spells never call pStartConcentration → isConcentrating is false
    assert(not(isConcentrating(ss)))
  }
  
  // Mending: instantaneous effect — Dispel Magic (modeled as concentration check) is a no-op
  run qa_instantaneous_dispel_magic_no_effect = {
    val ss = FRESH_SPELL_SLOTS
    // pConcentrationCheck short-circuits when not concentrating; instantaneous spell leaves nothing to dispel
    val ssAfterDispel = pConcentrationCheck(ss, false)
    assert(ssAfterDispel == ss)
  }
  
  // Mending: instantaneous effect cannot be suppressed by Antimagic Field (no concentration to break)
  run qa_instantaneous_antimagic_field_no_effect = {
    val ss = FRESH_SPELL_SLOTS
    // pBreakConcentration on a non-concentrating state is identity; no active spell to suppress
    val ssAfterField = pBreakConcentration(ss)
    assert(ssAfterField == ss and not(isConcentrating(ssAfterField)))
  }
  
  // Mending: resuming from Antimagic Field has no effect — there was never an ongoing spell to resume
  run qa_instantaneous_exits_antimagic_field_unchanged = {
    val ss = FRESH_SPELL_SLOTS
    // Entering then leaving an antimagic field leaves instantaneous effect state identical
    val ssInField  = pBreakConcentration(ss)
    val ssOutField = ssInField   // no pStartConcentration to resume → state unchanged
    assert(ssOutField == ss and not(isConcentrating(ssOutField)))
  }

  // Source: https://rpg.stackexchange.com/q/91161
  
  // Can a creature swap places with another willing creature on their turn?
  run qa_swap_positions_via_ready_action = {
    val creature = freshCreature(20)
    // A moves through B's space (5 ft, normal cost) — movement is consumed on A's turn
    val a_turn_after_move = pUseMovement(FRESH_TURN, 5, 1)
    // B readied an action on B's prior turn (trigger: A enters B's space) to move away
    val b_turn_after_ready = pUseAction(FRESH_TURN, creature, AReady)
    assert(
      // A's movement budget is reduced by moving into B's space
      a_turn_after_move.movementRemaining == FRESH_TURN.movementRemaining - 5
      // B's action is consumed — the Ready action is the cost of the swap per accepted answer
      and b_turn_after_ready.actionUsed == true
      and b_turn_after_ready.readiedAction == true
      // B's bonus action is NOT spent — only the action is consumed
      and b_turn_after_ready.bonusActionUsed == false
      // B's movement budget on B's own turn is unaffected by choosing Ready
      and b_turn_after_ready.movementRemaining == FRESH_TURN.movementRemaining
      // A second action attempt by B is silently ignored (action already spent)
      and pUseAction(b_turn_after_ready, creature, ADash).actionUsed == true
      and pUseAction(b_turn_after_ready, creature, ADash).attackActionUsed == false
    )
  }

  // Source: https://rpg.stackexchange.com/q/132490
  
  // Opportunity Attack, Ready Action, & Eldritch Blast/Repelling Blast: readied action fires after trigger, consuming reaction
  run qa_readied_action_fires_after_trigger = {
    val creature = freshCreature(20)
    val turn = FRESH_TURN
    // Taking the Ready action spends your action and sets the readiedAction flag,
    // but does NOT yet consume your reaction — the reaction is held in reserve
    val turnAfterReady = pUseAction(turn, creature, AReady)
    // The trigger (berserker attacks the druid) completes first — only then does
    // the readied action fire, spending the reaction (DMG p.252: reaction occurs
    // after its trigger finishes when timing is unspecified)
    val turnAfterFiring = pUseReaction(turnAfterReady)
    assert(and {
      turnAfterReady.actionUsed == true,
      turnAfterReady.readiedAction == true,
      // Reaction still available immediately after readying — trigger hasn't fired yet
      turnAfterReady.reactionAvailable == true,
      // Reaction spent only when the readied action is released (after trigger completes)
      turnAfterFiring.reactionAvailable == false,
    })
  }

  // Source: https://rpg.stackexchange.com/q/71977
  
  // Does the Compulsion spell affect as many creatures as desired?
  run qa_compulsion_multi_target = {
    // Compulsion targets any number of creatures satisfying conditions;
    // each makes an independent WIS save — no cap on target count imposed by the spell.
    val dc = spellSaveDC(TEST_CONFIG)
    val pb = proficiencyBonus(TEST_CONFIG.level)
    // Three creatures with WIS mod 0, unproficient — each rolls independently against the same DC
    val c1Affected    = not(saveSucceeds(5,  0, false, pb, 0, dc))
    val c2Affected    = not(saveSucceeds(4,  0, false, pb, 0, dc))
    val c3NotAffected =     saveSucceeds(15, 0, false, pb, 0, dc)
    // All three can be simultaneously targeted; each outcome is determined solely by roll vs DC
    assert(c1Affected and c2Affected and c3NotAffected)
  }

  // Source: https://rpg.stackexchange.com/q/183664
  
  // If you transmute Enervation to another element, do you still benefit from the healing?
  run qa_transmuted_spell_cannot_convert_necrotic = {
    // Transmuted Spell metamagic only operates on: acid, cold, fire, lightning, poison, thunder
    val transmutableTypes: Set[DamageType] = Set(Acid, Cold, Fire, Lightning, Poison, Thunder)
    // Enervation deals Necrotic — not in the eligible list, so the metamagic cannot apply
    assert(not(transmutableTypes.contains(Necrotic)))
  }

  // Source: https://rpg.stackexchange.com/q/104549
  
  // "Magical" isn't technically a damage type — WCMFTPOOR weapon still hits Force-immune creature
  run qa_wcmftpoor_slashing_bypasses_force_immunity = {
    // Kensei weapon counts as magical but deals Slashing — Force immunity is irrelevant
    val forceImmune = Set(Force)
    val damage = applyDamageModifiers(10, Slashing, forceImmune, Set(), Set())
    assert(damage == 10)
  }
  
  // Arcane Arrow deals Piercing, not Force — Force immunity does not block it
  run qa_magic_arrow_piercing_bypasses_force_immunity = {
    val forceImmune = Set(Force)
    val damage = applyDamageModifiers(8, Piercing, forceImmune, Set(), Set())
    assert(damage == 8)
  }
  
  // Force immunity does block actual Force damage (e.g., Eldritch Blast)
  run qa_force_immunity_blocks_force_damage = {
    val forceImmune = Set(Force)
    val damage = applyDamageModifiers(10, Force, forceImmune, Set(), Set())
    assert(damage == 0)
  }
  
  // Full state test: Force-immune creature survives Slashing from a "magical" weapon
  run qa_force_immune_creature_takes_slashing_from_magical_weapon = {
    val creature = freshCreature(20)
    val forceImmune = Set(Force)
    val after = pTakeDamage(creature, 8, Slashing, Set(), Set(), forceImmune, false)
    assert(after.hp == 12)
  }
  
  // Damage type identity: Slashing != Force regardless of weapon's magical property
  run qa_magical_tag_does_not_change_damage_type = {
    // A weapon "counting as magical" for overcoming nonmagical immunity still
    // has its base damage type; immunity lookup is strictly by DamageType variant
    val immuneToForceNotSlashing = Set(Force)
    val slashingDmg = applyDamageModifiers(12, Slashing, immuneToForceNotSlashing, Set(), Set())
    val forceDmg    = applyDamageModifiers(12, Force,    immuneToForceNotSlashing, Set(), Set())
    assert(slashingDmg == 12 and forceDmg == 0)
  }

  // Source: https://rpg.stackexchange.com/q/158628
  
  // SKIP: Spec has no model of "magical vs non-magical ability" classification, Antimagic Field suppression, or vampire stat block abilities (Charm, Children of the Night, Shapechanger, Spider Climb, Regeneration). Cannot encode the SAC criteria for what counts as magical using the existing pure functions and state types.

  // Source: https://rpg.stackexchange.com/q/167069
  
  // Does exhaustion affect passive perception in 5e?
  run qa_exhaustion_passive_perception = {
    val wisMod     = abilityModifier(TEST_CONFIG.abilityScores.get(Wis))
    val profBonus  = proficiencyBonus(TEST_CONFIG.level)
    // Perception is in TEST_CONFIG.skillProficiencies
    val profLevel  = Proficient
  
    val fresh     = freshCreature(20)
    val exhausted = pAddExhaustion(fresh, 1)
  
    val modsFresh     = pCheckModifiers(fresh,     false, false, false)
    val modsExhausted = pCheckModifiers(exhausted, false, false, false)
  
    val passiveFresh     = passiveCheck(wisMod, profLevel, profBonus,
                             modsFresh.hasAdvantage,     modsFresh.hasDisadvantage)
    val passiveExhausted = passiveCheck(wisMod, profLevel, profBonus,
                             modsExhausted.hasAdvantage, modsExhausted.hasDisadvantage)
  
    assert(
      // exhaustion 1 imposes disadvantage on ability checks → pCheckModifiers sets hasDisadvantage
      modsExhausted.hasDisadvantage == true
      and modsFresh.hasDisadvantage == false
      // disadvantage on the ability check translates to -5 in the passive check formula (PHB ch.7)
      and passiveFresh - passiveExhausted == 5
    )
  }

  // Source: https://rpg.stackexchange.com/q/78371
  
  // Why use leveled spells: damage type immunity can completely negate a cantrip but not a differently-typed leveled spell
  run qa_poison_immunity_nullifies_cantrip_not_thunder = {
    val creature = freshCreature(30)
    // Poison Spray (cantrip, 4d12 @ lvl17 = ~26): immune creature takes 0
    val afterPoisonSpray = pTakeDamage(creature, 26, Poison, Set(), Set(), Set(Poison), false)
    // Thunderwave (level 1, 2d8 = 12): same immune creature takes full thunder damage
    val afterThunderwave = pTakeDamage(creature, 12, Thunder, Set(), Set(), Set(Poison), false)
    assert(
      afterPoisonSpray.hp == 30 and  // poison immunity: 0 damage regardless of cantrip scaling
      afterThunderwave.hp == 18      // poison immunity irrelevant; 30 - 12 = 18
    )
  }
  
  // Why use leveled spells: Thunderwave still deals half damage on a successful save; Poison Spray deals 0 on success
  run qa_thunderwave_half_damage_on_successful_save = {
    val creature = freshCreature(30)
    val rawRoll = 12  // 2d8
    // Thunderwave: save = half damage (PHB); caller computes half before applying
    val halfDamage = rawRoll / 2
    val afterThunderwaveSaved = pTakeDamage(creature, halfDamage, Thunder, Set(), Set(), Set(), false)
    // Poison Spray: save = 0 damage (no effect on success)
    val afterPoisonSpraySaved = pTakeDamage(creature, 0, Poison, Set(), Set(), Set(), false)
    assert(
      afterThunderwaveSaved.hp == 24 and  // 30 - 6 = 24: save still costs the target HP
      afterPoisonSpraySaved.hp == 30      // save = completely avoided
    )
  }
  
  // Why use leveled spells: Thunderwave push + fall off a 200ft cliff yields far more damage than 4d12 Poison Spray
  run qa_thunderwave_push_plus_fall_exceeds_cantrip = {
    val creature = freshCreature(60)
    // Thunderwave damage component (2d8 = 10 thunder)
    val afterThunderwave = pTakeDamage(creature, 10, Thunder, Set(), Set(), Set(), false)
    // 200ft fall: pFallingDamageDice caps at 20d6; pre-resolved roll = 70
    val fallDice = pFallingDamageDice(200)
    val afterFall = pApplyFall(afterThunderwave, 70, Set(), Set(), Set())
    // Best-case Poison Spray (4d12, max = 48) against same creature
    val afterPoisonSpray = pTakeDamage(creature, 48, Poison, Set(), Set(), Set(), false)
    assert(
      fallDice == 20 and                          // 200 / 10 = 20 dice, at cap
      afterFall.hp == 0 and                       // 10 thunder + 70 bludgeoning = 80 total: knocked out
      afterFall.prone == true and                 // fall always lands prone
      afterPoisonSpray.hp == 12                   // max cantrip (48) only brings from 60 to 12
    )
  }

  // Source: https://rpg.stackexchange.com/q/158522
  
  // Can the target of Nature's Wrath use an action to attempt to free itself?
  run qa_restrained_no_action_escape = {
    // Accepted answer: no — restrained (Nature's Wrath) can only end via the end-of-turn save.
    // The spec has no pEscapeRestrained; pUseAction leaves the restrained condition untouched.
    val s = freshCreature(20).with("restrained", true)
    val t1 = pUseAction(FRESH_TURN, s, AAttack)
    // Action consumed, but restrained condition unchanged — no action-based escape exists
    assert(s.restrained == true and t1.actionUsed == true)
  }
  
  // Contrast: grapple explicitly has an action-based escape mechanic (pEscapeGrapple)
  run qa_grapple_has_action_escape_unlike_natures_wrath_restrained = {
    // pEscapeGrapple models the PHB rule "a grappled creature can use its action to escape";
    // no analogous function exists for restrained, encoding the accepted answer.
    val s = freshCreature(20).with("grappled", true)
    // BWins = grappled creature wins the contested Athletics/Acrobatics check → freed
    val escaped = pEscapeGrapple(s, BWins)
    assert(escaped.grappled == false)
  }

  // Source: https://rpg.stackexchange.com/q/80441
  
  // How does Aura of Protection work with multiple paladins?
  // Rule: same-named features don't stack; only the most potent applies (highest CHA mod).
  run qa_aura_of_protection_no_stack = {
    val paladin1ChaMod = abilityModifier(16) // +3
    val paladin2ChaMod = abilityModifier(18) // +4
  
    // Non-stacking (correct): take only the most potent aura bonus
    val auraBonus = intMax(paladin1ChaMod, paladin2ChaMod) // 4, not 7
  
    // Stacking (incorrect ruling): both modifiers added
    val stackingBonus = paladin1ChaMod + paladin2ChaMod // 7
  
    // Wizard: d20=8, CON mod=0, not proficient, DC 15
    // Correct:   8 + 0 + 4 = 12, fails DC 15
    // Incorrect: 8 + 0 + 7 = 15, would pass DC 15
    val correctResult  = saveSucceeds(8, 0, false, 0, auraBonus,    15)
    val incorrectResult = saveSucceeds(8, 0, false, 0, stackingBonus, 15)
  
    assert(
      auraBonus == 4          // most potent aura wins
      and not(correctResult)  // 8+4=12 < 15: save fails under correct rule
      and incorrectResult     // 8+7=15 >= 15: stacking would wrongly succeed
    )
  }

  // Source: https://rpg.stackexchange.com/q/204494
  
  // Beast Barbarian: claws add Str+Rage bonus to each attack—two attacks double the modifier contribution vs one greatsword attack
  run qa_beast_barbarian_claw_modifier_doubles = {
    val strRageMod = 6  // Str 18 (+4) + rage bonus (+2)
    // Greatsword: one attack, 2d6 average = 7, modifier added once
    val greatswordDmg = normalDamage(7, strRageMod)     // 13
    // Claws: two attacks, 1d6 average = 3 each, modifier added twice
    val clawTotal = normalDamage(3, strRageMod) + normalDamage(3, strRageMod)  // 18
    assert(clawTotal > greatswordDmg)
  }
  
  // Beast Barbarian: two claw hits each independently trigger a concentration save; failing the second breaks concentration even after passing the first
  run qa_beast_barbarian_claws_force_two_concentration_saves = {
    val ss0 = FRESH_SPELL_SLOTS.with("concentrationSpellId", "hold_person")
    // First claw hit: spellcaster passes concentration save → still concentrating
    val ss1 = pConcentrationCheck(ss0, true)
    // Second claw hit: spellcaster fails concentration save → concentration broken
    val ss2 = pConcentrationCheck(ss1, false)
    assert(isConcentrating(ss1) and not(isConcentrating(ss2)))
  }
  
  // Beast Barbarian: natural weapons free a hand for a shield, granting +2 AC the Barbarian couldn't get with a two-handed weapon
  run qa_beast_barbarian_shield_ac_bonus_from_natural_weapons = {
    val dexMod = 2  // Dex 14
    val conMod = 3  // Con 16
    val wisMod = 0  // unused for Barbarian UD
    val acNoShield  = calculateAC(Unarmored, dexMod, false, BarbarianUD, conMod, wisMod)  // 10+2+3 = 15
    val acWithShield = calculateAC(Unarmored, dexMod, true,  BarbarianUD, conMod, wisMod)  // 17
    assert(acWithShield == acNoShield + 2)
  }

  // Source: https://rpg.stackexchange.com/q/179248
  
  // Can you draw a weapon as part of a spell attack? — free object interaction is available in tandem with Cast a Spell action
  run qa_draw_weapon_during_cast_spell = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    // Cast a Spell uses the action but does not consume the free object interaction
    val t1 = pUseAction(t0, creature, ACastSpell)
    // Action is spent on the spell
    val actionSpent = t1.actionUsed
    // Free interaction slot is still open — drawing a weapon is possible in tandem
    val canStillDrawWeapon = not(t1.freeInteractionUsed)
    // Exercise the draw: pUseObjectInteraction marks it used
    val t2 = pUseObjectInteraction(t1)
    val weaponDrawn = t2.freeInteractionUsed
    assert(actionSpent and canStillDrawWeapon and weaponDrawn)
  }

  // Source: https://rpg.stackexchange.com/q/122330
  
  // Can you stay invisible by readying an attack instead of attacking?
  // Rule: taking the Ready action to ready an attack does NOT immediately end invisibility;
  // the invisible condition is only lost when the attack is actually executed.
  run qa_ready_action_preserves_invisibility = {
    val s0 = freshCreature(20).with("invisible", true)
    val t0 = FRESH_TURN
    // Creature uses their action to Ready (readying an attack, not casting)
    val t1 = pUseAction(t0, s0, AReady)
    assert(
      // Ready action was consumed
      t1.actionUsed == true
      and t1.readiedAction == true
      // invisible condition is NOT removed by the Ready action itself
      and s0.invisible == true
      // contrast: if they had used AAttack the action would also be consumed,
      // but still no auto-removal of invisible in the turn machinery
      and pUseAction(t0, s0, AAttack).attackActionUsed == true
      and s0.invisible == true
    )
  }

  // Source: https://rpg.stackexchange.com/q/153976
  
  // SKIP: Clone spell and Change Shape feature are not modeled in the spec; no functions exist for polymorph forms, cloning, or per-ability retention across form transitions.

  // Source: https://rpg.stackexchange.com/q/100405
  
  // How does time pass in combat? — one action per 6-second turn; second action attempt is blocked
  run qa_one_action_per_six_second_turn = {
    val creature = freshCreature(20)
    val t1 = pUseAction(FRESH_TURN, creature, AAttack)
    val t2 = pUseAction(t1, creature, ACastSpell)
    assert(
      t1.actionUsed
      and t2.actionUsed
      // second pUseAction call is a no-op: state unchanged
      and t2.attackActionUsed
      and not(t1.bonusActionUsed)
    )
  }
  
  // How does time pass in combat? — Extra Attack represents multiple hits within the same 6-second round
  run qa_extra_attack_multiple_hits_per_round = {
    val creature = freshCreature(20)
    val configNoExtra = TEST_CONFIG.with("features", Set())
    val turnWithExtra  = pStartTurn(TEST_CONFIG,      creature, Unarmored, false, 0, false, false)
    val turnNoExtra    = pStartTurn(configNoExtra,    creature, Unarmored, false, 0, false, false)
    assert(
      // experienced combatant (FExtraAttack) gets 1 bonus hit in the 6-second window
      turnWithExtra.extraAttacksRemaining == 1
      // average combatant without training lands only one blow per round
      and turnNoExtra.extraAttacksRemaining == 0
    )
  }
  
  // How does time pass in combat? — spending Extra Attack decrements remaining uses within the round
  run qa_extra_attack_consumed_within_round = {
    val t0 = FRESH_TURN   // initialized with extraAttacksRemaining = 1 (from TEST_CONFIG/FExtraAttack)
    val t1 = pUseExtraAttack(t0)
    val t2 = pUseExtraAttack(t1)  // already spent; should be no-op
    assert(
      t1.extraAttacksRemaining == 0
      and t2.extraAttacksRemaining == 0
    )
  }

  // Source: https://rpg.stackexchange.com/q/194639
  
  // SKIP: Spec has no aging mechanics, no polymorph form state, and no persistent non-concentration spell effect tracking; Time Ravage's aging condition and True Polymorph's form transformation cannot be encoded with existing functions.

  // Source: https://rpg.stackexchange.com/q/141441
  
  // SKIP: Clone spell soul-transfer mechanics (choosing among multiple matured clones on death) are not modeled in the spec; no clone/soul-destination state or functions exist.

  // Source: https://rpg.stackexchange.com/q/92936
  
  // Does a Gnome Mystic who replaces WIS save with an alternate attribute still have advantage on the save?
  run qa_gnome_cunning_advantage_persists_with_switched_proficiency = {
    // Gnome Mystic level 4: WIS 14 (+2), DEX 12 (+1), profBonus = 2
    // Mystic feature: proficiency switched from WIS saves → DEX saves
    val wisMod   = abilityModifier(14)    // +2
    val dexMod   = abilityModifier(12)    // +1
    val prof     = proficiencyBonus(4)    // +2
    val dc       = 15
  
    // WIS save against magic: Gnome Cunning still grants advantage on WIS saves
    // even though class proficiency was switched away. isProficient = false (no class prof on WIS).
    // Advantage rolls: 7 and 14 → take the higher (14)
    val wisHighRoll = 14
    val wisLowRoll  = 7
    // 14 + 2 + 0 = 16 >= 15 → succeeds (advantage matters)
    val wisWithAdvantage    = saveSucceeds(wisHighRoll, wisMod, false, prof, 0, dc)
    // 7  + 2 + 0 = 9  < 15 → fails (without advantage)
    val wisWithoutAdvantage = saveSucceeds(wisLowRoll,  wisMod, false, prof, 0, dc)
  
    // DEX save: now has proficiency (switched here), but no Gnome Cunning advantage
    // 11 + 1 + 2 = 14 < 15 → fails (proficiency alone not enough without the advantage boost)
    val dexRoll        = 11
    val dexWithProf    = saveSucceeds(dexRoll, dexMod, true, prof, 0, dc)
  
    assert(
      // Gnome Cunning advantage on WIS save succeeds despite no proficiency (14+2=16>=15)
      wisWithAdvantage    == true
      // Without advantage, same WIS save (no prof) fails (7+2=9<15)
      and wisWithoutAdvantage == false
      // Proficiency moved to DEX, but without racial advantage it still falls short (11+1+2=14<15)
      and dexWithProf     == false
    )
  }

  // Source: https://rpg.stackexchange.com/q/163472
  
  // Does the Avatar of Death make "attacks" for the purposes of resistance or immunity?
  // Reaping Scythe has no attack roll → not an "Attack"; werewolf immunity is
  // "from Nonmagical Attacks", so the qualifier never triggers and full slashing lands.
  run qa_non_attack_ability_bypasses_attack_conditional_immunity = {
    // Werewolf: immune to "Bludgeoning, Piercing, Slashing from Nonmagical Attacks"
    // Reaping Scythe is NOT an attack → immunity condition is not met → empty immunity set
    val slashingThrough = applyDamageModifiers(7, Slashing, Set(), Set(), Set())
    val necroticThrough  = applyDamageModifiers(4, Necrotic,  Set(), Set(), Set())
    assert(slashingThrough == 7 and necroticThrough == 4)
  }
  
  // Does the Avatar of Death make "attacks" for the purposes of resistance or immunity?
  // Black Pudding is immune to "Slashing" with no "from attacks" qualifier, so the
  // unconditional immunity applies to Reaping Scythe regardless of it not being an attack.
  run qa_non_attack_ability_still_triggers_unconditional_immunity = {
    // Black Pudding: immune to Slashing (no qualifier) → immunity always applies
    val slashingBlocked = applyDamageModifiers(7, Slashing, Set(Slashing), Set(), Set())
    val necroticThrough  = applyDamageModifiers(4, Necrotic,  Set(Slashing), Set(), Set())
    assert(slashingBlocked == 0 and necroticThrough == 4)
  }

  // Source: https://rpg.stackexchange.com/q/169992
  
  // NPC Knight ability "parry" - how often can it be used?
  run qa_parry_reaction_once_per_turn = {
    // Parry uses a reaction; PHB p.190: can't take another reaction until start of next turn.
    val t0 = FRESH_TURN
    val t1 = pUseReaction(t0)           // knight uses Parry
    val t2 = pUseReaction(t1)           // try to Parry again — no-op, already spent
    val creature = freshCreature(20)
    val t3 = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false) // next turn resets it
    assert(
      t0.reactionAvailable == true    // reaction starts available
      and t1.reactionAvailable == false  // consumed after first Parry
      and t2.reactionAvailable == false  // second attempt has no effect
      and t3.reactionAvailable == true   // restored at start of next turn
    )
  }

  // Source: https://rpg.stackexchange.com/q/50336
  
  // Dualwielding non-proficient Pact Weapon: are you proficient with the off-hand?
  run qa_pact_weapon_offhand_no_proficiency = {
    // Pact of the Blade proficiency applies only to the specific pact weapon itself,
    // not to other weapons of the same type wielded in the off-hand.
    val level = 5
    val dexMod = abilityModifier(12) // DEX 12 → +1
    val pb = proficiencyBonus(level)  // level 5 → +3
  
    // Off-hand attack with a regular (non-pact) shortsword of the same type: NoneProf
    val nonPactBonus = dexMod + profMultiplier(NoneProf, pb) // 1 + 0 = 1
    val nonPactAttack = resolveAttackRoll(15, nonPactBonus, 17, 0)
  
    // Off-hand attack with the actual pact weapon (light weapon, legal for TWF): Proficient
    val pactBonus = dexMod + profMultiplier(Proficient, pb) // 1 + 3 = 4
    val pactAttack = resolveAttackRoll(15, pactBonus, 17, 0)
  
    assert(
      // Non-pact off-hand misses AC 17: 15 + 1 = 16 < 17
      nonPactAttack.hits == false
      // Pact weapon in off-hand hits AC 17: 15 + 4 = 19 >= 17
      and pactAttack.hits == true
      // Proficiency bonus for a non-pact weapon is zero
      and profMultiplier(NoneProf, pb) == 0
      // Proficiency bonus for the actual pact weapon is the full proficiency bonus
      and profMultiplier(Proficient, pb) == pb
    )
  }

  // Source: https://rpg.stackexchange.com/q/101952
  
  // Restoring vitality with Hit Dice: spending a HD at non-max HP restores HP capped at effectiveMaxHp (not overflow)
  run qa_hit_die_heals_hp_not_vitality_below_max = {
    // Fighter: CON 15 -> conMod=2, effectiveMaxHp=19, currently at 17 HP, 1 HD remaining
    // Roll 8 + conMod 2 = 10 healing; 17+10=27 would overflow, but caps at 19 (gains only 2 HP)
    val creature = freshCreature(19).with("hp", 17).with("hitDiceRemaining", 1)
    val healed = pSpendHitDie(creature, 2, 8)
    assert(
      healed.hp == 19
      and healed.hitDiceRemaining == 0
    )
  }
  
  // Restoring vitality with Hit Dice: spending a HD when already at max HP produces no HP change (spec has no vitality field)
  run qa_hit_die_at_max_hp_no_additional_gain = {
    // Fighter at 19/19 HP (full), 1 HD remaining; roll 10 + conMod 2 = 12, but already at max — no change
    val creature = freshCreature(19).with("hp", 19).with("hitDiceRemaining", 1)
    val healed = pSpendHitDie(creature, 2, 10)
    assert(
      healed.hp == 19
      and healed.hitDiceRemaining == 0
    )
  }
  
  // SKIP: UA Vitality — the overflow-to-vitality mechanic (1 VIT per 10 pts healing at max HP) has no representation in the spec (no vitality field)

  // Source: https://rpg.stackexchange.com/q/161234
  
  // SKIP: The spec has no Flaming Sphere spell, no spell-effect movement mechanic, and no line-of-sight tracking for bonus-action spell movement; the rule cannot be encoded with existing functions.

  // Source: https://rpg.stackexchange.com/q/134450
  
  // Can an Abjurer wizard use Projected Ward without Arcane Ward? — No: ward at 0 HP absorbs nothing
  run qa_projected_ward_no_ward_no_absorption = {
    // Arcane Ward modeled as tempHp; ward absent (tempHp=0) means Projected Ward is useless
    val wizard = freshCreature(20).with("tempHp", 0)
    val afterDamage = pTakeDamage(wizard, 6, Force, Set(), Set(), Set(), false)
    // No ward to intercept: full damage reaches HP, tempHp unchanged at 0
    assert(afterDamage.tempHp == 0 and afterDamage.hp == 14)
  }
  
  // Can an Abjurer wizard use Projected Ward without Arcane Ward? — Active ward absorbs before HP
  run qa_projected_ward_active_ward_absorbs = {
    // Arcane Ward with HP remaining (tempHp=10) intercepts damage on behalf of the target
    val wizard = freshCreature(20).with("tempHp", 10)
    val afterDamage = pTakeDamage(wizard, 6, Force, Set(), Set(), Set(), false)
    // Ward (tempHp) absorbs 6 points; HP untouched; tempHp reduced by 6
    assert(afterDamage.tempHp == 4 and afterDamage.hp == 20)
  }
  
  // Can an Abjurer wizard use Projected Ward without Arcane Ward? — Ward at 0 HP, ward exhausted, damage breaks through
  run qa_projected_ward_exhausted_ward_no_absorption = {
    // Ward was reduced to 0 HP earlier; Projected Ward can be "used" but absorbs nothing
    val wizard = freshCreature(20).with("tempHp", 0)
    val afterDamage = pTakeDamage(wizard, 8, Force, Set(), Set(), Set(), false)
    // 0 tempHp = ward cannot absorb; damage passes directly to HP
    assert(afterDamage.hp == 12 and afterDamage.tempHp == 0)
  }

  // Source: https://rpg.stackexchange.com/q/111735
  
  // Can you use a weapon as an improvised version of another weapon?
  run qa_improvised_weapon_similar_grants_proficiency = {
    // PHB p.147: DM may allow a proficient character to use a similar object as that weapon and apply proficiency bonus
    // Mechanical claim: similar-weapon ruling turns a miss into a hit by adding proficiency bonus to attack roll
    val profBonus = proficiencyBonus(5)  // level 5 → +3
    val strMod = abilityModifier(14)     // STR 14 → +2
    val roll = 10
    val targetAC = 15
    // No similar-weapon ruling → treat as improvised, no proficiency: 10 + 2 = 12 < 15, miss
    val asImprovised = resolveAttackRoll(roll, strMod, targetAC, 0)
    // DM grants similar-weapon ruling → proficiency applies: 10 + 2 + 3 = 15 >= 15, hit
    val asSimilarWeapon = resolveAttackRoll(roll, strMod + profBonus, targetAC, 0)
    assert(not(asImprovised.hits) and asSimilarWeapon.hits)
  }

  // Source: https://rpg.stackexchange.com/q/124331
  
  // How can one make multiple opportunity attacks during one round?
  run qa_one_reaction_limits_oa_per_round = {
    // Default: single reaction means at most one OA per round
    val t0 = FRESH_TURN
    val t1 = pUseReaction(t0)
    // After spending the reaction on a first OA, no reaction remains for a second
    assert(not(t1.reactionAvailable))
  }
  
  // How can one make multiple opportunity attacks during one round?
  run qa_reaction_expended_is_not_restored_by_repeat_use = {
    // Spending an already-spent reaction is a no-op; still unavailable
    val t0 = FRESH_TURN
    val t1 = pUseReaction(t0)
    val t2 = pUseReaction(t1)
    assert(not(t2.reactionAvailable))
  }
  
  // How can one make multiple opportunity attacks during one round?
  run qa_reaction_resets_at_start_of_own_turn = {
    // After a surprised turn ends, reaction becomes available again on the next turn,
    // modeling the per-round reset that makes the single-reaction limit meaningful
    val t0 = FRESH_TURN.with("reactionAvailable", false).with("surprised", true)
    val t1 = pEndSurpriseTurn(t0)
    assert(t1.reactionAvailable)
  }

  // Source: https://rpg.stackexchange.com/q/211928
  
  // Could you kill someone using Enchantment School Wizard's Hypnotic Gaze forever?
  run qa_hypnotic_gaze_starvation_kills = {
    // Hypnotic Gaze: charmed + incapacitated; target starves over 6 days → exhaustion 6 → dead.
    val target = freshCreature(30)
    val underGaze = pApplyCondition(pApplyCondition(target, CCharmed), CIncapacitated)
    val d1 = pApplyStarvation(underGaze)
    val d2 = pApplyStarvation(d1)
    val d3 = pApplyStarvation(d2)
    val d4 = pApplyStarvation(d3)
    val d5 = pApplyStarvation(d4)
    val d6 = pApplyStarvation(d5)
    assert(d6.dead and d6.exhaustion == 6)
  }
  
  // Could you kill someone using Enchantment School Wizard's Hypnotic Gaze forever?
  run qa_hypnotic_gaze_incap_blocks_action = {
    // Hypnotic Gaze incapacitates the target; incapacitated creatures cannot take actions.
    val target = freshCreature(20)
    val underGaze = pApplyCondition(pApplyCondition(target, CCharmed), CIncapacitated)
    val t1 = pUseAction(FRESH_TURN, underGaze, AAttack)
    assert(not(t1.actionUsed))
  }
  
  // Could you kill someone using Enchantment School Wizard's Hypnotic Gaze forever?
  run qa_hypnotic_gaze_dehydration_accelerates_death = {
    // Dehydration stacks with starvation: once already exhausted (>=1), dehydration adds 2 levels.
    // Starvation day 1 → exh 1; dehydration (no water, save failed) → +2 = exh 3;
    // starvation days 2-4 → exh 4, 5, 6 = dead. Faster than starvation alone.
    val target = freshCreature(20)
    val underGaze = pApplyCondition(pApplyCondition(target, CCharmed), CIncapacitated)
    val s1 = pApplyStarvation(underGaze)          // exhaustion 1
    val s2 = pApplyDehydration(s1, false, false)  // already exhausted → +2 → exhaustion 3
    val s3 = pApplyStarvation(s2)                 // exhaustion 4, hp clamped to maxHp/2
    val s4 = pApplyStarvation(s3)                 // exhaustion 5
    val s5 = pApplyStarvation(s4)                 // exhaustion 6 → dead
    assert(s5.dead and s2.exhaustion == 3)
  }

  // Damage types have no rules of their own; cover is granted by CoverType, not damage type (PHB p.196)
  run qa_damage_types_dont_grant_cover = {
    // coverBonus takes CoverType only — DamageType is not a parameter; it cannot grant cover
    val noCover      = coverBonus(NoCover)
    val halfCover    = coverBonus(HalfCover)
    val threeFourths = coverBonus(ThreeQuartersCover)
    val totalCover   = coverBonus(TotalCover)
    assert(
      noCover == 0
      and halfCover == 2
      and threeFourths == 5
      and totalCover == 0
    )
  }
  
  // Cover bonus affects AC based solely on CoverType; the attacker's damage type is irrelevant
  run qa_cover_from_barrier_not_damage_type = {
    val roll  = 10
    val bonus = 5
    val ac    = 15
    // No cover: 10+5=15 >= 15 → hits
    val nocover   = resolveAttackRoll(roll, bonus, ac, coverBonus(NoCover))
    // Half cover: effective AC = 15+2=17, 15 < 17 → misses
    val halfcover = resolveAttackRoll(roll, bonus, ac, coverBonus(HalfCover))
    assert(nocover.hits and not(halfcover.hits))
  }
  
  // Damage types only govern resistance/immunity/vulnerability, never cover
  run qa_force_damage_type_only_affects_modifiers = {
    // Force damage resisted → halved; Fire damage not resisted → full
    val forceDmgResisted   = applyDamageModifiers(12, Force, Set(), Set(Force), Set())
    val fireDmgUnresisted  = applyDamageModifiers(12, Fire,  Set(), Set(Force), Set())
    // Cover bonus is the same regardless of which damage type an attack carries
    val coverVsForceAttack = coverBonus(HalfCover)
    val coverVsFireAttack  = coverBonus(HalfCover)
    assert(
      forceDmgResisted  == 6
      and fireDmgUnresisted == 12
      and coverVsForceAttack == coverVsFireAttack
      and coverVsForceAttack == 2
    )
  }

  // Source: https://rpg.stackexchange.com/q/105568
  
  // Does it require a free hand to use a Touch spell?
  // Accepted answer: no RAW rule requires a free hand for touch range; only Somatic components impose a free-hand requirement
  run qa_touch_spell_no_free_hand_rule = {
    val creature = freshCreature(20)
    // Somatic (S) component blocks casting without a free hand
    val somatic_blocked = not(pCanProvideComponents(creature, false, true, false))
    // Touch-range spell with no Somatic component: no free-hand requirement (touch range not a separate rule)
    val touch_no_somatic_ok = pCanProvideComponents(creature, false, false, false)
    assert(somatic_blocked and touch_no_somatic_ok)
  }

  // Source: https://rpg.stackexchange.com/q/212095
  
  // SKIP: Wall of Force spell, area-of-effect geometry, line-of-effect rules, and creature positional targeting are not modeled in the spec; the spec tracks movement budgets and speed types but has no functions for spell areas, unblocked-line checks, or terrain occlusion needed to encode burrowing-escape vs. walk/fly/swim-trap assertions.

  // Source: https://rpg.stackexchange.com/q/191106
  
  // Can you get the benefits from tool proficiency to make ability checks, even if you don't have/own the tool?
  run qa_tool_proficiency_requires_possessing_tool = {
    // PHB p.154: "add your proficiency bonus to any ability check you make USING that tool"
    // Without the tool in hand, profLevel = NoneProf (no bonus).
    val profBonus = proficiencyBonus(5)  // level 5 -> +3
    val abilityMod = abilityModifier(14) // score 14 -> +2
    val dc = 15
    val roll = 12
    // Using the tool (proficient): 12 + 2 + 3 = 17 >= 15, succeeds
    val withTool = checkSucceeds(roll, abilityMod, Proficient, profBonus, 0, dc)
    // Not possessing the tool (no bonus applies): 12 + 2 + 0 = 14 < 15, fails
    val withoutTool = checkSucceeds(roll, abilityMod, NoneProf, profBonus, 0, dc)
    assert(withTool and not(withoutTool))
  }

  // Source: https://rpg.stackexchange.com/q/197169
  
  // What mechanics allow you to target an Unseen Servant?
  // Attacking an unseen target (e.g. unseen servant at a location) imposes disadvantage per PHB p.194
  run qa_attack_unseen_servant_location_gives_disadvantage = {
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: true,
      attackerCanSeeTarget: false, // servant is invisible/unseen
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(mods.hasDisadvantage and not(mods.hasAdvantage) and not(mods.autoMiss))
  }
  
  // What mechanics allow you to target an Unseen Servant?
  // Advantage (attacker unseen to servant) and disadvantage (attacker can't see servant) cancel out
  run qa_attack_unseen_servant_mutual_unseen_cancels = {
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: false, // servant cannot see attacker -> advantage for attacker
      attackerCanSeeTarget: false, // attacker cannot see servant -> disadvantage
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(not(mods.hasAdvantage) and not(mods.hasDisadvantage))
  }
  
  // What mechanics allow you to target an Unseen Servant?
  // Even when targeting an unseen location, a nat 20 always hits and crits (PHB p.194)
  run qa_attack_unseen_servant_nat20_always_hits = {
    val result = resolveAttackRoll(20, 0, 30, 0)
    assert(result.hits and result.isCritical)
  }
  
  // What mechanics allow you to target an Unseen Servant?
  // A nat 1 always misses regardless of attack bonus (wrong location guess or any other miss)
  run qa_attack_unseen_servant_nat1_always_misses = {
    val result = resolveAttackRoll(1, 99, 10, 0)
    assert(not(result.hits) and not(result.isCritical))
  }

  // Source: https://rpg.stackexchange.com/q/168563
  
  // Magic Initiate feat: 1st-level spell needs no spell slot; long rest is the only reset mechanism
  run qa_magic_initiate_no_slot_needed = {
    // Character with 2 first-level spell slots (e.g., a multiclassed caster)
    val slots = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(1, 2))
      .with("slotsCurrent", EMPTY_SLOTS.set(1, 2))
  
    // Normal slot-based cast consumes a slot (the standard spellcasting path)
    val afterNormalCast = pExpendSlot(slots, 1)
  
    // Magic Initiate cast: NOT slot-based — PHB p.201 "special abilities that let them
    // cast spells without using spell slots"; no pExpendSlot called
    val afterMICast = slots  // slot state unchanged — MI feat spell needs no spell slot
  
    // Long rest restores all spell slots (the same rest that resets the once-per-LR MI use)
    val afterLR = pRestoreAllSlots(afterNormalCast)
  
    assert(
      // Normal cast reduces available slots by 1
      afterNormalCast.slotsCurrent.get(1) == 1
      // Magic Initiate cast leaves all slots intact
      and afterMICast.slotsCurrent.get(1) == 2
      // Long rest brings slots back to maximum
      and afterLR.slotsCurrent.get(1) == 2
    )
  }

  // Source: https://rpg.stackexchange.com/q/182088
  
  // Grease spell: Can a creature with 10 strength or more jump over the greased area?
  run qa_grease_jump_str10_equals_area_not_sufficient = {
    // STR 10 running long jump covers exactly 10ft — equals the grease square; lands at boundary,
    // does NOT clear it (needs strictly > 10ft), so DEX save still required
    val dist = pLongJumpDistance(10, true)
    val greaseAreaFeet = 10
    assert(dist == greaseAreaFeet and not(dist > greaseAreaFeet))
  }
  
  // Grease spell: Can a creature with 10 strength or more jump over the greased area?
  run qa_grease_jump_str11_clears_area = {
    // STR 11 running long jump covers 11ft > 10ft grease square — clears completely, no DEX save
    val dist = pLongJumpDistance(11, true)
    val greaseAreaFeet = 10
    assert(dist > greaseAreaFeet)
  }
  
  // Grease spell: Can a creature with 10 strength or more jump over the greased area?
  run qa_grease_standing_jump_str10_insufficient = {
    // Without a running start (standing jump), STR 10 covers only 5ft — far short of 10ft area
    val dist = pLongJumpDistance(10, false)
    assert(dist == 5 and dist < 10)
  }

  // Source: https://rpg.stackexchange.com/q/175773
  
  // Does Improved Abjuration affect spells that have a circumstantial ability check?
  run qa_improved_abjuration_only_applies_at_cast_time = {
    // Accepted answer: Improved Abjuration adds proficiency only to checks made
    // as part of casting — not to checks triggered by spell effects after casting.
    val level = 10
    val profBonus = proficiencyBonus(level) // (10-1)/4 + 2 = 4
    val intMod = abilityModifier(18)        // (18-10)/2 = 4
    val dc = 15
    val roll = 10
  
    // Cast-time check (Improved Abjuration applies → Proficient): 10+4+4=18 >= 15 → true
    val castTimeCheck = checkSucceeds(roll, intMod, Proficient, profBonus, 0, dc)
    // Post-cast check (Improved Abjuration does NOT apply → NoneProf): 10+4+0=14 < 15 → false
    val postCastCheck = checkSucceeds(roll, intMod, NoneProf, profBonus, 0, dc)
  
    assert(castTimeCheck and not(postCastCheck))
  }

  // Source: https://rpg.stackexchange.com/q/130108
  
  // Does feeblemind change the effect of Command Undead on high intelligence targets?
  run qa_feeblemind_removes_command_undead_repeat_threshold = {
    // Feeblemind reduces INT to 1; INT<12 removes hourly-repeat clause, INT<8 removes advantage clause
    val vampireIntBefore = 14   // typical vampire INT (>= 12 → gets hourly repeats)
    val feeblemindedInt  = 1    // feeblemind sets INT to 1
  
    val hasAdvantage_pre     = vampireIntBefore >= 8
    val hasHourlyRepeat_pre  = vampireIntBefore >= 12
    val hasAdvantage_post    = feeblemindedInt >= 8
    val hasHourlyRepeat_post = feeblemindedInt >= 12
  
    assert(
      // before feeblemind: both thresholds met
      hasAdvantage_pre and hasHourlyRepeat_pre
      // after feeblemind: neither threshold met
      and not(hasAdvantage_post) and not(hasHourlyRepeat_post)
    )
  }
  
  // Does feeblemind change the effect of Command Undead on high intelligence targets?
  run qa_feeblemind_cha1_almost_guarantees_command_undead_failure = {
    // Feeblemind also sets CHA to 1 → -5 modifier on the Charisma save
    val feeblemindedChaMod = abilityModifier(1)  // (1-10)/2 floor = -5
  
    // Level-14 wizard, INT 20: spell save DC = 8 + profBonus(14) + intMod(20)
    //   profBonus(14) = (14-1)/4 + 2 = 3+2 = 5
    //   abilityModifier(20) = 5
    //   DC = 18
    val wizDC = 8 + proficiencyBonus(14) + abilityModifier(20)
  
    // Even a natural 20 roll (not a guaranteed success on saves in 5e) still fails
    val roll20Passes = saveSucceeds(20, feeblemindedChaMod, false, 0, 0, wizDC)
    // A middling roll of 12 also fails
    val roll12Passes = saveSucceeds(12, feeblemindedChaMod, false, 0, 0, wizDC)
  
    assert(
      feeblemindedChaMod == -5
      and wizDC == 18
      and not(roll20Passes)   // 20 + (-5) = 15 < 18
      and not(roll12Passes)   // 12 + (-5) = 7  < 18
    )
  }

  // Source: https://rpg.stackexchange.com/q/203682
  
  // Can a Path of Wild Magic Barbarian/Rogue use a greataxe (with Thrown from Wild Surge) for sneak attack?
  run qa_thrown_property_does_not_enable_sneak_attack = {
    // Greataxe after Wild Surge #4: gains Thrown (and Light), damage becomes Force,
    // but the weapon's melee classification is unchanged — Thrown ≠ Ranged Weapon
    val greataxeWithThrown: Weapon = {
      name: "greataxe",
      damageDie: 12,
      versatileDie: 0,
      damageType: Force,
      properties: Set(Heavy, TwoHanded, Light_, Thrown),
      isMelee: true,     // still a melee weapon; Thrown does not reclassify it
      normalRange: 20,   // Thrown supplies a range, but category stays melee
      longRange: 60,
    }
    // Sneak Attack eligibility: weapon must have Finesse OR be a ranged weapon (not isMelee)
    val sneakAttackEligible =
      greataxeWithThrown.properties.contains(Finesse) or not(greataxeWithThrown.isMelee)
    assert(not(sneakAttackEligible))
  }

  // Source: https://rpg.stackexchange.com/q/169590
  
  // Using Extra Attack feature with two-handed weapon and additional thrown weapon; releasing grip is free, drawing uses free object interaction
  run qa_extra_attack_thrown_and_two_handed = {
    // Fresh turn: character holds halberd in both hands
    val t0 = FRESH_TURN
    // Releasing one hand from the halberd costs nothing (no spec call needed — absence of cost is the rule)
    // Draw the javelin using the one free object interaction
    val t1 = pUseObjectInteraction(t0)
    // Attack action: throw the javelin (first attack)
    val creature = freshCreature(20)
    val t2 = pUseAction(t1, creature, AAttack)
    // Regain grip on halberd (free per RAI) then make Extra Attack with it
    val t3 = pUseExtraAttack(t2)
    assert(
      // Drawing the javelin consumed the free object interaction
      t1.freeInteractionUsed == true
      // Attack action is used and flagged
      and t2.actionUsed == true
      and t2.attackActionUsed == true
      // Extra attack slot consumed for the halberd strike
      and t3.extraAttacksRemaining == 0
      // Bonus action still available (e.g. Polearm Master butt-end strike)
      and t3.bonusActionUsed == false
      // Reaction untouched
      and t3.reactionAvailable == true
    )
  }

  // Source: https://rpg.stackexchange.com/q/177723
  
  // Can reaction spells be cast without any trigger?
  run qa_reaction_spell_requires_trigger = {
      // RAW: reaction spells (e.g. Shield) can only be cast in response to their
      // specific trigger; mechanically the reaction slot is consumed and only one
      // is available per turn — a second reaction spell is blocked.
      val t0 = FRESH_TURN  // reactionAvailable starts true
      val t1 = pUseReaction(t0)        // spend reaction casting reaction spell (trigger occurred)
      val t2 = pUseReaction(t1)        // attempt second reaction spell — no-op, already spent
      val creature = freshCreature(20)
      // reaction resets at the start of the next turn (not surprised)
      val t3 = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
      assert(
          t0.reactionAvailable == true      // reaction available before use
          and t1.reactionAvailable == false // consumed by reaction spell
          and t2.reactionAvailable == false // idempotent: can't cast a second reaction spell
          and t2 == t1                      // state unchanged by second attempt
          and t3.reactionAvailable == true  // reaction is restored at start of next turn
      )
  }

  // Source: https://rpg.stackexchange.com/q/198686
  
  // Is Resilient Sphere opaque and soundproof? — sphere grants total cover, blocking targeting
  run qa_resilient_sphere_total_cover_blocks_targeting = {
      assert(canBeTargeted(TotalCover) == false)
  }
  
  // Is Resilient Sphere opaque and soundproof? — total cover gives 0 AC bonus (targeting blocked, not AC gated)
  run qa_resilient_sphere_total_cover_zero_ac_bonus = {
      assert(coverBonus(TotalCover) == 0)
  }
  
  // Is Resilient Sphere opaque and soundproof? — sphere is transparent: bright light outside = unobscured inside, creature not blinded
  run qa_resilient_sphere_transparent_not_blinded = {
      val obs = pEffectiveObscurement(Bright, false)
      assert(obs == Unobscured and pBlindedByObscurement(obs) == false)
  }
  
  // Is Resilient Sphere opaque and soundproof? — if sphere WERE opaque (dark inside), creature would be blinded by heavy obscurement
  run qa_resilient_sphere_opaque_counterfactual_blinds = {
      val obs = pEffectiveObscurement(Dark, false)
      assert(obs == HeavilyObscured and pBlindedByObscurement(obs) == true)
  }

  // Source: https://rpg.stackexchange.com/q/109595
  
  // Hex spell: extra 1d6 necrotic applies to every attack that hits, not just one
  run qa_hex_extra_d6_applies_to_all_attacks = {
    val maxHp = 30
    val creature = freshCreature(maxHp)
  
    // Pre-resolved dice for two separate attacks against the hexed target
    val weaponDmg1 = 7  // first attack weapon roll (e.g. 1d8 longsword)
    val hexD6_1    = 4  // first hit hex bonus, necrotic
    val weaponDmg2 = 5  // second attack weapon roll (Extra Attack / Scorching Ray bolt 2)
    val hexD6_2    = 2  // second hit hex bonus, necrotic
  
    // Attack 1 hits: weapon damage then hex bonus both applied
    val s1 = pTakeDamage(creature,  weaponDmg1, Slashing,  Set(), Set(), Set(), false)
    val s2 = pTakeDamage(s1,        hexD6_1,    Necrotic,  Set(), Set(), Set(), false)
  
    // Attack 2 hits: hex bonus fires AGAIN because the trigger is "whenever you hit"
    val s3 = pTakeDamage(s2,        weaponDmg2, Slashing,  Set(), Set(), Set(), false)
    val s4 = pTakeDamage(s3,        hexD6_2,    Necrotic,  Set(), Set(), Set(), false)
  
    val expectedHp = maxHp - weaponDmg1 - hexD6_1 - weaponDmg2 - hexD6_2
    assert(s4.hp == expectedHp)
  }

  // Source: https://rpg.stackexchange.com/q/167147
  
  // Is there a name for a single saving throw with multiple DCs?
  // Accepted answer: DMG "Degrees of Failure" — roll 16+ no effect, 10-15 fire damage, 9- fire + exhaustion
  
  run qa_degrees_of_failure_high_dc_no_effect = {
    // Roll meets DC 16 (highest DC) → no effect
    val roll = 16
    val abilityMod = 0
    val profBonus = 3
    val fireDmg = 4
    val creature = freshCreature(30)
    val meetsHighDC = saveSucceeds(roll, abilityMod, false, profBonus, 0, 16)
    val meetsLowDC  = saveSucceeds(roll, abilityMod, false, profBonus, 0, 10)
    val result = if (meetsHighDC) creature
                 else if (meetsLowDC)
                   pTakeDamage(creature, fireDmg, Fire, Set(), Set(), Set(), false)
                 else
                   pAddExhaustion(pTakeDamage(creature, fireDmg, Fire, Set(), Set(), Set(), false), 1)
    assert(meetsHighDC and result.hp == 30 and result.exhaustion == 0)
  }
  
  run qa_degrees_of_failure_partial_fire_only = {
    // Roll meets DC 10 but not DC 16 → fire damage, no exhaustion
    val roll = 12
    val abilityMod = 0
    val profBonus = 3
    val fireDmg = 4
    val creature = freshCreature(30)
    val meetsHighDC = saveSucceeds(roll, abilityMod, false, profBonus, 0, 16)
    val meetsLowDC  = saveSucceeds(roll, abilityMod, false, profBonus, 0, 10)
    val result = if (meetsHighDC) creature
                 else if (meetsLowDC)
                   pTakeDamage(creature, fireDmg, Fire, Set(), Set(), Set(), false)
                 else
                   pAddExhaustion(pTakeDamage(creature, fireDmg, Fire, Set(), Set(), Set(), false), 1)
    assert(not(meetsHighDC) and meetsLowDC and result.hp == 26 and result.exhaustion == 0)
  }
  
  run qa_degrees_of_failure_full_fire_and_exhaustion = {
    // Roll fails DC 10 (lowest DC) → fire damage + 1 exhaustion level
    val roll = 5
    val abilityMod = 0
    val profBonus = 3
    val fireDmg = 4
    val creature = freshCreature(30)
    val meetsHighDC = saveSucceeds(roll, abilityMod, false, profBonus, 0, 16)
    val meetsLowDC  = saveSucceeds(roll, abilityMod, false, profBonus, 0, 10)
    val result = if (meetsHighDC) creature
                 else if (meetsLowDC)
                   pTakeDamage(creature, fireDmg, Fire, Set(), Set(), Set(), false)
                 else
                   pAddExhaustion(pTakeDamage(creature, fireDmg, Fire, Set(), Set(), Set(), false), 1)
    assert(not(meetsHighDC) and not(meetsLowDC) and result.hp == 26 and result.exhaustion == 1)
  }

  // Source: https://rpg.stackexchange.com/q/80253
  
  // Can a 10th Level Bard use Magical Secrets to gain 5th level Paladin spells?
  run qa_bard_magical_secrets_5th_level_spells = {
    // Bard is a full caster: caster level == character level == 10.
    // Magical Secrets rule: may choose any spell of a level you can cast.
    // Verify a 10th-level full caster has 5th-level slots → can cast (and therefore learn) 5th-level spells.
    val casterLevel = 10
    val spellLevel  = 5
    val slotMap = pBuildSlotMap(casterLevel)
    val ss: SpellSlotState = {
      slotsMax:             slotMap,
      slotsCurrent:         slotMap,
      pactSlotsMax:         0,
      pactSlotsCurrent:     0,
      pactSlotLevel:        0,
      concentrationSpellId: "",
    }
    // pCanCastAtLevel checks slotLevel >= spellLevel AND current slots > 0.
    // At caster level 10, pSlotsPerLevel(10, 5) == 2, so the assertion holds.
    assert(pCanCastAtLevel(ss, spellLevel, spellLevel))
  }

  // Source: https://rpg.stackexchange.com/q/170151
  
  // Clockwork Amulet: affects all attack rolls (melee, ranged, spell) identically — no type restriction
  run qa_clockwork_amulet_all_attack_types_equal = {
    // The amulet replaces the d20 with a 10 for any attack roll the wearer makes.
    // resolveAttackRoll applies the same logic regardless of melee, ranged, or spell attack type.
    val bonus = 5
    val ac = 14
    val meleeResult  = resolveAttackRoll(10, bonus, ac, 0)
    val rangedResult = resolveAttackRoll(10, bonus, ac, 0)
    val spellResult  = resolveAttackRoll(10, bonus, ac, 0)
    assert(
      meleeResult  == { hits: true, isCritical: false } and
      rangedResult == { hits: true, isCritical: false } and
      spellResult  == { hits: true, isCritical: false } and
      meleeResult  == rangedResult and
      rangedResult == spellResult
    )
  }
  
  // Clockwork Amulet: d20=10 saves attack rolls that a low natural roll would miss, for any attack type
  run qa_clockwork_amulet_10_beats_low_natural = {
    // Without amulet: d20=3, bonus=5, AC=14 → 8 < 14 → miss regardless of attack type.
    // With amulet:    d20=10, bonus=5, AC=14 → 15 >= 14 → hit, uniformly across all attack types.
    val bonus = 5
    val ac = 14
    val naturalMiss     = resolveAttackRoll(3,  bonus, ac, 0)
    val amuletMelee     = resolveAttackRoll(10, bonus, ac, 0)
    val amuletRanged    = resolveAttackRoll(10, bonus, ac, 0)
    val amuletSpell     = resolveAttackRoll(10, bonus, ac, 0)
    assert(
      not(naturalMiss.hits) and
      amuletMelee.hits  and
      amuletRanged.hits and
      amuletSpell.hits
    )
  }
  
  // Clockwork Amulet: d20=10 still misses when bonus is insufficient for any attack type
  run qa_clockwork_amulet_10_still_misses_when_outmatched = {
    // Amulet is not a guaranteed hit; it just fixes the d20 at 10.
    // d20=10, bonus=2, AC=14 → 12 < 14 → miss for melee, ranged, and spell alike.
    val bonus = 2
    val ac = 14
    val meleeResult  = resolveAttackRoll(10, bonus, ac, 0)
    val rangedResult = resolveAttackRoll(10, bonus, ac, 0)
    val spellResult  = resolveAttackRoll(10, bonus, ac, 0)
    assert(
      not(meleeResult.hits)  and
      not(rangedResult.hits) and
      not(spellResult.hits)  and
      meleeResult == rangedResult and
      rangedResult == spellResult
    )
  }

  // Source: https://rpg.stackexchange.com/q/208935
  
  // Does Remarkable Recovery trigger on third successful death save? — Yes: self-stabilization via saves is identical to external stabilization
  run qa_remarkable_recovery_self_stabilize = {
    // Creature at 0 HP, 2 death save successes already accumulated
    val dying = freshCreature(10)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
      .with("deathSaves", { successes: 2, failures: 0 })
    // Third successful death save (roll 10+) triggers self-stabilization
    val afterThirdSave = pDeathSave(dying, 10)
    // External stabilization (e.g. Medicine check / healer's kit) on an equivalent creature
    val dyingFresh = freshCreature(10)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
    val afterExternalStabilize = pStabilize(dyingFresh)
    // Accepted answer: both paths produce stable == true; the feat triggers in both cases
    assert(
      afterThirdSave.stable == true
      and afterThirdSave.deathSaves.successes == 0
      and afterThirdSave.deathSaves.failures == 0
      and afterExternalStabilize.stable == true
      and afterExternalStabilize.deathSaves.successes == 0
      and afterExternalStabilize.deathSaves.failures == 0
    )
  }
  
  // Accepted answer: rolling each of three sequential death saves (all >= 10) reaches stable == true
  run qa_remarkable_recovery_three_sequential_saves = {
    val dying = freshCreature(20)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
      .with("deathSaves", { successes: 0, failures: 0 })
    val after1 = pDeathSave(dying, 11)
    val after2 = pDeathSave(after1, 14)
    val after3 = pDeathSave(after2, 10)
    // Three successes → stable, still at 0 HP (Remarkable Recovery would then trigger healing)
    assert(after3.stable == true and after3.hp == 0 and after3.dead == false)
  }

  // Source: https://rpg.stackexchange.com/q/70006
  
  // With Spirit Guardians up and Insect Plague: only breaking caster's concentration stops the spell
  run qa_insect_plague_failed_conc_save_ends_spell = {
    // Accepted answer: spell effects cannot be damaged; only breaking caster's concentration stops Insect Plague
    val ss0 = FRESH_SPELL_SLOTS.with("concentrationSpellId", "insect_plague")
    // Caster takes 20 damage → DC = max(20/2, 10) = 10
    val dc = pConcentrationDC(20)
    // Caster fails the CON save → concentration breaks → Insect Plague ends
    val ss1 = pConcentrationCheck(ss0, false)
    assert(dc == 10 and ss1.concentrationSpellId == "")
  }
  
  // With Spirit Guardians up and Insect Plague: spell persists while caster succeeds concentration saves
  run qa_insect_plague_successful_conc_save_sustains_spell = {
    val ss0 = FRESH_SPELL_SLOTS.with("concentrationSpellId", "insect_plague")
    // Caster takes 30 damage → DC = max(30/2, 10) = 15
    val dc = pConcentrationDC(30)
    // Caster succeeds → spell continues regardless of any damage to the swarm
    val ss1 = pConcentrationCheck(ss0, true)
    assert(dc == 15 and ss1.concentrationSpellId == "insect_plague" and isConcentrating(ss1))
  }
  
  // Concentration DC floors at 10 even for low damage (Spirit Guardians tick damage)
  run qa_insect_plague_conc_dc_minimum_ten = {
    // Repeated small hits from Spirit Guardians each require a DC-10 minimum save
    val dc1  = pConcentrationDC(1)
    val dc5  = pConcentrationDC(5)
    val dc10 = pConcentrationDC(10)
    val dc22 = pConcentrationDC(22)
    assert(dc1 == 10 and dc5 == 10 and dc10 == 10 and dc22 == 11)
  }
  
  // Damaging the caster is the only lever: death/incapacitation also breaks concentration
  run qa_insect_plague_caster_death_breaks_concentration = {
    val caster0 = freshCreature(10)
    val ss0 = FRESH_SPELL_SLOTS.with("concentrationSpellId", "insect_plague")
    // Caster drops to 0 HP (lethal damage with overflow >= maxHp → dead)
    val caster1 = pTakeDamage(caster0, 25, Slashing, Set(), Set(), Set(), false)
    // Breaking concentration on state-change (death)
    val ss1 = pBreakConcOnStateChange(ss0, caster0, caster1)
    assert(caster1.dead and ss1.concentrationSpellId == "")
  }

  // Source: https://rpg.stackexchange.com/q/101904
  
  // How high can a PC jump normally?
  run qa_high_jump_running_start = {
    // STR 16 (mod +3): 3 + 3 = 6 feet with ≥10 ft running start
    assert(pHighJumpHeight(16, true) == 6)
  }
  
  // How high can a PC jump normally?
  run qa_high_jump_standing = {
    // STR 16 (mod +3): half of 6 = 3 feet without running start
    assert(pHighJumpHeight(16, false) == 3)
  }
  
  // How high can a PC jump normally? — movement cost is foot-for-foot
  run qa_high_jump_costs_movement = {
    // Jumping 6 feet high costs exactly 6 feet of movement
    val jumpHeight = pHighJumpHeight(16, true)
    val t1 = pUseMovement(FRESH_TURN, jumpHeight, 1)
    assert(t1.movementRemaining == FRESH_TURN.movementRemaining - jumpHeight)
  }
  
  // How high can a PC jump normally? — minimum height is zero
  run qa_high_jump_min_zero = {
    // STR 1 (mod -5): max(0, 3 + (-5)) = 0 — height never negative
    assert(pHighJumpHeight(1, true) == 0)
  }
  
  // How high can a PC jump normally? — standing jump is half running jump
  run qa_high_jump_standing_half_of_running = {
    // For any STR score the standing height is floor(running / 2)
    val running = pHighJumpHeight(14, true)   // mod +2 → 5 ft
    val standing = pHighJumpHeight(14, false)  // 5 / 2 = 2 ft (integer division)
    assert(standing == running / 2)
  }

  // Source: https://rpg.stackexchange.com/q/211315
  
  // D&D 5e: Does the same spell prepared for different levels count as multiple prepared spells or the same prepared single spell?
  run qa_prepared_spell_single_entry_multiple_slot_levels = {
    // A level-4 cleric with 1st- and 2nd-level slots available.
    // Healing Word is a 1st-level spell prepared exactly once.
    // The spec separates preparation (not tracked) from slot expenditure,
    // encoding the PHB rule: one prepared spell entry, cast at any slot level >= spell level.
    val ss = {
      slotsMax: Map(1 -> 3, 2 -> 2, 3 -> 0, 4 -> 0, 5 -> 0, 6 -> 0, 7 -> 0, 8 -> 0, 9 -> 0),
      slotsCurrent: Map(1 -> 3, 2 -> 2, 3 -> 0, 4 -> 0, 5 -> 0, 6 -> 0, 7 -> 0, 8 -> 0, 9 -> 0),
      pactSlotsMax: 0,
      pactSlotsCurrent: 0,
      pactSlotLevel: 0,
      concentrationSpellId: "",
    }
    // Healing Word (spellLevel=1) can be cast with a 1st-level slot (normal cast)
    val canCastAtLevel1 = pCanCastAtLevel(ss, 1, 1)
    // ...or upcast with a 2nd-level slot — no second preparation required
    val canCastAtLevel2 = pCanCastAtLevel(ss, 1, 2)
    // Upcasting (expending a 2nd-level slot) does not affect 1st-level slots
    val ssAfterUpcast = pExpendSlot(ss, 2)
    val level1SlotsUntouched = ssAfterUpcast.slotsCurrent.get(1) == 3
    val level2SlotDecremented = ssAfterUpcast.slotsCurrent.get(2) == 1
    assert(canCastAtLevel1 and canCastAtLevel2 and level1SlotsUntouched and level2SlotDecremented)
  }

  // Source: https://rpg.stackexchange.com/q/208605
  
  // Does Halfling's Brave trait grant advantage on Bodak's Death Gaze?
  run qa_brave_not_apply_death_gaze = {
    // Brave grants advantage on saves against being frightened.
    // Death Gaze is a DC 13 CON save that does NOT impose the frightened condition → Brave does not apply.
    val deathGazeImposesfrightened = false
    val braveApplies = deathGazeImposesfrightened // false: Brave only triggers on frightened-imposing saves
    val advState = resolveAdvantage({ hasAdvantage: braveApplies, hasDisadvantage: false })
    assert(not(advState.hasAdvantage) and not(advState.hasDisadvantage))
  }
  
  // Brave trait grants advantage only when the saving throw would impose the frightened condition (contrast case)
  run qa_brave_applies_only_when_frightened_imposed = {
    // A save that DOES impose frightened (e.g. a fear spell) → Brave applies → advantage
    val saveImposesfrightened = true
    val braveApplies = saveImposesfrightened // true
    val advState = resolveAdvantage({ hasAdvantage: braveApplies, hasDisadvantage: false })
    assert(advState.hasAdvantage and not(advState.hasDisadvantage))
  }
  
  // Death Gaze save outcome is identical for halfling and non-halfling: Brave confers no benefit
  run qa_brave_no_benefit_on_death_gaze_outcome = {
    val deathGazeDC = 13
    val conMod = 1       // e.g. CON 12 halfling
    val isProficient = false
    val profBonus = 2
    val roll = 11        // 11 + 1 = 12 < 13: fails without advantage
  
    // Brave would grant advantage only if frightened were being imposed — it is not
    val deathGazeImposesfrightened = false
    val braveApplies = deathGazeImposesfrightened // false → no reroll available
  
    // With no advantage, the halfling resolves the save at face value
    val saveResult = saveSucceeds(roll, conMod, isProficient, profBonus, 0, deathGazeDC)
    assert(not(saveResult) and not(braveApplies))
  }

  // Source: https://rpg.stackexchange.com/q/213750
  
  // Is a Cleric multiclass the only way to gain Heavy Armor proficiency with a 1 level dip?
  run qa_fighter_multiclass_dip_no_heavy_armor = {
    // PHB 2024: multiclassing into Fighter grants only Light + Medium armor, not Heavy
    val sorcererFighterProfs = Set(LightArmor, MediumArmor)
    assert(lacksArmorProficiency(WearingArmor(PLATE), sorcererFighterProfs))
  }
  
  // Is a Cleric multiclass the only way to gain Heavy Armor proficiency with a 1 level dip?
  run qa_paladin_multiclass_dip_no_heavy_armor = {
    // PHB 2024: multiclassing into Paladin grants only Light + Medium armor + Shields, not Heavy
    val sorcererPaladinProfs = Set(LightArmor, MediumArmor)
    assert(lacksArmorProficiency(WearingArmor(PLATE), sorcererPaladinProfs))
  }
  
  // Is a Cleric multiclass the only way to gain Heavy Armor proficiency with a 1 level dip?
  run qa_cleric_protector_dip_grants_heavy_armor = {
    // PHB 2024: Cleric (Protector Divine Order) grants Heavy Armor proficiency at 1st level
    val sorcererClericProtectorProfs = Set(LightArmor, MediumArmor, HeavyArmor)
    assert(not(lacksArmorProficiency(WearingArmor(PLATE), sorcererClericProtectorProfs)))
  }
  
  // Is a Cleric multiclass the only way to gain Heavy Armor proficiency with a 1 level dip?
  run qa_cleric_multiclass_prereq_wis_13 = {
    // PHB 2024: Cleric multiclass requires WIS 13; a Sorcerer with WIS 13 can qualify
    val sorcererScores = Map(Str -> 10, Dex -> 8, Con -> 14, Int_ -> 10, Wis -> 13, Cha -> 16)
    assert(pMeetsMulticlassPrereq(sorcererScores, Cleric))
  }

  // Source: https://rpg.stackexchange.com/q/94032
  
  // When does Arcane Ward gain hit points? — ward recharges on ANY abjuration cast, not only at 0 HP
  run qa_arcane_ward_recharges_at_partial_hp = {
    // Ward max HP = 2 * wizardLevel + intMod; use TEST_CONFIG: level 5, INT 10 → mod 0 → max 10
    val wardMaxHp = 2 * 5 + abilityModifier(10)
    val wardPartial = freshCreature(wardMaxHp).with("hp", 5)
    // Cast 2nd-level abjuration spell: recharge = 2 * spellLevel = 4
    val spellLevel = 2
    val wardAfter = pHeal(wardPartial, 2 * spellLevel)
    assert(wardAfter.hp == 9)
  }
  
  // When does Arcane Ward gain hit points? — recharge also applies when ward is at 0 HP
  run qa_arcane_ward_recharges_at_zero_hp = {
    val wardMaxHp = 2 * 5 + abilityModifier(10)
    val wardEmpty = freshCreature(wardMaxHp).with("hp", 0)
    // Cast 1st-level abjuration spell: recharge = 2 * 1 = 2
    val wardAfter = pHeal(wardEmpty, 2 * 1)
    assert(wardAfter.hp == 2)
  }
  
  // When does Arcane Ward gain hit points? — recharge is capped at ward's hit point maximum
  run qa_arcane_ward_recharge_caps_at_max_hp = {
    val wardMaxHp = 2 * 5 + abilityModifier(10)  // 10
    val wardNearFull = freshCreature(wardMaxHp).with("hp", 8)
    // Cast 3rd-level abjuration spell: recharge = 6, would overflow to 14 but caps at 10
    val wardAfter = pHeal(wardNearFull, 2 * 3)
    assert(wardAfter.hp == wardMaxHp)
  }

  // Source: https://rpg.stackexchange.com/q/92092
  
  // Does sneak attack work against an invisible enemy?
  // Case 1: invisible target only → disadvantage persists → cannot sneak attack despite ally adjacent
  run qa_sneak_attack_invisible_disadv_blocks = {
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: true,       // target can see the rogue
      attackerCanSeeTarget: false,      // target is invisible → rogue can't see it
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    // PHB p.96: sneak attack requires advantage OR (ally adjacent AND no disadvantage on the roll)
    val allyAdjacent = true
    val canSneakAttack = mods.hasAdvantage or (allyAdjacent and not(mods.hasDisadvantage))
    // invisible target → disadvantage with no countervailing advantage → sneak attack blocked
    assert(mods.hasDisadvantage and not(mods.hasAdvantage) and not(canSneakAttack))
  }
  
  // Does sneak attack work against an invisible enemy?
  // Case 2: invisible target + rogue hidden (advantage) + ally adjacent → adv+disadv cancel → sneak attack allowed
  run qa_sneak_attack_invisible_hidden_cancels = {
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: false,      // rogue is hidden → target can't see attacker → advantage
      attackerCanSeeTarget: false,      // target is invisible → rogue can't see target → disadvantage
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    // PHB p.173: adv + disadv cancel to neither
    // PHB p.96: ally adjacent AND no disadvantage → sneak attack allowed
    val allyAdjacent = true
    val canSneakAttack = mods.hasAdvantage or (allyAdjacent and not(mods.hasDisadvantage))
    assert(not(mods.hasAdvantage) and not(mods.hasDisadvantage) and canSneakAttack)
  }

  // Source: https://rpg.stackexchange.com/q/136006
  
  // Is the AC of a Mirror Image Duplicate fixed at Point of Casting?
  run qa_mirror_image_duplicate_ac_tracks_dex = {
      // Accepted answer: duplicate AC = 10 + DEX mod, recalculates as DEX changes
      val dexAtCast    = 14  // mod +2 → duplicate AC 12 at cast time
      val dexAfterBuff = 18  // mod +4 → e.g. Dexterity-boosting spell/item applied mid-duration
      val dexAfterNerf = 8   // mod -1 → e.g. ability drain reduces DEX during duration
  
      val duplicateAC_atCast    = 10 + abilityModifier(dexAtCast)
      val duplicateAC_afterBuff = 10 + abilityModifier(dexAfterBuff)
      val duplicateAC_afterNerf = 10 + abilityModifier(dexAfterNerf)
  
      assert(
          // baseline
          duplicateAC_atCast    == 12
          // DEX increases → duplicate AC increases (not locked at 12)
          and duplicateAC_afterBuff == 14
          and duplicateAC_afterBuff != duplicateAC_atCast
          // DEX decreases → duplicate AC decreases (not locked at 12)
          and duplicateAC_afterNerf == 9
          and duplicateAC_afterNerf != duplicateAC_atCast
      )
  }

  // Source: https://rpg.stackexchange.com/q/60523
  
  // Can a wizard have more than one Alarm spell active at once?
  run qa_multiple_alarm_spells_active = {
    // Alarm is non-concentration: casting it does NOT call pStartConcentration.
    // Multiple instances are modeled by repeated casts that never touch concentrationSpellId.
    val ss0 = FRESH_SPELL_SLOTS
    // Cast alarm instance 1 (non-concentration — no pStartConcentration call)
    val ss1 = ss0
    // Cast alarm instance 2 (non-concentration — no pStartConcentration call)
    val ss2 = ss1
    // Contrast: a concentration spell IS exclusive — pStartConcentration replaces the active one
    val ss_conc_a = pStartConcentration(ss0, "hold_person")
    val ss_conc_b = pStartConcentration(ss_conc_a, "web")
    assert(
      // Both Alarm instances coexist: concentration slot never occupied
      not(isConcentrating(ss2)) and
      ss2.concentrationSpellId == "" and
      // Concentration spells are mutually exclusive: second cast evicts the first
      isConcentrating(ss_conc_a) and
      ss_conc_a.concentrationSpellId == "hold_person" and
      ss_conc_b.concentrationSpellId == "web"
    )
  }

  // Source: https://rpg.stackexchange.com/q/58551
  
  // Can I use a Familiar or a Ranger Companion as temporary mount?
  run qa_panther_push_drag_lift_capacity = {
    // Panther STR 14 can push/drag/lift 30×STR = 420 lbs (well over a ~95 lb elf)
    assert(pushDragLift(14, Medium) == 420)
  }
  
  // Can I use a Familiar or a Ranger Companion as temporary mount?
  run qa_panther_drag_elf_within_capacity = {
    // A 95-lb elf is within the panther's push/drag/lift limit
    assert(pushDragLift(14, Medium) >= 95)
  }
  
  // Can I use a Familiar or a Ranger Companion as temporary mount?
  run qa_panther_cannot_be_ridden_same_size = {
    // Mount must be at least one size larger than rider; Medium panther cannot carry Medium rider
    val mountSize = Medium
    val riderSize = Medium
    assert(not(sizeOrd(mountSize) >= sizeOrd(riderSize) + 1))
  }

  // Source: https://rpg.stackexchange.com/q/115258
  
  // Is there a proper way to handle large combat engagements with party members involved?
  // Accepted answer: no RAW mass combat rules; each creature uses standard individual combat.
  // Test encodes the described combatants: leather armor, longsword, level-1 militia/bandits.
  run qa_individual_combat_still_applies_in_large_battle = {
    // Leather armor on DEX 10 combatant -> AC 11
    val banditAC = calculateAC(WearingArmor(LEATHER), abilityModifier(10), false, NoUnarmoredDefense, 0, 0)
    // Level-1 attacker, STR 10: attack bonus = mod(0) + prof(+2) = +2
    val atkBonus = abilityModifier(10) + proficiencyBonus(1)
    // d20=9: 9+2=11 >= 11 -> hits exactly at AC threshold
    val hitResult = resolveAttackRoll(9, atkBonus, banditAC, 0)
    // d20=8: 8+2=10 < 11 -> misses
    val missResult = resolveAttackRoll(8, atkBonus, banditAC, 0)
    // Longsword (1d8 slashing): roll 6 + STR mod 0 = 6 damage
    val dmg = normalDamage(6, abilityModifier(10))
    assert(
      banditAC == 11
      and proficiencyBonus(1) == 2
      and hitResult.hits
      and not(hitResult.isCritical)
      and not(missResult.hits)
      and dmg == 6
    )
  }

  // Source: https://rpg.stackexchange.com/q/150355
  
  // Q: How often can a PC check with passive perception during a combat turn?
  // A: Passive Perception is a static formula (10 + mod + prof), not a rollable check; active Perception requires the Search action and is limited to once per turn.
  
  // Passive Perception is a fixed baseline — same value every time, no dice involved
  run qa_passive_perception_is_static_baseline = {
    val dexMod    = abilityModifier(12)     // score 12 → +1
    val profBonus = proficiencyBonus(5)     // level 5  → +3
    val pp = passiveCheck(dexMod, Proficient, profBonus, false, false)
    assert(pp == 14)                        // 10 + 1 + 3 = 14, identical on every "check"
  }
  
  // Active Perception (Search action) consumes the creature's one action for the turn
  run qa_active_perception_search_uses_action = {
    val creature = freshCreature(10)
    val t1 = pUseAction(FRESH_TURN, creature, ASearch)
    assert(t1.actionUsed == true)
  }
  
  // Once the action is spent, a second Search attempt is silently blocked — only one per turn
  run qa_active_perception_only_once_per_turn = {
    val creature = freshCreature(10)
    val t1 = pUseAction(FRESH_TURN, creature, ASearch)
    val t2 = pUseAction(t1, creature, ASearch)  // second attempt with action already used
    assert(t1 == t2)
  }
  
  // Passive Perception advantage adds exactly +5 (PHB rule), still no dice — it's a fixed modifier
  run qa_passive_perception_advantage_adds_5 = {
    val dexMod    = abilityModifier(14)     // score 14 → +2
    val profBonus = proficiencyBonus(5)     // level 5  → +3
    val ppNormal    = passiveCheck(dexMod, Proficient, profBonus, false, false)  // 15
    val ppAdvantage = passiveCheck(dexMod, Proficient, profBonus, true,  false)  // 20
    assert(ppAdvantage == ppNormal + 5)
  }

  // Source: https://rpg.stackexchange.com/q/77062
  
  // SKIP: Neither Flaming Sphere nor Pyrotechnics are modeled in the spec; the accepted answer is explicitly a DM judgment call with no assertable mechanical rule — no PHB-defined resolution function exists for spell-extinguishes-magical-fire interactions.

  // Source: https://rpg.stackexchange.com/q/185578
  
  // Tale of the Renowned Duelist: melee spell attack uses feature's 30 ft range, not caster's 5 ft reach
  run qa_tale_renowned_duelist_range = {
    // Clean attacker/target state: no conditions, no special modifiers
    val ctxAt5ft: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false, targetParalyzed: false, targetPetrified: false,
      targetStunned: false, targetUnconscious: false, targetRestrained: false, targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false, targetCanSeeAttacker: true, attackerCanSeeTarget: true,
      isRangedAttack: false, // melee spell attack — not classified as ranged
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false, squeezing: false,
      underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    // Same attack but attacker is 30 ft away (outside normal 5 ft melee reach)
    val ctxAt30ft = ctxAt5ft.with("attackerWithin5ft", false)
    val modsAt5ft  = pAggregateAttackMods(ctxAt5ft)
    val modsAt30ft = pAggregateAttackMods(ctxAt30ft)
    // isRangedAttack=false => disadv_rangedBeyondNormal and disadv_rangedCloseQuarters never fire,
    // so being outside 5 ft reach adds no disadvantage — the feature's 30 ft range governs validity
    assert(
      not(modsAt30ft.hasDisadvantage) and
      not(modsAt30ft.autoMiss)        and
      modsAt5ft == modsAt30ft         // identical resolution at 5 ft vs 30 ft within feature range
    )
  }

  // Source: https://rpg.stackexchange.com/q/99916
  
  // How does multi-classing Sorcerer/Bard total spell slots work at lv 20/20?
  // Both are full casters; caster level at 4/1 = 5, slots follow PHB table
  run qa_multiclass_sorcerer4_bard1_caster_level_5 = {
    // Sorcerer + Bard are both full casters: fullLevels = 4 + 1 = 5
    val casterLevel = pMulticlassCasterLevel(5, 0, 0)
    val slots = pBuildSlotMap(casterLevel)
    assert(
      casterLevel == 5
      and slots.get(1) == 4
      and slots.get(2) == 3
      and slots.get(3) == 2
      and slots.get(4) == 0
      and slots.get(9) == 0
    )
  }
  
  // How does multi-classing Sorcerer/Bard total spell slots work at lv 20/20?
  // Max character level is 20; table caps there — only 1 ninth-level slot, never more
  run qa_multiclass_full_casters_cap_at_character_level_20 = {
    // Character level cannot exceed 20; two full casters at 10/10 = caster level 20
    val casterLevel = pMulticlassCasterLevel(20, 0, 0)
    assert(
      casterLevel == 20
      and pSlotsPerLevel(20, 9) == 1
      and pSlotsPerLevel(20, 7) == 2
      and pSlotsPerLevel(20, 6) == 2
    )
  }

  // Source: https://rpg.stackexchange.com/q/57711
  
  // "What happens after T-Rex Grapples a creature in its mouth?" — restrained target gives attacker advantage; must still roll to hit (no auto-hit)
  run qa_restrained_target_grants_attacker_advantage = {
    // A creature grappled in the T-Rex's mouth is also restrained.
    // Restrained condition → attackers have advantage on rolls against it (PHB p.292).
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: true,   // grappled-in-mouth → restrained
      targetProne: false,
      attackerWithin5ft: false, // T-Rex reach is 10 ft
      targetDodging: false,
      targetCanSeeAttacker: true,
      attackerCanSeeTarget: true,
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(mods.hasAdvantage == true and mods.hasDisadvantage == false and mods.autoMiss == false and mods.autoCrit == false)
  }
  
  // "What happens after T-Rex Grapples a creature in its mouth?" — no auto-hit; T-Rex must still roll to hit (low roll misses)
  run qa_restrained_bite_still_requires_roll_to_hit = {
    // RAW: no auto-hit even when target is held in mouth. Roll 3 + 10 bonus = 13 vs AC 15 → miss.
    val result = resolveAttackRoll(3, 10, 15, 0)
    assert(result.hits == false and result.isCritical == false)
  }
  
  // "What happens after T-Rex Grapples a creature in its mouth?" — with advantage, a strong roll hits normally
  run qa_restrained_bite_hits_on_sufficient_roll = {
    // Roll 10 + 10 bonus = 20 vs AC 17 → hits (not a crit, not auto-miss)
    val result = resolveAttackRoll(10, 10, 17, 0)
    assert(result.hits == true and result.isCritical == false)
  }

  // Source: https://rpg.stackexchange.com/q/159725
  
  // Exchanging control of a mount: second rider spends half their movement to take control (PHB Ch9)
  run qa_new_rider_mount_costs_half_speed = {
    val afterMount = pMountOrDismount(FRESH_TURN)
    assert(afterMount.movementRemaining == FRESH_TURN.movementRemaining - FRESH_TURN.effectiveSpeed / 2)
  }
  
  // Exchanging control of a mount: cannot take control if rider's speed is 0 (PHB Ch9)
  run qa_cannot_take_control_at_zero_speed = {
    val zeroTurn = FRESH_TURN.with("effectiveSpeed", 0).with("movementRemaining", 0)
    assert(pMountOrDismount(zeroTurn) == zeroTurn)
  }
  
  // Exchanging control of a mount: cannot take control if remaining movement less than half speed (PHB Ch9)
  run qa_cannot_take_control_insufficient_movement = {
    // effectiveSpeed=30 so cost=15, but only 10ft remaining
    val lowMoveTurn = FRESH_TURN.with("movementRemaining", 10).with("effectiveSpeed", 30)
    assert(pMountOrDismount(lowMoveTurn) == lowMoveTurn)
  }
  
  // Exchanging control of a mount: mount's new initiative turn gives full fresh action economy (PHB Ch9)
  run qa_mount_fresh_turn_grants_full_mab = {
    val mountCreature = freshCreature(50).with("hitDiceRemaining", 3)
    // Model mount regaining its full MAB (action, bonus action, movement) on its next turn
    val mountTurn = pStartTurn(TEST_CONFIG, mountCreature, Unarmored, false, 0, false, false)
    assert(
      not(mountTurn.actionUsed) and
      not(mountTurn.bonusActionUsed) and
      mountTurn.movementRemaining == TEST_CONFIG.speeds.get(Walk)
    )
  }

  // Source: https://rpg.stackexchange.com/q/94850
  
  // When an ability lets you reduce a creature's speed to 0, does it include fly/swim/climb speed?
  run qa_speed_zero_flying_creature_falls = {
    val creature = freshCreature(50)
    // PHB p.191: flying creature with speed reduced to 0 falls (no hover, not held aloft by magic)
    assert(pFlyingCreatureFalls(creature, 0, false, false) == true)
  }
  
  // When an ability lets you reduce a creature's speed to 0, does it include fly/swim/climb speed?
  run qa_speed_zero_hover_prevents_fall = {
    val creature = freshCreature(50)
    // Exception: hover ability exempts creature from falling even when speed is 0
    assert(pFlyingCreatureFalls(creature, 0, true, false) == false)
  }
  
  // When an ability lets you reduce a creature's speed to 0, does it include fly/swim/climb speed?
  run qa_speed_zero_magic_aloft_prevents_fall = {
    val creature = freshCreature(50)
    // Exception: held aloft by magic (e.g. fly spell) also exempts from falling at speed 0
    assert(pFlyingCreatureFalls(creature, 0, false, true) == false)
  }
  
  // When an ability lets you reduce a creature's speed to 0, does it include fly/swim/climb speed?
  run qa_speed_zero_cannot_switch_to_fly_speed = {
    // PHB p.190: switching speeds subtracts distance already moved from new speed
    // If all speeds are reduced to 0, switching to fly speed (also 0) yields newRemaining = 0 - 0 = 0
    val t = FRESH_TURN.with("movementRemaining", 0).with("effectiveSpeed", 0)
    val t2 = pSwitchSpeedType(t, 0, 0)
    // newRemaining <= 0 → returns unchanged, fly speed unavailable
    assert(t2.movementRemaining == 0 and t2.effectiveSpeed == 0)
  }
  
  // When an ability lets you reduce a creature's speed to 0, does it include fly/swim/climb speed?
  run qa_speed_zero_no_movement_spendable = {
    // With movement reduced to 0, pUseMovement refuses any spend (climb, swim, etc. all depend on speed)
    val t = FRESH_TURN.with("movementRemaining", 0).with("effectiveSpeed", 0)
    val t2 = pUseMovement(t, 5, 1)
    assert(t2.movementRemaining == 0)
  }

  // Source: https://rpg.stackexchange.com/q/99770
  
  // Wizard/Sorcerer can pick any simple weapon as starting equipment; without weapon proficiency no bonus applies
  run qa_weapon_no_proficiency_omits_prof_bonus = {
    // Level 1 caster, STR mod 0, target AC 13, roll 11
    // Proficient: 11 + profBonus(1)=2 = 13 >= 13 → hits
    // Not proficient (chose a non-proficient simple weapon): 11 + 0 = 11 < 13 → misses
    val profBonus   = proficiencyBonus(1)
    val withProf    = resolveAttackRoll(11, profBonus, 13, 0)
    val withoutProf = resolveAttackRoll(11, 0, 13, 0)
    assert(withProf.hits and not(withoutProf.hits))
  }

  // Source: https://rpg.stackexchange.com/q/176482
  
  // Total distance per day for different travel paces? (multiples of 6 for hex maps)
  run qa_travel_pace_daily_distances_are_multiples_of_6 = {
    // Daily values (30/24/18) are not simply hourly × 8; all are multiples of 6
    val fastDay    = pTravelMilesPerDay(PaceFast)
    val normalDay  = pTravelMilesPerDay(PaceNormal)
    val slowDay    = pTravelMilesPerDay(PaceSlow)
    val fastHour   = pTravelMilesPerHour(PaceFast)
    val normalHour = pTravelMilesPerHour(PaceNormal)
    val slowHour   = pTravelMilesPerHour(PaceSlow)
    assert(and {
      // PHB table values are exactly 30/24/18
      fastDay   == 30,
      normalDay == 24,
      slowDay   == 18,
      // All are multiples of 6 (5/4/3 hexes at 6 miles/hex)
      fastDay   % 6 == 0,
      normalDay % 6 == 0,
      slowDay   % 6 == 0,
      // Fast and Slow deliberately differ from hourly × 8
      fastDay  != fastHour   * 8,  // 30 ≠ 32
      slowDay  != slowHour   * 8,  // 18 ≠ 16
      // Normal coincidentally matches
      normalDay == normalHour * 8,
      // Fast is 2 miles less than naïve hourly calc; Slow is 2 miles more
      fastHour   * 8 - fastDay  == 2,
      slowDay    - slowHour * 8 == 2,
    })
  }

  // Source: https://rpg.stackexchange.com/q/83817
  
  // How does Expertise work? — Expertise doubles only the proficiency bonus, not the full skill bonus
  run qa_expertise_doubles_proficiency_only = {
    val profBonus = 2   // level 1-4 proficiency bonus
    val wisMod    = 2   // Wisdom modifier (+2)
    val expertiseContribution = profMultiplier(Expertise,   profBonus) // 2*2 = 4
    val normalContribution    = profMultiplier(Proficient,  profBonus) // 1*2 = 2
    assert(
      // Expertise contribution is double the proficiency bonus only
      expertiseContribution == 4
      // Total Perception with Expertise = wisMod + doubled profBonus = 2 + 4 = 6
      and (wisMod + expertiseContribution) == 6
      // NOT the wrong answer: doubling the full bonus (wisMod + profBonus)*2 = 8
      and (wisMod + expertiseContribution) != (wisMod + normalContribution) * 2
    )
  }

  // Source: https://rpg.stackexchange.com/q/93743
  
  // Is it possible to combo Create Water + Lightning Bolt for extra damage via vulnerability?
  run qa_wet_vulnerability_doubles_lightning_too_strong = {
    // Accepted answer: vulnerability is too strong — doubles damage, don't grant it
    val baseDamage = 28 // average 8d6 lightning bolt
    val withVulnerability = applyDamageModifiers(baseDamage, Lightning, Set(), Set(), Set(Lightning))
    val withNoMod = applyDamageModifiers(baseDamage, Lightning, Set(), Set(), Set())
    // Vulnerability doubles 28 → 56; balanced ruling keeps it at 28
    assert(withVulnerability == 56 and withNoMod == 28 and withVulnerability == withNoMod * 2)
  }
  
  // Is it possible to combo Create Water + Lightning Bolt for extra damage via disadvantage on save?
  run qa_wet_disadvantage_dex_save_correct_ruling = {
    // Accepted answer: grant disadvantage on DEX save instead — balanced, within DM discretion (DMG 239)
    // Disadvantage = take lower of two d20 rolls
    val dexMod = 2        // typical creature
    val dc = 14           // typical wizard lightning bolt DC (8 + 4 prof + 2 INT mod at level 5)
    val highRoll = 15     // 15+2=17 >= 14, would normally save for half
    val lowRoll = 7       // 7+2=9 < 14, fails save → takes full 28 damage
    val saveNormal = saveSucceeds(highRoll, dexMod, false, 0, 0, dc)
    val saveWithDisadvantage = saveSucceeds(lowRoll, dexMod, false, 0, 0, dc)
    // With disadvantage the creature uses the lower roll and fails where it would otherwise succeed
    assert(saveNormal and not(saveWithDisadvantage))
  }

  // Source: https://rpg.stackexchange.com/q/136964
  
  // Can I drag a grappled creature and release it after moving half of my speed, then move the remainder of my speed?
  run qa_grapple_release_movement_recalculation = {
    val creature = freshCreature(20)
    // Turn started while dragging a grappled creature (not two sizes smaller) → effectiveSpeed halved to 15
    val t0 = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, true, false)
    // Move 15 feet (entire halved budget) at normal terrain cost
    val t1 = pUseMovement(t0, 15, 1)
    // Release grapple mid-turn: speed returns to 30; recalculate via PHB formula
    // movementLeft = newSpeed - distanceAlreadyMoved = 30 - 15 = 15
    val t2 = pSwitchSpeedType(t1, 30, 15)
    assert(
      t0.effectiveSpeed == 15     and  // halved while dragging
      t1.movementRemaining == 0   and  // all halved budget spent
      t2.effectiveSpeed == 30     and  // speed restored after release
      t2.movementRemaining == 15       // 15 feet remain
    )
  }

  // Source: https://rpg.stackexchange.com/q/103723
  
  // Does Aura of Warding protect you from Warding Bond? — Crawford RAI: Warding Bond damage retains original source type
  // Non-spell origin (sword strike, Slashing): "spell resistance" from Aura of Warding does NOT apply
  run qa_warding_bond_non_spell_no_resistance = {
    // Cleric bonded via Warding Bond; ward took 10 Slashing (sword).
    // Transferred damage is Slashing from a non-spell source.
    // Aura of Warding only covers spell damage → resistances set is empty for this transfer.
    val cleric = freshCreature(20)
    val s1 = pTakeDamage(cleric, 10, Slashing, Set(), Set(), Set(), false)
    // Full 10 damage: spell resistance gives no benefit when original source is not a spell
    assert(s1.hp == 10)
  }
  
  // Does Aura of Warding protect you from Warding Bond? — Crawford RAI: spell-sourced damage retains spell classification
  // Spell origin (Fireball, Fire): Aura of Warding resistance DOES apply because original damage was from a spell
  run qa_warding_bond_spell_origin_resistance_applies = {
    // Cleric bonded via Warding Bond; ward took 10 Fire (Fireball).
    // Transferred damage is Fire and retains its spell-source classification.
    // Caller passes Set(Fire) as resistances because Aura of Warding covers this spell-damage transfer.
    val cleric = freshCreature(20)
    val s1 = pTakeDamage(cleric, 10, Fire, Set(Fire), Set(), Set(), false)
    // 10 / 2 = 5 damage: spell resistance halves it
    assert(s1.hp == 15)
  }

  // Source: https://rpg.stackexchange.com/q/137529
  
  // What skills are Drow proficient in? — Drow racial features grant only Perception (from Elf ancestry), no other skill proficiencies
  run qa_drow_no_skill_proficiencies = {
    val wisMod   = abilityModifier(11)    // WIS 11 → +0
    val profBonus = proficiencyBonus(1)   // level 1 → +2
  
    // Drow receives only Perception (Elf trait); no other skills from race
    val drowSkillProficiencies: Set[Skill] = Set(Perception)
  
    val perceptionProfLevel = if (drowSkillProficiencies.contains(Perception)) Proficient else NoneProf
    val arcanaProfLevel     = if (drowSkillProficiencies.contains(Arcana))     Proficient else NoneProf
    val stealthProfLevel    = if (drowSkillProficiencies.contains(Stealth))    Proficient else NoneProf
  
    // DC 17, roll 15, WIS +0:
    //   Proficient:  15 + 0 + 2 = 17 >= 17 → succeeds
    //   NoneProf:    15 + 0 + 0 = 15 < 17  → fails
    val roll = 15
    val dc   = 17
  
    assert(
      perceptionProfLevel == Proficient
      and arcanaProfLevel  == NoneProf
      and stealthProfLevel == NoneProf
      and     checkSucceeds(roll, wisMod, perceptionProfLevel, profBonus, 0, dc)
      and not(checkSucceeds(roll, wisMod, arcanaProfLevel,     profBonus, 0, dc))
      and not(checkSucceeds(roll, wisMod, stealthProfLevel,    profBonus, 0, dc))
    )
  }

  // Source: https://rpg.stackexchange.com/q/119801
  
  // Does innate spellcasting by creatures have verbal or somatic components?
  run qa_innate_spell_requires_verbal_and_somatic_by_default = {
      // Innate spells follow normal rules: V+S required unless trait says otherwise
      val creature = freshCreature(20)
      assert(pCanProvideComponents(creature, true, true, true))
  }
  
  // Does innate spellcasting by creatures have verbal or somatic components?
  run qa_innate_spell_verbal_blocked_when_paralyzed = {
      // Paralyzed creature cannot speak → cannot provide verbal component (V still required by innate spell)
      val creature = pApplyCondition(freshCreature(20), CParalyzed)
      assert(not(pCanProvideComponents(creature, true, true, true)))
  }
  
  // Does innate spellcasting by creatures have verbal or somatic components?
  run qa_innate_spell_somatic_blocked_without_free_hand = {
      // No free hand → somatic component fails even for an innate spell
      val creature = freshCreature(20)
      assert(not(pCanProvideComponents(creature, false, true, false)))
  }
  
  // Does innate spellcasting by creatures have verbal or somatic components?
  run qa_innate_spell_material_waived_verbal_somatic_still_needed_unconscious = {
      // "No material components" trait waives M only; V+S still required per normal rules.
      // Unconscious creature cannot speak → cannot satisfy verbal component.
      val creature = freshCreature(20)
          .with("unconscious", true)
          .with("prone", true)
          .with("incapacitatedSources", Set(ISUnconscious))
      assert(not(pCanProvideComponents(creature, true, true, true)))
  }
  
  // Does innate spellcasting by creatures have verbal or somatic components?
  run qa_innate_spell_unless_noted_waived_verbal_allows_casting = {
      // "Unless otherwise noted": if a trait explicitly waives V, a creature that cannot speak
      // can still satisfy remaining components (S=true with free hand).
      val creature = pApplyCondition(freshCreature(20), CParalyzed)
      // requiresVerbal=false (trait waived it), requiresSomatic=true, hasFreeHand=true
      assert(pCanProvideComponents(creature, false, true, true))
  }

  // Source: https://rpg.stackexchange.com/q/180499
  
  // Does Voice of the Chain Master allow casting certain spells from an isolated space?
  // Accepted answer: spells with targets require a clear path; Total Cover blocks targeting entirely
  run qa_total_cover_blocks_targeting = {
    assert(canBeTargeted(TotalCover) == false)
  }
  
  // Does Voice of the Chain Master allow casting certain spells from an isolated space?
  // Accepted answer: activating familiar senses costs an action; no action remains to cast a spell on same turn
  run qa_familiar_senses_action_exhausts_action_economy = {
    val creature = freshCreature(20)
    // Spend the action activating familiar senses (modeled as AUseObject)
    val afterSenses = pUseAction(FRESH_TURN, creature, AUseObject)
    // Attempt to also cast a spell as an action — must be blocked
    val afterSpell = pUseAction(afterSenses, creature, ACastSpell)
    assert(afterSenses.actionUsed == true and afterSpell == afterSenses)
  }
  
  // Does Voice of the Chain Master allow casting certain spells from an isolated space?
  // Accepted answer: NoCover / HalfCover / ThreeQuartersCover all allow targeting; only TotalCover does not
  run qa_partial_cover_still_targetable = {
    assert(
      canBeTargeted(NoCover) == true and
      canBeTargeted(HalfCover) == true and
      canBeTargeted(ThreeQuartersCover) == true and
      canBeTargeted(TotalCover) == false
    )
  }

  // Path of the Giant Elemental Cleaver - ranged weapon given Thrown property still uses DEX (still a ranged weapon attack)
  run qa_elemental_cleaver_ranged_thrown_uses_dex = {
    val shortbow_with_thrown: Weapon = {
      name: "shortbow",
      damageDie: 6,
      versatileDie: 0,
      damageType: Piercing,
      properties: Set(Ammunition, Thrown),  // Elemental Cleaver adds Thrown; Ammunition remains
      isMelee: false,                       // ranged weapon: isMelee unchanged by Thrown property
      normalRange: 80,
      longRange: 320,
    }
    val strMod = 2
    val dexMod = 3
    // Adding Thrown to a ranged weapon doesn't make it a melee weapon; DEX still governs
    assert(weaponAttackAbility(shortbow_with_thrown, strMod, dexMod) == dexMod)
  }
  
  // Path of the Giant Elemental Cleaver - contrast: melee weapon given Thrown uses STR (ranged attack with melee weapon)
  run qa_elemental_cleaver_melee_thrown_uses_str = {
    val longsword_with_thrown: Weapon = {
      name: "longsword",
      damageDie: 8,
      versatileDie: 10,
      damageType: Slashing,
      properties: Set(Versatile, Thrown),  // Elemental Cleaver adds Thrown to melee weapon
      isMelee: true,                       // still a melee weapon
      normalRange: 20,
      longRange: 60,
    }
    val strMod = 3
    val dexMod = 2
    // Melee weapon with Thrown uses STR per Thrown property rule; contrast with ranged weapon above
    assert(weaponAttackAbility(longsword_with_thrown, strMod, dexMod) == strMod)
  }
  
  // Path of the Giant Elemental Cleaver - Sneak Attack eligibility: ranged weapon with Thrown still qualifies (finesse OR ranged weapon)
  run qa_elemental_cleaver_sneak_attack_eligible_ranged = {
    val shortbow_with_thrown: Weapon = {
      name: "shortbow",
      damageDie: 6,
      versatileDie: 0,
      damageType: Piercing,
      properties: Set(Ammunition, Thrown),
      isMelee: false,
      normalRange: 80,
      longRange: 320,
    }
    // Sneak Attack requires "finesse or ranged weapon"; ranged weapon = not(isMelee)
    val sneakAttackEligible = shortbow_with_thrown.properties.contains(Finesse)
                              or not(shortbow_with_thrown.isMelee)
    assert(sneakAttackEligible)
  }
  
  // Path of the Giant Elemental Cleaver - Archery Fighting Style +2 applies: weapon is still a ranged weapon after Elemental Cleaver
  run qa_elemental_cleaver_archery_style_applies = {
    val shortbow_with_thrown: Weapon = {
      name: "shortbow",
      damageDie: 6,
      versatileDie: 0,
      damageType: Piercing,
      properties: Set(Ammunition, Thrown),
      isMelee: false,
      normalRange: 80,
      longRange: 320,
    }
    val dexMod = 3
    // Archery Fighting Style: +2 to attack rolls with ranged weapons (not(isMelee))
    val archeryBonus = if (not(shortbow_with_thrown.isMelee)) 2 else 0
    val totalAttackBonus = weaponAttackAbility(shortbow_with_thrown, 1, dexMod) + archeryBonus
    // Roll 13 + 5 (dex 3 + archery 2) = 18 >= AC 17 → hits
    val result = resolveAttackRoll(13, totalAttackBonus, 17, 0)
    assert(result.hits and not(result.isCritical))
  }

  // Source: https://rpg.stackexchange.com/q/206898
  
  // With the Chef feat, can I cook more treats if I spend more hours cooking?
  run qa_chef_treat_grants_prof_bonus_temp_hp = {
    // Core mechanic: eating one Chef treat grants temp HP equal to caster's proficiency bonus
    val lvl = 5
    val pb = proficiencyBonus(lvl)   // (5-1)/4 + 2 = 3
    val eater = freshCreature(20)
    val afterEat = pGrantTempHp(eater, pb, false)
    assert(afterEat.tempHp == pb)
  }
  
  // With the Chef feat, can I cook more treats if I spend more hours cooking?
  run qa_chef_multiple_hours_multiply_batches = {
    // Accepted answer: one batch (= profBonus treats) per hour of work; long rest always one batch
    // 2 hours of work yields 2 batches; long rest yields exactly 1 batch regardless of duration
    val lvl = 5
    val pb = proficiencyBonus(lvl)   // 3
    val treatsFrom1Hour = 1 * pb     // 3
    val treatsFrom2Hours = 2 * pb    // 6
    val treatsFromLongRest = 1 * pb  // always 1 batch = 3, never scaled by rest hours
    assert(
      treatsFrom2Hours == treatsFrom1Hour * 2 and
      treatsFromLongRest == treatsFrom1Hour and
      treatsFrom2Hours > treatsFromLongRest
    )
  }
  
  // With the Chef feat, can I cook more treats if I spend more hours cooking?
  run qa_chef_temp_hp_not_additive = {
    // Accepted answer: temp HP are not additive; eating a second treat of same value never doubles it
    val lvl = 5
    val pb = proficiencyBonus(lvl)   // 3
    // Creature already has temp HP from first treat
    val creature = freshCreature(20).with("tempHp", pb)
    // Player may keep old (same value) or replace (same value) — neither produces 2*pb
    val afterKeepOld = pGrantTempHp(creature, pb, true)
    val afterReplace  = pGrantTempHp(creature, pb, false)
    assert(
      afterKeepOld.tempHp == pb and
      afterReplace.tempHp  == pb and
      afterKeepOld.tempHp != pb * 2
    )
  }

  // Source: https://rpg.stackexchange.com/q/190849
  
  // What happens to breastplate Armor when chosen as Armorer Artificer's Arcane Armor?
  run qa_arcane_armor_breastplate_retains_medium_category = {
    // Arcane Armor only applies its listed benefits; breastplate is still MediumArmor, not HeavyArmor
    assert(BREASTPLATE.category == MediumArmor)
  }
  
  // What happens to breastplate Armor when chosen as Armorer Artificer's Arcane Armor?
  run qa_arcane_armor_breastplate_no_stealth_disadvantage = {
    // Breastplate retains its original stealthDisadvantage: false — Arcane Armor does not add it
    assert(BREASTPLATE.stealthDisadvantage == false)
  }
  
  // What happens to breastplate Armor when chosen as Armorer Artificer's Arcane Armor?
  run qa_arcane_armor_breastplate_retains_base_ac = {
    // Breastplate baseAC stays 14, not 18 (full plate); Arcane Armor does not change the AC value
    assert(BREASTPLATE.baseAC == 14)
  }
  
  // What happens to breastplate Armor when chosen as Armorer Artificer's Arcane Armor?
  run qa_arcane_armor_breastplate_uses_dex_capped_at_2 = {
    // MediumArmor adds DEX mod capped at +2; breastplate does NOT become HeavyArmor (which ignores DEX)
    val dexMod = 3 // e.g. DEX 16
    val acBreastplate = calculateAC(WearingArmor(BREASTPLATE), dexMod, false, NoUnarmoredDefense, 0, 0)
    val acPlate      = calculateAC(WearingArmor(PLATE),       dexMod, false, NoUnarmoredDefense, 0, 0)
    // breastplate: 14 + min(3,2) = 16; full plate (HeavyArmor): 18 + 0 = 18
    assert(acBreastplate == 16 and acPlate == 18)
  }

  // Source: https://rpg.stackexchange.com/q/213482
  
  // What happens when you hide from a creature with Truesight? - heavy obscurement imposes Blinded, blocking sight-based checks
  run qa_truesight_blinded_auto_fails_sight_check = {
    // A Truesight creature blocked by a solid obstacle (heavily obscured target) is
    // effectively Blinded against that creature and auto-fails all sight-required checks.
    val viewer = pApplyCondition(freshCreature(20), CBlinded)
    val mods = pCheckModifiers(viewer, true, false, false) // requiresSight=true
    assert(mods.autoFail)
  }
  
  // What happens when you hide from a creature with Truesight? - Invisible creature behind cover retains condition benefits even vs Truesight
  run qa_truesight_invisible_behind_cover_no_adv = {
    // Truesight creature (attacker) is Blinded by heavy obscurement (rock between them)
    // and cannot see through the obstacle to the invisible/hidden creature (target).
    // The target also cannot see the attacker through the rock.
    // Result: the "unseen attacker" advantage cancels with "blinded attacker" disadvantage
    // → no advantage for Truesight; invisible creature retains its condition's protection.
    val ctx: AttackContext = {
      attackerBlinded: true,             // heavy obscurement = Blinded against that creature
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: false,
      targetDodging: false,
      targetCanSeeAttacker: false,       // hidden creature can't see Truesight creature through rock
      attackerCanSeeTarget: false,       // Truesight can't see through solid obstacle
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    // adv_unseenAttacker (target can't see attacker) + disadv_attackerBlinded + disadv_cantSeeTarget
    // → advantage and disadvantage both present → resolveAdvantage cancels to neither
    // Truesight grants NO advantage against the invisible creature behind cover.
    assert(not(mods.hasAdvantage) and not(mods.hasDisadvantage))
  }

  // Source: https://rpg.stackexchange.com/q/209031
  
  // Can you use Glyph of Warding to prepare for a difficult fight and avoid total party kill?
  run qa_glyph_healing_word_fits_in_3rd_level_slot = {
    // Healing Word is level 1; Glyph of Warding cast at slot 3: slotLevel >= spellLevel → can store
    val ss = FRESH_SPELL_SLOTS
      .with("slotsCurrent", EMPTY_SLOTS.set(3, 2))
      .with("slotsMax", EMPTY_SLOTS.set(3, 2))
    assert(pCanCastAtLevel(ss, 1, 3))
  }
  
  // Can you use Glyph of Warding to prepare for a difficult fight and avoid total party kill?
  run qa_glyph_aura_of_life_blocked_by_3rd_level_slot = {
    // Aura of Life is level 4; Glyph of Warding cast at slot 3: slotLevel < spellLevel → cannot store
    val ss = FRESH_SPELL_SLOTS
      .with("slotsCurrent", EMPTY_SLOTS.set(3, 2))
      .with("slotsMax", EMPTY_SLOTS.set(3, 2))
    assert(not(pCanCastAtLevel(ss, 4, 3)))
  }
  
  // Can you use Glyph of Warding to prepare for a difficult fight and avoid total party kill?
  run qa_glyph_aura_of_life_allowed_when_upcast_to_4th = {
    // Aura of Life is level 4; Glyph of Warding upcast to slot 4: slotLevel >= spellLevel → can store
    val ss = FRESH_SPELL_SLOTS
      .with("slotsCurrent", EMPTY_SLOTS.set(4, 1))
      .with("slotsMax", EMPTY_SLOTS.set(4, 1))
    assert(pCanCastAtLevel(ss, 4, 4))
  }
  
  // Can you use Glyph of Warding to prepare for a difficult fight and avoid total party kill?
  run qa_glyph_casting_expends_the_slot = {
    // Creating a Glyph of Warding expends the slot used to cast it
    val ss = FRESH_SPELL_SLOTS
      .with("slotsCurrent", EMPTY_SLOTS.set(3, 1))
      .with("slotsMax", EMPTY_SLOTS.set(3, 1))
    val ssAfter = pExpendSlot(ss, 3)
    assert(ssAfter.slotsCurrent.get(3) == 0)
  }

  // Source: https://rpg.stackexchange.com/q/143024
  
  // Dueling Fighting Style: not applicable to Shocking Grasp (melee spell attack — no weapon damage roll)
  run qa_dueling_shocking_grasp_no_bonus = {
    // Shocking Grasp is a melee spell attack; Dueling's +2 applies only to weapon damage rolls.
    // Damage = dice only, no Dueling modifier.
    val diceRoll = 6
    val damage = normalDamage(diceRoll, 0)
    assert(damage == 6)
  }
  
  // Dueling Fighting Style: +2 bonus applies to Booming Blade's initial weapon attack damage
  run qa_dueling_booming_blade_initial_weapon_hit = {
    // Booming Blade requires "a melee attack with a weapon"; Dueling's +2 is part of that weapon's damage modifier.
    val weaponDice = 6
    val dexMod = 3       // DEX 16 → +3
    val duelingBonus = 2
    val damage = normalDamage(weaponDice, dexMod + duelingBonus)
    assert(damage == 11)
  }
  
  // Dueling Fighting Style: does NOT apply to Booming Blade's secondary thunder damage (spell effect, not weapon)
  run qa_dueling_booming_blade_secondary_thunder_no_bonus = {
    // The 1d8 thunder damage when the target willingly moves comes from the spell, not from the weapon.
    // Dueling's +2 is not added to this secondary damage instance.
    val thunderDice = 6
    val damage = normalDamage(thunderDice, 0)
    assert(damage == 6)
  }
  
  // Contrast: Booming Blade initial hit exceeds Shocking Grasp by exactly (abilityMod + duelingBonus)
  run qa_dueling_bb_initial_vs_shocking_grasp_contrast = {
    val diceRoll = 5
    val dexMod = 3
    val duelingBonus = 2
    // Shocking Grasp: pure spell damage, no weapon modifiers
    val sgDamage = normalDamage(diceRoll, 0)
    // Booming Blade initial weapon hit: weapon damage + ability mod + Dueling bonus
    val bbInitialDamage = normalDamage(diceRoll, dexMod + duelingBonus)
    // BB secondary thunder: spell damage, same as SG — no Dueling bonus
    val bbThunderDamage = normalDamage(diceRoll, 0)
    assert(
      bbInitialDamage == sgDamage + dexMod + duelingBonus and
      bbThunderDamage == sgDamage
    )
  }

  // Source: https://rpg.stackexchange.com/q/178270
  
  // SKIP: Minor Conjuration placement rules (occupied vs. unoccupied space) require object/space tracking not modeled in the spec; no function covers conjuration target location validation.

  // Source: https://rpg.stackexchange.com/q/82818
  
  // Can Command Undead be used on my own undead created by Create/Animate Undead?
  run qa_command_undead_on_own_created_undead = {
    // Level 10 Wizard, INT 18: spellSaveDC = 8 + prof(4) + intMod(4) = 16
    val wizardConfig: CharConfig = {
      abilityScores: Map(Str -> 10, Dex -> 14, Con -> 12, Int_ -> 18, Wis -> 13, Cha -> 10),
      level: 10,
      size: Medium,
      speeds: Map(Walk -> 30, Fly -> 0, Swim -> 0, Climb -> 0, Burrow -> 0),
      saveProficiencies: Set(Int_, Wis),
      skillProficiencies: Set(Arcana, History),
      expertiseSkills: Set(),
      armorProficiencies: Set(LightArmor),
      hitDieType: 6,
      spellcastingAbility: Int_,
      hasSpellcasting: true,
      canRitualCast: true,
      unarmoredDefense: NoUnarmoredDefense,
      features: Set(),
    }
    val dc = spellSaveDC(wizardConfig)
    // Ghoul/Wight: Wis 6 → mod -2, not proficient in Wis saves
    val undeadWisMod = abilityModifier(6)
    // Low roll: undead fails save → Command Undead establishes control (ownership irrelevant)
    val commandSucceeds = not(saveSucceeds(5, undeadWisMod, false, 2, 0, dc))
    // High roll: undead passes save → Command Undead fails
    val commandFails = saveSucceeds(18, undeadWisMod, false, 2, 0, dc)
    assert(
      // DC is correct
      dc == 16
      // failed Wis save (5 - 2 = 3 < 16) → wizard controls even their own created undead
      and commandSucceeds
      // passed Wis save (18 - 2 = 16 >= 16) → no control granted
      and commandFails
    )
  }

  // Source: https://rpg.stackexchange.com/q/49477
  
  // Does Draconic Resilience stack with shields? Shield +2 always adds to any unarmored AC-setting formula
  run qa_draconic_resilience_shield_stacks = {
    // Draconic Resilience sets AC = 13 + Dex. Spec doesn't model the +3 base offset directly,
    // but the stacking rule is universal: shield bonus adds to whatever sets your base AC.
    // Verified via calculateAC: shieldBonus = 2 is always added on top of any unarmored formula.
    val dexMod = 3
    val acNoShield = calculateAC(Unarmored, dexMod, false, NoUnarmoredDefense, 0, 0)
    val acWithShield = calculateAC(Unarmored, dexMod, true, NoUnarmoredDefense, 0, 0)
    // 10 + 3 = 13 base; +2 shield = 15 (mirrors Draconic: 13+Dex base, 15+Dex with shield)
    assert(acNoShield == 13 and acWithShield == 15 and acWithShield == acNoShield + 2)
  }
  
  // Shield +2 is additive on top of every UnarmoredDefense variant (Barbarian analog to Draconic)
  run qa_shield_stacks_with_barbarian_ud = {
    // Barbarian Unarmored Defense (10+Dex+Con) explicitly allows shields per PHB;
    // Draconic Resilience (10+3+Dex) follows identical stacking logic.
    val dexMod = 2
    val conMod = 3
    val acNoShield = calculateAC(Unarmored, dexMod, false, BarbarianUD, conMod, 0)
    val acWithShield = calculateAC(Unarmored, dexMod, true, BarbarianUD, conMod, 0)
    // 10 + 2 + 3 = 15; with shield = 17
    assert(acNoShield == 15 and acWithShield == 17 and acWithShield == acNoShield + 2)
  }
  
  // Shield delta is exactly +2 regardless of unarmored defense type
  run qa_shield_delta_is_always_two = {
    val dexMod = 1
    val deltaNoUD  = calculateAC(Unarmored, dexMod, true, NoUnarmoredDefense, 0, 0)
                   - calculateAC(Unarmored, dexMod, false, NoUnarmoredDefense, 0, 0)
    val deltaBarbUD = calculateAC(Unarmored, dexMod, true, BarbarianUD, 2, 0)
                    - calculateAC(Unarmored, dexMod, false, BarbarianUD, 2, 0)
    val deltaMonkUD = calculateAC(Unarmored, dexMod, true, MonkUD, 0, 2)
                    - calculateAC(Unarmored, dexMod, false, MonkUD, 0, 2)
    assert(deltaNoUD == 2 and deltaBarbUD == 2 and deltaMonkUD == 2)
  }

  // Source: https://rpg.stackexchange.com/q/96950
  
  // Can a druid in Ape wildshape use weapons? — accepted: proficiency is retained in wild shape
  run qa_wildshape_ape_weapon_proficiency_retained = {
    // Giant Ape STR 28 (mod +9); use a level 5 druid retaining proficiency
    // Demonstrate: same roll hits WITH prof, misses WITHOUT prof
    val apeSuperStrMod = abilityModifier(16) // ape STR 16 → +3 for a normal Ape
    val profBonus     = proficiencyBonus(5)  // level 5 druid → +3
    val attackBonusWithProf    = apeSuperStrMod + profBonus // +6
    val attackBonusWithoutProf = apeSuperStrMod             // +3
    val targetAC = 18
    val roll     = 12
    // Retained proficiency (accepted answer): 12 + 6 = 18 >= 18 → hits
    val withProf    = resolveAttackRoll(roll, attackBonusWithProf,    targetAC, 0)
    // Without proficiency (alt ruling):       12 + 3 = 15 < 18  → misses
    val withoutProf = resolveAttackRoll(roll, attackBonusWithoutProf, targetAC, 0)
    assert(withProf.hits and not(withoutProf.hits))
  }
  
  // Can a druid in Ape wildshape use weapons? — non-finesse melee weapon uses STR modifier
  run qa_wildshape_ape_spear_uses_str_mod = {
    // Spear: melee, Thrown + Versatile, no Finesse → weaponAttackAbility picks STR
    val spear: Weapon = {
      name: "spear",
      damageDie: 6,
      versatileDie: 8,
      damageType: Piercing,
      properties: Set(Thrown, Versatile),
      isMelee: true,
      normalRange: 20,
      longRange: 60,
    }
    val strMod = abilityModifier(16) // ape STR 16 → +3
    val dexMod = abilityModifier(14) // ape DEX 14 → +2
    val chosen = weaponAttackAbility(spear, strMod, dexMod)
    assert(chosen == strMod)
  }

  // Source: https://rpg.stackexchange.com/q/180233
  
  // SKIP: The Suggestion spell and its "to the best of its ability" clause are not modeled in the spec. The accepted answer explicitly rules this undefined — a DM judgment call with no deterministic mechanic. The spec has no functions for spell behavioral constraints on NPCs, nor any model of the tradeoff between a reaction attack and a full Attack action with Extra Attack being "better." Nothing encodable as a testable assertion.

  // Source: https://rpg.stackexchange.com/q/123266
  
  // Power Word Kill -- Max HP or current HP?
  run qa_power_word_kill_threshold_is_current_hp = {
    // Tarrasque-scale creature: maxHp=686, after 587 damage currentHp=99
    // PWK kills if current HP <= 100; max HP > 100 is irrelevant to threshold
    val s0 = freshCreature(686)
    val s1 = pTakeDamage(s0, 587, Slashing, Set(), Set(), Set(), false)
    assert(
      s1.hp == 99 and
      s1.maxHp == 686 and
      s1.hp <= 100 and   // current HP within PWK kill threshold → spell kills
      s1.maxHp > 100     // max HP is above threshold — irrelevant per accepted answer
    )
  }
  
  // Power Word Kill -- Max HP or current HP? (above-threshold, no-effect case)
  run qa_power_word_kill_no_effect_above_threshold = {
    // Same creature at 101 current HP: PWK has no effect
    val s0 = freshCreature(686)
    val s1 = pTakeDamage(s0, 585, Slashing, Set(), Set(), Set(), false)
    assert(s1.hp == 101 and s1.hp > 100)  // above threshold → PWK does nothing
  }

  // Source: https://rpg.stackexchange.com/q/123421
  
  // How to increase survivability in Wild Shape? — Barbarian Rage resistance halves bludgeoning/piercing/slashing
  run qa_wild_shape_rage_resistance_halves_bps = {
    val creature = freshCreature(40)
    val rageResistances = Set(Bludgeoning, Piercing, Slashing)
    val afterBludgeoning = pTakeDamage(creature, 20, Bludgeoning, rageResistances, Set(), Set(), false)
    val afterSlashing    = pTakeDamage(creature, 20, Slashing,    rageResistances, Set(), Set(), false)
    val afterPiercing    = pTakeDamage(creature, 20, Piercing,    rageResistances, Set(), Set(), false)
    // 20 damage halved to 10 each; 40 - 10 = 30
    assert(afterBludgeoning.hp == 30 and afterSlashing.hp == 30 and afterPiercing.hp == 30)
  }
  
  // How to increase survivability in Wild Shape? — Bear Totem (Path of Totem Warrior 3) resists all except psychic
  run qa_wild_shape_bear_totem_resists_all_except_psychic = {
    val creature = freshCreature(30)
    // Bear totem grants resistance to all damage types except psychic
    val bearResistances = Set(Acid, Bludgeoning, Cold, Fire, Force,
                              Lightning, Necrotic, Piercing, Radiant, Slashing, Thunder)
    val afterFire    = pTakeDamage(creature, 10, Fire,    bearResistances, Set(), Set(), false)
    val afterPsychic = pTakeDamage(creature, 10, Psychic, bearResistances, Set(), Set(), false)
    // Fire is resisted: 10/2=5 damage → 30-5=25 HP
    // Psychic is NOT resisted: 10 damage → 30-10=20 HP
    assert(afterFire.hp == 25 and afterPsychic.hp == 20)
  }
  
  // How to increase survivability in Wild Shape? — Resistance and vulnerability on same type cancel to normal damage
  run qa_wild_shape_resist_vuln_cancel = {
    val creature = freshCreature(30)
    // If a beast somehow had both resistance and vulnerability to fire (edge case)
    val result = pTakeDamage(creature, 10, Fire, Set(Fire), Set(Fire), Set(), false)
    // resist: 10/2=5, then vuln: 5*2=10 → net normal damage, 30-10=20
    assert(result.hp == 20)
  }

  // Source: https://rpg.stackexchange.com/q/213277
  
  // Attack Action: Can you equip or unequip more than one weapon using the Extra Attack feature or free object interaction?
  run qa_free_interaction_not_consumed_by_attack_or_extra_attack = {
    // The per-attack equip/unequip and the free object interaction are tracked separately.
    // After using the Attack action and burning the extra attack (2 total attacks),
    // freeInteractionUsed must still be false — the turn-level free interaction is untouched.
    val creature = freshCreature(20)
    val t0 = FRESH_TURN   // extraAttacksRemaining: 1, freeInteractionUsed: false
    val t1 = pUseAction(t0, creature, AAttack)   // base attack
    val t2 = pUseExtraAttack(t1)                 // extra attack (Fighter 5 / FExtraAttack)
    assert(
      t2.attackActionUsed      == true  and
      t2.extraAttacksRemaining == 0     and
      t2.freeInteractionUsed   == false           // free interaction is separate
    )
  }
  
  // Attack Action: The free object interaction is usable on top of both attacks (the "third manipulation")
  run qa_free_interaction_usable_after_both_attacks = {
    // Accepted answer: draw + throw dagger (2 per-attack manipulations) then draw longsword again
    // (free object interaction) — all three are legal in one turn.
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, creature, AAttack)
    val t2 = pUseExtraAttack(t1)
    val t3 = pUseObjectInteraction(t2)   // third manipulation: free interaction
    assert(
      t3.attackActionUsed      == true  and
      t3.extraAttacksRemaining == 0     and
      t3.freeInteractionUsed   == true
    )
  }
  
  // Attack Action: Only one free interaction per turn; second attempt is blocked (requires Use Object action)
  run qa_only_one_free_interaction_per_turn = {
    // PHB: "one free interaction per turn; additional interactions require the Utilize action."
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseObjectInteraction(t0)   // first: free
    val t2 = pUseObjectInteraction(t1)   // second: no-op — blocked, would cost Use Object action
    assert(t1.freeInteractionUsed == true and t2 == t1)
  }

  // Source: https://rpg.stackexchange.com/q/57267
  
  // How can I create a playable monster in DnD 5e? — no Level Adjustment: proficiency bonus is purely level-based, not penalised by race/template
  run qa_no_level_adjustment_profbonus = {
    // 5e has no LA mechanic: a Vampire/Lycanthrope/Half-Dragon at level 5 has the
    // exact same proficiency bonus as any other level-5 character.
    assert(
      proficiencyBonus(1) == 2 and
      proficiencyBonus(5) == 3 and
      proficiencyBonus(20) == 6
    )
  }
  
  // How can I create a playable monster in DnD 5e? — monster race characters use standard ability score generation rules
  run qa_monster_race_point_buy_valid = {
    // Standard array [15,14,13,12,10,8] costs exactly 27 pts; valid for any race
    // including characters built from MM templates (Vampire, Lycanthrope, Half-Dragon).
    assert(pValidPointBuy([15, 14, 13, 12, 10, 8]))
  }
  
  // How can I create a playable monster in DnD 5e? — ASI progression is identical for monster race characters
  run qa_monster_race_asi_levels = {
    // No LA means ASI levels are unchanged: 4, 8, 12, 16, 19 for all characters.
    assert(
      pIsASILevel(4)  and
      pIsASILevel(8)  and
      pIsASILevel(12) and
      pIsASILevel(16) and
      pIsASILevel(19) and
      not(pIsASILevel(1)) and
      not(pIsASILevel(5))
    )
  }

  // Source: https://rpg.stackexchange.com/q/211794
  
  // Do you have to be holding the agate for Awaken to awaken a beast/plant?
  // Instantaneous duration: full effect (including the touch) resolves at cast time; no stored effect for later
  run qa_instantaneous_awaken_no_deferred_touch = {
    val slots: SpellSlotState = {
      slotsMax: Map(1->4, 2->3, 3->3, 4->3, 5->2, 6->1, 7->1, 8->1, 9->1),
      slotsCurrent: Map(1->4, 2->3, 3->3, 4->3, 5->2, 6->1, 7->1, 8->1, 9->1),
      pactSlotsMax: 0, pactSlotsCurrent: 0, pactSlotLevel: 0,
      concentrationSpellId: "",
    }
    // Awaken is 5th-level, instantaneous: casting = slot consumed + effect resolves immediately
    val afterCast = pExpendSlot(slots, 5)
    // No concentration started means no stored/pending effect — the touch cannot be deferred
    // A second awakening requires a fresh slot expenditure right then and there
    val afterSecondCast = pExpendSlot(afterCast, 5)
    assert(
      afterCast.slotsCurrent.get(5) == 1        // first slot consumed
      and not(isConcentrating(afterCast))        // no ongoing effect to trigger later
      and afterSecondCast.slotsCurrent.get(5) == 0 // each target needs its own immediate casting
      and not(isConcentrating(afterSecondCast))  // still no stored effect after second cast
    )
  }

  // Source: https://rpg.stackexchange.com/q/149159
  
  // Are there side effects from popping in and out into the Ethereal Plane for an extended time period?
  // Accepted answer: no mechanical side effects listed; Blink/ethereal only interacts via visibility rules.
  
  // Applying invisible (Blink/ethereal proxy) changes only that flag — no HP loss, no exhaustion, no extra conditions
  run qa_ethereal_invisible_no_side_effects = {
    val s = freshCreature(20)
    val s1 = pApplyCondition(s, CInvisible)
    assert(
      s1.invisible == true
      and s1.hp == s.hp
      and s1.exhaustion == s.exhaustion
      and s1.blinded == false
      and s1.prone == false
      and s1.poisoned == false
      and s1.stunned == false
      and s1.incapacitatedSources == Set()
    )
  }
  
  // Toggling in and out of ethereal (apply + remove invisible) leaves creature state identical to before
  run qa_ethereal_toggle_leaves_no_trace = {
    val s = freshCreature(20)
    val s1 = pApplyCondition(s, CInvisible)
    val s2 = pRemoveCondition(s1, CInvisible)
    assert(s2 == s)
  }
  
  // Ethereal (Blink) attacker is unseen by material target → attacker gets advantage, no disadvantage
  run qa_ethereal_blink_attacker_advantage = {
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: false,  // material plane target cannot see ethereal attacker
      attackerCanSeeTarget: true,   // ethereal attacker can see material plane target
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(mods.hasAdvantage == true and mods.hasDisadvantage == false)
  }
  
  // Material plane attacker cannot see ethereal (Blink) target → attacker gets disadvantage, no advantage
  run qa_ethereal_material_attacker_disadvantage = {
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: true,   // ethereal target can see material attacker
      attackerCanSeeTarget: false,  // material attacker cannot see ethereal target
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(mods.hasAdvantage == false and mods.hasDisadvantage == true)
  }
  
  // See Invisibility / True Sight lets material attacker see ethereal target → no visibility-based adv or disadv
  run qa_ethereal_see_invisibility_removes_penalty = {
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
