// -*- mode: Bluespec; -*-

/// ARCHIVED: Generated from the 2014 (SRD 5.1) Q&A corpus (.references/qa2014/).
/// Source data: dnd-5e-2014 tagged SE questions + Reddit r/dndnext (mixed era).
/// WARNING: Contains stale API names (ACastSpell, AUseObject, pEndSurpriseTurn, pHitDiceRecovery)
///          that no longer exist in dnd.qnt — does NOT compile against the current spec.
/// Superseded by qa_generated.qnt (2024 corpus, .references/qa/).

module qa_generated {
  import dnd.* from "./dnd"

  // Source: https://rpg.stackexchange.com/q/70308
  
  // Would a Flameskull remember who killed it in previous attacks?
  // INT 16 gives +3 modifier — the mechanical basis for the accepted answer's strategic reasoning claim
  run qa_flameskull_int16_modifier = {
    assert(abilityModifier(16) == 3)
  }
  
  // Would a Flameskull remember who killed it in previous attacks?
  // Flameskull (INT 16, proficient, CR 4 ≈ level 4 proficiency bonus) has passive INT 15 — high enough for tactical memory
  run qa_flameskull_passive_int_check = {
    val intMod = abilityModifier(16)
    val prof    = proficiencyBonus(4)
    val passive = passiveCheck(intMod, Proficient, prof, false, false)
    assert(intMod == 3 and prof == 2 and passive == 15)
  }

  // Source: https://rpg.stackexchange.com/q/205170
  
  // Is there a RAW rule for how a player could discover what type of skill check needs to be made?
  run qa_dm_determines_skill_check = {
    // PHB: DM picks which check applies based on character's described action; players narrate,
    // DM decides. DM may allow History instead of Arcana for arcane glyphs — both derive from Int_.
    val dc = 15
    val intMod = abilityModifier(16) // score 16 -> +3
    val prof = proficiencyBonus(5)   // level 5 -> +3
  
    // Both candidate skills share the same base ability
    val sameAbility = skillAbility(Arcana) == Int_ and skillAbility(History) == Int_
  
    // Character lacks Arcana prof: 12 + 3 + 0 = 15 >= 15 — barely passes
    val arcanaNoProf = checkSucceeds(12, intMod, NoneProf, prof, 0, dc)
  
    // DM allows History (per creative background); proficient: 12 + 3 + 3 = 18 >= 15 — also passes
    val historyProf = checkSucceeds(12, intMod, Proficient, prof, 0, dc)
  
    // Without any Int proficiency a lower roll fails — player cannot game check selection
    val noProf_lowRoll = checkSucceeds(8, intMod, NoneProf, prof, 0, dc) // 8+3=11 < 15
  
    assert(sameAbility and arcanaNoProf and historyProf and not(noProf_lowRoll))
  }

  // Source: https://rpg.stackexchange.com/q/197414
  
  // What happens if I roll a 1 on a death saving throw but the result is 10 or above?
  // Specific rule (nat 1 = two failures) overrides general rule (10+ = success), PHB p.197.
  run qa_nat1_death_save_always_two_failures = {
    // Creature at 0 HP, dying — even a hypothetical +9 bonus is irrelevant;
    // pDeathSave checks the raw d20 roll, so nat 1 must yield two failures.
    val dying = freshCreature(20)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
    val after = pDeathSave(dying, 1)
    assert(
      after.deathSaves.failures == 2
      and after.deathSaves.successes == 0
      and not(after.stable)
      and not(after.dead)
    )
  }

  // Source: https://rpg.stackexchange.com/q/172247
  
  // Do you lose concentration on a Readied spell when you use your reaction for something else?
  run qa_readied_spell_reaction_preserves_concentration = {
    // Using reaction (e.g. opportunity attack) only modifies TurnState — SpellSlotState untouched
    val ss = pStartConcentration(FRESH_SPELL_SLOTS, "firebolt_readied")
    val turn = FRESH_TURN
    val turn2 = pUseReaction(turn)
    assert(
      not(turn2.reactionAvailable) and
      isConcentrating(ss)
    )
  }
  
  // Contrast: concentration IS broken by failing a concentration save after damage
  run qa_readied_spell_conc_breaks_on_failed_save = {
    val ss = pStartConcentration(FRESH_SPELL_SLOTS, "firebolt_readied")
    val ss2 = pConcentrationCheck(ss, false)
    assert(not(isConcentrating(ss2)))
  }
  
  // Contrast: concentration IS broken when creature becomes incapacitated
  run qa_readied_spell_conc_breaks_on_incapacitation = {
    val creature = freshCreature(20)
    val ss = pStartConcentration(FRESH_SPELL_SLOTS, "firebolt_readied")
    val creature2 = pApplyCondition(creature, CStunned)
    val ss2 = pBreakConcOnStateChange(ss, creature, creature2)
    assert(not(isConcentrating(ss2)))
  }
  
  // Contrast: concentration IS broken when creature dies
  run qa_readied_spell_conc_breaks_on_death = {
    val creature = freshCreature(20)
    val ss = pStartConcentration(FRESH_SPELL_SLOTS, "firebolt_readied")
    val dead_creature = creature.with("dead", true).with("hp", 0)
    val ss2 = pBreakConcOnStateChange(ss, creature, dead_creature)
    assert(not(isConcentrating(ss2)))
  }
  
  // Contrast: concentration IS broken by active choice
  run qa_readied_spell_conc_breaks_on_active_end = {
    val ss = pStartConcentration(FRESH_SPELL_SLOTS, "firebolt_readied")
    val ss2 = pBreakConcentration(ss)
    assert(not(isConcentrating(ss2)))
  }

  // Source: https://rpg.stackexchange.com/q/213088
  
  // Is there a way to swap my longbow from being a ranger for a shortbow?
  run qa_small_creature_longbow_disadvantage = {
    val longbow: Weapon = {
      name: "longbow",
      damageDie: 8,
      versatileDie: 0,
      damageType: Piercing,
      properties: Set(Heavy, TwoHanded, Ammunition),
      isMelee: false,
      normalRange: 150,
      longRange: 600,
    }
    val shortbow: Weapon = {
      name: "shortbow",
      damageDie: 6,
      versatileDie: 0,
      damageType: Piercing,
      properties: Set(TwoHanded, Ammunition),
      isMelee: false,
      normalRange: 80,
      longRange: 320,
    }
    // Small fairy ranger: longbow (Heavy) imposes disadvantage; shortbow does not
    assert(
      heavyWeaponDisadvantage(longbow, Small) and
      not(heavyWeaponDisadvantage(shortbow, Small))
    )
  }

  // Source: https://rpg.stackexchange.com/q/181521
  
  // SKIP: The spec models spell slots, concentration, and component provision but has no functions for illusion spell effects, written-text perception, or the "designated creatures" mechanic of Illusory Script. The accepted answer's mechanical claim (text appears different to non-designated observers) is entirely outside the spec's scope, and the DM-adjudication binding-contract question is non-mechanical by definition.

  // Source: https://rpg.stackexchange.com/q/121679
  
  // Wildshape while "wearing" a living creature: only equipment merges, creatures are dropped
  run qa_wildshape_creature_not_merged = {
    // A creature being held/worn (e.g. a snake) is NOT equipment and cannot merge into Wild Shape.
    // The living creature must be dropped — it is not grappled by the spec's grapple mechanic,
    // but we can model the closest analogue: a grappled tiny creature is released on transform.
    // We verify that pReleaseGrapple correctly removes CGrappled from the held creature,
    // representing the mandatory drop of a non-equipment creature during Wild Shape.
    val heldCreature = pApplyCondition(freshCreature(3), CGrappled)
    val afterWildShape = pReleaseGrapple(heldCreature)
    assert(
      heldCreature.grappled == true
      and afterWildShape.grappled == false
      and afterWildShape.hp == heldCreature.hp
    )
  }

  // Source: https://rpg.stackexchange.com/q/118709
  
  // Half-orc cavalier, A lance seems rather un-orcish, Alternate item?
  // Accepted answer: changing damage type from piercing to bludgeoning/slashing has no balance impact
  run qa_physical_damage_types_equal_no_resistances = {
    // 1d12 weapon hit — same result regardless of physical damage type
    val amount = 12
    val s = freshCreature(20)
  
    val piercingResult  = applyDamageModifiers(amount, Piercing,    Set(), Set(), Set())
    val bludgeonResult  = applyDamageModifiers(amount, Bludgeoning, Set(), Set(), Set())
    val slashingResult  = applyDamageModifiers(amount, Slashing,    Set(), Set(), Set())
  
    val sAfterPiercing    = pTakeDamage(s, amount, Piercing,    Set(), Set(), Set(), false)
    val sAfterBludgeoning = pTakeDamage(s, amount, Bludgeoning, Set(), Set(), Set(), false)
    val sAfterSlashing    = pTakeDamage(s, amount, Slashing,    Set(), Set(), Set(), false)
  
    assert(
      // raw damage values are identical
      piercingResult == bludgeonResult
      and bludgeonResult == slashingResult
      // and resulting creature HP is identical
      and sAfterPiercing.hp == sAfterBludgeoning.hp
      and sAfterBludgeoning.hp == sAfterSlashing.hp
    )
  }

  // Source: https://rpg.stackexchange.com/q/62167
  
  // SKIP: Paladin oath-breaking is a DM-adjudicated narrative mechanic with no mechanical formula; the spec has no oath state, alignment tracking, or class-specific ability loss to encode as a testable assertion.

  // Source: https://rpg.stackexchange.com/q/65740
  
  // Catching poisoned arrows: Deflect Missiles applies to total attack damage (piercing + poison), not piercing alone
  run qa_deflect_missiles_reduces_total_including_poison = {
    // Yuan-ti shortbow: 4 (1d6+1) piercing + 7 (2d6) poison = 11 total
    val piercingDamage = normalDamage(3, 1)  // 4
    val poisonDamage   = normalDamage(7, 0)  // 7
    val totalDamage    = piercingDamage + poisonDamage  // 11
    // Deflect roll covering only piercing (4) is insufficient to catch — still 7 remaining
    val remainingIfOnlyPiercingCovered = intMax(0, totalDamage - 4)
    // Deflect roll covering full total (11) reduces to 0 — arrow caught
    val remainingIfTotalCovered = intMax(0, totalDamage - 11)
    assert(remainingIfOnlyPiercingCovered == 7 and remainingIfTotalCovered == 0)
  }
  
  // Catching poisoned arrows: when total damage reduced to 0 by deflect, creature takes no damage at all
  run qa_deflect_missiles_catch_prevents_all_damage = {
    val creature = freshCreature(30)
    // Yuan-ti shortbow: 4 piercing + 7 poison = 11 total
    val totalDamage = normalDamage(3, 1) + normalDamage(7, 0)  // 11
    // Deflect Missiles: 1d10(6) + DEX mod(3) + monk level(5) = 14 — exceeds 11
    val deflectReduction = normalDamage(6, 3) + 5  // 14
    val remainingDamage  = intMax(0, totalDamage - deflectReduction)  // 0 → caught
    // Caught: apply 0 damage, HP unchanged
    val s1 = pTakeDamage(creature, remainingDamage, Bludgeoning, Set(), Set(), Set(), false)
    assert(remainingDamage == 0 and s1.hp == 30)
  }
  
  // Catching poisoned arrows: if deflect only neutralises piercing, poison damage still reaches the creature
  run qa_deflect_missiles_uncaught_arrow_deals_remaining_damage = {
    val creature = freshCreature(30)
    val piercingDamage = normalDamage(3, 1)  // 4
    val poisonDamage   = normalDamage(7, 0)  // 7
    val totalDamage    = piercingDamage + poisonDamage  // 11
    // Deflect roll of 4 exactly cancels piercing; poison still gets through
    val deflectReduction = 4
    val remainingDamage  = intMax(0, totalDamage - deflectReduction)  // 7
    // Arrow not caught; apply remaining as single pool (per RAW, total reduced first)
    val s1 = pTakeDamage(creature, remainingDamage, Poison, Set(), Set(), Set(), false)
    assert(remainingDamage == 7 and s1.hp == 23)
  }

  // Source: https://rpg.stackexchange.com/q/215556
  
  // Do the effects of Enlarge/Reduce continue to apply after using Wild Shape? (2024 PHB)
  run qa_enlarge_reduce_persists_through_wild_shape = {
    // Druid (or ally) concentrating on Enlarge/Reduce before Wild Shape
    val preWildShape = freshCreature(30)
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "enlarge_reduce")
    // Wild Shape: 2024 PHB — "shape-shifting carries over ongoing effects";
    // beast form has a different HP pool but creature remains alive and not incapacitated.
    // pBreakConcOnStateChange only fires on death or new incapacitation — neither applies here.
    val postWildShape = freshCreature(20)
    val ssAfter = pBreakConcOnStateChange(ss, preWildShape, postWildShape)
    assert(
      isConcentrating(ssAfter) and
      ssAfter.concentrationSpellId == "enlarge_reduce"
    )
  }
  
  // P.S.: self-casting druid — Wild Shape doesn't break the druid's own concentration (PHB p.81)
  run qa_enlarge_reduce_self_cast_druid_wild_shape = {
    // Druid cast Enlarge/Reduce on themselves, then uses Wild Shape
    val druid = freshCreature(28)
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "enlarge_reduce")
    // Wild Shape transition: druid is still alive, still not incapacitated in beast form.
    // The druid cannot cast new spells in beast form, but an already-cast concentration spell
    // persists — pBreakConcOnStateChange does not trigger.
    val druidBeastForm = freshCreature(18)
    val ssAfter = pBreakConcOnStateChange(ss, druid, druidBeastForm)
    assert(
      not(druidBeastForm.dead) and
      not(isIncapacitated(druidBeastForm)) and
      isConcentrating(ssAfter) and
      ssAfter.concentrationSpellId == "enlarge_reduce"
    )
  }

  // In what ways can a druid's Wild Shape be detected?
  run qa_wild_shape_detect_magic_castable_with_1st_level_slot = {
    // Detect Magic is a 1st-level spell; any caster with a 1st-level slot can use it to sense Wild Shape's aura
    val ss = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(1, 4))
      .with("slotsCurrent", EMPTY_SLOTS.set(1, 4))
    assert(pCanCastAtLevel(ss, 1, 1))
  }
  
  // In what ways can a druid's Wild Shape be detected?
  run qa_wild_shape_true_seeing_requires_6th_level_slot = {
    // True Seeing is a 6th-level spell; a 5th-level slot is insufficient — slotLevel must be >= spellLevel
    val ss = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(5, 2).set(6, 1))
      .with("slotsCurrent", EMPTY_SLOTS.set(5, 2).set(6, 1))
    assert(not(pCanCastAtLevel(ss, 6, 5)) and pCanCastAtLevel(ss, 6, 6))
  }
  
  // In what ways can a druid's Wild Shape be detected?
  run qa_wild_shape_true_seeing_expends_only_6th_slot = {
    // Casting True Seeing expends the single 6th-level slot, leaving it unavailable for a second cast
    val ss = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(6, 1))
      .with("slotsCurrent", EMPTY_SLOTS.set(6, 1))
    val ssAfter = pExpendSlot(ss, 6)
    assert(ssAfter.slotsCurrent.get(6) == 0 and not(pCanCastAtLevel(ssAfter, 6, 6)))
  }
  
  // In what ways can a druid's Wild Shape be detected?
  run qa_wild_shape_detect_magic_expended_blocks_casting = {
    // Once the 1st-level slot is spent on Detect Magic, no further castings are possible without ritual or new slot
    val ss = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(1, 1))
      .with("slotsCurrent", EMPTY_SLOTS.set(1, 1))
    val ssAfter = pExpendSlot(ss, 1)
    assert(not(pCanCastAtLevel(ssAfter, 1, 1)))
  }

  // Source: https://rpg.stackexchange.com/q/136953
  
  // When does the Death Saving Throw happen w.r.t. sources of automatic ongoing damage?
  // Accepted answer: simultaneous by default (DM fiat); Xanathar's optional rule lets the
  // controlling player choose order — they pick death save first for the favorable outcome.
  run qa_simultaneous_death_save_and_damage_order = {
    // Creature at 0 HP, unconscious, with 2 existing death save failures (1 more = dead).
    // Models: start of turn, both a death save AND ongoing fire damage are triggered.
    val s0 = freshCreature(20)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
      .with("deathSaves", { successes: 0, failures: 2 })
  
    // Order A — damage first (unfavorable, DM might rule this):
    // ongoing fire damage at 0 HP adds 1 failure → 3 failures → instant death.
    // Player never gets to roll.
    val orderA_after_damage = pTakeDamage(s0, 5, Fire, Set(), Set(), Set(), false)
  
    // Order B — death save first (Xanathar's: player chooses favorable order):
    // nat 20 → regain 1 HP, remove unconscious, reset death saves.
    val orderB_after_save = pDeathSave(s0, 20)
    // Then the ongoing fire damage hits: drops from 1 HP back to 0 HP → unconscious again,
    // but death saves are fresh — creature is NOT dead, just back to dying.
    val orderB_after_damage = pTakeDamage(orderB_after_save, 5, Fire, Set(), Set(), Set(), false)
  
    assert(
      // Order A: the 3rd failure kills the creature before it can roll
      orderA_after_damage.dead == true
      // Order B: nat-20 death save first grants 1 HP (conscious, saves reset)
      and orderB_after_save.hp == 1
      and orderB_after_save.dead == false
      and orderB_after_save.unconscious == false
      and orderB_after_save.deathSaves.failures == 0
      // subsequent fire damage knocks them back down but does not kill them
      and orderB_after_damage.dead == false
      and orderB_after_damage.hp == 0
      and orderB_after_damage.unconscious == true
    )
  }

  // Source: https://rpg.stackexchange.com/q/213448
  
  // Does the Ring of Mind Shielding need to be attuned to hear a soul inside?
  // SKIP: The spec models creature/combat state and has no attunement, magic items, or telepathy mechanics.

  // Source: https://rpg.stackexchange.com/q/88452
  
  // Sending (PHB p.274): 3rd-level spell — slot level must be >= 3 to cast
  run qa_sending_requires_3rd_level_slot = {
      val ss = FRESH_SPELL_SLOTS.with("slotsCurrent", EMPTY_SLOTS.set(3, 2))
      assert(
          // slot level 3 meets spell level 3
          pCanCastAtLevel(ss, 3, 3)
          // slot level 2 is insufficient for a 3rd-level spell
          and not(pCanCastAtLevel(ss, 3, 2))
          // slot level 1 is also insufficient
          and not(pCanCastAtLevel(ss, 3, 1))
      )
  }
  
  // Sending (PHB p.274): upcasting with a 4th- or 5th-level slot is valid
  run qa_sending_upcast_valid = {
      val ss4 = FRESH_SPELL_SLOTS.with("slotsCurrent", EMPTY_SLOTS.set(4, 1))
      val ss5 = FRESH_SPELL_SLOTS.with("slotsCurrent", EMPTY_SLOTS.set(5, 1))
      assert(
          pCanCastAtLevel(ss4, 3, 4)
          and pCanCastAtLevel(ss5, 3, 5)
      )
  }
  
  // Sending (PHB p.274): casting expends exactly one 3rd-level slot
  run qa_sending_expends_slot = {
      val ss = FRESH_SPELL_SLOTS
          .with("slotsMax", EMPTY_SLOTS.set(3, 2))
          .with("slotsCurrent", EMPTY_SLOTS.set(3, 2))
      val ss1 = pExpendSlot(ss, 3)
      assert(
          // one slot consumed
          ss1.slotsCurrent.get(3) == 1
          // other levels untouched
          and ss1.slotsCurrent.get(2) == 0
          and ss1.slotsCurrent.get(4) == 0
          // slot cap unchanged
          and ss1.slotsMax.get(3) == 2
      )
  }
  
  // Sending (PHB p.274): no slots remaining means can't cast even at correct level
  run qa_sending_no_slots_blocks_cast = {
      val ss = FRESH_SPELL_SLOTS  // all slotsCurrent = 0
      assert(
          not(pCanCastAtLevel(ss, 3, 3))
          and not(pCanCastAtLevel(ss, 3, 4))
          and not(pCanCastAtLevel(ss, 3, 5))
      )
  }

  // Source: https://rpg.stackexchange.com/q/172150
  
  // Can the creature from a Bag of Tricks make opportunity attacks?
  run qa_bag_of_tricks_oa_reaction_consumed = {
    // OA is a reaction; any creature with reaction available (incl. summoned) can make one
    val t = FRESH_TURN
    val tAfterOA = pUseReaction(t)
    assert(t.reactionAvailable == true and tAfterOA.reactionAvailable == false)
  }
  
  // Can the creature from a Bag of Tricks make opportunity attacks?
  run qa_bag_of_tricks_oa_disengage_blocks = {
    // If the target uses Disengage, the summoned creature cannot make an OA against it
    val c = freshCreature(10)
    val t = FRESH_TURN
    val tAfterDisengage = pUseAction(t, c, ADisengage)
    assert(not(pCanBeOpportunityAttacked(tAfterDisengage)))
  }
  
  // Can the creature from a Bag of Tricks make opportunity attacks?
  run qa_bag_of_tricks_oa_no_disengage_allows_oa = {
    // Without Disengage, any creature (incl. summoned) is eligible to be OA'd
    val t = FRESH_TURN
    assert(pCanBeOpportunityAttacked(t))
  }
  
  // Can the creature from a Bag of Tricks make opportunity attacks?
  run qa_bag_of_tricks_oa_reaction_spent_blocks_second_oa = {
    // After the summoned creature uses its reaction for an OA, it cannot make another
    val t = FRESH_TURN
    val tSpent = pUseReaction(t)
    // Attempting to use reaction again is a no-op when already spent
    val tSpentAgain = pUseReaction(tSpent)
    assert(not(tSpent.reactionAvailable) and tSpentAgain == tSpent)
  }

  // Source: https://rpg.stackexchange.com/q/110738
  
  // SKIP: CR calculation and monster design (DMG p. 277 effective HP multiplier tables) are not modeled in this spec — the spec covers PHB player-facing mechanics only, with no monster CR, effective HP multiplier, or monster creation functions.

  // Source: https://rpg.stackexchange.com/q/58994
  
  // Is a Shillelagh attack a spell attack or a regular attack?
  run qa_shillelagh_is_normal_melee_attack = {
    // Shillelagh substitutes the spellcasting modifier as the attack/damage bonus,
    // but the weapon still makes a normal melee attack resolved via resolveAttackRoll.
    // TEST_CONFIG: WIS 13 (mod +1), level 5 (prof +3) → spellcastingBonus = +4
    val shillelaghBonus = spellcastingBonus(TEST_CONFIG)
    // Normal melee hit: roll + spellcasting bonus >= AC (standard weapon attack rule)
    val hitResult  = resolveAttackRoll(13, shillelaghBonus, 17, 0)  // 13+4=17 >= 17 → hits
    val missResult = resolveAttackRoll(12, shillelaghBonus, 17, 0)  // 12+4=16 < 17  → misses
    // Nat 20 auto-crits and nat 1 auto-misses: same rules as any melee weapon attack
    val critResult   = resolveAttackRoll(20, shillelaghBonus, 30, 0)
    val fumbleResult = resolveAttackRoll(1,  shillelaghBonus,  5, 0)
    assert(
      hitResult.hits    and not(hitResult.isCritical)    and
      not(missResult.hits)                               and
      critResult.hits   and critResult.isCritical        and
      not(fumbleResult.hits)
    )
  }

  // Source: https://rpg.stackexchange.com/q/191949
  
  // Does activating a magic item that does not specifically require an action still require an action?
  run qa_magic_item_explicit_action_consumes_action = {
    // Item like Eversmoking Bottle says "use an action" — activation uses AUseObject,
    // marking actionUsed = true and blocking further actions that turn.
    val s = freshCreature(10)
    val t = FRESH_TURN
    val t1 = pUseAction(t, s, AUseObject)
    // Trying to also take the Attack action is refused because actionUsed is already true
    val t2 = pUseAction(t1, s, AAttack)
    assert(
      t1.actionUsed == true and
      t2.actionUsed == true and
      t2.attackActionUsed == false // Attack action was NOT registered — action already spent
    )
  }
  
  // Does activating a magic item that does not specifically require an action still require an action?
  run qa_magic_item_no_action_stated_leaves_action_free = {
    // Items like Breathing Bubble or Eagle Whistle specify no action cost.
    // Activation does not call pUseAction, so the creature's action is untouched.
    val s = freshCreature(10)
    val t = FRESH_TURN
    // "Activate" the no-action item — no pUseAction call, turn state unchanged
    val t_after_free_activate = t
    // The creature still has its full action available and can use it normally
    val t_attack = pUseAction(t_after_free_activate, s, AAttack)
    assert(
      t_after_free_activate.actionUsed == false and
      t_attack.actionUsed == true and
      t_attack.attackActionUsed == true
    )
  }

  // Source: https://rpg.stackexchange.com/q/196896
  
  // What is highest Damage/GP poison? — Poison resistance halves damage (per DMG p.257 mechanics note)
  run qa_poison_resistance_halves_damage = {
    val result = applyDamageModifiers(10, Poison, Set(), Set(Poison), Set())
    assert(result == 5)
  }
  
  // What is highest Damage/GP poison? — Poison immunity negates damage entirely (most resisted damage type)
  run qa_poison_immunity_negates_damage = {
    val result = applyDamageModifiers(10, Poison, Set(Poison), Set(), Set())
    assert(result == 0)
  }
  
  // What is highest Damage/GP poison? — commoner (Con 10, no proficiency) fails DC 11 serpent venom save on roll of 10
  run qa_serpent_venom_dc11_commoner_fails_on_roll_10 = {
    val conMod = abilityModifier(10)
    val profBonus = proficiencyBonus(1)
    assert(not(saveSucceeds(10, conMod, false, profBonus, 0, 11)))
  }
  
  // What is highest Damage/GP poison? — same commoner succeeds DC 11 serpent venom save on roll of 11
  run qa_serpent_venom_dc11_commoner_succeeds_on_roll_11 = {
    val conMod = abilityModifier(10)
    val profBonus = proficiencyBonus(1)
    assert(saveSucceeds(11, conMod, false, profBonus, 0, 11))
  }

  // Source: https://rpg.stackexchange.com/q/53937
  
  // How is throwing distance computed in 5e? — improvised thrown weapon has normal range 20 ft, long range 60 ft (PHB 148)
  run qa_improvised_thrown_weapon_range_values = {
    val impWeapon: Weapon = {
      name: "oil flask",
      damageDie: 4,
      versatileDie: 0,
      damageType: Fire,
      properties: Set(Thrown),
      isMelee: false,
      normalRange: 20,
      longRange: 60,
    }
    assert(impWeapon.normalRange == 20 and impWeapon.longRange == 60)
  }
  
  // How is throwing distance computed in 5e? — beyond normal range (>20 ft, up to 60 ft) imposes disadvantage on the ranged attack roll (PHB 148)
  run qa_improvised_thrown_beyond_normal_range_gives_disadvantage = {
    val baseCtx: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false, targetParalyzed: false, targetPetrified: false,
      targetStunned: false, targetUnconscious: false, targetRestrained: false, targetProne: false,
      attackerWithin5ft: false,
      targetDodging: false, targetCanSeeAttacker: true,
      attackerCanSeeTarget: true,
      isRangedAttack: true,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false,
      squeezing: false, underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    val modsWithin = pAggregateAttackMods(baseCtx)
    val modsLong   = pAggregateAttackMods(baseCtx.with("beyondNormalRange", true))
    assert(
      not(modsWithin.hasDisadvantage) and
      not(modsWithin.hasAdvantage) and
      modsLong.hasDisadvantage
    )
  }

  // Source: https://rpg.stackexchange.com/q/120418
  
  // How do I create an Accursed Specter? — warlock must deal the killing blow (reduce humanoid to dead)
  run qa_accursed_specter_killing_blow = {
    // Humanoid with maxHp 10 is at 1 HP; warlock deals 11 necrotic damage.
    // Overflow (10) >= maxHp (10) → instant death, satisfying the "slay" requirement.
    val humanoid = freshCreature(10).with("hp", 1)
    val afterBlow = pTakeDamage(humanoid, 11, Necrotic, Set(), Set(), Set(), false)
    assert(afterBlow.dead and afterBlow.hp == 0)
  }

  // Source: https://rpg.stackexchange.com/q/123558
  
  // Scorching Ray with Faerie Fire: "any attack roll against an affected creature has advantage" — each ray rolls independently with advantage
  run qa_faerie_fire_advantage_per_scorching_ray = {
    // Faerie Fire: "Any attack roll against an affected creature has advantage."
    // Modelled via targetBlinded=true (same mechanical effect: all attacks vs. target gain advantage).
    // Scorching Ray makes 3 separate ranged spell attack rolls; each evaluates the same context
    // independently — advantage is not "consumed" after the first roll.
    val ctx = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: true,
      targetParalyzed: false, targetPetrified: false, targetStunned: false,
      targetUnconscious: false, targetRestrained: false, targetProne: false,
      attackerWithin5ft: false, targetDodging: false, targetCanSeeAttacker: true,
      attackerCanSeeTarget: true, isRangedAttack: true, beyondNormalRange: false,
      hostileWithin5ft: false, isHeavyWeapon: false, wielderSizeSmallOrTiny: false,
      squeezing: false, underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    // Each ray independently derives its own modifier context from the same Faerie Fire condition
    val ray1Mods = pAggregateAttackMods(ctx)
    val ray2Mods = pAggregateAttackMods(ctx)
    val ray3Mods = pAggregateAttackMods(ctx)
    // Each ray uses its own advantaged d20 result (higher of two dice, chosen by caller)
    val ray1 = resolveAttackRoll(15, 5, 14, 0) // 15+5=20 >= AC 14
    val ray2 = resolveAttackRoll(12, 5, 14, 0) // 12+5=17 >= AC 14
    val ray3 = resolveAttackRoll(10, 5, 14, 0) // 10+5=15 >= AC 14
    assert(
      // All three rays have advantage — Faerie Fire's "any attack roll" wording covers each
      ray1Mods.hasAdvantage and not(ray1Mods.hasDisadvantage) and
      ray2Mods.hasAdvantage and not(ray2Mods.hasDisadvantage) and
      ray3Mods.hasAdvantage and not(ray3Mods.hasDisadvantage) and
      // Each ray resolves its own attack roll independently with its advantaged die
      ray1.hits and ray2.hits and ray3.hits
    )
  }

  // Source: https://rpg.stackexchange.com/q/150288
  
  // "What happens when your group is victim of a surprise attack but you can't be surprised?"
  // Rule: A character immune to surprise acts fully on their first turn; surprised allies cannot move or act.
  run qa_immune_to_surprise_gets_full_turn = {
    val creature = freshCreature(30)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    assert(
      not(t.actionUsed) and
      not(t.bonusActionUsed) and
      t.reactionAvailable and
      t.movementRemaining == 30 and
      not(t.surprised)
    )
  }
  
  // Rule: A surprised creature cannot move or take an action on its first turn, and cannot react until that turn ends.
  run qa_surprised_creature_locked_out = {
    val creature = freshCreature(30)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, true, 0, false, false)
    assert(
      t.actionUsed and
      t.bonusActionUsed and
      not(t.reactionAvailable) and
      t.movementRemaining == 0 and
      t.surprised
    )
  }
  
  // Rule: A member of a group can be surprised even if the other members aren't — both states are independently valid.
  run qa_partial_surprise_independent_per_creature = {
    val creature = freshCreature(30)
    val immuneTurn   = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    val surprisedTurn = pStartTurn(TEST_CONFIG, creature, Unarmored, true,  0, false, false)
    assert(
      // Immune character (e.g. Weapon of Warning bearer) can act, move, and react
      not(immuneTurn.actionUsed) and
      immuneTurn.movementRemaining > 0 and
      immuneTurn.reactionAvailable and
      // Surprised ally is locked out for the first turn
      surprisedTurn.actionUsed and
      surprisedTurn.movementRemaining == 0 and
      not(surprisedTurn.reactionAvailable)
    )
  }
  
  // Rule: After the surprised turn ends, a previously surprised creature regains its reaction.
  run qa_surprised_creature_regains_reaction_after_first_turn = {
    val creature = freshCreature(30)
    val t0 = pStartTurn(TEST_CONFIG, creature, Unarmored, true, 0, false, false)
    val t1 = pEndSurpriseTurn(t0)
    assert(
      not(t0.reactionAvailable) and
      t1.reactionAvailable and
      not(t1.surprised)
    )
  }

  // Source: https://rpg.stackexchange.com/q/210831
  
  // Is it possible to hold back on skill checks by using a lower modifier than you actually have in the rules as written?
  run qa_cannot_reduce_modifier_for_skill_check = {
    // RAW: ability modifier is fixed by score; spec provides no mechanism to voluntarily use a lower value.
    // STR 16 → mod +3; no rule allows pretending to have mod +0 to feign weakness.
    val actualMod    = abilityModifier(16)  // +3, fixed by score
    val pretendMod   = abilityModifier(10)  // +0, the "held back" value — non-RAW, not supported
    val profBonus    = proficiencyBonus(3)  // level 3 → +2
    val dc           = 14
    val d20Roll      = 11
    // RAW result (must use actual mod): 11 + 3 + 0 = 14 >= 14 → succeeds
    val rawResult      = checkSucceeds(d20Roll, actualMod,  NoneProf, profBonus, 0, dc)
    // Non-RAW "held back" result: 11 + 0 + 0 = 11 < 14 → fails (but this path has no spec support)
    val heldBackResult = checkSucceeds(d20Roll, pretendMod, NoneProf, profBonus, 0, dc)
    // abilityModifier is deterministic from score — no choosable reduction exists in the spec
    assert(
      actualMod      == 3    and  // modifier fixed, not chooseable
      rawResult      == true and  // must use the real modifier per RAW
      heldBackResult == false     // the "held back" outcome only reachable via a non-RAW fake input
    )
  }

  // Source: https://rpg.stackexchange.com/q/107470
  
  // Using shields with versatile/two-handed weapons?
  run qa_shield_don_doff_costs_action = {
    // PHB p.146: donning a shield costs 1 action; only one action per turn.
    // A character cannot both attack (action) and don a shield (action) on the same turn.
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    // Use the action to attack
    val t1 = pUseAction(t0, creature, AAttack)
    // Attempt a second action to don the shield — blocked, action already consumed
    val t2 = pUseAction(t1, creature, AUseObject)
    assert(t1.actionUsed and t2 == t1)
  }

  // Source: https://rpg.stackexchange.com/q/167936
  
  // Does moving away from a prone creature trigger an opportunity attack?
  run qa_prone_oa_triggers_at_disadvantage = {
    // Prone creature is the OA attacker; mover hasn't disengaged so OA triggers
    val proneCreature = pApplyCondition(freshCreature(20), CProne)
  
    // Prone does NOT cause incapacitation, so the creature can still take reactions / make OAs
    val canAct = pCanAct(proneCreature)
  
    // Moving creature started a fresh turn and never used Disengage, so it can be OA'd
    val canBeOAd = pCanBeOpportunityAttacked(FRESH_TURN)
  
    // PHB Appendix A / Prone: prone creature has disadvantage on its own attack rolls (incl. OA)
    val ownMods = pOwnAttackModifiers(proneCreature, false)
  
    assert(
      canAct        and   // prone ≠ incapacitated; OA is legal
      canBeOAd      and   // mover didn't Disengage; OA is triggered
      ownMods.hasDisadvantage and   // OA roll made at disadvantage
      not(ownMods.hasAdvantage)     // no advantage cancelling it out
    )
  }

  // Source: https://rpg.stackexchange.com/q/112717
  
  // Spell Mastery Shield cannot freely recharge Arcane Ward: reaction consumed on use, cannot be used again same round
  run qa_shield_spell_mastery_reaction_limit = {
    val t0 = FRESH_TURN
    val t1 = pUseReaction(t0)   // reaction fires on trigger (hit by attack / Magic Missile)
    val t2 = pUseReaction(t1)   // attempt second cast — reaction already spent
    assert(
      t0.reactionAvailable == true
      and t1.reactionAvailable == false
      and t2.reactionAvailable == false
    )
  }
  
  // Mage Armor (action spell) with Spell Mastery: uses action slot, reaction remains available for other uses
  run qa_mage_armor_action_not_reaction = {
    val c = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, c, ACastSpell)
    assert(
      t1.actionUsed == true
      and t1.reactionAvailable == true
    )
  }
  
  // Reaction resets at start of each new turn, so Shield is eligible again next round (if triggered)
  run qa_reaction_resets_each_turn = {
    val c = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseReaction(t0)
    val t2 = pStartTurn(TEST_CONFIG, c, Unarmored, false, 0, false, false)
    assert(
      t1.reactionAvailable == false
      and t2.reactionAvailable == true
    )
  }

  // Source: https://rpg.stackexchange.com/q/95317
  
  // Can I make an opportunity attack against a grappled creature if it's being moved out of my reach?
  run qa_grappled_creature_moved_by_grappler_no_oa = {
      // Grappled creature: grapple condition sets own speed to 0 on its turn
      val grappled = freshCreature(20).with("grappled", true)
      val grappledTurn = pStartTurn(TEST_CONFIG, grappled, Unarmored, false, 0, false, false)
  
      // Grappler uses THEIR OWN movement to drag the grappled creature (separate TurnState)
      // PHB p.195: dragging costs 1 extra foot per foot (2x multiplier) — 10 ft drag = 20 ft spent
      val grapplerTurnAfterDrag = pUseMovement(FRESH_TURN, 10, 2)
  
      assert(and {
          // Grappled creature's own speed is 0 — it cannot use its own movement/action/reaction
          grappledTurn.effectiveSpeed == 0,
          grappledTurn.movementRemaining == 0,
          // Grappler consumed their own movement budget, not the grappled creature's
          grapplerTurnAfterDrag.movementRemaining == 10,
          // PHB p.195: "you don't provoke an OA when someone or something moves you
          // without using your movement, action, or reaction."
          // The grappled creature's TurnState is completely unmodified by the drag —
          // no self-movement, no action spent, not disengaged.
          not(grappledTurn.actionUsed),
          not(grappledTurn.disengaged),
          not(grappledTurn.attackActionUsed),
      })
  }

  // Source: https://rpg.stackexchange.com/q/95088
  
  // SKIP: Spec models a single creature with no companion/pet state; Beast Conclave ranger companion ASI independence cannot be encoded without a second CharConfig/CreatureState representing the pet and ranger-subclass feature logic that does not exist in the spec.

  // Source: https://rpg.stackexchange.com/q/101645
  
  // For a creature affected by the spell See Invisibility, can they see air?
  // Accepted answer: invisibility (CInvisible condition) and transparency are distinct mechanics;
  // See Invisibility interacts only with the game-mechanical CInvisible condition, not physical transparency.
  run qa_see_invisibility_vs_transparent = {
    // "Air" analogy: a thing that is physically transparent but has NO CInvisible condition
    val transparent_thing = freshCreature(10)
    // A creature that actually has the game-mechanical invisible condition
    val invisible_creature = pApplyCondition(freshCreature(10), CInvisible)
    // See Invisibility negates CInvisible — modelled as pRemoveCondition(CInvisible)
    val seen_through_spell = pRemoveCondition(invisible_creature, CInvisible)
    assert(
      // Transparent-but-not-invisible thing has no CInvisible condition (air is not affected)
      not(transparent_thing.invisible)
      // CInvisible is what grants game-mechanical invisibility
      and invisible_creature.invisible
      // CInvisible also grants attacker advantage; transparent things do not
      and pOwnAttackModifiers(invisible_creature, false).hasAdvantage
      and not(pOwnAttackModifiers(transparent_thing, false).hasAdvantage)
      // See Invisibility removes the condition; the transparent thing never had it to remove
      and not(seen_through_spell.invisible)
      and not(pRemoveCondition(transparent_thing, CInvisible).invisible)
    )
  }

  // Source: https://rpg.stackexchange.com/q/44530
  
  // Overchannel with cantrips: spell level 0 means 2d12 × 0 = 0 necrotic damage (RAW)
  run qa_overchannel_cantrip_zero_necrotic = {
    val maxHp = 20
    val creature = freshCreature(maxHp)
    val spellLevel = 0  // cantrip level is 0
    val d12a = 9
    val d12b = 7
    // PHB overchannel: 2d12 necrotic per spell level after first free use
    val overchannelDamage = (d12a + d12b) * spellLevel  // 16 * 0 = 0
    val s1 = pTakeDamage(creature, overchannelDamage, Necrotic, Set(), Set(), Set(), false)
    assert(s1.hp == maxHp and s1 == creature)
  }
  
  // Overchannel with a level-1 spell (second use): 2d12 × 1 necrotic, ignores immunity/resistance
  run qa_overchannel_level1_ignores_immunity = {
    val maxHp = 30
    val creature = freshCreature(maxHp)
    val spellLevel = 1
    val d12a = 8
    val d12b = 6
    // 2d12 * spellLevel = 14 necrotic; overchannel bypasses immunity so pass empty sets
    val overchannelDamage = (d12a + d12b) * spellLevel  // = 14
    val s1 = pTakeDamage(creature, overchannelDamage, Necrotic, Set(), Set(), Set(), false)
    assert(s1.hp == maxHp - 14)
  }
  
  // Overchannel necrotic escalates by 1d12 per spell level on subsequent uses (level-2 spell, third use = 3d12×2)
  run qa_overchannel_escalating_penalty = {
    val maxHp = 40
    val creature = freshCreature(maxHp)
    val spellLevel = 2
    // Third use: (2 + 1) d12 per level = 3d12 per spell level
    val dicePerLevel = 3
    val d12a = 10
    val d12b = 5
    val d12c = 8
    val overchannelDamage = (d12a + d12b + d12c) * spellLevel  // 23 * 2 = 46
    // Overchannel bypasses immunity — pass empty immunity/resistance sets
    val s1 = pTakeDamage(creature, overchannelDamage, Necrotic, Set(), Set(), Set(), false)
    assert(s1.hp == 0 and s1.unconscious)
  }

  // Source: https://rpg.stackexchange.com/q/87192
  
  // Do ability modifiers get added to each roll when achieving a critical hit?
  run qa_crit_modifier_added_once = {
    // Dagger crit: roll 2d4, then add STR mod exactly once (not once per die)
    val die1    = 3   // first d4 result
    val die2    = 2   // bonus d4 result (extra crit die)
    val strMod  = 3
    val critDmg = criticalDamage(die1, die2, strMod)
    // PHB p.196: "roll all damage dice twice … then add any relevant modifiers as normal"
    // Modifier added once → 3+2+3 = 8, NOT 3+2+3+3 = 11
    assert(
      critDmg == die1 + die2 + strMod          // modifier added once
      and critDmg != die1 + die2 + strMod * 2  // NOT added per die
    )
  }

