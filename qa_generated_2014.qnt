  // Source: https://rpg.stackexchange.com/q/171085
  
  // What does the spell Compelled Duel actually do? — failed WIS save (DM ruling): movement >30 ft blocked that turn
  run qa_compelled_duel_failed_save_blocks_movement = {
    val wisMod = abilityModifier(14)          // score 14 → mod +2
    val profBonus = proficiencyBonus(5)       // level 5 → +3
    val saveFailed = not(saveSucceeds(4, wisMod, false, profBonus, 0, 14))
    // DM ruling: failed save means no movement away from caster (model: movementRemaining = 0)
    val t = FRESH_TURN.with("movementRemaining", 0)
    val tAfter = pUseMovement(t, 5, 1)
    assert(saveFailed and tAfter.movementRemaining == 0)
  }
  
  // What does the spell Compelled Duel actually do? — successful WIS save: movement unrestricted for that turn
  run qa_compelled_duel_success_save_allows_movement = {
    val wisMod = abilityModifier(14)          // score 14 → mod +2
    val profBonus = proficiencyBonus(5)       // level 5 → +3
    val saveSucceeded = saveSucceeds(15, wisMod, false, profBonus, 0, 14)
    // DM ruling: on success the spell does not restrict movement for that turn
    val t = FRESH_TURN                        // 30 ft remaining
    val tAfter = pUseMovement(t, 10, 1)
    assert(saveSucceeded and tAfter.movementRemaining == 20)
  }

  // Source: https://rpg.stackexchange.com/q/131181
  
  // How does the Fighter's possible bonus action from Action Surge work?
  // Action Surge grants one extra Action; it does NOT grant or consume a bonus action.
  run qa_action_surge_does_not_grant_bonus_action = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    // Simulate using the action (e.g. via Action Surge's extra action)
    val t1 = pUseAction(t0, creature, AAttack)
    // Action is consumed, but bonus action remains untouched
    assert(t1.actionUsed and not(t1.bonusActionUsed))
  }
  
  // "Possible" bonus action means bonus actions require a separate feature to exist at all.
  // Action and bonus action are fully independent resources on the same turn.
  run qa_bonus_action_is_independent_of_action = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, creature, AAttack)
    val t2 = pUseBonusAction(t1, creature)
    // Spending the bonus action is a distinct operation from spending the action
    assert(t2.actionUsed and t2.bonusActionUsed)
  }

  // Source: https://rpg.stackexchange.com/q/211636
  
  // Can Blindness/Deafness from Find Familiar be removed by Lesser Restoration?
  // Accepted answer: Lesser Restoration technically removes the condition, but the ongoing
  // spell effect immediately reapplies it — net result is the creature remains blinded/deafened.
  run qa_lesser_restoration_cannot_remove_find_familiar_blindness = {
    val creature = freshCreature(20)
    // Step 1: Find Familiar "see through familiar's eyes" applies blinded + deafened
    val afterFindFamiliar = pApplyCondition(pApplyCondition(creature, CBlinded), CDeafened)
    // Step 2: Lesser Restoration removes the blinded condition (it technically works)
    val afterLesserRestoration = pRemoveCondition(afterFindFamiliar, CBlinded)
    // Intermediate: blinded is gone, deafened persists
    val midCheck = afterLesserRestoration.blinded == false and afterLesserRestoration.deafened == true
    // Step 3: The still-active Find Familiar effect immediately reapplies blinded
    val afterReapplication = pApplyCondition(afterLesserRestoration, CBlinded)
    // Net result: creature is still blinded and deafened — Lesser Restoration did nothing lasting
    assert(midCheck and afterReapplication.blinded == true and afterReapplication.deafened == true)
  }

  // Source: https://rpg.stackexchange.com/q/182022
  
  // What happens when an aboleth enslaves another aboleth who's enslaved a werewolf?
  // Key ruling: CCharmed does NOT incapacitate — a charmed aboleth 1 can still act and speak,
  // so aboleth 2's commands can flow indirectly through aboleth 1 to the werewolf.
  run qa_charmed_creature_can_act_and_relay_commands = {
    // Aboleth 1 enslaved (charmed) by Aboleth 2
    val aboleth1 = pApplyCondition(freshCreature(50), CCharmed)
    // Werewolf enslaved (charmed) by Aboleth 1
    val werewolf = pApplyCondition(freshCreature(30), CCharmed)
    assert(
      // Aboleth 1 is charmed but NOT incapacitated — it retains the ability to act
      // and speak, which is what makes the indirect command chain possible
      aboleth1.charmed == true
      and not(isIncapacitated(aboleth1))
      and pCanAct(aboleth1)
      and pCanSpeak(aboleth1)
      // Werewolf is charmed but also still capable of acting (can receive and obey commands)
      and werewolf.charmed == true
      and not(isIncapacitated(werewolf))
      and pCanAct(werewolf)
      and pCanSpeak(werewolf)
    )
  }

  // Can multiple characters cast concentration spells from the same item by passing it around?
  run qa_concentration_per_caster_not_per_item = {
    // Caster A casts a concentration spell from a wand; item is then passed to Caster B.
    // Concentration belongs to the caster, not the item — modelled as two independent SpellSlotStates.
    val casterA_slots = pStartConcentration(FRESH_SPELL_SLOTS, "detect_magic")
    // Passing the wand has no effect on casterA_slots — no operation touches it.
    // Caster B now casts their own concentration spell from the same wand.
    val casterB_slots = pStartConcentration(FRESH_SPELL_SLOTS, "detect_magic")
    // Both casters are independently concentrating; neither broke the other.
    assert(
      isConcentrating(casterA_slots) and
      isConcentrating(casterB_slots) and
      casterA_slots.concentrationSpellId == "detect_magic" and
      casterB_slots.concentrationSpellId == "detect_magic"
    )
  }
  
  // Can multiple characters cast concentration spells from the same item by passing it around?
  run qa_item_pass_leaves_original_concentration_intact = {
    // Accepted answer: concentration is per-caster. Handing the wand away does not break
    // the first caster's concentration. Verify that nothing in the spec touches casterA's
    // slot state when casterB starts concentrating on their own state.
    val casterA_slots = pStartConcentration(FRESH_SPELL_SLOTS, "detect_magic")
    // Simulate caster B receiving the item and starting concentration — entirely separate state.
    val casterB_slots = pStartConcentration(FRESH_SPELL_SLOTS, "detect_magic")
    // casterA_slots is structurally identical after the "pass": concentration never broken.
    assert(
      casterA_slots == pStartConcentration(FRESH_SPELL_SLOTS, "detect_magic")
    )
  }
  
  // Can multiple characters cast concentration spells from the same item by passing it around?
  run qa_each_caster_limited_to_one_concentration = {
    // Even with the item available, a single caster still cannot concentrate on two spells.
    // Starting a second concentration spell replaces the first (PHB rule, modelled by pStartConcentration).
    val after_first  = pStartConcentration(FRESH_SPELL_SLOTS, "detect_magic")
    val after_second = pStartConcentration(after_first, "detect_magic")
    assert(
      isConcentrating(after_second) and
      after_second.concentrationSpellId == "detect_magic" and
      // Only one spell tracked — not two simultaneous concentrations.
      after_second == after_first
    )
  }

  // Source: https://rpg.stackexchange.com/q/200858
  
  // What effect does reducing a Spelljamming Vessel to 0 hp have?
  // Accepted: per DMG object rules, objects at 0 HP lose structural integrity (disabled/destroyed)
  run qa_vessel_reduced_to_0hp_becomes_incapacitated = {
    // Ship modeled as creature; exactly-0-HP result = unconscious + incapacitated (non-functional)
    val vessel = freshCreature(20)
    val result = pTakeDamage(vessel, 20, Bludgeoning, Set(), Set(), Set(), false)
    assert(result.hp == 0 and result.unconscious == true and isIncapacitated(result))
  }
  
  // What effect does reducing a Spelljamming Vessel to 0 hp have?
  // Accepted: massive damage overflow >= maxHp destroys the object outright (no incapacitation — just dead)
  run qa_vessel_massive_damage_overflow_is_destroyed = {
    // freshCreature(10): maxHp=10; 20 damage → overflow=10 >= effMax=10 → dead, not merely unconscious
    val vessel = freshCreature(10)
    val result = pTakeDamage(vessel, 20, Bludgeoning, Set(), Set(), Set(), false)
    assert(result.dead == true and result.hp == 0 and not(result.unconscious))
  }
  
  // What effect does reducing a Spelljamming Vessel to 0 hp have?
  // Accepted: once destroyed, the ship cannot be further meaningfully damaged (absorbing state)
  run qa_vessel_destroyed_absorbs_further_damage = {
    val vessel = freshCreature(10)
    // Reduce to dead via overflow
    val destroyed = pTakeDamage(vessel, 20, Bludgeoning, Set(), Set(), Set(), false)
    // Additional damage on a dead object has no effect
    val afterMoreDamage = pTakeDamage(destroyed, 50, Fire, Set(), Set(), Set(), false)
    assert(destroyed.dead == true and afterMoreDamage == destroyed)
  }

  // Source: https://rpg.stackexchange.com/q/177167
  
  // SKIP: Stone Shape's reshaping mechanics (volume conservation, dimensional extension) operate on physical object geometry — no functions in the spec model stone dimensions, mass, or environmental object manipulation.

  // Source: https://rpg.stackexchange.com/q/147079
  
  // Is it possible to Ready a spell triggered by an ally's attack? Ready action uses action slot and sets flag.
  run qa_ready_action_sets_readied_flag = {
    val creature = freshCreature(20)
    val t1 = pUseAction(FRESH_TURN, creature, AReady)
    assert(t1.readiedAction == true and t1.actionUsed == true)
  }
  
  // Readying a non-cantrip spell (e.g. Slow) requires concentration; supersedes any prior concentration.
  run qa_readied_spell_breaks_prior_concentration = {
    val ss_with_bless = FRESH_SPELL_SLOTS.with("concentrationSpellId", "bless")
    val ss_after_ready = pStartConcentration(ss_with_bless, "slow")
    assert(ss_after_ready.concentrationSpellId == "slow")
  }
  
  // After readied spell fires and next turn begins, creature has full action economy (enables back-to-back casts).
  run qa_next_turn_after_ready_has_full_action_economy = {
    val creature = freshCreature(20)
    val t_next = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    assert(
      t_next.actionUsed == false and
      t_next.bonusActionUsed == false and
      t_next.movementRemaining == 30
    )
  }
  
  // AReady does NOT set nonCantripActionSpellCast, so bonus-action spell casting remains unrestricted that turn.
  run qa_ready_does_not_block_bonus_action_spell = {
    val creature = freshCreature(20)
    val t1 = pUseAction(FRESH_TURN, creature, AReady)
    assert(t1.nonCantripActionSpellCast == false and canCastBonusActionSpell(t1) == true)
  }

  // Source: https://rpg.stackexchange.com/q/152926
  
  // SKIP: spec has no model of spell-created physical objects, antimagic field interactions, or Dispel Magic mechanics; the "is it magical?" Sage Advice predicate has no corresponding function in the spec.

  // Source: https://rpg.stackexchange.com/q/212402
  
  // SKIP: Spec has no container volume, item packing, or chest capacity functions; the Q&A is a real-world volumetric estimation problem with no mechanical analogue in the dnd module.

  // Source: https://rpg.stackexchange.com/q/129737
  
  // Does drinking an Antitoxin take an action?
  // RAW: antitoxin is not magical and not a potion; it qualifies as the free object interaction, leaving the action available
  run qa_antitoxin_free_object_interaction = {
    val t = pUseObjectInteraction(FRESH_TURN)
    assert(
      t.freeInteractionUsed == true and
      t.actionUsed == false
    )
  }
  
  // Does drinking an Antitoxin take an action? (contrast: a healing potion uses the AUseObject action)
  // Drinking a magical potion is "Use Magic Item" / Use an Object action, consuming actionUsed
  run qa_magic_potion_requires_action = {
    val creature = freshCreature(20)
    val t = pUseAction(FRESH_TURN, creature, AUseObject)
    assert(
      t.actionUsed == true and
      t.freeInteractionUsed == false
    )
  }
  
  // Does drinking an Antitoxin take an action? (second free interaction in a turn is not free)
  // Only one free object interaction per turn; a second one does not change state — caller must use an action
  run qa_antitoxin_second_use_needs_action = {
    val t1 = pUseObjectInteraction(FRESH_TURN)
    val t2 = pUseObjectInteraction(t1)
    assert(t1 == t2)
  }

  // Source: https://rpg.stackexchange.com/q/93507
  
  // Can the Mage Slayer reaction attack be triggered by a cantrip?
  run qa_mage_slayer_cantrip_triggers_reaction = {
    val casterCreature = freshCreature(10)
    // Caster uses action to cast a cantrip (spell level 0): ACastSpell, no slot expended,
    // nonCantripActionSpellCast stays false because it is a cantrip
    val casterTurn = pUseAction(FRESH_TURN, casterCreature, ACastSpell)
    // Mage Slayer holder is within 5ft with reaction available
    val mageSlayerTurn = FRESH_TURN
    // A cantrip IS a spell (level 0) → Mage Slayer triggers → reaction consumed
    val afterReaction = pUseReaction(mageSlayerTurn)
    assert(
      // Caster did cast a spell (their action was used)
      casterTurn.actionUsed == true and
      // It was a cantrip: nonCantripActionSpellCast not set (level-0 spell)
      casterTurn.nonCantripActionSpellCast == false and
      // Reaction was available before Mage Slayer fires
      mageSlayerTurn.reactionAvailable == true and
      // Reaction is consumed after the Mage Slayer attack
      afterReaction.reactionAvailable == false
    )
  }

  // Source: https://rpg.stackexchange.com/q/145125
  
  // SKIP: Q&A asks whether prestige classes exist as published content — a content-availability question with no mechanical rule to encode. The spec models no prestige-class concept, prerequisites, or advancement path, so there is nothing to assert against.

  // Source: https://rpg.stackexchange.com/q/102864
  
  // Do clerics have to prepare ritual spells?
  // Accepted answer: ritual casting requires the spell to be prepared (for clerics);
  // the spec models canRitualCast but has no "prepared spells" set on CharConfig —
  // spell preparation tracking is not present in the spec.
  // SKIP: spec does not model spell preparation lists or ritual-vs-prepared validation

  // Source: https://rpg.stackexchange.com/q/162370
  
  // "How can I hit what I can't see?" — a freely chosen point in open air has NoCover and is always targetable; what lies beyond it is irrelevant
  run qa_point_in_space_is_targetable = {
    // The designated point is in open air — NoCover — so it can be targeted.
    // The mountain (or any obstacle) behind that point does not retroactively
    // impose cover on the point itself; only the point's own cover status matters.
    assert(canBeTargeted(NoCover) == true)
      and assert(canBeTargeted(HalfCover) == true)
      and assert(canBeTargeted(ThreeQuartersCover) == true)
      and assert(canBeTargeted(TotalCover) == false)
  }

  // Source: https://rpg.stackexchange.com/q/142644
  
  // Heat Metal on full-body armor (Scale Mail/Plate): mount in physical contact takes full 2d8 fire damage
  run qa_heat_metal_mount_fullbody_armor_takes_fire_damage = {
    val mountMaxHp = 30
    val mount = freshCreature(mountMaxHp)
    // Pre-resolved 2d8 = 11; full-body armor (Scale Mail / Plate) contacts mount seat
    val heatMetalRoll = 11
    val mountAfter = pTakeDamage(mount, heatMetalRoll, Fire, Set(), Set(), Set(), false)
    assert(mountAfter.hp == mountMaxHp - heatMetalRoll)
  }
  
  // Heat Metal on upper-body-only armor (Chain Shirt/Breastplate): no lower-body contact, mount takes 0 damage
  run qa_heat_metal_upper_body_armor_mount_no_damage = {
    val mountMaxHp = 30
    val mount = freshCreature(mountMaxHp)
    // Upper-body armor does not contact the mount; damage dealt to mount is 0
    val mountAfter = pTakeDamage(mount, 0, Fire, Set(), Set(), Set(), false)
    assert(mountAfter.hp == mountMaxHp)
  }
  
  // Heat Metal: partial contact still triggers full 2d8—contact area does not scale damage
  run qa_heat_metal_partial_contact_full_damage = {
    val mountMaxHp = 20
    val mount = freshCreature(mountMaxHp)
    // Even minimal metal contact (e.g. one gauntlet) delivers the full roll; no partial reduction
    val heatMetalRoll = 9
    val mountAfter = pTakeDamage(mount, heatMetalRoll, Fire, Set(), Set(), Set(), false)
    assert(mountAfter.hp == mountMaxHp - heatMetalRoll)
  }
  
  // Heat Metal: fire-resistant mount (e.g. fire lizard) still takes halved damage even when in full contact
  run qa_heat_metal_fire_resistant_mount_halved = {
    val mountMaxHp = 20
    val mount = freshCreature(mountMaxHp)
    val heatMetalRoll = 10
    // Resistance to Fire halves the damage; contact area is irrelevant to this reduction
    val mountAfter = pTakeDamage(mount, heatMetalRoll, Fire, Set(Fire), Set(), Set(), false)
    assert(mountAfter.hp == mountMaxHp - 5)
  }

  // Source: https://rpg.stackexchange.com/q/196624
  
  // Is there an effect that will cause more than one level of exhaustion to be gained? — PHB Ch8 dehydration: already-exhausted creature takes 2 levels
  run qa_dehydration_two_levels_if_already_exhausted = {
    val s0 = freshCreature(20).with("exhaustion", 1)
    val s1 = pApplyDehydration(s0, false, false)
    assert(s1.exhaustion == 3)
  }
  
  // Dehydration baseline: creature with no prior exhaustion gains only 1 level
  run qa_dehydration_one_level_when_not_exhausted = {
    val s0 = freshCreature(20).with("exhaustion", 0)
    val s1 = pApplyDehydration(s0, false, false)
    assert(s1.exhaustion == 1)
  }
  
  // Half water + failed CON save still inflicts 2 levels when creature is already exhausted
  run qa_dehydration_half_water_failed_save_two_levels_if_exhausted = {
    val s0 = freshCreature(20).with("exhaustion", 2)
    val s1 = pApplyDehydration(s0, true, false)
    assert(s1.exhaustion == 4)
  }
  
  // Half water + successful CON save → no exhaustion gained regardless of prior exhaustion
  run qa_dehydration_half_water_passed_save_no_change = {
    val s0 = freshCreature(20).with("exhaustion", 3)
    val s1 = pApplyDehydration(s0, true, true)
    assert(s1.exhaustion == 3)
  }
  
  // Two levels of dehydration exhaustion can jump exhaustion 4 straight to 6 (death), skipping 5
  run qa_dehydration_exhaustion_4_to_dead_via_two_levels = {
    val s0 = freshCreature(20).with("exhaustion", 4)
    val s1 = pApplyDehydration(s0, false, false)
    assert(s1.exhaustion == 6 and s1.dead)
  }

  // Source: https://rpg.stackexchange.com/q/206952
  
  // Does the penalty to passive Perception for a fast travel pace stack with disadvantage from light obscurity?
  run qa_fast_pace_and_dim_light_passive_perception_stack = {
    // TEST_CONFIG: Wis 13 -> mod +1; level 5 -> profBonus +3; Perception is proficient
    val wisMod       = abilityModifier(13)            // +1
    val prof         = proficiencyBonus(5)            // +3
  
    // Dim light -> LightlyObscured -> disadvantage on sight-based Perception checks
    val obs          = pEffectiveObscurement(Dim, false)   // LightlyObscured
    val hasDisadv    = pPerceptionDisadvantage(obs)         // true
  
    // Baseline passive Perception (no penalties)
    val passiveBase  = passiveCheck(wisMod, Proficient, prof, false, false)
    // = 10 + 1 + 3 = 14
  
    // Passive Perception with disadvantage from dim light (-5)
    val passiveDisadv = passiveCheck(wisMod, Proficient, prof, false, hasDisadv)
    // = 10 + 1 + 3 - 5 = 9
  
    // Fast pace is a flat -5 penalty, RAW does NOT say it is disadvantage, so it stacks
    val travelPenalty = pTravelPerceptionPenalty(PaceFast)
    // = -5
  
    // Accepted answer: both penalties stack -> total passive Perception = baseline - 10
    val totalPassive  = passiveDisadv + travelPenalty
    // = 9 + (-5) = 4
  
    assert(
      obs == LightlyObscured
      and hasDisadv == true
      and travelPenalty == -5
      // disadvantage alone costs exactly 5 points
      and passiveDisadv == passiveBase - 5
      // flat fast-pace penalty stacks on top for a combined -10
      and totalPassive == passiveBase - 10
    )
  }

  // Source: https://rpg.stackexchange.com/q/46623
  
  // Long rest regains half hit dice - round up or down?
  run qa_long_rest_hd_level1_minimum_one = {
    // Level 1: floor(1/2)=0 but minimum of 1 always applies — character recovers their sole HD
    val recovery = pHitDiceRecovery(1, 0)
    assert(recovery == 1)
  }
  
  // Long rest regains half hit dice - round up or down?
  run qa_long_rest_hd_rounds_down_odd = {
    // Level 5: floor(5/2)=2, not 3 — general rule is round down
    val recovery = pHitDiceRecovery(5, 0)
    assert(recovery == 2)
  }
  
  // Long rest regains half hit dice - round up or down?
  run qa_long_rest_hd_rounds_down_even = {
    // Level 4: floor(4/2)=2, exact half, no rounding ambiguity
    val recovery = pHitDiceRecovery(4, 0)
    assert(recovery == 2)
  }
  
  // Long rest regains half hit dice - round up or down?
  run qa_long_rest_hd_caps_at_spent = {
    // Level 5, only 1 HD spent: can't recover more than was spent even if quota allows 2
    val recovery = pHitDiceRecovery(5, 4)
    assert(recovery == 1)
  }
  
  // Long rest regains half hit dice - round up or down?
  run qa_long_rest_hd_nothing_spent_no_recovery = {
    // All HD intact: recover 0 (nothing was spent)
    val recovery = pHitDiceRecovery(5, 5)
    assert(recovery == 0)
  }
  
  // Long rest regains half hit dice - round up or down?
  run qa_long_rest_integration_level1 = {
    // Full pLongRest integration: level 1 char with 0 HD remaining gets back exactly 1
    val c = freshCreature(8).with("hitDiceRemaining", 0)
    val after = pLongRest(c, 1, true)
    assert(after.hitDiceRemaining == 1)
  }
  
  // Long rest regains half hit dice - round up or down?
  run qa_long_rest_integration_level5_rounds_down = {
    // Full pLongRest integration: level 5 char recovers 2 HD, not 3 (floor division)
    val c = freshCreature(40).with("hitDiceRemaining", 0)
    val after = pLongRest(c, 5, true)
    assert(after.hitDiceRemaining == 2)
  }

  // Source: https://rpg.stackexchange.com/q/161339
  
  // SKIP: The spec models post-construction state mechanics (combat, conditions, HP, spells). Character creation step ordering — race selection (step 1) before ability score determination (step 3) — is not modeled; there is no step-sequencing state machine, no race type, and no "Variant Human" concept in the spec.

  // Source: https://rpg.stackexchange.com/q/167697
  
  // SKIP: Yuan-Ti hibernation/dormancy is a lore/monster stat block question with no mechanical encoding possible in this spec (no creature types, monster stat blocks, or hibernation mechanics exist).

  // Source: https://rpg.stackexchange.com/q/69785
  
  // Does the Ready action give advantage if I attack while not seen?
  run qa_readied_attack_unseen_grants_advantage = {
    // Readied reaction attack: target cannot see attacker (hidden) → advantage regardless of action type
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: false, // target cannot see the hidden attacker
      attackerCanSeeTarget: true,
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    // PHB p.195: "When a creature can't see you, you have advantage on attack rolls against it."
    // Action type (readied reaction, normal action, etc.) is irrelevant to this advantage source.
    assert(mods.hasAdvantage and not(mods.hasDisadvantage) and not(mods.autoMiss))
  }
  
  // Confirm: a normal (non-readied) attack while seen grants NO advantage from visibility alone
  run qa_normal_attack_seen_no_visibility_advantage = {
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: true, // target CAN see attacker — no visibility advantage
      attackerCanSeeTarget: true,
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(not(mods.hasAdvantage) and not(mods.hasDisadvantage))
  }

  // Source: https://rpg.stackexchange.com/q/144148
  
  // Can you replace a racial trait cantrip when leveling up?
  run qa_cannot_replace_cantrip_no_level0_slots = {
    // Accepted answer: warlock spell replacement requires "a level for which you have spell
    // slots." Cantrips are spell level 0; pSlotsPerLevel falls through to 0 for level 0
    // at every caster level — no 0th-level slots exist, so cantrips can never be replaced.
    assert(1.to(20).forall(cl => pSlotsPerLevel(cl, 0) == 0))
  }

  // Source: https://rpg.stackexchange.com/q/184625
  
  // Effects of wearing armor without proficiency: Str/Dex disadvantage applies to checks, saves, AND attacks (not attacks only)
  run qa_nonproficient_armor_strdex_disadv = {
    // Chain mail = HeavyArmor; only Light+Medium proficiency → lacks prof
    val lacksProf = lacksArmorProficiency(WearingArmor(CHAIN_MAIL), Set(LightArmor, MediumArmor))
  
    val strMod = abilityModifier(14) // +2
    val dc = 13
  
    // Str ability check: normal roll succeeds, disadvantage roll fails
    val strCheckNormal = checkSucceeds(11, strMod, NoneProf, 4, 0, dc)
    val strCheckDisadv  = checkSucceeds(7,  strMod, NoneProf, 4, 0, dc)
  
    // Accepted answer: the Str/Dex qualifier applies to saving throws too, not just attacks
    val strSaveNormal = saveSucceeds(11, strMod, false, 4, 0, dc)
    val strSaveDisadv  = saveSucceeds(7,  strMod, false, 4, 0, dc)
  
    // Attack roll: same Str/Dex disadvantage pattern
    val attackNormal = resolveAttackRoll(11, strMod, 13, 0)
    val attackDisadv  = resolveAttackRoll(7,  strMod, 13, 0)
  
    assert(
      lacksProf
      and strCheckNormal and not(strCheckDisadv)   // Str check: normal ok, disadv fails
      and strSaveNormal  and not(strSaveDisadv)    // Str save: same (accepted interp — not attacks-only)
      and attackNormal.hits and not(attackDisadv.hits) // Str attack: same
    )
  }

  // Source: https://rpg.stackexchange.com/q/102157
  
  // Remorhaz Heated Body: special trait (not action/reaction) triggers once per melee attack hit
  run qa_heated_body_triggers_per_attack = {
    val attacker = freshCreature(40)
    // First melee attack hits → Heated Body triggers (10 fire damage)
    val s1 = pTakeDamage(attacker, 10, Fire, Set(), Set(), Set(), false)
    // Second melee attack also hits → Heated Body triggers again (10 fire damage)
    val s2 = pTakeDamage(s1, 10, Fire, Set(), Set(), Set(), false)
    // Two hits = two independent Heated Body triggers = 20 total fire damage
    assert(s2.hp == 20)
  }
  
  // Remorhaz Heated Body: grappling (touching) triggers damage once at moment of initial contact
  run qa_heated_body_grapple_triggers_once = {
    val grappler = freshCreature(30)
    val remorhaz = freshCreature(100)
    // Grapple succeeds (AWins, free hand, Medium vs Large is within one size)
    val result = pGrapple(Medium, Large, remorhaz, AWins, true)
    // Grappler took one touch → one Heated Body damage instance (10 fire)
    val grappler_after = pTakeDamage(grappler, 10, Fire, Set(), Set(), Set(), false)
    assert(result.success and result.targetState.grappled and grappler_after.hp == 20)
  }
  
  // Remorhaz Swallow: swallowed creature takes only acid damage; Heated Body does NOT apply (RAI)
  run qa_swallow_acid_only_no_heated_body = {
    val victim = freshCreature(50)
    // Swallow deals 6d6 acid damage only (21 here); Heated Body is a counter-trait, not triggered by remorhaz's own attacks
    val after_swallow = pTakeDamage(victim, 21, Acid, Set(), Set(), Set(), false)
    // HP = 50 - 21 = 29 (no additional 10 fire from Heated Body)
    assert(after_swallow.hp == 29)
  }

  // Source: https://rpg.stackexchange.com/q/127297
  
  // Is there a reason this homebrew spell wouldn't work with the Attack action?
  run qa_lightning_lash_attack_action_next_turn = {
    val creature = freshCreature(20)
    // Turn 1: cast 2nd-level concentration spell — uses action, starts concentration
    val t1 = pMarkNonCantripActionSpell(pUseAction(FRESH_TURN, creature, ACastSpell))
    val ss1 = pStartConcentration(FRESH_SPELL_SLOTS, "lightning_lash")
    // Turn 2: fresh turn — Attack action fully available (arc persists via concentration)
    val t2 = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    val t2a = pUseAction(t2, creature, AAttack)
    assert(
      t1.actionUsed and
      isConcentrating(ss1) and
      not(t2.actionUsed) and
      t2a.attackActionUsed
    )
  }
  
  // Is there a reason this homebrew spell wouldn't work with the Attack action?
  run qa_lightning_lash_light_property_enables_twf = {
    // Arc has finesse + light + reach — Light_ qualifies it for TWF off-hand
    val lightningArc = {
      name: "lightning_arc",
      damageDie: 4,
      versatileDie: 0,
      damageType: Lightning,
      properties: Set(Finesse, Light_, Reach),
      isMelee: true,
      normalRange: 0,
      longRange: 0,
    }
    val dagger = {
      name: "dagger",
      damageDie: 4,
      versatileDie: 0,
      damageType: Piercing,
      properties: Set(Finesse, Light_, Thrown),
      isMelee: true,
      normalRange: 20,
      longRange: 60,
    }
    val creature = freshCreature(20)
    // Attack action already taken this turn; bonus action still available
    val t = FRESH_TURN.with("attackActionUsed", true)
    assert(pCanTWFWithWeapons(lightningArc, dagger, t, creature))
  }
  
  // Is there a reason this homebrew spell wouldn't work with the Attack action?
  run qa_lightning_lash_concentration_check = {
    val ss = pStartConcentration(FRESH_SPELL_SLOTS, "lightning_lash")
    // Taking damage requires CON save; failure ends the spell
    val ss_fail = pConcentrationCheck(ss, false)
    val ss_pass = pConcentrationCheck(ss, true)
    assert(
      isConcentrating(ss) and
      not(isConcentrating(ss_fail)) and
      isConcentrating(ss_pass)
    )
  }
  
  // Is there a reason this homebrew spell wouldn't work with the Attack action?
  run qa_lightning_lash_extra_attack_applies = {
    // Arc acts as a melee weapon — Extra Attack applies identically to any other weapon
    val creature = freshCreature(20)
    // TEST_CONFIG: level 5 with FExtraAttack => extraAttacksRemaining starts at 1
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    val t1 = pUseAction(t, creature, AAttack)
    val t2 = pUseExtraAttack(t1)
    assert(
      t1.extraAttacksRemaining == 1 and
      t2.extraAttacksRemaining == 0
    )
  }

  // Source: https://rpg.stackexchange.com/q/179286
  
  // True Polymorph + Awaken: failed concentration check ends True Polymorph, losing the 1000gp Awaken investment
  run qa_true_polymorph_concentration_check_failure_breaks_spell = {
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "true_polymorph")
    val damageTaken = 20
    val dc = pConcentrationDC(damageTaken)   // max(10, 20/2) = 10
    val ss1 = pConcentrationCheck(ss, false) // caster fails the save
    assert(
      dc == 10
      and not(isConcentrating(ss1))
      and ss1.concentrationSpellId == ""
    )
  }
  
  // True Polymorph + Awaken: heavier damage raises the concentration save DC, increasing risk to the Awaken investment
  run qa_true_polymorph_concentration_dc_scales_with_damage = {
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "true_polymorph")
    val dc_low  = pConcentrationDC(8)   // max(10, 4)  = 10 (floor kicks in)
    val dc_mid  = pConcentrationDC(30)  // max(10, 15) = 15
    val dc_high = pConcentrationDC(50)  // max(10, 25) = 25
    assert(dc_low == 10 and dc_mid == 15 and dc_high == 25)
  }
  
  // True Polymorph + Awaken: caster death immediately breaks concentration → True Polymorph ends, Awaken lost
  run qa_true_polymorph_breaks_on_caster_death = {
    val s  = freshCreature(10)
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "true_polymorph")
    val s1  = pTakeDamage(s, 100, Slashing, Set(), Set(), Set(), false)
    val ss1 = pBreakConcOnStateChange(ss, s, s1)
    assert(
      s1.dead
      and not(isConcentrating(ss1))
      and ss1.concentrationSpellId == ""
    )
  }
  
  // True Polymorph + Awaken: passing the concentration save preserves the spell (and the Awaken investment)
  run qa_true_polymorph_concentration_maintained_on_passed_save = {
    val ss  = FRESH_SPELL_SLOTS.with("concentrationSpellId", "true_polymorph")
    val ss1 = pConcentrationCheck(ss, true) // caster succeeds the save
    assert(
      isConcentrating(ss1)
      and ss1.concentrationSpellId == "true_polymorph"
    )
  }

  // Source: https://rpg.stackexchange.com/q/195034
  
  // Can I target someone who I can see in a mirror?
  // Accepted answer: seeing a target via mirror counts as seeing them; spell targeting requires only no total cover (clear path).
  run qa_mirror_sight_targeting = {
    // Illusory wall provides no actual cover — target is fully targetable.
    // Mirror view satisfies "see the target"; only TotalCover blocks spell targeting.
    assert(
      canBeTargeted(NoCover)             == true
      and canBeTargeted(HalfCover)       == true
      and canBeTargeted(ThreeQuartersCover) == true
      and canBeTargeted(TotalCover)      == false
    )
  }

  // Source: https://rpg.stackexchange.com/q/55077
  
  // Are there generic enchanted implements in D&D 5e?
  // Accepted: no generic +X implement exists; specific items (Rod of the Pact Keeper, Wand of the War Mage)
  // add a flat bonus on top of the base formula: spellAttack = abilityMod + profBonus; spellDC = 8 + that.
  run qa_rod_of_pact_keeper_adds_flat_bonus_to_spell_attack_and_dc = {
    // TEST_CONFIG: Wis=13 → mod=1, level=5 → profBonus=3; spellcastingAbility=Wis
    // baseSpellAttack = 1 + 3 = 4; baseSpellDC = 8 + 4 = 12
    val base_attack = spellAttackBonus(TEST_CONFIG)
    val base_dc    = spellSaveDC(TEST_CONFIG)
    // Rod of the Pact Keeper +1: adds 1 to both spell attack and spell save DC
    val rod_bonus = 1
    assert(
      base_attack == 4 and
      base_dc     == 12 and
      base_attack + rod_bonus == 5 and
      base_dc     + rod_bonus == 13
    )
  }
  
  // Wand of the War Mage only improves spell attack bonus, NOT spell save DC
  run qa_wand_of_war_mage_only_affects_spell_attack = {
    val base_attack = spellAttackBonus(TEST_CONFIG)  // 4
    val base_dc    = spellSaveDC(TEST_CONFIG)         // 12
    val wand_bonus = 1
    // Wand of the War Mage +1 raises spell attack but leaves save DC unchanged
    assert(
      base_attack + wand_bonus == 5 and
      base_dc == 12
    )
  }

  // Source: https://rpg.stackexchange.com/q/67757
  
  // Does Arcane Lock Make An Object More Resistant to Damage?
  // RAW: Arcane Lock raises the break/pick DC by 10 but does NOT change object AC,
  // so attack rolls against the object are completely unaffected by the spell.
  run qa_arcane_lock_does_not_affect_ac = {
    val objectAC          = 15   // e.g. a sturdy wooden door
    val normalBreakDC     = 15
    val arcaneLockDcBonus = 10
    val arcaneLockBreakDC = normalBreakDC + arcaneLockDcBonus  // 25
  
    // Attack roll: Arcane Lock provides no AC bonus, so both rolls resolve identically.
    val d20Attack   = 12   // 12 + 5 = 17, clears AC 15
    val attackBonus = 5
    val hit_normal       = resolveAttackRoll(d20Attack, attackBonus, objectAC, 0)
    val hit_arcaneLocked = resolveAttackRoll(d20Attack, attackBonus, objectAC, 0) // AC unchanged
  
    // Ability check to break: DC rises by 10 under Arcane Lock.
    // Roll that beats DC 15 but not DC 25: 14 + 3 (STR mod) + 2 (prof) = 19.
    val d20Check  = 14
    val strMod    = 3
    val profBonus = 2
    val breakCheck_normal       = checkSucceeds(d20Check, strMod, Proficient, profBonus, 0, normalBreakDC)
    val breakCheck_arcaneLocked = checkSucceeds(d20Check, strMod, Proficient, profBonus, 0, arcaneLockBreakDC)
  
    assert(
      // Attack resolves identically — Arcane Lock never touches AC
      hit_normal == hit_arcaneLocked
      // The attack still hits the object (AC 15, total 17)
      and hit_arcaneLocked.hits
      // A STR check total of 19 breaks a normal door (DC 15)
      and breakCheck_normal
      // The same check total of 19 fails an Arcane Locked door (DC 25)
      and not(breakCheck_arcaneLocked)
    )
  }

  // Source: https://rpg.stackexchange.com/q/152805
  
  // Barbarian Rage bonus damage applies to each Strength melee attack including TWF off-hand
  run qa_rage_bonus_applies_to_each_twf_attack = {
    // STR 16 => +3 mod; Level 1-8 barbarian rage bonus = +2
    val dieRoll  = 4
    val strMod   = 3
    val rageBonus = 2
    // Main-hand: dice + STR mod + rage bonus (all three components)
    val mainHandDmg = normalDamage(dieRoll, strMod + rageBonus)
    // TWF off-hand: STR mod suppressed by TWF rule, but rage bonus still applies
    // (it is a melee weapon attack using Strength — PHB rage wording)
    val offHandDmg = pTWFOffHandDamage(dieRoll, strMod) + rageBonus
    assert(
      mainHandDmg == 9 and  // 4 + 3 + 2
      offHandDmg  == 6      // 4 + 0(strMod suppressed) + 2
    )
  }
  
  // TWF off-hand with negative STR mod: negative mod IS kept (TWF rule), rage bonus still added
  run qa_rage_bonus_twf_offhand_negative_str = {
    val dieRoll   = 3
    val strMod    = -1  // STR 8 => -1 mod
    val rageBonus = 2
    // Negative mod is NOT suppressed by TWF rule; rage bonus still added on top
    val offHandDmg = pTWFOffHandDamage(dieRoll, strMod) + rageBonus
    assert(offHandDmg == 4)  // 3 + (-1) + 2
  }

  // Source: https://rpg.stackexchange.com/q/163841
  
  // Do ingested poisons have a taste? — Detection requires active Investigation check, CON save resists effect
  
  // Failed CON save against ingested poison results in the Poisoned condition being applied
  run qa_ingested_poison_con_save_fail_applies_poisoned = {
    val creature = freshCreature(20)
    val conMod = 1      // CON 12 → +1
    val profBonus = 2
    val isProficient = false
    val poisonDC = 14
    val d20Roll = 8     // 8 + 1 = 9, fails DC 14
    val savePassed = saveSucceeds(d20Roll, conMod, isProficient, profBonus, 0, poisonDC)
    val s1 = if (not(savePassed)) pApplyCondition(creature, CPoisoned) else creature
    assert(not(savePassed) and s1.poisoned)
  }
  
  // Successful CON save against ingested poison — creature is not poisoned
  run qa_ingested_poison_con_save_success_no_poisoned = {
    val creature = freshCreature(20)
    val conMod = 3      // CON 16 → +3
    val profBonus = 2
    val isProficient = true
    val poisonDC = 14
    val d20Roll = 12    // 12 + 3 + 2 = 17, passes DC 14
    val savePassed = saveSucceeds(d20Roll, conMod, isProficient, profBonus, 0, poisonDC)
    val s1 = if (not(savePassed)) pApplyCondition(creature, CPoisoned) else creature
    assert(savePassed and not(s1.poisoned))
  }
  
  // Casual detection fails — active Investigation check with low roll cannot identify poison at consumption
  run qa_ingested_poison_casual_detection_fails = {
    // Answer: detection is not incidental; requires active Investigation (Int) check vs DM-set DC
    val intMod = abilityModifier(10)   // average Int → 0
    val profBonus = 2
    val poisonDetectDC = 15            // representative DM-assigned DC for subtle ingested poison
    val d20Roll = 9                    // 9 + 0 (no proficiency) = 9, fails DC 15
    val detected = checkSucceeds(d20Roll, intMod, NoneProf, profBonus, 0, poisonDetectDC)
    assert(not(detected))
  }
  
  // Proficient investigator can actively detect poison with a good roll
  run qa_ingested_poison_proficient_check_succeeds = {
    // An expert with Investigation proficiency and decent Int can succeed on an active check
    val intMod = abilityModifier(16)   // Int 16 → +3
    val profBonus = 2
    val poisonDetectDC = 15
    val d20Roll = 14                   // 14 + 3 + 2 = 19, beats DC 15
    val detected = checkSucceeds(d20Roll, intMod, Proficient, profBonus, 0, poisonDetectDC)
    assert(detected)
  }
  
  // Poisoned condition imposes disadvantage on attack rolls and ability checks
  run qa_ingested_poison_condition_imposes_disadvantage = {
    val creature = freshCreature(20)
    val poisoned = pApplyCondition(creature, CPoisoned)
    val mods = pCheckModifiers(poisoned, false, false, false)
    assert(poisoned.poisoned and mods.hasDisadvantage)
  }

  // Source: https://rpg.stackexchange.com/q/209586
  
  // SKIP: Q&A concerns whether the rules explicitly state characters lack knowledge of game mechanics (HP, hit dice, levels) — a metagame/narrative question with no mechanical representation in the spec. The spec models HP, hit dice, and levels as pure numbers but has no notion of diegetic character knowledge vs. player knowledge; there is no function or state field to assert against.

  // Source: https://rpg.stackexchange.com/q/192571
  
  // Blessed Strike triggered by Word of Radiance — once-per-round limit means bonus damage applies to only one chosen creature
  run qa_blessed_strikes_word_of_radiance_one_creature = {
    val creatureA = freshCreature(20)
    val creatureB = freshCreature(20)
    val creatureC = freshCreature(20)
  
    // Word of Radiance: pre-resolved d6 = 4; all three fail their CON save
    val wordDmg = normalDamage(4, 0)
    val aAfterWoR = pTakeDamage(creatureA, wordDmg, Radiant, Set(), Set(), Set(), false)
    val bAfterWoR = pTakeDamage(creatureB, wordDmg, Radiant, Set(), Set(), Set(), false)
    val cAfterWoR = pTakeDamage(creatureC, wordDmg, Radiant, Set(), Set(), Set(), false)
  
    // Blessed Strikes: pre-resolved d8 = 6; player chooses creature A (once per round — B and C do not receive the bonus)
    val blessedDmg = normalDamage(6, 0)
    val aFinal = pTakeDamage(aAfterWoR, blessedDmg, Radiant, Set(), Set(), Set(), false)
  
    assert(
      // Chosen creature took cantrip damage + Blessed Strikes bonus
      aFinal.hp == 20 - wordDmg - blessedDmg and
      // Remaining creatures took only Word of Radiance damage (Blessed Strikes expended)
      bAfterWoR.hp == 20 - wordDmg and
      cAfterWoR.hp == 20 - wordDmg
    )
  }

  // Source: https://rpg.stackexchange.com/q/98014
  
  // Can a paladin use the Magic Initiate feat or racial spells to smite?
  // Rule: Divine Smite requires expending an actual spell slot; free racial/feat casts grant no slot.
  
  // A paladin with a spell slot can expend it — slot count drops, confirming smite is fueled.
  run qa_divine_smite_slot_is_consumed = {
    val ss = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(1, 1))
      .with("slotsCurrent", EMPTY_SLOTS.set(1, 1))
    val afterSmite = pExpendSlot(ss, 1)
    assert(afterSmite.slotsCurrent.get(1) == 0)
  }
  
  // Racial abilities / Magic Initiate grant no spell slots; pExpendSlot is a no-op when empty,
  // modelling that smite cannot be triggered without a real slot to spend.
  run qa_divine_smite_no_slot_no_smite = {
    // FRESH_SPELL_SLOTS has all slots at 0 — simulates racial/feat free-cast scenario
    val afterAttempt = pExpendSlot(FRESH_SPELL_SLOTS, 1)
    assert(afterAttempt == FRESH_SPELL_SLOTS)
  }
  
  // pCanCastAtLevel is false when no slot exists, confirming the smite precondition fails.
  run qa_divine_smite_can_cast_check_no_slot = {
    assert(not(pCanCastAtLevel(FRESH_SPELL_SLOTS, 1, 1)))
  }
  
  // pCanCastAtLevel is true when a slot exists — smite precondition passes with a real slot.
  run qa_divine_smite_can_cast_check_with_slot = {
    val ss = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(2, 1))
      .with("slotsCurrent", EMPTY_SLOTS.set(2, 1))
    // A 2nd-level slot satisfies a 1st-level spell slot requirement (slot >= spell level)
    assert(pCanCastAtLevel(ss, 1, 2))
  }

  // Source: https://rpg.stackexchange.com/q/188610
  
  // Can Dual Wielder feat sheathe/draw same weapon to free hand for somatic casting while TWF?
  
  // (1) Sheathing the rapier via free object interaction frees a hand for somatic components
  run qa_dual_wielder_somatic_free_hand = {
    val creature = freshCreature(20)
    // After sheathing rapier (free object interaction), hasFreeHand=true
    // pCanProvideComponents: somatic (S) component satisfied by free hand
    assert(pCanProvideComponents(creature, false, true, true))
  }
  
  // (2) Without a free hand (both occupied), somatic component fails
  run qa_dual_wielder_somatic_no_free_hand = {
    val creature = freshCreature(20)
    // Holding two weapons, no free hand — cannot provide somatic component
    assert(not(pCanProvideComponents(creature, false, true, false)))
  }
  
  // (3) Free object interaction is consumed by the sheathe maneuver
  run qa_dual_wielder_object_interaction_consumed = {
    val t1 = pUseObjectInteraction(FRESH_TURN)
    // First free interaction used; a second sheathe/draw would need Use Object action
    assert(t1.freeInteractionUsed and not(FRESH_TURN.freeInteractionUsed))
  }
  
  // (4) Attack action leaves bonus action available for TWF off-hand attack
  run qa_dual_wielder_attack_leaves_bonus_action = {
    val creature = freshCreature(20)
    val t1 = pUseAction(FRESH_TURN, creature, AAttack)
    // Bonus action not consumed by the Attack action; TWF off-hand is still possible
    assert(pCanTwoWeaponFighting(t1, creature))
  }
  
  // (5) Casting a cantrip as action does NOT mark nonCantripActionSpell,
  //     so bonus action for TWF weapon attack is still legal
  run qa_dual_wielder_cantrip_does_not_block_bonus = {
    // A cantrip uses the action slot (actionUsed=true) but does NOT call pMarkNonCantripActionSpell
    // Simulate: action used for cantrip (not AAttack, no attackActionUsed side-effect needed here)
    val creature = freshCreature(20)
    val t1 = pUseAction(FRESH_TURN, creature, ACastSpell)
    // nonCantripActionSpellCast is only set by pMarkNonCantripActionSpell, not by ACastSpell action
    // So canCastBonusActionSpell remains true, and bonus action is still unused
    assert(canCastBonusActionSpell(t1) and not(t1.bonusActionUsed))
  }

  // Source: https://rpg.stackexchange.com/q/200180
  
  // Can a Bag of Holding be used with Astral Projection to move items to/from the Astral Plane?
  // SKIP: The accepted answer is "this is up to the DM" — no determinate rule exists in the PHB that the spec models; the spec contains no mechanics for extradimensional spaces, Astral Projection, or item replication.

  // Source: https://rpg.stackexchange.com/q/71129
  
  // Suggestion: verbal component requires ability to speak (mystic words separate from the spell's effect)
  run qa_verbal_component_requires_speech_a715a56d = {
    val normalCreature = freshCreature(20)
    val paralyzedCreature = pApplyCondition(freshCreature(20), CParalyzed)
    all {
      // A creature that can speak satisfies the verbal component requirement
      assert(pCanProvideComponents(normalCreature, true, false, true)),
      // A paralyzed creature cannot produce the required mystic words — verbal component fails
      assert(not(pCanProvideComponents(paralyzedCreature, true, false, true))),
    }
  }

  // Source: https://rpg.stackexchange.com/q/48729
  
  // How many Actions are allowed per round in DND 5e for a 2nd level Rogue
  run qa_action_and_bonus_action_limit_per_round = {
    // Attack (action) + TWF off-hand (bonus action) exhausts both slots;
    // subsequent Disengage attempt via pUseAction is a no-op
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, creature, AAttack)
    val t2 = pUseBonusAction(t1, creature)
    val t3 = pUseAction(t2, creature, ADisengage)
    assert(
      t1.actionUsed == true
      and t2.bonusActionUsed == true
      // Disengage was not granted — action already consumed
      and t3.disengaged == false
      and t3.actionUsed == true
    )
  }
  
  // How many Actions are allowed per round in DND 5e for a 2nd level Rogue
  run qa_cunning_action_blocked_when_bonus_already_spent = {
    // Cunning Action (Rogue): Disengage as a bonus action.
    // If the bonus action was already spent on TWF off-hand, a second bonus action is a no-op.
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, creature, AAttack)
    val t2 = pUseBonusAction(t1, creature)
    // Attempt Cunning Action Disengage (bonus action) — should be a no-op
    val t3 = pUseBonusAction(t2, creature)
    assert(t3 == t2)
  }
  
  // How many Actions are allowed per round in DND 5e for a 2nd level Rogue
  run qa_movement_is_independent_of_action_economy = {
    // Movement budget is separate from action + bonus action;
    // after both are spent, movement can still be used (e.g. retreat to pillar)
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, creature, AAttack)
    val t2 = pUseBonusAction(t1, creature)
    val t3 = pUseMovement(t2, 10, 1)
    assert(
      t3.actionUsed == true
      and t3.bonusActionUsed == true
      and t3.movementRemaining == 20
    )
  }
  
  // How many Actions are allowed per round in DND 5e for a 2nd level Rogue
  run qa_use_object_needs_action_which_is_exhausted = {
    // Drinking a potion (Use an Object action) cannot be done after the action
    // was already spent on the Attack action
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, creature, AAttack)
    val t2 = pUseBonusAction(t1, creature)
    val t3 = pUseAction(t2, creature, AUseObject)
    // t3 must equal t2: pUseAction is a no-op when actionUsed is already true
    assert(t3 == t2)
  }

  // Source: https://rpg.stackexchange.com/q/80006
  
  // Would a mummy (undead) react to a minor illusion? - Investigation check vs spell save DC applies to all creature types
  run qa_minor_illusion_investigation_check_undead = {
    // Bard (TEST_CONFIG: level 5, Wis 13) casts Minor Illusion
    // spell save DC = 8 + prof(5) + wisMod(13) = 8 + 3 + 1 = 12
    val bardDC = spellSaveDC(TEST_CONFIG)
  
    // Mummy: Int 7 (-2 mod), not proficient in Investigation
    val mummyIntMod = abilityModifier(7)
    val mummyProfBonus = proficiencyBonus(3)
  
    // Low roll: mummy fails to discern the illusion (10 - 2 = 8 < 12)
    val lowRollFails = not(checkSucceeds(10, mummyIntMod, NoneProf, mummyProfBonus, 0, bardDC))
  
    // High roll: mummy succeeds in discerning the illusion (15 - 2 = 13 >= 12)
    val highRollPasses = checkSucceeds(15, mummyIntMod, NoneProf, mummyProfBonus, 0, bardDC)
  
    // Same DC and formula applies regardless of creature type (undead/mummy is not exempt)
    assert(bardDC == 12 and lowRollFails and highRollPasses)
  }

  // Source: https://rpg.stackexchange.com/q/212191
  
  // Can my Battle Smith Artificer attack twice with his musket?
  // Repeating Shot infusion removes Loading property, enabling Extra Attack
  run qa_battle_smith_repeating_shot_removes_loading = {
    val musketRepeatShot: Weapon = {
      name: "musket_repeating_shot",
      damageDie: 12,
      versatileDie: 0,
      damageType: Piercing,
      properties: Set(Ammunition, TwoHanded),  // Loading removed by infusion
      isMelee: false,
      normalRange: 40,
      longRange: 120,
    }
    assert(pCanExtraAttackWithWeapon(musketRepeatShot))
  }
  
  // Can my Battle Smith Artificer attack twice with his musket?
  // Standard musket retains Loading — Extra Attack is blocked
  run qa_battle_smith_loading_blocks_extra_attack = {
    val musketStandard: Weapon = {
      name: "musket_standard",
      damageDie: 12,
      versatileDie: 0,
      damageType: Piercing,
      properties: Set(Ammunition, TwoHanded, Loading),
      isMelee: false,
      normalRange: 40,
      longRange: 120,
    }
    assert(not(pCanExtraAttackWithWeapon(musketStandard)))
  }
  
  // Can my Battle Smith Artificer attack twice with his musket?
  // Battle Smith level 5 (FExtraAttack) starts turn with 1 extra attack available
  run qa_battle_smith_extra_attack_turn_state = {
    val creature = freshCreature(30)
    // TEST_CONFIG is level 5 with features: Set(FExtraAttack)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    assert(t.extraAttacksRemaining == 1)
  }
  
  // Can my Battle Smith Artificer attack twice with his musket?
  // Attack bonus: INT 18 (+4) + PB at level 5 (+3) + Repeating Shot (+1) = +8
  run qa_battle_smith_attack_bonus_total = {
    val intMod    = abilityModifier(18)  // 4
    val pb        = proficiencyBonus(5)  // 3
    val magicBon  = 1                    // Repeating Shot
    assert(intMod + pb + magicBon == 8)
  }
  
  // Can my Battle Smith Artificer attack twice with his musket?
  // Damage: 1d12 roll 10 + INT(+4) + Repeating Shot(+1) = 15
  run qa_battle_smith_damage_calc = {
    val intMod    = abilityModifier(18)        // 4
    val magicBon  = 1                          // Repeating Shot
    val damageMod = intMod + magicBon          // 5
    assert(normalDamage(10, damageMod) == 15)
  }

  // Source: https://rpg.stackexchange.com/q/160006
  
  // Does Mage Hand require line of sight to summon?
  run qa_mage_hand_total_cover_blocks_targeting = {
    // Accepted answer: clear path required — total cover (wall/door) blocks summoning
    assert(not(canBeTargeted(TotalCover)))
  }
  
  // Does Mage Hand require line of sight to summon?
  run qa_mage_hand_partial_cover_and_no_cover_allow_targeting = {
    // Accepted answer: line of sight NOT required — fog/blindfolded still targetable if no total cover
    assert(
      canBeTargeted(NoCover) and
      canBeTargeted(HalfCover) and
      canBeTargeted(ThreeQuartersCover)
    )
  }

  // Is there a feat akin to the Fighter's Action Surge which is available to other classes?
  run qa_no_feat_grants_action_surge = {
    // Accepted answer: no such feat exists; extra attacks come only from class features.
    // A Paladin-like config with no Fighter features gets 0 extra attacks — the Feature
    // type (FExtraAttack / FExtraAttack2 / FExtraAttack3) contains only class features,
    // not feats, so no feat can grant Action Surge-style attack doubling.
    val paladinConfig: CharConfig = TEST_CONFIG.with("features", Set())
    assert(extraAttacksFromConfig(paladinConfig) == 0)
  }

  // Source: https://rpg.stackexchange.com/q/171423
  
  // In D&D 5e is there a spell or ability that mimics the D&D 2e Priest spell Combine?
  // Accepted answer: No such feature exists in 5e — no ability increases effective caster level or Turn Undead strength by combining with others.
  // The spec has no "combine caster levels" or "boost effective level" mechanic; proficiencyBonus and spellcastingBonus are fixed by individual level alone.
  run qa_no_combine_caster_level_boost = {
    // A level-5 cleric's spellcasting bonus is purely their own level + ability mod.
    // There is no function to combine levels with another caster.
    val config = TEST_CONFIG.with("level", 5)
                            .with("spellcastingAbility", Wis)
                            .with("abilityScores", Map(Str -> 14, Dex -> 12, Con -> 14, Int_ -> 10, Wis -> 16, Cha -> 8))
                            .with("hasSpellcasting", true)
    // proficiencyBonus(5) = 3, wisMod = (16-10)/2 = 3, so spellcastingBonus = 6, spellSaveDC = 14
    val pb = proficiencyBonus(config.level)
    val wisMod = abilityModifier(config.abilityScores.get(Wis))
    val bonus = spellcastingBonus(config)
    val dc = spellSaveDC(config)
    // Verify: bonus is exactly pb + wisMod, not inflated by any "combine" mechanic
    assert(
      pb == 3
      and wisMod == 3
      and bonus == pb + wisMod
      and dc == 8 + bonus
      // A hypothetical "combined" level-10 cleric would have pb=4, bonus=7, dc=15 — not achievable here
      and bonus != proficiencyBonus(10) + wisMod
    )
  }

  // Source: https://rpg.stackexchange.com/q/198960
  
  // How would resistance to non magical weapons change a creature's challenge rating?
  // Accepted answer: BPS nonmagical resistance halves each physical damage instance (floor),
  // making effective HP ~1.5-2x for CR defensive calculation purposes.
  run qa_resistance_halves_bps_damage = {
    // All three nonmagical weapon damage types are halved by resistance
    val dmgB = applyDamageModifiers(30, Bludgeoning, Set(), Set(Bludgeoning, Piercing, Slashing), Set())
    val dmgP = applyDamageModifiers(30, Piercing,    Set(), Set(Bludgeoning, Piercing, Slashing), Set())
    val dmgS = applyDamageModifiers(30, Slashing,    Set(), Set(Bludgeoning, Piercing, Slashing), Set())
    assert(dmgB == 15 and dmgP == 15 and dmgS == 15)
  }
  
  // How would resistance to non magical weapons change a creature's challenge rating?
  // Accepted answer: a damage amount that kills an unresisted creature leaves a BPS-resistant
  // creature alive, illustrating the effective-HP doubling that underlies the 1.5x CR multiplier.
  run qa_resistance_effective_hp_vs_no_resistance = {
    val lion = freshCreature(58) // lion ~58 HP
    // Without resistance: 60 slashing kills the creature (HP → 0)
    val without_resist = pTakeDamage(lion, 60, Slashing, Set(), Set(), Set(), false)
    // With Slashing resistance: 60 → 30 actual damage, creature survives at 28 HP
    val with_resist = pTakeDamage(lion, 60, Slashing, Set(Slashing), Set(), Set(), false)
    assert(without_resist.hp == 0 and with_resist.hp == 28)
  }

  // Source: https://rpg.stackexchange.com/q/79462
  
  // How much does Heavy Mariner's Armor weigh? — Mariner's Armor is an enchantment on a base armor type; it inherits all base stats (AC, STR req, stealth) unchanged
  run qa_mariners_armor_inherits_base_armor_stats = {
    // Mariner's Chain Mail = CHAIN_MAIL + swim speed enchantment; no new armor type, so base stats are identical
    val marinersChainMail = CHAIN_MAIL
    // Heavy armor AC ignores DEX mod
    val ac = calculateAC(WearingArmor(marinersChainMail), 3, false, NoUnarmoredDefense, 0, 0)
    assert(
      ac == 16                                  // inherits baseAC from chain mail
      and marinersChainMail.strRequirement == 13 // inherits STR requirement
      and marinersChainMail.stealthDisadvantage  // inherits stealth disadvantage
      and marinersChainMail.category == HeavyArmor
    )
  }

  // Source: https://rpg.stackexchange.com/q/142771
  
  // Can you train your ranger to master different fighting styles?
  run qa_extra_attack_at_level5_before_multiclass_dip = {
    // Accepted answer: wait until level 5 (Extra Attack) before dipping Fighter
    val config = TEST_CONFIG.with("features", Set(FExtraAttack))
    val creature = freshCreature(30)
    val t = pStartTurn(config, creature, Unarmored, false, 0, false, false)
    assert(t.extraAttacksRemaining == 1)
  }
  
  // Can you train your ranger to master different fighting styles?
  run qa_no_extra_attack_without_feature = {
    // Without FExtraAttack (pre-level-5 ranger), no extra attacks
    val config = TEST_CONFIG.with("features", Set())
    val creature = freshCreature(30)
    val t = pStartTurn(config, creature, Unarmored, false, 0, false, false)
    assert(t.extraAttacksRemaining == 0)
  }
  
  // Can you train your ranger to master different fighting styles?
  run qa_fighter_multiclass_prereq_str_or_dex_13 = {
    // Fighter multiclass requires STR 13 or DEX 13; both paths valid
    val scoresViaDex = Map(Str -> 10, Dex -> 13, Con -> 10, Int_ -> 10, Wis -> 10, Cha -> 10)
    val scoresViaStr = Map(Str -> 13, Dex -> 10, Con -> 10, Int_ -> 10, Wis -> 10, Cha -> 10)
    val scoresFail   = Map(Str -> 12, Dex -> 12, Con -> 10, Int_ -> 10, Wis -> 10, Cha -> 10)
    assert(
      pMeetsMulticlassPrereq(scoresViaStr, Fighter) and
      pMeetsMulticlassPrereq(scoresViaDex, Fighter) and
      not(pMeetsMulticlassPrereq(scoresFail, Fighter))
    )
  }
  
  // Can you train your ranger to master different fighting styles?
  run qa_twf_offhand_no_positive_ability_mod = {
    // TWF off-hand attack: positive STR/DEX mod NOT added (PHB two-weapon fighting rule)
    val dmg = pTWFOffHandDamage(6, 3)
    assert(dmg == 6)
  }
  
  // Can you train your ranger to master different fighting styles?
  run qa_twf_offhand_negative_mod_applied = {
    // TWF off-hand attack: negative ability mod IS subtracted
    val dmg = pTWFOffHandDamage(4, -2)
    assert(dmg == 2)
  }

  // Source: https://rpg.stackexchange.com/q/69812
  
  // Hidden attacker gets advantage on attack rolls (target cannot see the attacker)
  run qa_hidden_attacker_gets_advantage = {
      val ctx: AttackContext = {
          attackerBlinded: false,
          attackerProne: false,
          attackerRestrained: false,
          attackerPoisoned: false,
          attackerFrightened: false,
          attackerFrightSourceInLOS: false,
          attackerExhaustion: 0,
          targetBlinded: false,
          targetParalyzed: false,
          targetPetrified: false,
          targetStunned: false,
          targetUnconscious: false,
          targetRestrained: false,
          targetProne: false,
          attackerWithin5ft: false,
          targetDodging: false,
          targetCanSeeAttacker: false,
          attackerCanSeeTarget: true,
          isRangedAttack: true,
          beyondNormalRange: false,
          hostileWithin5ft: false,
          isHeavyWeapon: false,
          wielderSizeSmallOrTiny: false,
          squeezing: false,
          underwater: false,
          attackerHasSwimSpeed: false,
          isUnderwaterMeleeException: false,
          isUnderwaterRangedException: false,
      }
      val mods = pAggregateAttackMods(ctx)
      assert(mods.hasAdvantage and not(mods.hasDisadvantage))
  }
  
  // Hidden rogue with a hostile monster adjacent: ranged-in-melee disadvantage cancels hidden advantage
