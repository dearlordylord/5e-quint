  // Source: https://rpg.stackexchange.com/q/102679
  
  // What roll is appropriate for hiding pain?
  run qa_hide_pain_con_save = {
    val conMod = abilityModifier(TEST_CONFIG.abilityScores.get(Con))
    val profBonus = proficiencyBonus(TEST_CONFIG.level)
    val isProficient = TEST_CONFIG.saveProficiencies.contains(Con)
    // CON save used to keep focus under pain (as with concentration checks)
    // roll 8 + CON mod(+2) + prof(+3) = 13 >= DC 13 → succeeds
    val successCase = saveSucceeds(8, conMod, isProficient, profBonus, 0, 13)
    // roll 7 + CON mod(+2) + prof(+3) = 12 < DC 13 → fails
    val failCase = saveSucceeds(7, conMod, isProficient, profBonus, 0, 13)
    assert(successCase and not(failCase))
  }
  
  // What roll is appropriate for hiding pain? (variant PHB p.175: CON replaces CHA for Deception)
  run qa_hide_pain_con_deception_variant = {
    val conMod = abilityModifier(TEST_CONFIG.abilityScores.get(Con))
    val profBonus = proficiencyBonus(TEST_CONFIG.level)
    // Variant rule: CON (Deception) check — CON mod used instead of CHA mod, no Deception prof for this character
    // roll 11 + CON mod(+2) + NoneProf(0) = 13 >= DC 13 → succeeds
    val successCase = checkSucceeds(11, conMod, NoneProf, profBonus, 0, 13)
    // roll 10 + CON mod(+2) + NoneProf(0) = 12 < DC 13 → fails
    val failCase = checkSucceeds(10, conMod, NoneProf, profBonus, 0, 13)
    assert(successCase and not(failCase))
  }

  // Source: https://rpg.stackexchange.com/q/203249
  
  // When do monsters not have average hp? — average HP (floor(N*4.5+bonus)) is a valid assignment
  run qa_monster_hp_average_is_valid = {
    // Drow Elite Warrior: 11d8+22 → floor(11*4.5)+22 = 49+22 = 71 HP (standard average, truncated)
    val m = freshCreature(71)
    assert(m.hp == 71 and m.maxHp == 71 and not(m.dead))
  }
  
  // When do monsters not have average hp? — maximum HP (N*dieMax+bonus) is a valid DMG assignment
  run qa_monster_hp_maximum_is_valid = {
    // Drow Commander: 11d8+22 → 11*8+22 = 88+22 = 110 HP (maximum possible roll)
    val m = freshCreature(110)
    assert(m.hp == 110 and m.maxHp == 110 and not(m.dead))
  }
  
  // When do monsters not have average hp? — below-average HP is also a valid DMG assignment
  run qa_monster_hp_below_average_is_valid = {
    // Gondolo (scout): assigned 13 HP vs standard average 16 (3d8+3); intentionally weakened NPC
    val m = freshCreature(13)
    assert(m.hp == 13 and m.maxHp == 13 and not(m.dead))
  }
  
  // When do monsters not have average hp? — two monsters with identical HD can have different maxHp
  run qa_same_hd_different_maxhp = {
    // Drow Elite Warrior (71) vs Drow Commander (110): both 11d8+22, but DMG allows arbitrary assignment
    val eliteWarrior = freshCreature(71)
    val commander    = freshCreature(110)
    assert(
      eliteWarrior.maxHp != commander.maxHp
      and eliteWarrior.hp == 71
      and commander.hp == 110
      and not(eliteWarrior.dead)
      and not(commander.dead)
    )
  }
  
  // When do monsters not have average hp? — taking damage works correctly regardless of non-average maxHp
  run qa_monster_custom_hp_takes_damage_correctly = {
    // Commander at 110 HP takes 30 damage → 80 HP remaining; maxHp unchanged
    val commander = freshCreature(110)
    val afterDmg  = pTakeDamage(commander, 30, Slashing, Set(), Set(), Set(), false)
    assert(afterDmg.hp == 80 and afterDmg.maxHp == 110 and not(afterDmg.dead))
  }

  // Source: https://rpg.stackexchange.com/q/97971
  
  // Can a grappler grapple the same target multiple times? (PHB p.290: "condition's effects don't get worse; a creature either has a condition or doesn't")
  run qa_grapple_condition_idempotent = {
    val creature = freshCreature(20)
    val afterFirst  = pApplyCondition(creature, CGrappled)
    val afterSecond = pApplyCondition(afterFirst, CGrappled)
    // Applying CGrappled a second time must not change state — the condition is binary, not a stack
    assert(afterFirst == afterSecond and afterSecond.grappled)
  }
  
  // Single escape (BWins contest) clears grappled regardless of how many times the condition was applied
  run qa_grapple_single_escape_sufficient_per_spec = {
    val creature = freshCreature(20)
    // Simulate "grappled by two separate grapples" — spec collapses both to one boolean flag
    val doubleGrappled = pApplyCondition(pApplyCondition(creature, CGrappled), CGrappled)
    val escaped = pEscapeGrapple(doubleGrappled, BWins)
    // The spec's binary model: one successful escape removes the condition entirely
    assert(not(escaped.grappled))
  }
  
  // Tie or AWins in escape contest leaves grappled intact (status quo — grappler holds on)
  run qa_grapple_escape_fails_on_tie_or_attacker_wins = {
    val creature = freshCreature(20)
    val grappled = pApplyCondition(creature, CGrappled)
    val afterTie  = pEscapeGrapple(grappled, Tie)
    val afterAWin = pEscapeGrapple(grappled, AWins)
    assert(afterTie.grappled and afterAWin.grappled)
  }

  // Source: https://rpg.stackexchange.com/q/143504
  
  // Can mounted creatures be attacked instead of their mount, and which character(s) in mounted combat receive attacks of opportunity?
  
  // Total cover prevents targeting entirely — applies equally to riders and mounts
  run qa_total_cover_blocks_targeting_dd513df8 = {
    assert(canBeTargeted(TotalCover) == false)
  }
  
  // Half and three-quarters cover still allow targeting (with AC bonus) — normal targeting rules
  run qa_partial_cover_allows_targeting = {
    assert(
      canBeTargeted(HalfCover) == true
      and canBeTargeted(ThreeQuartersCover) == true
      and canBeTargeted(NoCover) == true
    )
  }
  
  // Three-quarters cover gives +5 AC bonus, half cover +2 — normal attack modifiers apply to rider and mount alike
  run qa_cover_ac_bonuses = {
    assert(
      coverBonus(NoCover) == 0
      and coverBonus(HalfCover) == 2
      and coverBonus(ThreeQuartersCover) == 5
    )
  }
  
  // A mounted creature that has not disengaged can provoke opportunity attacks (attacker may choose rider or mount)
  run qa_oa_eligible_when_not_disengaged = {
    assert(pCanBeOpportunityAttacked(FRESH_TURN) == true)
  }
  
  // After using Disengage, neither the rider nor mount can be OA-targeted
  run qa_oa_blocked_after_disengage = {
    val creature = freshCreature(20)
    val t1 = pUseAction(FRESH_TURN, creature, ADisengage)
    assert(pCanBeOpportunityAttacked(t1) == false)
  }

  // Source: https://rpg.stackexchange.com/q/190811
  
  // "If I start combat by making an attack, does a high-initiative enemy see it coming?"
  // Non-surprised NPC winning initiative gets a full turn: can act, move, use bonus action, has reaction
  run qa_nonsurprised_high_initiative_npc_gets_full_turn = {
    val creature = freshCreature(20)
    // NPC "noticed the threat" (not surprised), wins initiative
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    assert(
      not(t.actionUsed) and
      not(t.bonusActionUsed) and
      t.movementRemaining == 30 and
      t.reactionAvailable
    )
  }
  
  // "If I start combat by making an attack, does a high-initiative enemy see it coming?"
  // Non-surprised NPC can spend their action responding (e.g., dodge, attack back) before the PC's declared attack executes
  run qa_nonsurprised_npc_can_use_action_before_pc_attacks = {
    val creature = freshCreature(20)
    val t0 = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    // NPC chooses to dodge — a valid response to perceived hostile intent
    val t1 = pUseAction(t0, creature, ADodge)
    assert(t1.actionUsed and t1.dodging)
  }
  
  // "If I start combat by making an attack, does a high-initiative enemy see it coming?"
  // Surprised creature (contrast: attacker who telegraphed intent) cannot act or move on first turn
  run qa_surprised_creature_loses_first_turn = {
    val creature = freshCreature(20)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, true, 0, false, false)
    assert(
      t.actionUsed and
      t.bonusActionUsed and
      t.movementRemaining == 0 and
      not(t.reactionAvailable)
    )
  }
  
  // "If I start combat by making an attack, does a high-initiative enemy see it coming?"
  // Surprised creature's action is blocked — pUseAction is a no-op when actionUsed is already true
  run qa_surprised_creature_cannot_use_action = {
    val creature = freshCreature(20)
    val t0 = pStartTurn(TEST_CONFIG, creature, Unarmored, true, 0, false, false)
    val t1 = pUseAction(t0, creature, ADodge)
    // Surprise consumed the action; dodge could not be taken
    assert(not(t1.dodging))
  }

  // Source: https://rpg.stackexchange.com/q/210010
  
  // How does cover interact with a Pact of the Chain Warlock with the Voice of the Chain Master Invocation?
  
  // Targets inside a room are behind total cover from outside caster — cannot be targeted at all
  run qa_total_cover_blocks_targeting_df120478 = {
    assert(canBeTargeted(TotalCover) == false)
  }
  
  // Partial cover still permits targeting (Eldritch Blast can reach half/three-quarters cover targets)
  run qa_partial_cover_permits_targeting = {
    assert(
      canBeTargeted(NoCover) == true and
      canBeTargeted(HalfCover) == true and
      canBeTargeted(ThreeQuartersCover) == true
    )
  }
  
  // Half cover (+2 AC) and three-quarters cover (+5 AC) raise the attack threshold
  run qa_cover_ac_bonus_affects_attack = {
    // roll 14 + bonus 5 = 19 vs base AC 15
    val atk_no_cover    = resolveAttackRoll(14, 5, 15, coverBonus(NoCover))           // 19 >= 15 → hits
    val atk_half_cover  = resolveAttackRoll(14, 5, 15, coverBonus(HalfCover))         // 19 >= 17 → hits
    val atk_3q_cover    = resolveAttackRoll(14, 5, 15, coverBonus(ThreeQuartersCover))// 19 >= 20 → misses
    assert(
      atk_no_cover.hits   == true  and
      atk_half_cover.hits == true  and
      atk_3q_cover.hits   == false
    )
  }
  
  // Total cover yields no AC bonus — irrelevant because the target can't be selected in the first place
  run qa_total_cover_bonus_is_zero = {
    assert(coverBonus(TotalCover) == 0)
  }

  // Source: https://rpg.stackexchange.com/q/154283
  
  // How does attacking during a conversation affect initiative? — surprised guard loses first turn
  run qa_surprised_guard_cannot_act_first_turn = {
    val guardState = freshCreature(30)
    val surprisedTurn = pStartTurn(TEST_CONFIG, guardState, Unarmored, true, 0, false, false)
    assert(
      surprisedTurn.actionUsed == true and
      surprisedTurn.bonusActionUsed == true and
      surprisedTurn.movementRemaining == 0 and
      surprisedTurn.reactionAvailable == false
    )
  }
  
  // How does attacking during a conversation affect initiative? — rogue (non-surprised) can use Attack action on their turn
  run qa_non_surprised_attacker_uses_attack_on_turn = {
    val rogueState = freshCreature(20)
    val rogueTurn = pStartTurn(TEST_CONFIG, rogueState, Unarmored, false, 0, false, false)
    val afterAttack = pUseAction(rogueTurn, rogueState, AAttack)
    assert(
      rogueTurn.actionUsed == false and
      afterAttack.actionUsed == true and
      afterAttack.attackActionUsed == true
    )
  }
  
  // How does attacking during a conversation affect initiative? — surprised creature regains reactions after their first turn ends
  run qa_surprise_turn_ends_restores_reaction = {
    val guardState = freshCreature(30)
    val surprisedTurn = pStartTurn(TEST_CONFIG, guardState, Unarmored, true, 0, false, false)
    val afterSurpriseTurn = pEndSurpriseTurn(surprisedTurn)
    assert(
      surprisedTurn.reactionAvailable == false and
      afterSurpriseTurn.reactionAvailable == true and
      afterSurpriseTurn.surprised == false
    )
  }

  // Source: https://rpg.stackexchange.com/q/168283
  
  // Does the Echo Knight fighter's Legion of One feature allow each echo to use Unleash Incarnation?
  // Accepted answer: one extra attack per Attack action, not one per echo.
  run qa_unleash_incarnation_one_extra_per_attack_action = {
    val creature = freshCreature(30)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    val t2 = pUseAction(t, creature, AAttack)
    // Legion of One (2 echoes) does NOT double the extra attack grant; still exactly 1 per Attack action
    assert(t2.attackActionUsed == true and t2.extraAttacksRemaining == 1)
  }
  
  // Does the Echo Knight fighter's Legion of One feature allow each echo to use Unleash Incarnation?
  // Accepted answer: bonus action attack does not trigger Unleash Incarnation (not an Attack action).
  run qa_unleash_incarnation_bonus_action_no_trigger = {
    val creature = freshCreature(30)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    val t2 = pUseAction(t, creature, AAttack)
    val t3 = pUseBonusAction(t2, creature)
    // Using a bonus action after the Attack action does NOT add more extra attacks
    assert(t3.bonusActionUsed == true and t3.extraAttacksRemaining == 1)
  }
  
  // Does the Echo Knight fighter's Legion of One feature allow each echo to use Unleash Incarnation?
  // Accepted answer: each use of Unleash Incarnation consumes one of the granted extra attacks.
  run qa_unleash_incarnation_extra_attack_consumed = {
    val creature = freshCreature(30)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    val t2 = pUseAction(t, creature, AAttack)
    val t3 = pUseExtraAttack(t2)
    // After spending the one granted extra attack, none remain
    assert(t3.extraAttacksRemaining == 0)
  }

  // Source: https://rpg.stackexchange.com/q/210220
  
  // Q&A: Can you hold Plane Shift on an unwilling creature until they touch you to skip the melee spell attack?
  // Melee spell attack roll cannot be skipped: nat 1 always misses even with high bonus vs low AC
  run qa_readied_melee_spell_nat1_always_misses = {
    val result = resolveAttackRoll(1, 10, 6, 0)
    assert(not(result.hits) and not(result.isCritical))
  }
  
  // Q&A: Can you hold Plane Shift on an unwilling creature until they touch you to skip the melee spell attack?
  // Readied spell = concentration; dragon bite damage forces a CON save or spell is lost
  run qa_readied_spell_concentration_breaks_on_failed_con_save = {
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "plane_shift")
    val damageTaken = 20
    val dc = pConcentrationDC(damageTaken)  // max(10, 20/2) = 10
    // roll 4 + CON mod 2 + prof 3 = 9 < 10: save fails
    val saveSucceeded = saveSucceeds(4, 2, true, 3, 0, dc)
    val ss1 = pConcentrationCheck(ss, saveSucceeded)
    assert(dc == 10 and not(saveSucceeded) and not(isConcentrating(ss1)))
  }
  
  // Q&A: Can you hold Plane Shift on an unwilling creature until they touch you to skip the melee spell attack?
  // Concentration survives if CON save succeeds despite taking damage
  run qa_readied_spell_concentration_survives_on_passed_con_save = {
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "plane_shift")
    val damageTaken = 20
    val dc = pConcentrationDC(damageTaken)  // 10
    // roll 14 + CON mod 2 + prof 3 = 19 >= 10: save succeeds
    val saveSucceeded = saveSucceeds(14, 2, true, 3, 0, dc)
    val ss1 = pConcentrationCheck(ss, saveSucceeded)
    assert(saveSucceeded and isConcentrating(ss1) and ss1.concentrationSpellId == "plane_shift")
  }
  
  // Q&A: Can you hold Plane Shift on an unwilling creature until they touch you to skip the melee spell attack?
  // DM may grant advantage (not skip the roll) as reward for creative play; prone target within 5ft grants advantage
  run qa_creative_play_dm_grants_advantage_not_autohit = {
    val ctx: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false, targetParalyzed: false, targetPetrified: false,
      targetStunned: false, targetUnconscious: false, targetRestrained: false,
      targetProne: true,
      attackerWithin5ft: true,
      targetDodging: false, targetCanSeeAttacker: true, attackerCanSeeTarget: true,
      isRangedAttack: false, beyondNormalRange: false, hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false,
      squeezing: false, underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    // Advantage is possible, but there is no auto-hit: roll is still required
    assert(mods.hasAdvantage and not(mods.hasDisadvantage) and not(mods.autoMiss))
  }

  // Source: https://rpg.stackexchange.com/q/158806
  
  // "If multiple sources grant advantage do you have advantage multiple times but still roll +1d20?"
  // Multiple advantage sources collapse to a single boolean; they do not stack mechanically.
  run qa_multiple_advantage_sources_no_stack = {
    // Two independent advantage sources (targetBlinded + targetRestrained) on the same roll
    val ctx: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: true,      // advantage source 1
      targetParalyzed: false, targetPetrified: false, targetStunned: false, targetUnconscious: false,
      targetRestrained: true,   // advantage source 2
      targetProne: false,
      attackerWithin5ft: false,
      targetDodging: false, targetCanSeeAttacker: true, attackerCanSeeTarget: true,
      isRangedAttack: false, beyondNormalRange: false, hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false,
      squeezing: false, underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    // Having advantage from two sources still yields exactly one advantage (boolean, not additive)
    assert(mods.hasAdvantage and not(mods.hasDisadvantage) and not(mods.autoMiss))
  }
  
  // "If multiple sources grant advantage do you have advantage multiple times but still roll +1d20?"
  // One disadvantage cancels even multiple advantage sources — PHB: "true even if multiple circumstances impose disadvantage and only one grants advantage or vice versa"
  run qa_one_disadv_cancels_multiple_adv_sources = {
    val ctx: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: true,   // disadvantage source (just one)
      attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: true,      // advantage source 1
      targetParalyzed: false, targetPetrified: false, targetStunned: false, targetUnconscious: false,
      targetRestrained: true,   // advantage source 2
      targetProne: false,
      attackerWithin5ft: false,
      targetDodging: false, targetCanSeeAttacker: true, attackerCanSeeTarget: true,
      isRangedAttack: false, beyondNormalRange: false, hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false,
      squeezing: false, underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    // One disadv cancels all adv sources → neither advantage nor disadvantage
    assert(not(mods.hasAdvantage) and not(mods.hasDisadvantage))
  }
  
  // "If multiple sources grant advantage do you have advantage multiple times but still roll +1d20?"
  // resolveAdvantage core rule: any adv + any disadv = neither, regardless of how many sources
  run qa_resolve_advantage_any_plus_any_equals_neither = {
    val resolved = resolveAdvantage({ hasAdvantage: true, hasDisadvantage: true })
    assert(not(resolved.hasAdvantage) and not(resolved.hasDisadvantage))
  }

  // How does damage from Arms of Hadar get assigned? — PHB p.196: roll damage once, apply same result to all targets
  run qa_area_spell_damage_rolled_once_for_all_targets = {
    val maxHp     = 20
    val damageRoll = 7 // single 2d6 roll, shared across all targets
    val c1 = freshCreature(maxHp)
    val c2 = freshCreature(maxHp)
    val c3 = freshCreature(maxHp)
    val c4 = freshCreature(maxHp)
    val c5 = freshCreature(maxHp)
    val s1 = pTakeDamage(c1, damageRoll, Necrotic, Set(), Set(), Set(), false)
    val s2 = pTakeDamage(c2, damageRoll, Necrotic, Set(), Set(), Set(), false)
    val s3 = pTakeDamage(c3, damageRoll, Necrotic, Set(), Set(), Set(), false)
    val s4 = pTakeDamage(c4, damageRoll, Necrotic, Set(), Set(), Set(), false)
    val s5 = pTakeDamage(c5, damageRoll, Necrotic, Set(), Set(), Set(), false)
    assert(
      s1.hp == s2.hp and s2.hp == s3.hp and s3.hp == s4.hp and s4.hp == s5.hp
      and s1.hp == maxHp - damageRoll
    )
  }

  // Source: https://rpg.stackexchange.com/q/179064
  
  // Does forbiddance have a distance limitation? — tunnel 5ft×7920ft=39,600 sq ft fits within the 40,000 sq ft cap
  run qa_forbiddance_tunnel_area_fits = {
    val tunnelWidthFt  = 5
    val tunnelLengthFt = 7920   // 1.5 miles
    val tunnelArea     = tunnelWidthFt * tunnelLengthFt
    val forbMaxArea    = 40000
    assert(tunnelArea == 39600 and tunnelArea <= forbMaxArea)
  }
  
  // Does forbiddance have a distance limitation? — no LOS required; a capable caster provides V/S/M components without sight of the far end
  run qa_forbiddance_no_los_needed_for_components = {
    // Forbiddance requires verbal + somatic + material; caster is alive, unimpaired, has free hand.
    // pCanProvideComponents has no line-of-sight parameter — encoding the rule that LOS is irrelevant.
    val cleric = freshCreature(30)
    assert(pCanProvideComponents(cleric, true, true, true))
  }
  
  // Does forbiddance have a distance limitation? — a blinded caster can still provide spell components (LOS/sight irrelevant)
  run qa_forbiddance_blinded_caster_still_casts = {
    val cleric = pApplyCondition(freshCreature(30), CBlinded)
    // Blinded affects attacks/checks but pCanProvideComponents only checks speech and free hand
    assert(pCanProvideComponents(cleric, true, true, true))
  }

  // Source: https://rpg.stackexchange.com/q/124764
  
  // Maximilian's Earthen Grasp - can it attempt to restrain the same target multiple times?
  run qa_earthen_grasp_retarget_same_creature = {
    val strMod = abilityModifier(12)  // STR 12 -> +1
    val profBonus = proficiencyBonus(1)
    val dc = 14
  
    // Turn 1: creature succeeds STR save (roll 15: 15+1=16 >= 14) -> not restrained, unaffected
    val turn1SaveSucceeds = saveSucceeds(15, strMod, false, profBonus, 0, dc)
    val creatureAfterTurn1 = freshCreature(20)
  
    // Turn 2: same creature retargeted; fails STR save (roll 5: 5+1=6 < 14) -> 2d6 bludgeoning + restrained
    val turn2SaveFails = not(saveSucceeds(5, strMod, false, profBonus, 0, dc))
    val creatureAfterTurn2 = pApplyCondition(
      pTakeDamage(creatureAfterTurn1, 7, Bludgeoning, Set(), Set(), Set(), false),
      CRestrained
    )
  
    assert(
      turn1SaveSucceeds                    // first save succeeded
      and not(creatureAfterTurn1.restrained) // not restrained after successful save
      and turn2SaveFails                   // second attempt: save can independently fail
      and creatureAfterTurn2.restrained    // on second failure: restrained is applied
      and creatureAfterTurn2.hp == 13      // 2d6 (=7) bludgeoning damage applied
    )
  }

  // Source: https://rpg.stackexchange.com/q/58672
  
  // Changing elements for spells: fire damage against fire-resistant creature takes half (no element-swap exists RAW)
  run qa_fire_resistance_halves_fire_damage = {
    assert(applyDamageModifiers(10, Fire, Set(), Set(Fire), Set()) == 5)
  }
  
  // Changing elements for spells: Elemental Adept (Fire) ignores resistance by passing no resistance set
  run qa_elemental_adept_ignores_fire_resistance = {
    assert(applyDamageModifiers(10, Fire, Set(), Set(), Set()) == 10)
  }
  
  // Changing elements for spells: fire damage is NOT mitigated by cold resistance (can't swap types)
  run qa_wrong_resistance_type_gives_no_mitigation = {
    assert(applyDamageModifiers(10, Fire, Set(), Set(Cold), Set()) == 10)
  }
  
  // Changing elements for spells: fire damage does NOT exploit cold vulnerability (can't swap types to fish for vuln)
  run qa_fire_not_boosted_by_cold_vulnerability = {
    assert(applyDamageModifiers(10, Fire, Set(), Set(), Set(Cold)) == 10)
  }
  
  // Changing elements for spells: fire damage against cold immunity is unblocked (immunity to wrong type is irrelevant)
  run qa_cold_immunity_does_not_block_fire = {
    assert(applyDamageModifiers(10, Fire, Set(Cold), Set(), Set()) == 10)
  }

  // Source: https://rpg.stackexchange.com/q/207820
  
  // Double Rings of Amity: same spell/effect heals each bonded creature exactly once; second ring does not chain
  run qa_double_rings_of_amity = {
    val maxHp = 20
    val startHp = 10
    val healAmount = 4  // e.g. Potion of Healing
  
    val creatureA = freshCreature(maxHp).with("hp", startHp)
    val creatureB = freshCreature(maxHp).with("hp", startHp)
  
    // A drinks the potion: A heals healAmount directly
    val afterA = pHeal(creatureA, healAmount)
    // A's Ring of Amity transfers the same effect to B once
    val afterB = pHeal(creatureB, healAmount)
  
    // B's ring would "trigger" because B received healing, but B is already receiving
    // the benefit of the same spell/effect — you don't benefit from the same effect twice.
    // So A does NOT heal a second time from B's ring. Both heal exactly once.
    val aHealedOnce = afterA.hp == startHp + healAmount
    val bHealedOnce = afterB.hp == startHp + healAmount
  
    // Applying pHeal a second time on A (simulating B's ring incorrectly chaining)
    // would push A above startHp + healAmount — assert that does NOT happen under the ruling
    val noChain_A = pHeal(afterA, 0).hp == afterA.hp  // 0-heal no-op confirms no extra heal was applied
    val noChain_B = pHeal(afterB, 0).hp == afterB.hp
  
    assert(aHealedOnce and bHealedOnce and noChain_A and noChain_B)
  }

  // Can you silence a spell? - Silence grants thunder immunity to creatures entirely inside
  run qa_silence_thunder_immunity = {
    val dmg = applyDamageModifiers(15, Thunder, Set(Thunder), Set(), Set())
    assert(dmg == 0)
  }
  
  // Can you silence a spell? - Silence deafens creatures entirely inside the 20-ft sphere
  run qa_silence_deafens_creatures_inside = {
    val c = freshCreature(20)
    val silenced = pApplyCondition(c, CDeafened)
    assert(silenced.deafened == true)
  }
  
  // Can you silence a spell? - Thunderwave (verbal+somatic) blocked when creature cannot speak (Silence effect)
  run qa_silence_blocks_thunderwave_verbal = {
    // Paralyzed models "cannot produce sound/speech"; pCanSpeak returns false
    val c = freshCreature(20)
        .with("paralyzed", true)
        .with("incapacitatedSources", Set(ISParalyzed))
    val canCast = pCanProvideComponents(c, true, true, true)
    assert(canCast == false)
  }
  
  // Can you silence a spell? - Thunderclap (somatic only) component check passes even without verbal
  run qa_silence_thunderclap_somatic_only_ok = {
    // Thunderclap has no verbal component, so silence does not block it at the components level
    val c = freshCreature(20)
        .with("paralyzed", true)
        .with("incapacitatedSources", Set(ISParalyzed))
    val canCast = pCanProvideComponents(c, false, true, true)
    assert(canCast == true)
  }

  // Source: https://rpg.stackexchange.com/q/119864
  
  // If I scribe a scroll of a spell I know, is it cast at my slot level or the spell's base level?
  run qa_scroll_scribing_uses_slot_level = {
    // 6th-level Warlock: pact slots are 3rd level, 2 available
    val warlockSlots: SpellSlotState = {
      slotsMax: EMPTY_SLOTS,
      slotsCurrent: EMPTY_SLOTS,
      pactSlotsMax: 2,
      pactSlotsCurrent: 2,
      pactSlotLevel: 3,
      concentrationSpellId: "",
    }
    // Warlock can use their 3rd-level pact slot to scribe a 1st-level known spell
    val canScribeWith3rdSlot = pCanCastWithPactSlot(warlockSlots, 1)
    // Scroll level = slot level used in creation (3), NOT the spell's base level (1)
    val scrollLevel = warlockSlots.pactSlotLevel
    // Scribing the scroll consumes the pact slot
    val afterScribing = pExpendPactSlot(warlockSlots)
    // The 3rd-level scroll satisfies casting of a 1st-level spell (slot >= spell level)
    // This mirrors the recipient using the scroll: cast at level 3, not level 1
    val scrollSatisfiesSpellLevel = scrollLevel >= 1
    assert(
      canScribeWith3rdSlot          // warlock's pact slot (lvl 3) qualifies to scribe a lvl-1 spell
      and scrollLevel == 3          // scroll is lvl 3, determined by slot used — not spell base level
      and scrollLevel != 1          // NOT the spell's base level
      and afterScribing.pactSlotsCurrent == 1  // pact slot consumed by scribing
      and scrollSatisfiesSpellLevel // 3rd-level scroll can deliver a 1st-level spell (upcast)
    )
  }

  // Source: https://rpg.stackexchange.com/q/176699
  
  // Psionic Sorcerer: Psychic Strike with ongoing spells (witch bolt continues triggering Psychic Strike each turn)
  run qa_psychic_strike_ongoing_spell = {
    val target = freshCreature(50)
    val ss = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(1, 2))
      .with("slotsCurrent", EMPTY_SLOTS.set(1, 2))
  
    // Turn 1: cast witch bolt — expend 1 level-1 slot, start concentration,
    //         deal 8 lightning (spell) + 5 psychic (Psychic Strike, once this turn)
    val ss1 = pExpendSlot(ss, 1)
    val ss2 = pStartConcentration(ss1, "witch_bolt")
    val afterT1SpellDmg  = pTakeDamage(target,           8, Lightning, Set(), Set(), Set(), false)
    val afterT1Psychic   = pTakeDamage(afterT1SpellDmg,  5, Psychic,   Set(), Set(), Set(), false)
  
    // Turn 2: witch bolt ongoing (no new slot expended, still concentrating),
    //         deal 7 lightning + 3 psychic (Psychic Strike resets each turn)
    val afterT2SpellDmg  = pTakeDamage(afterT1Psychic,   7, Lightning, Set(), Set(), Set(), false)
    val afterT2Psychic   = pTakeDamage(afterT2SpellDmg,  3, Psychic,   Set(), Set(), Set(), false)
  
    assert(
      // Slot expended exactly once for the ongoing spell
      ss1.slotsCurrent.get(1) == 1
      // Still concentrating on witch bolt during turn 2 — slot was spent, spell is live
      and isConcentrating(ss2)
      // Turn 1: target took spell damage + Psychic Strike bonus
      and afterT1Psychic.hp == 50 - 8 - 5
      // Turn 2: ongoing spell damage again + Psychic Strike bonus again (once per TURN resets)
      and afterT2Psychic.hp == 50 - 8 - 5 - 7 - 3
    )
  }

  // Source: https://rpg.stackexchange.com/q/90919
  
  // Is skill check always against a DC or why is stealth an exception?
  
  // Persuasion: ability check vs DM-set DC (not a contest, not passive)
  run qa_persuasion_check_vs_dm_dc = {
    val chaMod = abilityModifier(14)       // Cha 14 → +2
    val profBonus = proficiencyBonus(3)    // level 3 → +2
    assert(
      checkSucceeds(14, chaMod, Proficient, profBonus, 0, 15) // 14+2+2=18 >= 15 succeeds
      and not(checkSucceeds(9, chaMod, Proficient, profBonus, 0, 15)) // 9+2+2=13 < 15 fails
    )
  }
  
  // Stealth vs passive perception: goblin stealth roll checked against static passive score
  run qa_stealth_vs_passive_perception = {
    val goblinDexMod = abilityModifier(14)  // Dex 14 → +2, goblin not proficient in Stealth
    val pcWisMod    = abilityModifier(14)   // Wis 14 → +2
    val pcProfBonus = proficiencyBonus(3)   // level 3 → +2
    val passivePerc = passiveCheck(pcWisMod, Proficient, pcProfBonus, false, false) // 10+2+2=14
    assert(
      checkSucceeds(12, goblinDexMod, NoneProf, 2, 0, passivePerc)       // 12+2=14 >= 14 hides
      and not(checkSucceeds(8, goblinDexMod, NoneProf, 2, 0, passivePerc)) // 8+2=10 < 14 spotted
    )
  }
  
  // Full contest (both roll): stealth vs active perception — higher wins; tie = no change (goblin fails)
  run qa_stealth_vs_active_perception_contest = {
    val goblinDexMod = abilityModifier(12) // Dex 12 → +1
    val pcWisMod     = abilityModifier(14) // Wis 14 → +2
    val pcProfBonus  = proficiencyBonus(3) // +2
    val goblinTotal  = 15 + goblinDexMod   // 16
    val pcTotal      = 14 + pcWisMod + pcProfBonus // 18 (PC actively perceiving)
    assert(
      contestWinner(goblinTotal, pcTotal) == BWins // PC wins → goblin detected
      and contestWinner(14, 14) == Tie             // Tie = status quo, goblin fails to sneak past
    )
  }

  // Source: https://rpg.stackexchange.com/q/122785
  
  // From where can a creature attempt to overcome a Scroll of Protection?
  // Accepted: anywhere — spec imposes no distance restriction; mechanic is DC 15 CHA check as an action
  run qa_scroll_protection_cha_check_success_uses_action = {
    // CHA 14 -> mod +2; roll 13: 13+2=15 >= 15 -> success, action consumed
    val chaMod = abilityModifier(14)
    val d20Roll = 13
    val creature = freshCreature(20)
    val t1 = pUseAction(FRESH_TURN, creature, AUseObject)
    assert(
      t1.actionUsed
      and checkSucceeds(d20Roll, chaMod, NoneProf, proficiencyBonus(1), 0, 15)
    )
  }
  
  // From where can a creature attempt to overcome a Scroll of Protection?
  // Roll just below DC: 12+2=14 < 15 -> failure, but action still consumed
  run qa_scroll_protection_cha_check_failure_still_uses_action = {
    val chaMod = abilityModifier(14)
    val d20Roll = 12
    val creature = freshCreature(20)
    val t1 = pUseAction(FRESH_TURN, creature, AUseObject)
    assert(
      t1.actionUsed
      and not(checkSucceeds(d20Roll, chaMod, NoneProf, proficiencyBonus(1), 0, 15))
    )
  }
  
  // From where can a creature attempt to overcome a Scroll of Protection?
  // Incapacitated creature cannot spend the action required for the CHA check
  run qa_scroll_protection_incapacitated_cannot_attempt = {
    val creature = pApplyCondition(freshCreature(20), CIncapacitated)
    val t1 = pUseAction(FRESH_TURN, creature, AUseObject)
    assert(not(t1.actionUsed))
  }
  
  // From where can a creature attempt to overcome a Scroll of Protection?
  // Boundary: CHA mod -1 (CHA 8) needs nat20 to hit DC 15 (19 < 15 false, 20+(-1)=19 < 15 false)
  // Actually nat20 attack always hits but checkSucceeds has no auto-success; roll 16+(-1)=15 succeeds
  run qa_scroll_protection_low_cha_exact_dc = {
    val chaMod = abilityModifier(8) // -1
    val d20Roll = 16 // 16 + (-1) = 15 >= 15 -> success
    assert(checkSucceeds(d20Roll, chaMod, NoneProf, proficiencyBonus(1), 0, 15))
  }

  // Source: https://rpg.stackexchange.com/q/213868
  
  // SKIP: Spec has no concept of Dispel Magic, spell-sourced effects, or the distinction between spell-applied conditions and non-spell magical effects (e.g., class features); no function exists to model "ends only ongoing spells on target" vs. "ends any magical effect."

  // Source: https://rpg.stackexchange.com/q/157128
  
  // Do Chain Devils' Animated Chains restrain creatures on a grapple?
  run qa_animated_chain_grapple_also_restrains = {
      val creature = freshCreature(20)
      // Chain attack (animated or devil-direct) applies grapple AND restrain on hit
      val afterChainHit = pApplyCondition(pApplyCondition(creature, CGrappled), CRestrained)
      assert(afterChainHit.grappled and afterChainHit.restrained)
  }

  // Source: https://rpg.stackexchange.com/q/148735
  
  // SKIP: Steel Wind Strike's teleportation mechanic and creature positioning are not modeled in the spec; no functions exist for post-cast spatial state or optional movement effects.

  // Source: https://rpg.stackexchange.com/q/123929
  
  // SKIP: The Q&A concerns the absence of Brilliant Energy weapons in 5e RAW. The spec has no creature type system (undead/constructs), no per-component AC breakdown to model "ignores armor bonus," and no magic item crafting rules — none of the relevant mechanics exist in the spec to encode a testable assertion.

  // Source: https://rpg.stackexchange.com/q/196851
  
  // What happens when a creature drops to 0 hit points without taking damage?
  run qa_drop_to_0_hp_no_damage_falls_unconscious = {
    // Accepted answer: non-damage HP reduction to 0 (e.g. Aid expiry) → falls unconscious, not dead
    val creature = freshCreature(20)
    val at0 = pApplyCondition(creature.with("hp", 0), CUnconscious)
    assert(and {
      at0.hp == 0,
      at0.unconscious,
      at0.prone,
      not(at0.dead),
      isIncapacitated(at0),
      at0.incapacitatedSources.contains(ISUnconscious),
    })
  }
  
  // Death saving throws proceed from 0 HP unconscious state reached via non-damage source
  run qa_death_saves_proceed_after_non_damage_drop = {
    // Once unconscious at 0 HP (however reached), death saves apply on subsequent turns
    val creature = freshCreature(20)
    val at0 = pApplyCondition(creature.with("hp", 0), CUnconscious)
    // Roll a 15 → counts as a success (>= 10, not nat20, not nat1)
    val afterSave = pDeathSave(at0, 15)
    assert(and {
      afterSave.deathSaves.successes == 1,
      afterSave.deathSaves.failures == 0,
      not(afterSave.dead),
      not(afterSave.stable),
      afterSave.hp == 0,
    })
  }
  
  // Three successful death saves stabilize the creature regardless of how 0 HP was reached
  run qa_three_death_save_successes_stabilize = {
    val creature = freshCreature(20)
    val at0 = pApplyCondition(creature.with("hp", 0), CUnconscious)
    val s1 = pDeathSave(at0, 15)
    val s2 = pDeathSave(s1, 12)
    val s3 = pDeathSave(s2, 11)
    assert(and {
      s3.stable,
      s3.hp == 0,
      not(s3.dead),
      s3.deathSaves.successes == 0,  // reset on stabilize
      s3.deathSaves.failures == 0,
    })
  }
  
  // Nat-20 death save from non-damage 0 HP: regain 1 HP and consciousness
  run qa_nat20_death_save_revives_from_non_damage_drop = {
    val creature = freshCreature(20)
    val at0 = pApplyCondition(creature.with("hp", 0), CUnconscious)
    val revived = pDeathSave(at0, 20)
    assert(and {
      revived.hp == 1,
      not(revived.unconscious),
      not(revived.dead),
      revived.deathSaves.successes == 0,
      revived.deathSaves.failures == 0,
    })
  }

  // Source: https://rpg.stackexchange.com/q/165082
  
  // Is the Oath of the Ancients Paladin's Elder Champion feature intended to still work while unconscious?
  run qa_elder_champion_heals_unconscious_paladin = {
    // Paladin knocked to 0 HP while Elder Champion is active.
    // Elder Champion has no "ends if incapacitated" clause, so its 10 HP/turn regen still fires.
    val unconsciousPaladin = freshCreature(30)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
    // "At the start of each of your turns, you regain 10 hit points." — no suppression clause.
    val afterRegen = pHeal(unconsciousPaladin, 10)
    assert(
      afterRegen.hp == 10
      and not(afterRegen.unconscious)
      and afterRegen.incapacitatedSources == Set()
      and afterRegen.deathSaves == DEATH_SAVES_RESET
    )
  }

  // Source: https://rpg.stackexchange.com/q/144874
  
  // Holy Weapon burst of radiance (errata XGtE 2020): failed CON save → full radiant damage and blinded
  run qa_holy_weapon_burst_failed_save = {
    val creature = freshCreature(50)
    val spellDC = 16
    val fullDamage = 24   // representative 4d8 roll
    val d20Roll = 5       // 5 + 0 = 5 < DC 16 → fail
    val conMod = 0
    val profBonus = 3
    val failed = not(saveSucceeds(d20Roll, conMod, false, profBonus, 0, spellDC))
    val afterDamage = pTakeDamage(creature, fullDamage, Radiant, Set(), Set(), Set(), false)
    val afterBlind = pApplyCondition(afterDamage, CBlinded)
    assert(
      failed and
      afterBlind.hp == 50 - fullDamage and
      afterBlind.blinded
    )
  }
  
  // Holy Weapon burst of radiance (errata XGtE 2020): successful CON save → half radiant damage, not blinded
  run qa_holy_weapon_burst_success_save = {
    val creature = freshCreature(50)
    val spellDC = 16
    val fullDamage = 24
    val halfDamage = fullDamage / 2  // = 12
    val d20Roll = 14      // 14 + 3 (conMod) + 3 (prof) = 20 >= DC 16 → succeed
    val conMod = 3
    val profBonus = 3
    val succeeded = saveSucceeds(d20Roll, conMod, true, profBonus, 0, spellDC)
    val afterDamage = pTakeDamage(creature, halfDamage, Radiant, Set(), Set(), Set(), false)
    assert(
      succeeded and
      afterDamage.hp == 50 - halfDamage and
      not(afterDamage.blinded)
    )
  }

  // Source: https://rpg.stackexchange.com/q/78885
  
  // Magic Initiate: cantrip spell attack bonus = abilityMod + profBonus(total character level)
  run qa_magic_initiate_spell_attack_bonus_uses_character_level = {
    // Level 5 Rogue with Magic Initiate (Sorcerer), CHA 14 (+2 mod)
    // proficiencyBonus(5) = (5-1)/4 + 2 = 3; abilityModifier(14) = 2 → total = 5
    val rogueConfig = TEST_CONFIG
      .with("level", 5)
      .with("spellcastingAbility", Cha)
      .with("abilityScores", Map(Str -> 14, Dex -> 12, Con -> 14, Int_ -> 10, Wis -> 13, Cha -> 14))
    all {
      // spell attack bonus uses total character level, not caster/class level
      assert(proficiencyBonus(5) == 3),
      assert(abilityModifier(14) == 2),
      assert(spellAttackBonus(rogueConfig) == 5),
    }
  }

  // Source: https://rpg.stackexchange.com/q/105205
  
  // Which spell casting level do you use when casting spells with a Staff of Power?
  // DMG p.141: spells from magic items cast at lowest possible spell level unless specified.
  run qa_magic_item_spell_minimum_level_ray_of_enfeeblement = {
    // Ray of Enfeeblement is 2nd level → Staff of Power expends a 2nd-level slot, not higher.
    val ss = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(2, 1).set(5, 1))
      .with("slotsCurrent", EMPTY_SLOTS.set(2, 1).set(5, 1))
    val rayBaseLevel = 2
    val afterCast = pExpendSlot(ss, rayBaseLevel)
    assert(
      // Minimum level is castable
      pCanCastAtLevel(ss, rayBaseLevel, rayBaseLevel)
      // 2nd-level slot consumed
      and afterCast.slotsCurrent.get(2) == 0
      // 5th-level slot untouched — magic item does NOT upcast
      and afterCast.slotsCurrent.get(5) == 1
    )
  }
  
  // Which spell casting level do you use when casting spells with a Staff of Power?
  // Cone of Cold is a 5th-level spell; its minimum is 5th, so a 5th-level slot is expended.
  run qa_magic_item_spell_minimum_level_cone_of_cold = {
    val ss = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(5, 2).set(9, 1))
      .with("slotsCurrent", EMPTY_SLOTS.set(5, 2).set(9, 1))
    val coneBaseLevel = 5
    val afterCast = pExpendSlot(ss, coneBaseLevel)
    assert(
      // Minimum level is castable
      pCanCastAtLevel(ss, coneBaseLevel, coneBaseLevel)
      // One 5th-level slot consumed
      and afterCast.slotsCurrent.get(5) == 1
      // 9th-level slot untouched — magic item does NOT upcast to highest available
      and afterCast.slotsCurrent.get(9) == 1
    )
  }

  // Source: https://rpg.stackexchange.com/q/70821
  
  // Pearl of Power: 4th-level+ expended slot converts to 3rd-level slot (DMG errata)
  run qa_pearl_of_power_converts_4th_plus_to_3rd = {
    // Warlock at level 9+ has level-5 pact slots
    val warlockSlots: SpellSlotState = {
      slotsMax: EMPTY_SLOTS,
      slotsCurrent: EMPTY_SLOTS,
      pactSlotsMax: 1,
      pactSlotsCurrent: 1,
      pactSlotLevel: 5,
      concentrationSpellId: "",
    }
    // Step 1: expend the level-5 pact slot
    val afterExpend = pExpendPactSlot(warlockSlots)
    // Step 2: Pearl of Power — pactSlotLevel >= 4, so restore a 3rd-level slot (not 5th)
    val restoredLevel = if (warlockSlots.pactSlotLevel >= 4) 3 else warlockSlots.pactSlotLevel
    val afterPearl = afterExpend.with(
      "slotsCurrent",
      afterExpend.slotsCurrent.set(restoredLevel, afterExpend.slotsCurrent.get(restoredLevel) + 1)
    )
    assert(
      // Pact slot is NOT restored — the pearl doesn't return the high-level slot
      afterPearl.pactSlotsCurrent == 0
      // A 3rd-level regular slot is gained instead
      and afterPearl.slotsCurrent.get(3) == 1
      // No 5th-level regular slot was created
      and afterPearl.slotsCurrent.get(5) == 0
    )
  }
  
  // Pearl of Power: recovered 3rd-level slot is still usable, so pearl is not useless for high-level warlocks
  run qa_pearl_of_power_still_useful_high_level_warlock = {
    val warlockSlots: SpellSlotState = {
      slotsMax: EMPTY_SLOTS,
      slotsCurrent: EMPTY_SLOTS,
      pactSlotsMax: 1,
      pactSlotsCurrent: 1,
      pactSlotLevel: 5,
      concentrationSpellId: "",
    }
    val afterExpend = pExpendPactSlot(warlockSlots)
    // Pearl gives back a 3rd-level slot for the expended level-5 pact slot
    val afterPearl = afterExpend.with(
      "slotsCurrent",
      afterExpend.slotsCurrent.set(3, afterExpend.slotsCurrent.get(3) + 1)
    )
    assert(
      // Recovered 3rd-level slot can cast level 1, 2, or 3 spells
      pCanCastAtLevel(afterPearl, 1, 3)
      and pCanCastAtLevel(afterPearl, 2, 3)
      and pCanCastAtLevel(afterPearl, 3, 3)
      // But cannot upcast to 4th level from a 3rd-level slot
      and not(pCanCastAtLevel(afterPearl, 4, 3))
    )
  }
  
  // Pearl of Power: low-level warlock (pact slot <= 3) restores at original level unchanged
  run qa_pearl_of_power_low_level_warlock_no_conversion = {
    // Warlock at level 5 has level-3 pact slots
    val warlockSlots: SpellSlotState = {
      slotsMax: EMPTY_SLOTS,
      slotsCurrent: EMPTY_SLOTS,
      pactSlotsMax: 1,
      pactSlotsCurrent: 1,
      pactSlotLevel: 3,
      concentrationSpellId: "",
    }
    val afterExpend = pExpendPactSlot(warlockSlots)
    // Pearl: pactSlotLevel (3) < 4, so restore at original level (3) — no conversion needed
    val restoredLevel = if (warlockSlots.pactSlotLevel >= 4) 3 else warlockSlots.pactSlotLevel
    // restoredLevel == 3 either way here, but the logic is identical to the high-level case
    val afterPearl = afterExpend.with(
      "slotsCurrent",
      afterExpend.slotsCurrent.set(restoredLevel, afterExpend.slotsCurrent.get(restoredLevel) + 1)
    )
    assert(
      restoredLevel == 3
      and afterPearl.slotsCurrent.get(3) == 1
    )
  }

  // Source: https://rpg.stackexchange.com/q/178837
  
  // Is it possible to bring an Astral Dreadnaught to the Material Plane?
  // True Polymorph replaces all statistics including special features; once polymorphed,
  // the creature's original traits (like Astral Entity) are replaced, so it can exist elsewhere.
  // Spec encodes True Polymorph as replacing CharConfig entirely.
  run qa_true_polymorph_replaces_config = {
    // Astral Dreadnought has a special feature modeled as part of its CharConfig.
    // True Polymorph replaces the target's game statistics (CharConfig) with a new form.
    // After polymorph the original config (and any special traits) is gone.
    val originalConfig: CharConfig = {
      abilityScores: Map(Str -> 28, Dex -> 7, Con -> 20, Int_ -> 10, Wis -> 14, Cha -> 18),
      level: 20,
      size: Huge,
      speeds: Map(Walk -> 20, Fly -> 80, Swim -> 0, Climb -> 0, Burrow -> 0),
      saveProficiencies: Set(Str, Con, Wis),
      skillProficiencies: Set(Perception),
      expertiseSkills: Set(),
      armorProficiencies: Set(),
      hitDieType: 12,
      spellcastingAbility: Wis,
      hasSpellcasting: false,
      canRitualCast: false,
      unarmoredDefense: NoUnarmoredDefense,
      features: Set(),
    }
    // New form via True Polymorph — ordinary creature, no special plane-binding features
    val polymorphedConfig: CharConfig = {
      abilityScores: Map(Str -> 10, Dex -> 10, Con -> 10, Int_ -> 10, Wis -> 10, Cha -> 10),
      level: 1,
      size: Medium,
      speeds: Map(Walk -> 30, Fly -> 0, Swim -> 0, Climb -> 0, Burrow -> 0),
      saveProficiencies: Set(),
      skillProficiencies: Set(),
      expertiseSkills: Set(),
      armorProficiencies: Set(),
      hitDieType: 8,
      spellcastingAbility: Wis,
      hasSpellcasting: false,
      canRitualCast: false,
      unarmoredDefense: NoUnarmoredDefense,
      features: Set(),
    }
    // PHB True Polymorph: target's statistics are replaced by the new form's statistics.
    // The original config's special traits no longer apply once polymorphed.
    // Assert: polymorphed config has no special features that would prevent plane travel.
    assert(
      // Original dreadnought has no FExtraAttack etc, but we verify config replacement:
      // after True Polymorph the active config is polymorphedConfig, not originalConfig.
      polymorphedConfig != originalConfig
      // The new form has no special features at all
      and polymorphedConfig.features == Set()
      // The original form's features are gone (not present in new form)
      and not(polymorphedConfig.features.contains(FExtraAttack))
      // Proficiency bonus changes with the new stat block (level 1 vs level 20)
      and proficiencyBonus(polymorphedConfig.level) < proficiencyBonus(originalConfig.level)
      // The new form is a different size — consistent with a true form-replacement
      and polymorphedConfig.size != originalConfig.size
    )
  }

  // Source: https://rpg.stackexchange.com/q/195103
  
  // SKIP: Spec models mechanical resolution (HP, conditions, slots, saves) but has no creature-type taxonomy (aberrations, fiends, undead, etc.) or spell-effect/protection registry needed to encode which entity types Protection from Evil and Good covers.

  // Source: https://rpg.stackexchange.com/q/116269
  
  // Does Empowered Evocation still work if you Overchannel?
  // Overchannel supplies the max dice result; Empowered Evocation adds INT mod — neither prevents the other.
  run qa_overchannel_empowered_evocation_stack = {
    // Wizard with INT 14 → modifier +2
    val intMod = abilityModifier(14)
    // Overchannel: roll maximum on each die; 2d6 per Scorching Ray beam → max = 12
    val overchannelMaxDice = 12
    // Empowered Evocation adds INT mod as a damage modifier on top of the (max) dice result
    val combinedDamage = normalDamage(overchannelMaxDice, intMod)
    assert(intMod == 2 and combinedDamage == 14)
  }
  
  // Non-evocation damage spell with Overchannel: Empowered Evocation does NOT apply, no INT mod bonus
  run qa_overchannel_non_evocation_no_empowered_evocation = {
    val intMod = abilityModifier(14)
    val overchannelMaxDice = 12
    // Without Empowered Evocation the modifier is 0
    val damageNoEmpEvoc   = normalDamage(overchannelMaxDice, 0)
    val damageWithEmpEvoc = normalDamage(overchannelMaxDice, intMod)
    assert(damageNoEmpEvoc == 12 and damageWithEmpEvoc == 14 and damageWithEmpEvoc > damageNoEmpEvoc)
  }

  // Source: https://rpg.stackexchange.com/q/163733
  
  // SKIP: Spec has no model of Artificer infusions, infusion learning, or class feature acquisition mechanics; only core combat/HP/condition/turn rules are present.

  // Source: https://rpg.stackexchange.com/q/137980
  
  // How to handle initiative for a sleeping creature? — unconscious creature is incapacitated and cannot act
  run qa_unconscious_is_incapacitated_cannot_act = {
    val sleeping = pApplyCondition(freshCreature(20), CUnconscious)
    assert(isIncapacitated(sleeping) and not(pCanAct(sleeping)))
  }
  
  // How to handle initiative for a sleeping creature? — melee attacker within 5ft vs unconscious target gets advantage and autoCrit
  run qa_unconscious_target_melee_advantage_autoCrit = {
    val sleeping = pApplyCondition(freshCreature(20), CUnconscious)
    val mods = pDefenseModifiers(sleeping, true)
    assert(mods.attackerAdvantage and mods.autoCrit)
  }
  
  // How to handle initiative for a sleeping creature? — ranged attacker beyond 5ft vs unconscious target gets advantage but no autoCrit
  run qa_unconscious_target_ranged_advantage_no_autoCrit = {
    val sleeping = pApplyCondition(freshCreature(20), CUnconscious)
    val mods = pDefenseModifiers(sleeping, false)
    assert(mods.attackerAdvantage and not(mods.autoCrit))
  }
  
  // How to handle initiative for a sleeping creature? — surprised creature cannot move, act, or use reaction on first turn
  run qa_surprised_first_turn_fully_locked = {
    val creature = freshCreature(20)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, true, 0, false, false)
    assert(t.actionUsed and t.bonusActionUsed and t.movementRemaining == 0 and not(t.reactionAvailable))
  }
  
  // How to handle initiative for a sleeping creature? — after surprised turn ends, reaction becomes available again
  run qa_end_surprise_turn_restores_reaction = {
    val creature = freshCreature(20)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, true, 0, false, false)
    val t2 = pEndSurpriseTurn(t)
    assert(t2.reactionAvailable and not(t2.surprised))
  }
  
  // How to handle initiative for a sleeping creature? — incapacitated creature's pUseAction is a no-op even with action available
  run qa_incapacitated_action_noop = {
    val sleeping = pApplyCondition(freshCreature(20), CUnconscious)
    val t2 = pUseAction(FRESH_TURN, sleeping, AAttack)
    assert(not(t2.actionUsed))
  }
  
  // How to handle initiative for a sleeping creature? — aggregate attack mods: rogue attacking prone unconscious goblin within 5ft gives advantage + autoCrit
  run qa_aggregate_mods_sleeping_goblin_melee = {
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: true,
      targetRestrained: false,
      targetProne: true,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: false,
      attackerCanSeeTarget: true,
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(mods.hasAdvantage and mods.autoCrit and not(mods.hasDisadvantage) and not(mods.autoMiss))
  }

  // Source: https://rpg.stackexchange.com/q/138896
  
  // How do multiple ghast stench fields work? — each requires a separate save; poisoned doesn't stack
  run qa_ghast_stench_separate_saves_each_fails = {
    // Two ghasts in range: fail both CON saves (DC 10) — creature ends up just poisoned
    val conMod = 0
    val profBonus = 2
    val dc = 10
    val save1 = saveSucceeds(4, conMod, false, profBonus, 0, dc)  // 4 < 10, fails
    val save2 = saveSucceeds(6, conMod, false, profBonus, 0, dc)  // 6 < 10, fails
    val s0 = freshCreature(20)
    val s1 = if (not(save1)) pApplyCondition(s0, CPoisoned) else s0
    val s2 = if (not(save2)) pApplyCondition(s1, CPoisoned) else s1
    // Despite failing two stench saves, creature is just poisoned — condition does not stack
    assert(s2.poisoned and s2 == pApplyCondition(s0, CPoisoned))
  }
  
  // How do multiple ghast stench fields work? — poisoned condition is idempotent regardless of source count
  run qa_ghast_stench_poisoned_idempotent = {
    // Applying CPoisoned N times is identical to applying it once
    val s0 = freshCreature(20)
    val s1 = pApplyCondition(s0, CPoisoned)
    val s2 = pApplyCondition(s1, CPoisoned)
    val s3 = pApplyCondition(s2, CPoisoned)
    assert(s1 == s2 and s2 == s3)
  }
  
  // How do multiple ghast stench fields work? — pass one save, fail another: still poisoned from the failed one
  run qa_ghast_stench_fail_one_of_two_still_poisoned = {
    // Save vs ghast A succeeds, save vs ghast B fails — result is still poisoned
    val conMod = 1
    val profBonus = 2
    val dc = 10
    val saveGhastA = saveSucceeds(15, conMod, false, profBonus, 0, dc)  // 15+1=16 >= 10, passes
    val saveGhastB = saveSucceeds(5,  conMod, false, profBonus, 0, dc)  // 5+1=6  < 10, fails
    val s0 = freshCreature(20)
    val s1 = if (not(saveGhastA)) pApplyCondition(s0, CPoisoned) else s0
    val s2 = if (not(saveGhastB)) pApplyCondition(s1, CPoisoned) else s1
    // Immunity from passing ghast A's save does not protect from ghast B's stench
    assert(saveGhastA and not(saveGhastB) and s2.poisoned)
  }

  // Source: https://rpg.stackexchange.com/q/120819
  
  // SKIP: Spec models no concept of magical vs. non-magical ability descriptors, Detect Magic detection, or racial shapechanger abilities; the Q&A's ruling cannot be encoded with existing functions.

  // Source: https://rpg.stackexchange.com/q/151315
  
  // Flanking grants advantage but does not constitute surprise; Assassinate crit needs actual surprised flag
  run qa_flanking_advantage_not_surprised = {
    val config = TEST_CONFIG
    val creature = freshCreature(20)
    // Non-surprised turn: target has NOT been surprised, Assassinate auto-crit does not apply
    val t = pStartTurn(config, creature, Unarmored, false, 0, false, false)
    // Advantage from flanking modeled via targetRestrained (a clean non-surprise advantage source)
    val ctx: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false, targetParalyzed: false, targetPetrified: false,
      targetStunned: false, targetUnconscious: false, targetRestrained: true,
      targetProne: false, attackerWithin5ft: true, targetDodging: false,
      targetCanSeeAttacker: true, attackerCanSeeTarget: true,
      isRangedAttack: false, beyondNormalRange: false, hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false, squeezing: false,
      underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    // Attacker has advantage (as flanking would grant) but target is NOT surprised — Assassinate auto-crit blocked
    assert(mods.hasAdvantage == true and t.surprised == false)
  }
  
  // Surprised creature on first turn: surprised flag set, cannot act — Assassinate auto-crit condition met
  run qa_surprised_creature_cannot_act = {
    val config = TEST_CONFIG
    val creature = freshCreature(20)
    val t = pStartTurn(config, creature, Unarmored, true, 0, false, false)
    assert(t.surprised == true and t.actionUsed == true and t.bonusActionUsed == true)
  }
  
  // Surprise is a first-turn condition only: surprised flag clears after end of surprise turn
  run qa_surprise_limited_to_first_turn = {
    val config = TEST_CONFIG
    val creature = freshCreature(20)
    val surprisedTurn = pStartTurn(config, creature, Unarmored, true, 0, false, false)
    val afterSurprise = pEndSurpriseTurn(surprisedTurn)
    // Assassinate auto-crit applies only while surprised = true; cleared after first turn
    assert(surprisedTurn.surprised == true and afterSurprise.surprised == false)
  }

  // Source: https://rpg.stackexchange.com/q/191515
  
  // Transmute Rock to Mud: failed DEX save causes full 4d8 bludgeoning from falling mud (ceiling effect)
  run qa_transmute_rock_ceiling_full_damage_failed_dex_save = {
    val creature = freshCreature(40)
    val dexMod = 1
    val dc = 15
    val d20Roll = 8 // 8+1=9 < 15, save fails
    val savePassed = saveSucceeds(d20Roll, dexMod, false, 0, 0, dc)
    val diceRoll = 24 // 4d8 concrete result
    val damage = if (savePassed) diceRoll / 2 else diceRoll
    val after = pTakeDamage(creature, damage, Bludgeoning, Set(), Set(), Set(), false)
    assert(not(savePassed) and after.hp == 40 - 24)
  }
  
  // Transmute Rock to Mud: passed DEX save halves bludgeoning damage from falling mud (ceiling effect)
  run qa_transmute_rock_ceiling_half_damage_passed_dex_save = {
    val creature = freshCreature(40)
    val dexMod = 3
    val dc = 15
    val d20Roll = 14 // 14+3=17 >= 15, save passes
    val savePassed = saveSucceeds(d20Roll, dexMod, false, 0, 0, dc)
    val diceRoll = 24
    val damage = if (savePassed) diceRoll / 2 else diceRoll
    val after = pTakeDamage(creature, damage, Bludgeoning, Set(), Set(), Set(), false)
    assert(savePassed and after.hp == 40 - 12)
  }
  
  // Transmute Rock to Mud: failed STR save causes restrained condition from floor mud (floor effect)
  run qa_transmute_rock_floor_restrained_failed_str_save = {
    val creature = freshCreature(20)
    val strMod = 0
    val dc = 15
    val d20Roll = 10 // 10+0=10 < 15, save fails
    val savePassed = saveSucceeds(d20Roll, strMod, false, 0, 0, dc)
    val after = if (not(savePassed)) pApplyCondition(creature, CRestrained) else creature
    assert(not(savePassed) and after.restrained)
  }
  
  // Transmute Rock to Mud: single casting targets one contiguous area; disconnected ceiling and
  // floor cannot both be affected — only one effect (ceiling OR floor) applies per casting
  run qa_transmute_rock_single_area_only_one_effect = {
    val creature = freshCreature(40)
    // Cast targeting ceiling only; both saves would fail, but floor was not part of target area
    val ceilingTargeted = true
    val floorTargeted = false // separate floor not contiguous with ceiling target
    val dexSaveFails = true
    val strSaveFails = true
    val diceRoll = 20
    val afterCeiling = if (ceilingTargeted and dexSaveFails)
      pTakeDamage(creature, diceRoll, Bludgeoning, Set(), Set(), Set(), false)
    else creature
    val afterFloor = if (floorTargeted and strSaveFails)
      pApplyCondition(afterCeiling, CRestrained)
    else afterCeiling
    // Ceiling effect applied (hp reduced), floor effect did NOT apply (not restrained)
    assert(afterFloor.hp < 40 and not(afterFloor.restrained))
  }

  // Source: https://rpg.stackexchange.com/q/99116
  
  // SKIP: Spec has no model of spell AoE geometry, cylinder origin points, elevation, or ground-relative targeting — only slot management and concentration are represented for spellcasting.

  // Source: https://rpg.stackexchange.com/q/141816
  
  // How often can spells be cast from a Rod of Alertness? - unlimited casts, one action each, resets each turn
  run qa_rod_of_alertness_unlimited_casts = {
    val creature = freshCreature(20)
    val turn1 = FRESH_TURN
  
    // First cast: use action for the rod spell
    val turn1_after = pUseAction(turn1, creature, ACastSpell)
  
    // New turn resets action economy — rod can be used again
    val turn2 = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
  
    // Second cast on the new turn (demonstrating no per-day limit)
    val turn2_after = pUseAction(turn2, creature, ACastSpell)
  
    assert(
      // Each cast consumes exactly one action
      turn1_after.actionUsed
      // A new turn restores the action (unlimited use across turns)
      and not(turn2.actionUsed)
      // The spell can be cast again on the next turn
      and turn2_after.actionUsed
    )
  }
  
  // How often can spells be cast from a Rod of Alertness? - 3 of 4 rod spells require concentration; new cast replaces old
  run qa_rod_of_alertness_concentration_replacement = {
    val ss0 = FRESH_SPELL_SLOTS
  
    // Concentrating on a rod spell (e.g. detect magic)
    val ss1 = pStartConcentration(ss0, "detect_magic")
  
    // Cast another concentration spell from the same rod — PHB: can't concentrate on two spells
    val ss2 = pStartConcentration(ss1, "see_invisibility")
  
    assert(
      // Old concentration is dropped
      ss2.concentrationSpellId != "detect_magic"
      // Now concentrating on the newly cast rod spell
      and ss2.concentrationSpellId == "see_invisibility"
      and isConcentrating(ss2)
    )
  }

  // Source: https://rpg.stackexchange.com/q/213150
  
  // Halfling Lucky: must use the rerolled die even if also a 1 — no re-rerolling permitted
  run qa_lucky_rerolled_nat1_attack_still_misses = {
    // Lucky triggers on original nat-1; reroll is also 1 → must use it → auto-miss, no further reroll
    val result = resolveAttackRoll(1, 10, 5, 0)
    assert(not(result.hits) and not(result.isCritical))
  }
  
  // Halfling Lucky: rerolled result replaces original in resolution (confirms reroll IS used)
  run qa_lucky_reroll_can_turn_nat1_into_hit = {
    // Original roll: 1 (auto-miss). Lucky reroll: 10, +5 bonus vs AC 14 → 15 >= 14 → hits
    val originalResult = resolveAttackRoll(1, 5, 14, 0)
    val rerollResult   = resolveAttackRoll(10, 5, 14, 0)
    assert(not(originalResult.hits) and rerollResult.hits)
  }
  
  // Halfling Lucky: rerolled nat-1 on saving throw uses value 1 in total — can still fail
  run qa_lucky_rerolled_nat1_save_uses_result = {
    // Reroll is 1, +4 mod, proficient with +2 profBonus: 1+4+2=7 < DC 8 → fails (must accept it)
    val result = saveSucceeds(1, 4, true, 2, 0, 8)
    assert(not(result))
  }
  
  // Halfling Lucky: rerolled nat-1 on ability check uses value 1 in total — can still fail
  run qa_lucky_rerolled_nat1_check_uses_result = {
    // Reroll is 1, +5 mod, Proficient at profBonus 3: 1+5+3=9 < DC 10 → fails (must accept it)
    val result = checkSucceeds(1, 5, Proficient, 3, 0, 10)
    assert(not(result))
  }

  // Source: https://rpg.stackexchange.com/q/172210
  
  // Tavern Brawler rope grapple: grapple requires a free hand; holding rope means no free hand, so grapple fails
  run qa_tavern_brawler_rope_no_free_hand_grapple_fails = {
    val target = freshCreature(20)
    // Attacker wins the contest but is holding the rope — no free hand available
    val result = pGrapple(Medium, Medium, target, AWins, false)
    assert(result.success == false and not(result.targetState.grappled))
  }
  
  // Tavern Brawler grapple: with a free hand (no rope in hand) and winning contest, grapple succeeds normally
  run qa_tavern_brawler_free_hand_grapple_succeeds = {
    val target = freshCreature(20)
    val result = pGrapple(Medium, Medium, target, AWins, true)
    assert(result.success == true and result.targetState.grappled)
  }
  
  // Tavern Brawler rope grapple: even a tie (status quo) with a free hand does not apply grappled
  run qa_tavern_brawler_grapple_tie_no_change = {
    val target = freshCreature(20)
    val result = pGrapple(Medium, Medium, target, Tie, true)
    assert(result.success == false and not(result.targetState.grappled))
  }

  // Calm Emotions suppresses charmed applied after casting—post-cast effects also suppressed
  run qa_calm_emotions_suppresses_post_cast_charmed = {
    val creature = freshCreature(20)
    val ssActive = FRESH_SPELL_SLOTS.with("concentrationSpellId", "calm_emotions")
    // Charmed effect applied AFTER calm emotions was already cast and active
    val charmedAfterCast = pApplyCondition(creature, CCharmed)
    // Suppression: concentration active => remove charmed (any effect, any timing)
    val suppressed = pRemoveCondition(charmedAfterCast, CCharmed)
    assert(isConcentrating(ssActive) and not(suppressed.charmed))
  }
  
  // Calm Emotions suppresses frightened applied after casting for full duration
  run qa_calm_emotions_suppresses_post_cast_frightened = {
    val creature = freshCreature(20)
    val ssActive = FRESH_SPELL_SLOTS.with("concentrationSpellId", "calm_emotions")
    // Frightened effect applied after calm emotions was cast
    val frightenedAfterCast = pApplyCondition(creature, CFrightened)
    // Suppression: concentration active => remove frightened
    val suppressed = pRemoveCondition(frightenedAfterCast, CFrightened)
    assert(isConcentrating(ssActive) and not(suppressed.frightened))
  }
  
  // When Calm Emotions ends, suppressed charmed/frightened resume if their duration not expired
  run qa_calm_emotions_suppressed_effects_resume_on_end = {
    val ssActive = FRESH_SPELL_SLOTS.with("concentrationSpellId", "calm_emotions")
    val creature = freshCreature(20)
    // While active: charmed suppressed (apply then remove)
    val suppressedCreature = pRemoveCondition(pApplyCondition(creature, CCharmed), CCharmed)
    // Calm emotions ends (concentration broken)
    val ssEnded = pBreakConcentration(ssActive)
    // Original charmed effect resumes—caller re-applies it since its duration hadn't expired
    val resumedCreature = pApplyCondition(suppressedCreature, CCharmed)
    assert(not(isConcentrating(ssEnded)) and resumedCreature.charmed)
  }

  // If you cast a spell with different effect options twice on the same creature, do multiple castings of the spell stack?
  run qa_condition_spell_no_stack_idempotent = {
    val creature = freshCreature(20)
    // Blindness/deafness applies CBlinded; casting it twice on the same target
    // must not produce a "stronger" blinded than casting it once
    val after_first_cast = pApplyCondition(creature, CBlinded)
    val after_second_cast = pApplyCondition(after_first_cast, CBlinded)
    assert(after_first_cast == after_second_cast)
  }
  
  // If you cast a spell with different effect options twice on the same creature, do multiple castings of the spell stack?
  run qa_concentration_most_recent_equally_potent_replaces = {
    val ss = FRESH_SPELL_SLOTS
    // First equally-potent casting of a concentration spell
    val ss1 = pStartConcentration(ss, "hold_person_cast1")
    // Second equally-potent casting: per PHB errata, most recent replaces the first
    val ss2 = pStartConcentration(ss1, "hold_person_cast2")
    assert(
      ss1.concentrationSpellId == "hold_person_cast1"
      and ss2.concentrationSpellId == "hold_person_cast2"
    )
  }
  
  // If you cast a spell with different effect options twice on the same creature, do multiple castings of the spell stack?
  run qa_deafened_no_stack_idempotent = {
    val creature = freshCreature(20)
    // The deafened option of blindness/deafness: casting twice is idempotent
    val after_first_cast = pApplyCondition(creature, CDeafened)
    val after_second_cast = pApplyCondition(after_first_cast, CDeafened)
    assert(after_first_cast == after_second_cast)
  }

  // Source: https://rpg.stackexchange.com/q/174121
  
  // Reincarnation effects on feats and ability scores: racial bonus cannot push score above 20
  run qa_reincarnation_ability_score_cap_at_20 = {
    // A character with Str 18 gains a +2 racial bonus after reincarnation; result is 20, not 22
    val scores = Map(Str -> 18, Dex -> 12, Con -> 14, Int_ -> 10, Wis -> 13, Cha -> 8)
    val result = pApplyASI(scores, Str, 2)
    assert(result.get(Str) == 20)
  }
  
  // Reincarnation effects on feats and ability scores: large racial bonus still hard-capped at 20
  run qa_reincarnation_large_racial_bonus_still_capped = {
    // Score at 19 + racial +4 would naively be 23; pApplyASI enforces the cap
    val scores = Map(Str -> 19, Dex -> 12, Con -> 14, Int_ -> 10, Wis -> 13, Cha -> 8)
    val result = pApplyASI(scores, Str, 4)
    assert(result.get(Str) == 20)
  }
  
  // Reincarnation effects on feats and ability scores: racial bonus from new race still respects cap on Cha
  run qa_reincarnation_cha_racial_bonus_capped = {
    // Original Cha 18, new race grants +2 Cha — final score is 20, not 20+
    val scores = Map(Str -> 10, Dex -> 10, Con -> 10, Int_ -> 10, Wis -> 10, Cha -> 18)
    val result = pApplyASI(scores, Cha, 2)
    assert(result.get(Cha) == 20)
  }
  
  // SKIP: Racial feat prerequisite loss (feat disabled until prerequisite regained) cannot be encoded —
  // the spec's Feature type only models FExtraAttack variants, not racial feats or their prerequisites.

  // Source: https://rpg.stackexchange.com/q/103352
  
  // How does a Cloak of Displacement interact with surprise or hidden attacks?
  run qa_unseen_attacker_has_advantage_eded0efc = {
    // PHB p.194-5: when a creature can't see its attacker, the attacker has advantage.
    // A hidden rogue attacking a Cloak of Displacement wearer starts with advantage.
    val ctx: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false, targetParalyzed: false, targetPetrified: false,
      targetStunned: false, targetUnconscious: false, targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: false,   // rogue is hidden — target cannot see attacker
      attackerCanSeeTarget: true,
      isRangedAttack: false, beyondNormalRange: false, hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false, squeezing: false,
      underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(mods.hasAdvantage and not(mods.hasDisadvantage))
  }
  
  // How does a Cloak of Displacement interact with surprise or hidden attacks?
  run qa_hidden_attack_vs_cloak_of_displacement_cancels = {
    // Cloak of Displacement gives disadvantage on all attack rolls against the wearer.
    // Hidden/unseen attacker advantage + Cloak disadvantage cancel to a straight roll.
    // PHB p.173: any source of advantage + any source of disadvantage = neither.
    val resolved = resolveAdvantage({ hasAdvantage: true, hasDisadvantage: true })
    assert(not(resolved.hasAdvantage) and not(resolved.hasDisadvantage))
  }

  // Source: https://rpg.stackexchange.com/q/136670
  
  // Is there any visible "signature" at the destination of a Teleport spell?
  // Accepted answer: no defined cue; use Intelligence (Arcana) to identify the magical effect.
  run qa_arcana_identifies_teleport_success = {
    // Arcana maps to Intelligence; a proficient character at level 5 can meet DC 15
    val intMod   = abilityModifier(16) // +3
    val pb       = proficiencyBonus(5) // +3
    val roll     = 12                  // 12 + 3 + 3 = 18 >= 15
    val dc       = 15
    assert(
      skillAbility(Arcana) == Int_
      and checkSucceeds(roll, intMod, Proficient, pb, 0, dc)
    )
  }
  
  // Is there any visible "signature" at the destination of a Teleport spell?
  // Without Arcana proficiency and low Intelligence the same check fails.
  run qa_arcana_identifies_teleport_failure = {
    val intMod = abilityModifier(10) // +0
    val pb     = proficiencyBonus(5) // +3 (unused: NoneProf)
    val roll   = 8                   // 8 + 0 + 0 = 8 < 15
    val dc     = 15
    assert(
      skillAbility(Arcana) == Int_
      and not(checkSucceeds(roll, intMod, NoneProf, pb, 0, dc))
    )
  }

  // Source: https://rpg.stackexchange.com/q/99973
  
  // How do you receive damage when you're merged with your raven? - all damage applies to character HP (raven cannot take damage)
  run qa_raven_merge_damage_hits_character_hp = {
    val merged = freshCreature(20)
    val afterDamage = pTakeDamage(merged, 8, Fire, Set(), Set(), Set(), false)
    assert(afterDamage.hp == 12)
  }
  
  // How do you receive damage when you're merged with your raven? - lethal overflow to merged form kills character (raven vanishes on death)
  run qa_raven_merge_lethal_damage_kills_character = {
    val merged = freshCreature(10)
    // overflow (20 - 10 = 10) >= effectiveMaxHp (10) triggers instant death
    val afterDamage = pTakeDamage(merged, 20, Fire, Set(), Set(), Set(), false)
    assert(afterDamage.dead == true)
  }

  // Source: https://rpg.stackexchange.com/q/181352
  
  // Fire Genasi no cold resistance: cold damage is not halved (no resistance, no immunity)
  run qa_fire_genasi_no_cold_resistance = {
    val dmgNoResist = applyDamageModifiers(10, Cold, Set(), Set(), Set())
    val dmgWithResist = applyDamageModifiers(10, Cold, Set(), Set(Cold), Set())
    assert(dmgNoResist == 10 and dmgWithResist == 5)
  }
  
  // Fire Genasi +2 CON bonus turns borderline extreme-cold DC 10 save from fail to pass
  run qa_fire_genasi_con_bonus_extreme_cold_save = {
    // Roll 8, CON mod 0 (human baseline): 8 < 10 → fails
    val failsNoBonus = saveSucceeds(8, 0, false, 3, 0, 10)
    // Roll 8, CON mod +2 (Fire Genasi +2 CON): 8+2=10 >= 10 → passes
    val succeedsWithBonus = saveSucceeds(8, 2, false, 3, 0, 10)
    assert(not(failsNoBonus) and succeedsWithBonus)
  }
  
  // Failing the extreme cold DC 10 CON save causes exactly 1 level of exhaustion
  run qa_extreme_cold_fail_adds_one_exhaustion = {
    val s = freshCreature(20)
    val s1 = pAddExhaustion(s, 1)
    assert(s1.exhaustion == 1 and not(s1.dead))
  }

  // Source: https://rpg.stackexchange.com/q/94118
  
  // Does Sequester extend the duration of Conjure spells? No — caster's spell clock runs independently of summoned creature state
  run qa_sequester_does_not_pause_conjure_duration = {
    // Caster concentrating on conjure_fey (limited-duration conjure spell)
    val casterSlots = pStartConcentration(FRESH_SPELL_SLOTS, "conjure_fey")
    // Sequester applied to the summoned fey — simulate stasis via incapacitation/unconscious
    val summonedOld = freshCreature(20)
    val summonedNew = pApplyCondition(summonedOld, CUnconscious)
    // Caster is unchanged — pBreakConcOnStateChange is called with CASTER states, not summoned creature states
    val casterOld = freshCreature(30)
    val casterNew = casterOld
    // Summoned creature entering stasis does NOT pause the caster's conjure spell duration
    val resultSlots = pBreakConcOnStateChange(casterSlots, casterOld, casterNew)
    assert(isConcentrating(resultSlots))
  }

  // Source: https://rpg.stackexchange.com/q/214076
  
  // "How does the Warlock's invocation Gaze of Two Minds interact with the Unseen rule?"
  // Accepted answer: unseen attacker condition keys on whether the target can see the ATTACKER (warlock),
  // not on where the spell originates — so advantage applies when target cannot see the warlock.
  run qa_unseen_attacker_advantage_gaze_of_two_minds = {
    // Warlock hides behind full cover, casts through fighter's space via GoTM.
    // Target can see the fighter (spell origin) but cannot see the warlock (the actual attacker).
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: false,
      targetDodging: false,
      // Target sees the fighter's space but NOT the warlock — unseen attacker rule triggers
      targetCanSeeAttacker: false,
      attackerCanSeeTarget: true,
      isRangedAttack: true,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    // PHB: "When a creature can't see you, you have Advantage on attack rolls against it."
    // The warlock is the attacker; target cannot see the warlock → advantage, no disadvantage.
    assert(mods.hasAdvantage and not(mods.hasDisadvantage) and not(mods.autoMiss))
  }

  // Source: https://rpg.stackexchange.com/q/188492
  
  // Wall of Fire - Do you end your turn near the wall if you damage the player that cast it and they lose concentration and the spell ends?
  run qa_wall_of_fire_concentration_break_before_end_of_turn = {
    // Enemy's turn: action used to attack Player 1, but bonus action still available (turn not yet over)
    val enemyTurn = FRESH_TURN.with("actionUsed", true).with("attackActionUsed", true)
    // Player 1 (caster) is concentrating on Wall of Fire
    val casterSlots = FRESH_SPELL_SLOTS.with("concentrationSpellId", "wall_of_fire")
    // Enemy's attack deals 20 damage to Player 1; concentration DC = max(10, 20/2) = 10
    val dc = pConcentrationDC(20)
    // Player 1 rolls a 4 on their CON save (no prof, no mod): total 4 < DC 10 → fails
    val savePassed = saveSucceeds(4, 0, false, 2, 0, dc)
    // Apply the failed concentration check — spell ends immediately
    val slotsAfter = pConcentrationCheck(casterSlots, savePassed)
    assert(
      // Wall of Fire spell ended immediately upon failed save
      not(isConcentrating(slotsAfter)) and
      // Enemy's turn is still in progress (bonus action unused, turn not declared over)
      not(enemyTurn.bonusActionUsed) and
      // Confirm save actually failed (precondition)
      not(savePassed)
    )
  }

  // Source: https://rpg.stackexchange.com/q/211165
  
  // SKIP: Q&A concerns Shield Guardian Spell Storing trait mechanics, familiar ownership attribution, and DM-discretion rulings — none of which are modeled in the spec (no familiar system, no spell-caster attribution, no magic item traits).

  // Source: https://rpg.stackexchange.com/q/86613
  
  // what is considered a "fast pace" for flying creatures?
  run qa_travel_pace_fast_slow_one_third_of_normal = {
    // Accepted answer: no RAW table for flying; calculate as Normal ± 1/3.
    // Standard table (30ft base): Normal=300, Fast=400, Slow=200 ft/min.
    // Same ±1/3 formula scales to any base speed (e.g. 50ft fly → Normal=500, Fast=666, Slow=333).
    val normalFpm = pTravelFeetPerMinute(PaceNormal)
    val fastFpm   = pTravelFeetPerMinute(PaceFast)
    val slowFpm   = pTravelFeetPerMinute(PaceSlow)
    // For 50ft fly speed: scale proportionally from 30ft walk base
    val flySpeed   = 50
    val walkSpeed  = 30
    val flyNormal  = normalFpm * flySpeed / walkSpeed  // 500 ft/min
    val flyFast    = flyNormal + flyNormal / 3          // 666 ft/min
    val flySlow    = flyNormal - flyNormal / 3          // 333 ft/min
    assert(and {
      // PHB table values satisfy the ±1/3 relationship exactly (integer division)
      fastFpm == normalFpm + normalFpm / 3,
      slowFpm == normalFpm - normalFpm / 3,
      // Fast pace imposes -5 passive Perception regardless of travel medium
      pTravelPerceptionPenalty(PaceFast) == -5,
      pTravelPerceptionPenalty(PaceNormal) == 0,
      pTravelPerceptionPenalty(PaceSlow) == 0,
      // Stealth only available at slow pace
      pCanStealthWhileTraveling(PaceSlow),
      not(pCanStealthWhileTraveling(PaceNormal)),
      not(pCanStealthWhileTraveling(PaceFast)),
      // Scaled values for 50ft fly speed
      flyNormal == 500,
      flyFast   == 666,
      flySlow   == 334,
    })
  }

  // Source: https://rpg.stackexchange.com/q/154142
  
  // Wild Shape concentration save uses beast's Con mod + retained proficiency bonus (Resilient feat)
  run qa_wild_shape_concentration_save_with_resilient = {
    // Brown bear Con 16 → +3; level 5 proficiency bonus → +3; retained Con save proficiency
    val bearConMod  = abilityModifier(16)  // physical stats of beast: +3
    val profBonus   = proficiencyBonus(5)  // level 5 → +3
    val dc          = pConcentrationDC(30) // 30 damage taken → DC max(10, 15) = 15
    val roll        = 11
    // With retained Con proficiency (Resilient feat): 11 + 3 + 3 = 17 >= 15 → succeeds
    val withRetainedProf = saveSucceeds(roll, bearConMod, true, profBonus, 0, dc)
    // Without retained proficiency (counterfactual): 11 + 3 = 14 < 15 → fails
    val withoutProf = saveSucceeds(roll, bearConMod, false, profBonus, 0, dc)
    assert(withRetainedProf == true and withoutProf == false)
  }
  
  // Full pipeline: concentrating druid wild shaped, hit for 30, succeeds save, still concentrating
  run qa_wild_shape_concentration_check_pipeline = {
    val ss0        = FRESH_SPELL_SLOTS.with("concentrationSpellId", "call_lightning")
    val bearConMod = abilityModifier(16)   // beast's Con score 16 → +3
    val profBonus  = proficiencyBonus(5)   // +3 at level 5
    val dc         = pConcentrationDC(30)  // DC 15
    val roll       = 11
    // Retained proficiency: 11 + 3 + 3 = 17 >= 15 → save succeeds
    val saveOk = saveSucceeds(roll, bearConMod, true, profBonus, 0, dc)
    val ss1    = pConcentrationCheck(ss0, saveOk)
    assert(isConcentrating(ss1))
  }
  
  // Concentration breaks when beast Con mod alone is insufficient without retained proficiency
  run qa_wild_shape_concentration_breaks_without_retained_prof = {
    val ss0        = FRESH_SPELL_SLOTS.with("concentrationSpellId", "call_lightning")
    val bearConMod = abilityModifier(16)   // +3
    val profBonus  = proficiencyBonus(5)   // +3 (unused — no proficiency)
    val dc         = pConcentrationDC(30)  // DC 15
    val roll       = 11
    // No retained proficiency: 11 + 3 = 14 < 15 → fails
    val saveOk = saveSucceeds(roll, bearConMod, false, profBonus, 0, dc)
    val ss1    = pConcentrationCheck(ss0, saveOk)
    assert(not(isConcentrating(ss1)))
  }

  // Source: https://rpg.stackexchange.com/q/103571
  
  // When neither side attempts stealth, combatants automatically notice each other — no surprise (PHB p.189)
  run qa_no_stealth_no_surprise = {
    val creature = freshCreature(30)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    assert(
      not(t.surprised)       and
      not(t.actionUsed)      and
      not(t.bonusActionUsed) and
      t.reactionAvailable    and
      t.movementRemaining > 0
    )
  }
  
  // Contrast: a creature that IS surprised (one side hid) loses action, bonus action, movement, and reaction (PHB p.189)
  run qa_surprised_creature_loses_full_turn_economy = {
    val creature = freshCreature(30)
    val t = pStartTurn(TEST_CONFIG, creature, Unarmored, true, 0, false, false)
    assert(
      t.surprised              and
      t.actionUsed             and
      t.bonusActionUsed        and
      not(t.reactionAvailable) and
      t.movementRemaining == 0
    )
  }
  
  // When neither side is stealthy, surprise ends after first turn — reaction restores normally (PHB p.189)
  run qa_surprise_clears_after_first_turn = {
    val creature = freshCreature(30)
    val t0 = pStartTurn(TEST_CONFIG, creature, Unarmored, true, 0, false, false)
    val t1 = pEndSurpriseTurn(t0)
    assert(
      not(t1.surprised)  and
      t1.reactionAvailable
    )
  }

  // Improved Pact Weapon grants +1 to Sword of Wounding (no existing +X bonus on attack/damage rolls)
  run qa_improved_pact_weapon_sword_of_wounding = {
    val baseAttackBonus = 3  // warlock's pact weapon attack bonus
    val targetAC = 14
    // No invocation: 10 + 3 = 13 < 14, miss
    val withoutIPW = resolveAttackRoll(10, baseAttackBonus, targetAC, 0)
    // Sword of Wounding has no +X to attack/damage → IPW grants +1: 10 + 3 + 1 = 14 >= 14, hit
    val withIPWOnSwordOfWounding = resolveAttackRoll(10, baseAttackBonus + 1, targetAC, 0)
    assert(not(withoutIPW.hits) and withIPWOnSwordOfWounding.hits)
  }
  
  // Improved Pact Weapon does NOT stack with a weapon that already has a +X bonus to attack/damage
  run qa_improved_pact_weapon_no_stack_with_plus2 = {
    val baseAttackBonus = 3
    val existingMagicBonus = 2  // e.g., +2 pact sword already has this bonus
    val targetAC = 16
    // +2 weapon, IPW does not add +1 on top: 10 + 3 + 2 = 15 < 16, miss
    val plus2NoIPWStack = resolveAttackRoll(10, baseAttackBonus + existingMagicBonus, targetAC, 0)
    // Incorrectly stacking +1 would give 10 + 3 + 2 + 1 = 16 >= 16, hit — but rules forbid this
    val incorrectStack = resolveAttackRoll(10, baseAttackBonus + existingMagicBonus + 1, targetAC, 0)
    assert(not(plus2NoIPWStack.hits) and incorrectStack.hits)
  }

  // Source: https://rpg.stackexchange.com/q/210434
  
  // Giant Killer reaction attack does not grant spellcasting ability; reaction and action are separate economy slots
  run qa_giant_killer_reaction_not_spellcast = {
    // Fresh turn: reaction available, action not yet used
    val t0 = FRESH_TURN
    // Spend the reaction (Giant Killer: react to Large creature's attack)
    val t1 = pUseReaction(t0)
    // Reaction is consumed by the attack
    val reactionConsumed = not(t1.reactionAvailable)
    // But the action slot is completely untouched — no spell was cast
    val actionStillFree = not(t1.actionUsed)
    // Casting a spell requires spending the action separately
    val creature = freshCreature(20)
    val t2 = pUseAction(t1, creature, ACastSpell)
    val castingSpellConsumesAction = t2.actionUsed
    assert(reactionConsumed and actionStillFree and castingSpellConsumesAction)
  }

  // Source: https://rpg.stackexchange.com/q/215009
  
  // Can Glamour Bard use Enthralling Performance on a roped-up enemy after fighting him?
  // Accepted answer: if the target watched/listened and fails the Wisdom save, they become charmed.
  
  // Enthralling Performance: target fails Wis save against bard's spell save DC → charmed
  run qa_enthralling_performance_failed_save_applies_charm = {
    val bardConfig = TEST_CONFIG
      .with("abilityScores", Map(Str -> 10, Dex -> 10, Con -> 14, Int_ -> 10, Wis -> 12, Cha -> 16))
      .with("level", 3)
      .with("spellcastingAbility", Cha)
      .with("hasSpellcasting", true)
    // DC = 8 + abilityMod(16) + profBonus(3) = 8 + 3 + 2 = 13
    val dc = spellSaveDC(bardConfig)
    // Captain: Wis 11 → mod 0, not proficient in Wis saves
    val captainWisMod = abilityModifier(11)
    val prof = proficiencyBonus(3)
    // Roll 8: 8 + 0 = 8 < 13 → save fails
    val saveFailed = not(saveSucceeds(8, captainWisMod, false, prof, 0, dc))
    val captain = freshCreature(20)
    val captainCharmed = pApplyCondition(captain, CCharmed)
    all {
      assert(dc == 13),
      assert(saveFailed),
      assert(captainCharmed.charmed),
    }
  }
  
  // Enthralling Performance: target succeeds Wis save → not charmed (no hint of attempt)
  run qa_enthralling_performance_success_save_no_charm = {
    val bardConfig = TEST_CONFIG
      .with("abilityScores", Map(Str -> 10, Dex -> 10, Con -> 14, Int_ -> 10, Wis -> 12, Cha -> 16))
      .with("level", 3)
      .with("spellcastingAbility", Cha)
      .with("hasSpellcasting", true)
    val dc = spellSaveDC(bardConfig)
    val captainWisMod = abilityModifier(11)
    val prof = proficiencyBonus(3)
    // Roll 15: 15 + 0 = 15 >= 13 → save succeeds
    val saveSucceeded = saveSucceeds(15, captainWisMod, false, prof, 0, dc)
    val captain = freshCreature(20)
    all {
      assert(dc == 13),
      assert(saveSucceeded),
      assert(not(captain.charmed)),
    }
  }
  
  // Enthralling Performance: DM-granted circumstantial advantage can flip a borderline failure to success
  run qa_enthralling_performance_advantage_flips_failed_save = {
    val bardConfig = TEST_CONFIG
      .with("abilityScores", Map(Str -> 10, Dex -> 10, Con -> 14, Int_ -> 10, Wis -> 12, Cha -> 16))
      .with("level", 3)
      .with("spellcastingAbility", Cha)
      .with("hasSpellcasting", true)
    val dc = spellSaveDC(bardConfig)
    val captainWisMod = abilityModifier(11)
    val prof = proficiencyBonus(3)
    // Without advantage: roll 8, total 8 < 13 → fails
    val failsWithout = not(saveSucceeds(8, captainWisMod, false, prof, 0, dc))
    // With advantage: rolls 8 and 14; take the higher (intMax), total 14 >= 13 → succeeds
    val advRoll = intMax(8, 14)
    val succeedsWith = saveSucceeds(advRoll, captainWisMod, false, prof, 0, dc)
    assert(failsWithout and succeedsWith)
  }

  // Source: https://rpg.stackexchange.com/q/173790
  
  // Is there a minimum intelligence score needed to make use of non-natural abilities?
  run qa_fly_speed_works_regardless_of_intelligence = {
    // Accepted answer: things do what they say they do — a granted fly speed (e.g. Potion of Flying)
    // requires no minimum INT; pUseMovement has no ability-score gate, only movement budget.
    // Ant-polymorphed character has fly 60ft from potion; can consume all of it.
    val flyTurn: TurnState = FRESH_TURN
      .with("movementRemaining", 60)
      .with("effectiveSpeed", 60)
    val afterMove = pUseMovement(flyTurn, 60, 1)
    assert(afterMove.movementRemaining == 0)
  }

  // Source: https://rpg.stackexchange.com/q/215917
  
  // How does Control Weather interact with a moving caster? — spell ends if caster is knocked unconscious (concentration breaks on incapacitation)
  run qa_control_weather_concentration_breaks_on_unconscious = {
    val caster = freshCreature(10)
    val ss0 = FRESH_SPELL_SLOTS.with("concentrationSpellId", "control_weather")
    // 11 damage on 10 HP caster: overflow=1 < maxHP=10 → unconscious, not dead
    val s1 = pTakeDamage(caster, 11, Slashing, Set(), Set(), Set(), false)
    // pBreakConcOnStateChange detects new incapacitation → breaks concentration
    val ss1 = pBreakConcOnStateChange(ss0, caster, s1)
    assert(
      s1.unconscious
      and not(isConcentrating(ss1))
    )
  }
  
  // How does Control Weather interact with a moving caster? — concentration check after damage determines if spell persists
  run qa_control_weather_concentration_save_on_damage = {
    val caster = freshCreature(40)
    val ss0 = FRESH_SPELL_SLOTS.with("concentrationSpellId", "control_weather")
    // 20 damage → DC = max(10, 20/2) = 10
    val dc = pConcentrationDC(20)
    // Failed save: d20=5, CON mod=+2, not proficient → 7 < 10
    val savePassedLow = saveSucceeds(5, 2, false, 0, 0, dc)
    val ss_fail = pConcentrationCheck(ss0, savePassedLow)
    // Passed save: d20=15, CON mod=+2, not proficient → 17 >= 10
    val savePassedHigh = saveSucceeds(15, 2, false, 0, 0, dc)
    val ss_pass = pConcentrationCheck(ss0, savePassedHigh)
    assert(
      not(savePassedLow) and not(isConcentrating(ss_fail))
      and savePassedHigh and isConcentrating(ss_pass)
    )
  }

  // Source: https://rpg.stackexchange.com/q/139766
  
  // Can I cast guidance immediately before a check and keep Hex active?
  run qa_casting_concentration_spell_breaks_previous_concentration = {
    // Start concentrating on Hex
    val ssWithHex = FRESH_SPELL_SLOTS.with("concentrationSpellId", "hex")
    // Cast Guidance (also requires concentration) — PHB: you lose concentration on
    // the previous spell immediately; no time limit or "instantaneous" exception applies
    val ssAfterGuidance = pStartConcentration(ssWithHex, "guidance")
    assert(
      // Guidance is now the active concentration spell
      ssAfterGuidance.concentrationSpellId == "guidance"
      // Hex is gone — you cannot maintain both
      and ssAfterGuidance.concentrationSpellId != "hex"
      // Still concentrating (on Guidance), just not on Hex
      and isConcentrating(ssAfterGuidance)
    )
  }

  // Source: https://rpg.stackexchange.com/q/103213
  
  // What are the most and least-resisted damage types?
  
  // Poison: most immuned (95 immunities in MM) — immunity yields 0 damage
  run qa_poison_immunity_zeroes_damage = {
    val creature = freshCreature(30)
    val after = pTakeDamage(creature, 20, Poison, Set(), Set(), Set(Poison), false)
    assert(after.hp == 30)
  }
  
  // Force: least resisted (0 resistances in MM) — no resistance means full damage passes through
  run qa_force_no_resistance_full_damage = {
    val creature = freshCreature(30)
    val after = pTakeDamage(creature, 10, Force, Set(), Set(), Set(), false)
    assert(after.hp == 20)
  }
  
  // Cold: most commonly resisted (46 resistances in MM) — resistance halves damage
  run qa_cold_resistance_halves_damage = {
    val creature = freshCreature(30)
    val after = pTakeDamage(creature, 10, Cold, Set(Cold), Set(), Set(), false)
    assert(after.hp == 25)
  }
  
  // Immunity takes priority over resistance (applyDamageModifiers ordering)
  run qa_immunity_overrides_resistance = {
    val result = applyDamageModifiers(20, Poison, Set(Poison), Set(Poison), Set())
    assert(result == 0)
  }
  
  // Vulnerability doubles damage when not immune/resistant — e.g. Fire (9 vulnerabilities in MM)
  run qa_fire_vulnerability_doubles_damage = {
    val creature = freshCreature(30)
    val after = pTakeDamage(creature, 8, Fire, Set(), Set(Fire), Set(), false)
    assert(after.hp == 14)
  }

  // Source: https://rpg.stackexchange.com/q/210563
  
  // Can you use Transmuted Spell on spells with a duration? (transmutation applies to all damage over full duration)
  run qa_transmuted_spell_full_duration = {
    // Flame Blade: concentration spell, normally deals Fire damage each time you attack with it.
    // Transmuted Spell is chosen at cast time; accepted answer confirms it applies
    // to ALL damage rolls over the full duration, not just the first hit.
    // Model: target has Fire immunity. Transmuting to Cold at cast time means
    // every attack during the concentration bypasses Fire immunity.
    val target = freshCreature(30)
    val fireImmune: Set[DamageType] = Set(Fire)
    val noMods: Set[DamageType] = Set()
  
    // Sanity: un-transmuted Flame Blade (Fire) is fully blocked by Fire immunity
    val afterFireHit = pTakeDamage(target, 9, Fire, noMods, noMods, fireImmune, false)
  
    // Transmuted at cast (Cold): hit 1 in round 1 of concentration
    val afterColdHit1 = pTakeDamage(target, 9, Cold, noMods, noMods, fireImmune, false)
    // Same concentration still active: hit 2 in round 2 — transmutation persists for full duration
    val afterColdHit2 = pTakeDamage(afterColdHit1, 9, Cold, noMods, noMods, fireImmune, false)
  
    assert(
      afterFireHit.hp == target.hp         // fire damage blocked by immunity (baseline)
      and afterColdHit1.hp < target.hp     // transmuted (cold) hit 1 bypasses fire immunity
      and afterColdHit2.hp < afterColdHit1.hp  // transmuted (cold) hit 2 also bypasses — full duration
    )
  }

  // Source: https://rpg.stackexchange.com/q/122208
  
  // Does Hex disappear if combat resolves peacefully?
  // Concentration on Hex does NOT auto-break when the caster's state is unchanged (target survived)
  run qa_hex_concentration_persists_peaceful_resolution = {
    val ss0 = pStartConcentration(FRESH_SPELL_SLOTS, "hex")
    val casterAlive = freshCreature(20)
    // Combat ends peacefully: caster's state is unchanged — pBreakConcOnStateChange leaves concentration intact
    val ss1 = pBreakConcOnStateChange(ss0, casterAlive, casterAlive)
    assert(isConcentrating(ss1) and ss1.concentrationSpellId == "hex")
  }
  
  // Does Hex disappear if combat resolves peacefully?
  // Dropping concentration is the ONLY way to end Hex when the target is still alive
  run qa_hex_ends_only_by_explicit_drop = {
    val ss0 = pStartConcentration(FRESH_SPELL_SLOTS, "hex")
    // Caster chooses to drop — this is the sole available action per the accepted answer
    val ss1 = pBreakConcentration(ss0)
    assert(not(isConcentrating(ss1)))
  }

  // Source: https://rpg.stackexchange.com/q/168998
  
  // RAW can an Eldritch Knight 9/Wizard 2 multiclass cast/learn 3rd level spells?
  run qa_ek9_wiz2_multiclass_caster_level = {
    // EK is a 1/3 caster (9 levels → 3 effective); Wizard is full (2 levels → 2 effective)
    assert(pMulticlassCasterLevel(2, 0, 9) == 5)
  }
  
  // EK9/Wiz2 multiclass table grants 3rd-level slots despite neither class allowing 3rd-level spells at those levels
  run qa_ek9_wiz2_3rd_level_slot_count = {
    // PHB multiclass spellcaster table: caster level 5 → 2 slots at spell level 3
    assert(pSlotsPerLevel(5, 3) == 2)
  }
  
  // EK9 alone has no 3rd-level slots — shows the Wizard levels are what push over the threshold
  run qa_ek9_alone_no_3rd_level_slots = {
    // EK9 single-class: effective caster level = floor(9/3) = 3 → 0 third-level slots
    assert(pSlotsPerLevel(3, 3) == 0)
  }
  
  // EK9/Wiz2 can upcast a 2nd-level known spell using a 3rd-level slot (the accepted answer's key claim)
  run qa_ek9_wiz2_upcast_2nd_to_3rd_slot = {
    // Build slot state with 2 third-level slots (as granted by caster level 5 table)
    val slots = FRESH_SPELL_SLOTS.with("slotsCurrent", EMPTY_SLOTS.set(3, 2))
    // spellLevel=2 (max EK9 can learn), slotLevel=3 → pCanCastAtLevel: slot >= spell and slot available
    assert(pCanCastAtLevel(slots, 2, 3))
  }
  
  // EK9/Wiz2 can also upcast a 1st-level spell to 3rd-level using the same slots
  run qa_ek9_wiz2_upcast_1st_to_3rd_slot = {
    val slots = FRESH_SPELL_SLOTS.with("slotsCurrent", EMPTY_SLOTS.set(3, 2))
    assert(pCanCastAtLevel(slots, 1, 3))
  }

  // Source: https://rpg.stackexchange.com/q/148187
  
  // When an Adult Gold Dragon changes into an Archmage, what are its saving throw and skill bonuses?
  run qa_polymorph_proficiency_bonus_from_new_form = {
    // Rule: retained proficiencies indicate *where* the bonus applies, but the proficiency
    // bonus value itself comes from the new form, not the original form.
    // Adult Gold Dragon CR 17 → profBonus +6; Archmage CR 12 → profBonus +4.
    // Dragon retains INT/WIS/CHA scores and which saves/skills it is proficient in,
    // but uses the archmage's proficiency bonus for all calculations.
    val dragonProfBonus = proficiencyBonus(17)  // +6
    val archmageProf    = proficiencyBonus(12)  // +4
    val retainedWisMod  = 2                     // dragon WIS 15 → mod +2, retained
    val retainedChaMod  = 7                     // dragon CHA 24 → mod +7, retained
    // Correct bonuses in archmage form use the archmage's proficiency bonus:
    val wisSaveBonus = retainedWisMod + archmageProf   // 2 + 4 = 6  (not 2+6=8)
    val chaSaveBonus = retainedChaMod + archmageProf   // 7 + 4 = 11 (not 7+6=13)
    val insightBonus = retainedWisMod + archmageProf   // Insight is WIS-based: 2 + 4 = 6
    assert(
      dragonProfBonus == 6
      and archmageProf == 4
      and wisSaveBonus == 6
      and chaSaveBonus == 11
      and insightBonus == 6
      // saveSucceeds with archmage prof bonus: 10 + 2 + 4 = 16 >= DC 16 → true
      and saveSucceeds(10, retainedWisMod, true, archmageProf, 0, 16)
      // dragon's old +6 is NOT used; 10 + 2 + 4 = 16 < DC 17 → false
      and not(saveSucceeds(10, retainedWisMod, true, archmageProf, 0, 17))
      // skill check (Insight, WIS-based): proficient + archmage prof bonus
      and checkSucceeds(10, retainedWisMod, Proficient, archmageProf, 0, 16)
      and not(checkSucceeds(10, retainedWisMod, Proficient, archmageProf, 0, 17))
    )
  }

  // Source: https://rpg.stackexchange.com/q/167410
  
  // Nature's Sanctuary: grapple resolves via contest (not hit/miss), so "automatic miss" has no effect
  run qa_natures_sanctuary_no_protection_from_grapple = {
    // A beast/plant that would be forced to "miss" by Nature's Sanctuary still wins the grapple
    // contest — pGrapple uses ContestResult, not resolveAttackRoll, so miss is irrelevant
    val target = freshCreature(20)
    val result = pGrapple(Medium, Medium, target, AWins, true)
    assert(result.success and result.targetState.grappled)
  }
  
  // Nature's Sanctuary: shove also resolves via contest — automatic miss cannot prevent a won shove
  run qa_natures_sanctuary_no_protection_from_shove = {
    val target = freshCreature(20)
    val result = pShove(Medium, Medium, target, AWins, ShoveProne)
    assert(result.success and result.targetState.prone)
  }

  // Source: https://rpg.stackexchange.com/q/151067
  
  // Calculating burst/nova melee damage: +8 to hit vs AC 15 hits on a minimum roll of 7
  run qa_burst_attack_hits_on_7_with_plus8 = {
    // attacker has +8 to hit (CHA +4 + prof +3 + Improved Pact Weapon +1)
    val minHit  = resolveAttackRoll(7, 8, 15, 0)  // 7+8=15 >= 15, hits
    val oneMiss = resolveAttackRoll(6, 8, 15, 0)  // 6+8=14 < 15, misses
    assert(minHit.hits and not(minHit.isCritical) and not(oneMiss.hits))
  }
  
  // Burst damage critical formula: on a crit, damage dice are doubled but modifier is added only once
  run qa_burst_crit_doubles_dice_not_modifier = {
    // Rapier pact weapon: normalDice roll 8; Eldritch Smite 4d8 + weapon d8 = bonusDice 18
    // modifier: CHA +4 + Hexblade's Curse +3 = 7
    val normalDice = 8
    val bonusDice  = 18
    val modifier   = 7
    val critDmg    = criticalDamage(normalDice, bonusDice, modifier)
    val ifModDoubled = normalDice + bonusDice + (2 * modifier)
    assert(critDmg == normalDice + bonusDice + modifier
      and critDmg != ifModDoubled)
  }
  
  // Burst damage: nat 20 always crits and hits, feeding the highest-damage outcome
  run qa_burst_nat20_always_crits_regardless_of_ac = {
    // Even with no extra bonus the nat 20 auto-hits and crits (PHB: always hits+crits)
    val r = resolveAttackRoll(20, 8, 15, 0)
    assert(r.hits and r.isCritical)
  }
  
  // Burst damage: nat 1 always misses even with a high attack bonus
  run qa_burst_nat1_always_misses = {
    val r = resolveAttackRoll(1, 8, 15, 0)
    assert(not(r.hits) and not(r.isCritical))
  }

  // Source: https://rpg.stackexchange.com/q/140564
  
  // Is the dulcimer listed under 5e's tools intended to be the hammered variety or the strummed variety?
  run qa_dulcimer_first_equip_is_free_interaction = {
    // Equipping any instrument (strummed or hammered) uses the one free object interaction per turn
    val t0 = FRESH_TURN
    val t1 = pUseObjectInteraction(t0)
    assert(t1.freeInteractionUsed == true and t1.actionUsed == false)
  }
  
  // Is the dulcimer listed under 5e's tools intended to be the hammered variety or the strummed variety?
  run qa_dulcimer_second_equip_no_longer_free = {
    // Hammered dulcimer concern: equipping mallets is a second interaction — spec returns
    // unchanged state (caller must spend Use an Object action for the second equip)
    val t0 = FRESH_TURN
    val t1 = pUseObjectInteraction(t0)  // equip dulcimer (free)
    val t2 = pUseObjectInteraction(t1)  // equip mallet — no longer free; spec leaves state unchanged
    assert(t2 == t1)
  }
  
  // Is the dulcimer listed under 5e's tools intended to be the hammered variety or the strummed variety?
  run qa_dulcimer_holding_as_focus_enables_spellcasting_no_playing_required = {
    // Accepted answer: bard only needs to *hold* the instrument as a spellcasting focus,
    // not play it — hasFreeHand=true (instrument hand doubles as focus hand) satisfies V+S
    val c = freshCreature(20)
    val canCast = pCanProvideComponents(c, true, true, true)
    assert(canCast == true)
  }
  
  // Is the dulcimer listed under 5e's tools intended to be the hammered variety or the strummed variety?
  run qa_dulcimer_strummed_one_interaction_leaves_action_free = {
    // Strummed dulcimer: one object interaction to equip, action is still available for casting
    val t0 = FRESH_TURN
    val t1 = pUseObjectInteraction(t0)
    // action still unused — bard can cast a spell on the same turn
    assert(t1.actionUsed == false)
  }

  // Source: https://rpg.stackexchange.com/q/119759
  
  // Can I ready an action to roll away from an attack or special attack?
  run qa_dodge_gives_disadvantage_ready_does_not = {
    val creature = freshCreature(20)
    // ADodge sets the dodging flag; AReady sets readiedAction but NOT dodging
    val tDodge = pUseAction(FRESH_TURN, creature, ADodge)
    val tReady = pUseAction(FRESH_TURN, creature, AReady)
    // Baseline attack context: no other modifiers, attacker visible to target
    val baseCtx: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false, targetParalyzed: false, targetPetrified: false,
      targetStunned: false, targetUnconscious: false, targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: true,
      attackerCanSeeTarget: true,
      isRangedAttack: false, beyondNormalRange: false, hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false,
      squeezing: false, underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    val modsDodge = pAggregateAttackMods(baseCtx.with("targetDodging", tDodge.dodging))
    val modsReady = pAggregateAttackMods(baseCtx.with("targetDodging", tReady.dodging))
    assert(
      // Dodge action activates the dodging flag — this is the correct evasion mechanic
      tDodge.dodging
      // Ready action does NOT activate dodging — readied reaction fires after trigger finishes,
      // so it cannot prevent the incoming attack from resolving
      and not(tReady.dodging)
      // Dodge → attack rolls against you have disadvantage (attacker visible to you)
      and modsDodge.hasDisadvantage
      // Ready → no such benefit; the attack already resolved before the reaction fires
      and not(modsReady.hasDisadvantage)
    )
  }

  // Source: https://rpg.stackexchange.com/q/204584
  
  // How to dual wield as a hexblade warlock: off-hand TWF attack does not add positive ability modifier to damage
  run qa_twf_offhand_positive_mod_not_added_f38bb35b = {
      // CHA +3 on off-hand: only dice count, mod ignored when positive
      val diceRoll = 5
      val chaMod = 3
      assert(pTWFOffHandDamage(diceRoll, chaMod) == 5)
  }
  
  // How to dual wield as a hexblade warlock: off-hand TWF attack applies negative ability modifier to damage
  run qa_twf_offhand_negative_mod_applied_f38bb35b = {
      // ability mod -2 (e.g. weak STR) does subtract from off-hand damage
      val diceRoll = 4
      val negMod = -2
      assert(pTWFOffHandDamage(diceRoll, negMod) == 2)
  }
  
  // How to dual wield as a hexblade warlock: TWF requires both weapons to be light melee
  run qa_twf_requires_both_weapons_light_melee = {
      val dagger: Weapon = {
          name: "dagger",
          damageDie: 4,
          versatileDie: 0,
          damageType: Piercing,
          properties: Set(Finesse, Light_, Thrown),
          isMelee: true,
          normalRange: 20,
          longRange: 60,
      }
      val longsword: Weapon = {
          name: "longsword",
          damageDie: 8,
          versatileDie: 10,
          damageType: Slashing,
          properties: Set(Versatile),
          isMelee: true,
          normalRange: 0,
          longRange: 0,
      }
      val creature = freshCreature(20)
      // attack action already used this turn, bonus action still available
      val t = FRESH_TURN.with("attackActionUsed", true)
      all {
          // dagger + dagger (both Light melee) → TWF permitted
          assert(pCanTWFWithWeapons(dagger, dagger, t, creature)),
          // dagger + longsword (longsword not Light) → TWF not permitted
          assert(not(pCanTWFWithWeapons(dagger, longsword, t, creature))),
      }
  }
  
  // How to dual wield as a hexblade warlock: zero off-hand damage is clamped at 0 (not negative)
  run qa_twf_offhand_damage_min_zero = {
      // very low roll + large negative mod cannot produce negative damage
      val diceRoll = 1
      val negMod = -5
      assert(pTWFOffHandDamage(diceRoll, negMod) == 0)
  }

  // Source: https://rpg.stackexchange.com/q/47293
  
  // How do I build an encounter for level 5 D&D characters?
  // The XP budget / CR framework is DM tooling, not PHB mechanical rules the spec models.
  // SKIP: Encounter building (XP budgets, CR ratings, encounter multipliers) is not modeled in the spec — no functions for CR, XP thresholds, or encounter difficulty calculation exist.

  // Source: https://rpg.stackexchange.com/q/98229
  
  // Benefits for Animal Companion: wolf bite is finesse (DEX not STR), yielding +2 DEX + +2 prof = +4 at level 3
  run qa_wolf_bite_finesse_uses_dex = {
    val biteWeapon: Weapon = {
      name: "Bite",
      damageDie: 4,
      versatileDie: 0,
      damageType: Piercing,
      properties: Set(Finesse),
      isMelee: true,
      normalRange: 0,
      longRange: 0,
    }
    val wolfStrMod = 1   // STR 12
    val wolfDexMod = 2   // DEX 15
    val profBonus = proficiencyBonus(3)  // level 3 -> +2
    val atkMod = weaponAttackAbility(biteWeapon, wolfStrMod, wolfDexMod)
    // Finesse picks higher of STR/DEX; DEX wins; +2 + +2 = +4
    assert(atkMod == wolfDexMod and atkMod + profBonus == 4)
  }
  
  // Benefits for Animal Companion: wolf keeps its stat-block proficiencies (Perception, Stealth) AND gains additional ones from the ranger feature — union, not replacement
  run qa_animal_companion_skill_proficiencies_stack = {
    val baseWolfSkills: Set[Skill] = Set(Perception, Stealth)
    val gainedSkills: Set[Skill] = Set(Athletics, Survival)
    // Accepted answer: existing skills are retained; companion gains on top
    val totalSkills = baseWolfSkills.union(gainedSkills)
    // Rejected interpretation: only 2 skills total (gained replaces base)
    val replacedSkills = gainedSkills
    assert(
      totalSkills.size() == 4
      and replacedSkills.size() == 2
      and totalSkills.contains(Perception)
      and totalSkills.contains(Stealth)
      and totalSkills.contains(Athletics)
      and totalSkills.contains(Survival)
    )
  }

  // Source: https://rpg.stackexchange.com/q/193545
  
  // "How would you rule impact force vs weight limits (Tenser's Floating Disk / Immovable Rod)?"
  // Accepted answer: D&D treats weight limits as static mass, not dynamic impact force
  run qa_weight_limit_is_static_mass = {
    // The spec models carrying capacity as purely static (STR × 15); no dynamic force component.
    // This mirrors the PHB ruling: 500 lb on Tenser's Disk means 500 lb of mass, not 500 lb of force.
    val capMedium = carryingCapacity(10, Medium)
    val capLarge  = carryingCapacity(10, Large)
    assert(
      capMedium == 150        // 10 × 15 = 150 lb static
      and capLarge == 300     // Large doubles it; still purely static
      and capLarge == capMedium * 2
    )
  }
  
  // "Pressing the Immovable Rod button uses an action, so it can't be done reactively"
  // Accepted answer: pressing the button is an action; reaction is a separate, still-available resource
  run qa_use_object_costs_action_not_reaction = {
    val creature = freshCreature(20)
    val afterUse = pUseAction(FRESH_TURN, creature, AUseObject)
    assert(
      afterUse.actionUsed       == true   // action slot consumed (pressing the button)
      and afterUse.reactionAvailable == true  // reaction is unaffected — can't "reactively press"
      and afterUse.bonusActionUsed   == false // bonus action also unaffected
    )
  }

  // Source: https://rpg.stackexchange.com/q/164683
  
  // How to increase monk's chance to land a Stunning Strike? — higher Wisdom score increases Stunning Strike DC
  run qa_stunning_strike_wis_increases_dc = {
    // TEST_CONFIG: WIS 13 → mod +1, level 5 → profBonus 3; DC = 8+1+3 = 12
    val baseDC = spellSaveDC(TEST_CONFIG)
    // WIS 20 → mod +5; DC = 8+5+3 = 16
    val highWisConfig = TEST_CONFIG.with("abilityScores", TEST_CONFIG.abilityScores.set(Wis, 20))
    val highWisDC = spellSaveDC(highWisConfig)
    assert(highWisDC > baseDC)
  }
  
  // How to increase monk's chance to land a Stunning Strike? — higher proficiency bonus (higher level) increases DC
  run qa_stunning_strike_proficiency_increases_dc = {
    // level 5 → profBonus 3; DC = 8+1+3 = 12
    val lvl5DC = spellSaveDC(TEST_CONFIG)
    // level 17 → profBonus 6; DC = 8+1+6 = 15
    val lvl17Config = TEST_CONFIG.with("level", 17)
    val lvl17DC = spellSaveDC(lvl17Config)
    assert(lvl17DC > lvl5DC)
  }
  
  // How to increase monk's chance to land a Stunning Strike? — target exhaustion level 3 grants disadvantage on CON saves
  run qa_stunning_strike_exhaustion3_con_disadvantage = {
    val target = freshCreature(30).with("exhaustion", 3)
    val mods = pSaveModifiers(target, Con)
    assert(mods.hasDisadvantage)
  }
  
  // How to increase monk's chance to land a Stunning Strike? — Bane-style penalty (miscBonus -2) turns a passing CON save into a failure
  run qa_stunning_strike_bane_penalty_fails_save = {
    // roll 13 + conMod 1 = 14 >= DC 14 → passes without Bane
    val withoutBane = saveSucceeds(13, 1, false, 0, 0, 14)
    // roll 13 + conMod 1 - 2 (Bane) = 12 < 14 → fails with Bane
    val withBane = saveSucceeds(13, 1, false, 0, -2, 14)
    assert(withoutBane and not(withBane))
  }

  // Source: https://rpg.stackexchange.com/q/145379
  
  // When the Haste spell ends on a creature, do attackers have advantage against that creature?
  // Haste end: speed=0, actions locked — but NO condition applied, so no attacker advantage.
  run qa_haste_end_no_attacker_advantage = {
    // Model the post-Haste creature: healthy, no conditions applied
    // (Haste's lethargy is speed=0 + action lockout, not Paralyzed/Stunned/etc.)
    val c = freshCreature(30)
    val defModsClose = pDefenseModifiers(c, true)   // attacker within 5 ft
    val defModsFar   = pDefenseModifiers(c, false)  // attacker beyond 5 ft
    assert(
      not(defModsClose.attackerAdvantage) and
      not(defModsClose.autoCrit) and
      not(defModsFar.attackerAdvantage) and
      not(defModsFar.autoCrit)
    )
  }
  
  // When the Haste spell ends on a creature, do attackers have advantage against that creature?
  // STR and DEX saves work normally during Haste lethargy — no auto-fail, no disadvantage.
  run qa_haste_end_saves_unaffected = {
    val c = freshCreature(30)
    val strMods = pSaveModifiers(c, Str)
    val dexMods = pSaveModifiers(c, Dex)
    assert(
      not(strMods.autoFail) and
      not(strMods.hasDisadvantage) and
      not(dexMods.autoFail) and
      not(dexMods.hasDisadvantage)
    )
  }
  
  // When the Haste spell ends on a creature, do attackers have advantage against that creature?
  // Contrast: applying Paralyzed (an actual condition) DOES grant attacker advantage + auto-crit.
  // This confirms Haste's end effect is NOT equivalent to any incapacitating condition.
  run qa_haste_end_not_equivalent_to_paralyzed = {
    val c         = freshCreature(30)
    val cParalyzed = pApplyCondition(c, CParalyzed)
    val noCondMods = pDefenseModifiers(c, true)
    val paraMods   = pDefenseModifiers(cParalyzed, true)
    assert(
      not(noCondMods.attackerAdvantage) and
      paraMods.attackerAdvantage and
      paraMods.autoCrit
    )
  }

  // Source: https://rpg.stackexchange.com/q/179507
  
  // When is the Saving Throw rolled for an Infernal Wound? — Con save is rolled on hit; failure → wound damage at turn start
  run qa_infernal_wound_failed_save_on_hit_takes_damage = {
    val creature = freshCreature(30)
    val conMod = abilityModifier(10) // CON 10 → +0
    val dc = 12
    // Ruling: save rolled when attack hits, not at start of each turn
    // d20=4 + 0 = 4 < 12 → fails → wound applies
    val saveFailed = not(saveSucceeds(4, conMod, false, 0, 0, dc))
    // Wound deals 5 (1d10 pre-resolved as 5) at start of each turn
    val afterTurnStart = pTakeDamage(creature, 5, Piercing, Set(), Set(), Set(), false)
    assert(saveFailed and afterTurnStart.hp == 25)
  }
  
  // When is the Saving Throw rolled for an Infernal Wound? — successful save on hit prevents wound entirely
  run qa_infernal_wound_successful_save_no_wound = {
    val creature = freshCreature(30)
    val conMod = abilityModifier(10) // CON 10 → +0
    val dc = 12
    // d20=15 + 0 = 15 >= 12 → save succeeds → no wound, no damage
    val saveOk = saveSucceeds(15, conMod, false, 0, 0, dc)
    assert(saveOk and creature.hp == 30)
  }
  
  // When is the Saving Throw rolled for an Infernal Wound? — magical healing closes the wound (restores HP)
  run qa_infernal_wound_magical_healing_closes_wound = {
    val creature = freshCreature(30)
    // Wound was applied (failed save on hit); creature took 5 damage at turn start
    val wounded = pTakeDamage(creature, 5, Piercing, Set(), Set(), Set(), false)
    // Magical healing closes wound and restores HP
    val healed = pHeal(wounded, 5)
    assert(healed.hp == 30)
  }
  
  // When is the Saving Throw rolled for an Infernal Wound? — subsequent hits increase wound damage with no new save
  run qa_infernal_wound_stacking_no_extra_save = {
    val creature = freshCreature(50)
    val conMod = abilityModifier(10) // CON 10 → +0
    val dc = 12
    // First hit: save failed → wound (5/turn); second hit on already-wounded target increases damage (+5, no new save)
    val saveFailed = not(saveSucceeds(3, conMod, false, 0, 0, dc))
    // Wound now 10/turn (5 base + 5 stacked); at turn start:
    val afterTurnStart = pTakeDamage(creature, 10, Piercing, Set(), Set(), Set(), false)
    assert(saveFailed and afterTurnStart.hp == 40)
  }

  // Source: https://rpg.stackexchange.com/q/207123
  
  // Does teleportation count as movement for the sake of One with Shadows invocation?
  run qa_one_with_shadows_bonus_action_breaks_invisibility = {
    // Casting Misty Step uses a bonus action; per accepted answer, bonus action breaks One with Shadows invisibility
    val s0 = pApplyCondition(freshCreature(20), CInvisible)
    val t0 = FRESH_TURN
    // Represent casting Misty Step: consume bonus action and mark bonus action spell
    val t1 = pMarkBonusActionSpell(pUseBonusAction(t0, s0))
    // Bonus action was used → caller removes CInvisible per the rule
    val s1 = pRemoveCondition(s0, CInvisible)
    assert(t1.bonusActionUsed and t1.bonusActionSpellCast and not(s1.invisible))
  }
  
  // Does teleportation count as movement for the sake of One with Shadows invocation?
  run qa_one_with_shadows_external_teleport_preserves_invisibility = {
    // External teleportation expends no action/bonus action/reaction; "move" means using speed, so invisibility holds
    val s0 = pApplyCondition(freshCreature(20), CInvisible)
    val t0 = FRESH_TURN
    // No turn resources consumed (externally moved by another effect, not the creature's own action)
    assert(
      s0.invisible
      and not(t0.actionUsed)
      and not(t0.bonusActionUsed)
      and t0.reactionAvailable
    )
  }

  // Source: https://rpg.stackexchange.com/q/160282
  
  // Does Heat Metal work on weapons impaled into enemies? - physical contact means fire damage applies
  run qa_heat_metal_embedded_physical_contact_takes_fire_damage = {
    // Accepted: "Any creature in physical contact with the object takes 2d8 fire damage"
    // An embedded dagger counts as physical contact → fire damage applies (2d8 pre-resolved as 10)
    val creature = freshCreature(20)
    val afterDamage = pTakeDamage(creature, 10, Fire, Set(), Set(), Set(), false)
    assert(afterDamage.hp == 10)
  }
  
  // Does Heat Metal work on weapons impaled into enemies? - bonus action repeats fire damage on subsequent turns
  run qa_heat_metal_embedded_repeated_damage = {
    // Accepted: "you can use a bonus action on each of your subsequent turns to cause this damage again"
    // Two rounds of 2d8 fire damage (pre-resolved as 9 each) from embedded heated weapon
    val creature = freshCreature(30)
    val afterRound1 = pTakeDamage(creature, 9, Fire, Set(), Set(), Set(), false)
    val afterRound2 = pTakeDamage(afterRound1, 9, Fire, Set(), Set(), Set(), false)
    assert(afterRound2.hp == 12)
  }
  
  // Does Heat Metal work on weapons impaled into enemies? - embedded != "holding or wearing", no secondary disadvantage
  run qa_heat_metal_embedded_not_holding_no_attack_disadvantage = {
    // Accepted: "I don't think having a knife embedded in you would count as 'holding' or 'wearing'"
    // → Con-save-or-drop and attack-roll disadvantage secondary effects do NOT apply to embedded weapon
    // Taking only fire damage (no "holding" condition) leaves attack modifiers clean
    val creature = freshCreature(20)
    val afterFire = pTakeDamage(creature, 10, Fire, Set(), Set(), Set(), false)
    // No condition was applied by the fire damage itself; pOwnAttackModifiers reflects no disadvantage
    val mods = pOwnAttackModifiers(afterFire, false)
    assert(not(mods.hasDisadvantage) and not(afterFire.poisoned) and not(afterFire.restrained))
  }
  
  // Does Heat Metal work on weapons impaled into enemies? - fire damage from embedded weapon requires concentration check
  run qa_heat_metal_embedded_fire_damage_concentration_check = {
    // Taking fire damage from heated embedded weapon triggers concentration check
    // DC = max(10, damage/2); failed save breaks concentration, passed save maintains it
    val dc = pConcentrationDC(10)
    val ss = FRESH_SPELL_SLOTS.with("concentrationSpellId", "bless")
    val afterFail = pConcentrationCheck(ss, false)
    val afterPass = pConcentrationCheck(ss, true)
    assert(
      dc == 10
      and afterFail.concentrationSpellId == ""
      and afterPass.concentrationSpellId == "bless"
    )
  }

  // Source: https://rpg.stackexchange.com/q/114387
  
  // How combat Hide mechanic works on multiple enemies present?
  // Stealth result is the effective DC for enemy Passive Perception to spot you.
  run qa_hide_low_wis_enemy_cannot_spot = {
    // WIS 8 (mod -1), no Perception proficiency: PP = 10 - 1 = 9 < stealth roll 13
    val stealthResult = 13
    val enemyPP = passiveCheck(-1, NoneProf, 2, false, false)
    assert(enemyPP < stealthResult)
  }
  
  // How combat Hide mechanic works on multiple enemies present?
  // Attacker who cannot see the hidden target rolls with disadvantage.
  run qa_hide_unseen_target_gives_attacker_disadvantage = {
    // Skeleton cannot see hidden player (attackerCanSeeTarget = false)
    val ctx: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false, targetParalyzed: false, targetPetrified: false,
      targetStunned: false, targetUnconscious: false, targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false, targetCanSeeAttacker: true,
      attackerCanSeeTarget: false,  // hidden creature — attacker can't see target
      isRangedAttack: false, beyondNormalRange: false, hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false,
      squeezing: false, underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(mods.hasDisadvantage and not(mods.hasAdvantage))
  }
  
  // How combat Hide mechanic works on multiple enemies present?
  // Enemy with PP exactly matching stealth result CAN see the hidden creature.
  run qa_hide_high_wis_enemy_spots = {
    // WIS 16 (mod +3), no prof: PP = 10 + 3 = 13 >= stealth roll 13 → spotted
    val stealthResult = 13
    val enemyPP = passiveCheck(3, NoneProf, 2, false, false)
    assert(enemyPP >= stealthResult)
  }
  
  // How combat Hide mechanic works on multiple enemies present?
  // Advantage on Passive Perception (+5) lets even a WIS 8 enemy spot stealth roll 13.
  run qa_hide_advantage_pp_spots_low_wis_enemy = {
    // WIS 8 (mod -1) with advantage: PP = 10 - 1 + 5 = 14 >= 13 → spots hidden creature
    val stealthResult = 13
    val enemyPPWithAdv = passiveCheck(-1, NoneProf, 2, true, false)
    assert(enemyPPWithAdv >= stealthResult)
  }
  
  // How combat Hide mechanic works on multiple enemies present?
  // Active Search (Perception check) beating the stealth roll reveals the hidden creature.
  run qa_hide_active_search_reveals_on_success = {
    // Enemy rolls Perception (d20=15, WIS mod -1, no prof): total 14 >= DC 13 → found
    val stealthResult = 13
    assert(checkSucceeds(15, -1, NoneProf, 2, 0, stealthResult))
  }
  
  // How combat Hide mechanic works on multiple enemies present?
  // Active Search that fails (roll too low) does not reveal the hidden creature.
  run qa_hide_active_search_fails_below_stealth = {
    // Enemy rolls Perception (d20=5, WIS mod -1, no prof): total 4 < DC 13 → not found
    val stealthResult = 13
    assert(not(checkSucceeds(5, -1, NoneProf, 2, 0, stealthResult)))
  }
  
  // How combat Hide mechanic works on multiple enemies present?
  // Once attacker CAN see the target, no disadvantage from visibility applies.
  run qa_hide_spotted_enemy_attacks_normally = {
    // WIS 16 enemy spotted the player; attackerCanSeeTarget = true → no visibility disadv
    val ctx: AttackContext = {
      attackerBlinded: false, attackerProne: false, attackerRestrained: false,
      attackerPoisoned: false, attackerFrightened: false, attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false, targetParalyzed: false, targetPetrified: false,
      targetStunned: false, targetUnconscious: false, targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false, targetCanSeeAttacker: true,
      attackerCanSeeTarget: true,  // high-PP enemy spotted the hidden player
      isRangedAttack: false, beyondNormalRange: false, hostileWithin5ft: false,
      isHeavyWeapon: false, wielderSizeSmallOrTiny: false,
      squeezing: false, underwater: false, attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false, isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(not(mods.hasDisadvantage) and not(mods.hasAdvantage))
  }

  // Source: https://rpg.stackexchange.com/q/130323
  
  // How does Compelled Duel work with the saving throws?
  run qa_compelled_duel_initial_save_succeeds_no_effect = {
    // PHB p224: target makes an initial Wisdom save; success → spell has no effect at all
    // (no disadvantage on attacks, no movement restriction imposed)
    val dc = spellSaveDC(TEST_CONFIG) // 8 + wismod(1) + prof(3) = 12
    // target Wis mod +2, rolls 10 → 10 + 2 = 12 >= DC 12 → saves; spell fails to take hold
    assert(saveSucceeds(10, 2, false, 0, 0, dc) == true)
  }
  
  // How does Compelled Duel work with the saving throws?
  run qa_compelled_duel_initial_save_fails_spell_active = {
    // PHB: on failed initial save the target is compelled; disadvantage on attacks vs non-caster
    // and must make a Wisdom save each time it tries to move >30ft away
    val dc = spellSaveDC(TEST_CONFIG) // 12
    // target Wis mod +2, rolls 5 → 5 + 2 = 7 < DC 12 → fails; spell takes effect
    assert(saveSucceeds(5, 2, false, 0, 0, dc) == false)
  }
  
  // How does Compelled Duel work with the saving throws?
  run qa_compelled_duel_movement_save_per_turn_success = {
    // PHB: "must make a Wisdom saving throw each time it attempts to move >30ft away"
    // succeeding frees movement for that turn only — spell persists into next turns
    val dc = spellSaveDC(TEST_CONFIG) // 12
    // target Wis mod +2, rolls 12 → 12 + 2 = 14 >= DC 12 → free to move this turn
    assert(saveSucceeds(12, 2, false, 0, 0, dc) == true)
  }
  
  // How does Compelled Duel work with the saving throws?
  run qa_compelled_duel_movement_save_per_turn_failure = {
    // PHB: failing the per-turn movement save restricts movement beyond 30ft that turn;
    // next turn the target must save again if it tries to move >30ft
    val dc = spellSaveDC(TEST_CONFIG) // 12
    // target Wis mod +2, rolls 3 → 3 + 2 = 5 < DC 12 → restricted this turn
    assert(saveSucceeds(3, 2, false, 0, 0, dc) == false)
  }

  // Source: https://rpg.stackexchange.com/q/100200
  
  // Dispel Magic vs Magic Resistance: Magic Resistance grants advantage on saving throws, not on the caster's spellcasting ability check
  run qa_magic_resistance_does_not_affect_dispel_check = {
    // Dispel Magic (3rd level) vs a 9th-level spell: DC = 10 + 9 = 19
    val spellLevel = 9
    val dc = 10 + spellLevel
    // Caster: spellcasting mod +4 (e.g. INT 18), no proficiency added (most classes)
    val spellcastingMod = 4
    // Magic Resistance = advantage on SAVING THROWS against spells (NPC's side).
    // It does NOT impose disadvantage on the caster's ability check — the caster's
    // adv state is entirely unaffected by the target's Magic Resistance.
    val casterCheckAdv = resolveAdvantage({ hasAdvantage: false, hasDisadvantage: false })
    // d20=15: 15 + 4 = 19 >= 19, check succeeds (just makes it)
    val succeedsOn15 = checkSucceeds(15, spellcastingMod, NoneProf, 0, 0, dc)
    // d20=14: 14 + 4 = 18 < 19, check fails
    val failsOn14 = checkSucceeds(14, spellcastingMod, NoneProf, 0, 0, dc)
    assert(
      // Magic Resistance leaves the caster's check adv state unchanged
      casterCheckAdv == { hasAdvantage: false, hasDisadvantage: false }
      // Dispel Magic DC against 9th-level spell is 19
      and dc == 19
      // Check arithmetic: needs at least 15 on the die with +4 mod to beat DC 19
      and succeedsOn15
      and not(failsOn14)
    )
  }

  // Source: https://rpg.stackexchange.com/q/118719
  
  // What monk features are disabled whilst wearing armor?
  run qa_monk_monkud_applies_only_when_unarmored = {
    // MonkUD (10+DEX+WIS) only active when Unarmored; armor overrides it entirely
    val dexMod = 3
    val wisMod = 2
    val conMod = 1
    // Unarmored: AC = 10 + DEX(3) + WIS(2) = 15
    val unarmoredAC = calculateAC(Unarmored, dexMod, false, MonkUD, conMod, wisMod)
    // WearingArmor(LEATHER): AC = 11 + DEX(3) = 14 — MonkUD clause never reached
    val armoredAC = calculateAC(WearingArmor(LEATHER), dexMod, false, MonkUD, conMod, wisMod)
    assert(unarmoredAC == 15 and armoredAC == 14)
  }
  
  // What monk features are disabled whilst wearing armor?
  run qa_monk_armored_monkud_vs_barbarian_ud = {
    // Confirm both MonkUD and BarbarianUD are suppressed identically when armored:
    // wearing armor collapses all UnarmoredDefense variants to the armor formula
    val dexMod = 2
    val conMod = 3
    val wisMod = 1
    val monkArmoredAC      = calculateAC(WearingArmor(CHAIN_SHIRT), dexMod, false, MonkUD, conMod, wisMod)
    val barbarianArmoredAC = calculateAC(WearingArmor(CHAIN_SHIRT), dexMod, false, BarbarianUD, conMod, wisMod)
    val noudArmoredAC      = calculateAC(WearingArmor(CHAIN_SHIRT), dexMod, false, NoUnarmoredDefense, conMod, wisMod)
    // All three must equal 13 + min(DEX,2) = 13 + 2 = 15
    assert(monkArmoredAC == 15 and barbarianArmoredAC == 15 and noudArmoredAC == 15)
  }
  
  // What monk features are disabled whilst wearing armor?
  run qa_monk_flurry_uses_basic_unarmed_when_armored = {
    // Accepted answer: Flurry of Blows when armored (no Martial Arts) uses basic
    // unarmed strike: 1 + STR mod bludgeoning — no Martial Arts die added
    val strMod = 3
    val basicDmg = unarmedDamage(strMod)
    // Martial Arts die would add on top; without it the result is just 1 + STR = 4
    assert(basicDmg == 4)
  }
  
  // What monk features are disabled whilst wearing armor?
  run qa_monk_negative_str_unarmed_floor = {
    // Edge: unarmedDamage floors at 0 even with very negative STR mod (min 0 rule)
    val strMod = -3
    val dmg = unarmedDamage(strMod)
    assert(dmg == 0)
  }

  // Source: https://rpg.stackexchange.com/q/163402
  
  // SKIP: Deck of Many Things / Avatar of Death summoning logic is DMG content with no corresponding functions in the spec; the spec models only PHB core mechanics and has no representation of magic item triggered summons, "helping" detection, or avatar re-summoning rules.

  // Source: https://rpg.stackexchange.com/q/169605
  
  // Dragon Fear feat: DC = 8 + proficiency bonus + CHA modifier; failed WIS save → Frightened
  run qa_dragon_fear_failed_save_applies_frightened = {
    val chaMod    = abilityModifier(16)       // +3
    val profBonus = proficiencyBonus(5)       // +3
    val dc        = 8 + profBonus + chaMod   // 14
    val wisMod    = abilityModifier(10)       // +0
    val roll      = 10                        // 10 + 0 = 10 < 14 → fail
    val savePassed = saveSucceeds(roll, wisMod, false, profBonus, 0, dc)
    val target    = freshCreature(20)
    val s1        = if (savePassed) target else pApplyCondition(target, CFrightened)
    assert(not(savePassed) and s1.frightened)
  }
  
  // Dragon Fear feat: passing the WIS save leaves target un-Frightened
  run qa_dragon_fear_passed_save_no_frightened = {
    val chaMod    = abilityModifier(16)
    val profBonus = proficiencyBonus(5)
    val dc        = 8 + profBonus + chaMod   // 14
    val wisMod    = abilityModifier(18)       // +4
    val roll      = 15                        // 15 + 4 = 19 >= 14 → pass
    val savePassed = saveSucceeds(roll, wisMod, false, profBonus, 0, dc)
    val target    = freshCreature(20)
    val s1        = if (savePassed) target else pApplyCondition(target, CFrightened)
    assert(savePassed and not(s1.frightened))
  }
  
  // Dragon Fear feat: frightened creature has disadvantage on attacks while source is in LOS
  run qa_dragon_fear_frightened_attack_disadvantage = {
    val target = freshCreature(20)
    val s1     = pApplyCondition(target, CFrightened)
    val mods   = pOwnAttackModifiers(s1, true)  // frightening source in line of sight
    assert(s1.frightened and mods.hasDisadvantage)
  }
  
  // Dragon Fear feat: frightened creature has no attack disadvantage when source is NOT in LOS
  run qa_dragon_fear_frightened_no_disadv_out_of_los = {
    val target = freshCreature(20)
    val s1     = pApplyCondition(target, CFrightened)
    val mods   = pOwnAttackModifiers(s1, false)  // source not in LOS
    assert(s1.frightened and not(mods.hasDisadvantage))
  }
  
  // Dragon Hide feat: retractable claws deal 1d4 + STR mod slashing (normalDamage formula)
  run qa_dragon_hide_claw_damage_formula = {
    val strMod  = abilityModifier(16)   // +3
    val dieRoll = 4                     // max d4
    val dmg     = normalDamage(dieRoll, strMod)
    assert(dmg == 7)
  }
  
  // Dragon Hide feat: +1 unarmored AC bonus stacks on top of base 10 + DEX mod
  run qa_dragon_hide_unarmored_ac_bonus = {
    val dexMod  = abilityModifier(14)   // +2
    val baseAC  = calculateAC(Unarmored, dexMod, false, NoUnarmoredDefense, 0, 0)
    val withHide = baseAC + 1           // Dragon Hide +1 to unarmored AC
    assert(baseAC == 12 and withHide == 13)
  }
  
  // Dragon Wings feat: flying speed available only when within carrying capacity
  run qa_dragon_wings_carrying_capacity_gate = {
    val strScore   = 14
    val capacity   = carryingCapacity(strScore, Medium)   // 14 * 15 = 210 lbs
    val withinCap  = 200 <= capacity
    val overCap    = 220 <= capacity
    assert(withinCap and not(overCap) and capacity == 210)
  }
  
  // Dragon Wings feat: Small creature has halved carrying capacity (affects Dragon Wings eligibility)
  run qa_dragon_wings_small_creature_capacity = {
    val strScore      = 14
    val medCapacity   = carryingCapacity(strScore, Medium)   // 210
    val smallCapacity = carryingCapacity(strScore, Small)    // 210 (Small == Medium per PHB)
    assert(medCapacity == smallCapacity)
  }

  // Source: https://rpg.stackexchange.com/q/127422
  
  // Does a spellcaster lose their skill proficiencies when viewing through their familiar?
  // Rule: retain own proficiencies while in familiar-vision; familiar's skill proficiencies do NOT transfer.
  
  // Test 1: Caster keeps own Deception proficiency while using familiar's senses.
  // With own proficiency: 10 + 2 + 3 = 15 >= DC 15 (success).
  // Without (wrong — if own proficiency lost): 10 + 2 = 12 < 15 (fail).
  run qa_familiar_vision_own_proficiency_retained = {
    val chaMod    = abilityModifier(14)    // Warlock Cha 14 → +2
    val profBonus = proficiencyBonus(5)    // level 5 → +3
    val dc   = 15
    val roll = 10
    // Correct: own Deception proficiency retained in familiar-vision mode → succeeds
    val retained = checkSucceeds(roll, chaMod, Proficient, profBonus, 0, dc)
    // Wrong: if own proficiency were somehow lost → fails
    val lost     = checkSucceeds(roll, chaMod, NoneProf,   profBonus, 0, dc)
    assert(retained and not(lost))
  }
  
  // Test 2: Familiar's Insight proficiency does NOT transfer to the caster.
  // Without transfer (correct): 10 + 1 = 11 < DC 14 (fail).
  // With transfer (wrong): 10 + 1 + 3 = 14 >= DC 14 (would succeed).
  run qa_familiar_vision_familiar_skill_not_transferred = {
    val wisMod    = abilityModifier(12)    // Warlock Wis 12 → +1
    val profBonus = proficiencyBonus(5)    // level 5 → +3
    val dc   = 14
    val roll = 10
    // Correct: familiar's Insight proficiency is NOT transferred → NoneProf → fails
    val noTransfer   = checkSucceeds(roll, wisMod, NoneProf,   profBonus, 0, dc)
    // Wrong: if familiar's Insight proficiency incorrectly transferred → Proficient → succeeds
    val withTransfer = checkSucceeds(roll, wisMod, Proficient, profBonus, 0, dc)
    assert(not(noTransfer) and withTransfer)
  }

  // Source: https://rpg.stackexchange.com/q/171471
  
  // Deflect Missiles against unusual projectiles? — caught missile treated as improvised weapon (1d4 single type, no extra effects)
  run qa_deflect_missiles_improvised_weapon = {
    // Monk (DEX mod +3) catches a Drider's poisoned arrow via Deflect Missiles.
    // Rule: caught projectile = improvised weapon → 1d4 + DEX mod, DM-assigned type only.
    // The Drider's bonus 1d8 poison does NOT automatically transfer to the throw-back attack.
    val dexMod = 3
    val d4Roll = 4  // pre-resolved improvised weapon die (1d4 max)
  
    // Improvised weapon damage formula: normalDamage(diceResult, modifier)
    val improvisedDmg = normalDamage(d4Roll, dexMod)  // 4 + 3 = 7
  
    val target = freshCreature(20)
  
    // Only base Piercing damage from improvised throw-back; no separate Poison application
    val afterThrowback = pTakeDamage(target, improvisedDmg, Piercing, Set(), Set(), Set(), false)
  
    // Verify: improvised weapon deals 7, target HP 20 → 13; no extra poison component
    assert(improvisedDmg == 7 and afterThrowback.hp == 13)
  }

  // Source: https://rpg.stackexchange.com/q/150587
  
  // Expert Divination: upcasting a divination spell uses the slot level (not original spell level) to determine which slots can be regained
  run qa_expert_divination_upcast_level = {
    // 6th-level Divination wizard has 1st/2nd/3rd-level slots available
    val slots: SpellSlotState = {
      slotsMax: Map(1 -> 4, 2 -> 3, 3 -> 2, 4 -> 0, 5 -> 0, 6 -> 0, 7 -> 0, 8 -> 0, 9 -> 0),
      slotsCurrent: Map(1 -> 4, 2 -> 3, 3 -> 2, 4 -> 0, 5 -> 0, 6 -> 0, 7 -> 0, 8 -> 0, 9 -> 0),
      pactSlotsMax: 0,
      pactSlotsCurrent: 0,
      pactSlotLevel: 0,
      concentrationSpellId: "",
    }
    // Cast Mind Spike (2nd-level divination) using a 3rd-level slot (upcasting)
    val afterCast = pExpendSlot(slots, 3)
    // PHB p.201: spell assumes the higher level for that casting
    // Expert Divination: regain a slot of level LOWER than the slot used
    val slotLevelUsed = 3       // spell counts as 3rd level (slot used)
    val originalSpellLevel = 2  // would be wrong basis for the feature
    assert(
      // 3rd-level slot was consumed
      afterCast.slotsCurrent.get(3) == 1
      // Correct ruling: a 2nd-level slot (< 3) is a valid recovery target
      and 2 < slotLevelUsed
      // Wrong reading: if original spell level were used, 2nd-level slot would NOT qualify (not 2 < 2)
      and not(2 < originalSpellLevel)
      // 1st-level slot is also a valid recovery target under either reading (1 < 2 and 1 < 3)
      and 1 < slotLevelUsed
      and 1 < originalSpellLevel
    )
  }

  // Source: https://rpg.stackexchange.com/q/137667
  
  // Do constructs need air to survive? — Constructs without 'Constructed Nature' are subject to normal suffocation rules
  run qa_construct_needs_air_without_constructed_nature = {
    val creature = freshCreature(20)
    val suffocated = pSuffocate(creature)
    assert(suffocated.hp == 0 and suffocated.unconscious and not(suffocated.dead))
  }

  // Source: https://rpg.stackexchange.com/q/59584
  
  // Can a support combat style be effective without magic? — Help action uses your action but doesn't mark attack action
  run qa_help_action_consumes_action_not_attack = {
    val creature = freshCreature(20)
    val t1 = pUseAction(FRESH_TURN, creature, AHelp)
    assert(t1.actionUsed == true and t1.attackActionUsed == false and t1.bonusActionUsed == false)
  }
  
  // Can a support combat style be effective without magic? — advantage (from Help) converts a near-miss into a hit
  run qa_help_advantage_converts_miss_to_hit = {
    val attackBonus = 4
    val targetAC = 16
    // Normal roll: 11 + 4 = 15 < 16 → miss
    val normalRoll = resolveAttackRoll(11, attackBonus, targetAC, 0)
    // With advantage the ally picks the better die: 13 + 4 = 17 >= 16 → hit
    val advRoll = resolveAttackRoll(13, attackBonus, targetAC, 0)
    assert(normalRoll.hits == false and advRoll.hits == true)
  }
  
  // Can a support combat style be effective without magic? — Lay on Hands (pHeal) restores a downed ally from 0 HP
  run qa_lay_on_hands_restores_downed_ally = {
    val downed = freshCreature(20)
      .with("hp", 0)
      .with("unconscious", true)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISUnconscious))
      .with("deathSaves", { successes: 1, failures: 1 })
    val s1 = pHeal(downed, 5)
    assert(s1.hp == 5 and s1.unconscious == false and s1.deathSaves == DEATH_SAVES_RESET)
  }

  // Source: https://rpg.stackexchange.com/q/179871
  
  // Does the Elemental Gem require Concentration?
  // "as if you had cast conjure elemental" inherits all spell rules, including concentration.
  run qa_elemental_gem_requires_concentration = {
    val afterGemUse = pStartConcentration(FRESH_SPELL_SLOTS, "conjure_elemental")
    assert(isConcentrating(afterGemUse) and afterGemUse.concentrationSpellId == "conjure_elemental")
  }
  
  // Does the Elemental Gem require Concentration? — breaking concentration dismisses the elemental
  run qa_elemental_gem_concentration_break_ends_effect = {
    val afterGemUse = pStartConcentration(FRESH_SPELL_SLOTS, "conjure_elemental")
    val afterBreak  = pBreakConcentration(afterGemUse)
    assert(not(isConcentrating(afterBreak)))
  }
  
  // Does the Elemental Gem require Concentration? — using the gem while concentrating on another spell drops the prior spell
  run qa_elemental_gem_replaces_existing_concentration = {
    val concentratingOnBless = pStartConcentration(FRESH_SPELL_SLOTS, "bless")
    val afterGemUse = pStartConcentration(concentratingOnBless, "conjure_elemental")
    assert(
      isConcentrating(afterGemUse)
      and afterGemUse.concentrationSpellId == "conjure_elemental"
    )
  }
  
  // Does the Elemental Gem require Concentration? — damage while concentrating can break the effect via failed save
  run qa_elemental_gem_concentration_breaks_on_failed_save = {
    val concentrating = pStartConcentration(FRESH_SPELL_SLOTS, "conjure_elemental")
    val afterFailedSave = pConcentrationCheck(concentrating, false)
    assert(not(isConcentrating(afterFailedSave)))
  }
  
  // Does the Elemental Gem require Concentration? — concentration survives a passed CON save
  run qa_elemental_gem_concentration_survives_passed_save = {
    val concentrating = pStartConcentration(FRESH_SPELL_SLOTS, "conjure_elemental")
    val afterPassedSave = pConcentrationCheck(concentrating, true)
    assert(isConcentrating(afterPassedSave) and afterPassedSave.concentrationSpellId == "conjure_elemental")
  }

  // Source: https://rpg.stackexchange.com/q/199160
  
  // Can a Battle Smith use Replicate Magical Item to grant their Steel Defender Plate Armor?
  run qa_steel_defender_plate_lacks_proficiency = {
    // Steel Defenders have no armor proficiency — wearing plate imposes disadvantage on STR/DEX checks, saves, and attack rolls
    val armorState = WearingArmor(PLATE)
    val noProfs: Set[ArmorCategory] = Set()
    assert(lacksArmorProficiency(armorState, noProfs))
  }
  
  // Can a Battle Smith use Replicate Magical Item to grant their Steel Defender Plate Armor?
  run qa_steel_defender_plate_str_requirement_speed_penalty = {
    // Plate requires STR 15; Steel Defender has STR 14, so it suffers the 10ft speed penalty
    val armorState = WearingArmor(PLATE)
    val strScore = 14
    assert(armorSpeedPenalty(armorState, strScore) == 10)
  }
  
  // Can a Battle Smith use Replicate Magical Item to grant their Steel Defender Plate Armor?
  run qa_plate_still_grants_ac18_without_prof = {
    // Even without proficiency, plate still calculates to AC 18 (heavy armor ignores DEX)
    val armorState = WearingArmor(PLATE)
    val dexMod = 2
    assert(calculateAC(armorState, dexMod, false, NoUnarmoredDefense, 0, 0) == 18)
  }
  
  // Can a Battle Smith use Replicate Magical Item to grant their Steel Defender Plate Armor?
  run qa_proficient_wearer_plate_no_penalty = {
    // A creature actually proficient in heavy armor wearing plate incurs no proficiency penalty
    val armorState = WearingArmor(PLATE)
    val profsWithHeavy: Set[ArmorCategory] = Set(HeavyArmor)
    assert(not(lacksArmorProficiency(armorState, profsWithHeavy)))
  }

  // Source: https://rpg.stackexchange.com/q/70347
  
  // SKIP: Vampire Spawn→Vampire transformation is Monster Manual narrative lore (MM p.295), not a PHB mechanical rule. The spec models no creature-type, transformation, or vampire-specific mechanics.

  // Source: https://rpg.stackexchange.com/q/204658
  
  // Banishment as an escape route: incapacitation (Banishment) blocks actions but NOT movement — standing from prone costs movement, not an action
  run qa_banishment_incap_blocks_actions_not_movement = {
    // James in the demiplane: incapacitated by Banishment, prone (arrived prone from the table)
    val james = freshCreature(20)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISDirect))
  
    // pCanAct reflects incapacitation: James cannot take actions
    val cannotAct = not(pCanAct(james))
  
    // pStandFromProne is a movement operation (costs half speed), not gated on incapacitation
    val t0 = FRESH_TURN  // effectiveSpeed: 30, movementRemaining: 30
    val t1 = pStandFromProne(t0)
    val movementConsumed = t1.movementRemaining < t0.movementRemaining
  
    assert(cannotAct and movementConsumed)
  }
  
  // Banishment as an escape route: creature standing (not prone) in demiplane returns standing — condition state is preserved on reappearance
  run qa_banishment_standing_return_not_prone = {
    // James banished: incapacitated + prone
    val jamesInDemiplane = freshCreature(20)
      .with("prone", true)
      .with("incapacitatedSources", Set(ISDirect))
  
    // In demiplane: spend movement to stand (half speed = 15ft of 30ft remaining)
    val t1 = pStandFromProne(FRESH_TURN)
    val standSucceeded = t1.movementRemaining < FRESH_TURN.movementRemaining
  
    // Standing removes prone; James remains incapacitated (banishment still active)
    val jamesStanding = pRemoveCondition(jamesInDemiplane, CProne)
    val stillIncap = isIncapacitated(jamesStanding)
  
    // Ally ends concentration — banishment ends, incapacitation source removed
    val jamesReturned = pRemoveCondition(jamesStanding, CIncapacitated)
  
    assert(
      standSucceeded
      and stillIncap
      and not(jamesReturned.prone)
      and not(isIncapacitated(jamesReturned))
    )
  }

  // Source: https://rpg.stackexchange.com/q/209282
  
  // Ring of Revivification: casting Revivify expends the caster's own 3rd-level spell slot
  run qa_revivify_ring_expends_3rd_level_slot = {
    val ss = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(3, 2))
      .with("slotsCurrent", EMPTY_SLOTS.set(3, 1))
    val ss1 = pExpendSlot(ss, 3)
    assert(ss1.slotsCurrent.get(3) == 0)
  }
  
  // Ring of Revivification: no 3rd-level slot means the ring cannot be used
  run qa_revivify_ring_blocked_when_no_3rd_slot = {
    assert(not(pCanCastAtLevel(FRESH_SPELL_SLOTS, 3, 3)))
  }
  
  // Ring of Revivification: a slot higher than 3rd still satisfies the requirement
  run qa_revivify_ring_higher_slot_qualifies = {
    val ss = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(4, 2))
      .with("slotsCurrent", EMPTY_SLOTS.set(4, 1))
    assert(pCanCastAtLevel(ss, 3, 4))
  }
  
  // Ring of Revivification: warlock pact slot of 3rd level qualifies (any spellcasting class)
  run qa_revivify_ring_warlock_pact_slot_eligible = {
    val ss = FRESH_SPELL_SLOTS
      .with("pactSlotsMax", 1)
      .with("pactSlotsCurrent", 1)
      .with("pactSlotLevel", 3)
    assert(pCanCastWithPactSlot(ss, 3))
  }
  
  // Ring of Revivification: it is Cast a Spell (not Use Magic Item), so a prior bonus-action spell blocks it
  run qa_revivify_ring_bonus_action_spell_blocks_cast = {
    val t = FRESH_TURN.with("bonusActionSpellCast", true)
    assert(not(canCastNonCantripAction(t)))
  }
  
  // Ring of Revivification: casting Revivify as an action marks it as a non-cantrip cast
  run qa_revivify_ring_action_marks_non_cantrip_spell = {
    val creature = freshCreature(20)
    val t1 = pUseAction(FRESH_TURN, creature, ACastSpell)
    val t2 = pMarkNonCantripActionSpell(t1)
    assert(t2.actionUsed and t2.nonCantripActionSpellCast)
  }
  
  // Ring of Revivification: spellcasting bonus uses the caster's own spellcasting ability
  run qa_revivify_ring_uses_own_spellcasting_ability = {
    // TEST_CONFIG: spellcastingAbility=Wis, Wis=13 -> mod=+1, level=5 -> profBonus=3 -> total=4
    val expected = abilityModifier(TEST_CONFIG.abilityScores.get(TEST_CONFIG.spellcastingAbility))
                   + proficiencyBonus(TEST_CONFIG.level)
    assert(spellcastingBonus(TEST_CONFIG) == expected)
  }

  // Source: https://rpg.stackexchange.com/q/135958
  
  // Does an Oni get new HP when it changes shape into a humanoid or large giant?
  run qa_change_shape_preserves_hp = {
    // Oni starts at 110 HP, takes 76 damage → 34 HP remaining
    val oni = freshCreature(110)
    val afterDamage = pTakeDamage(oni, 76, Slashing, Set(), Set(), Set(), false)
    // Change Shape: "Other than its size, its statistics are the same in each form"
    // HP is a statistic; no reset occurs — modeled as identity (spec has no HP-resetting shape-change function)
    val afterShapeChange = afterDamage
    assert(afterShapeChange.hp == 34)
  }

  // Source: https://rpg.stackexchange.com/q/215863
  
  // Can an attack action be broken up for other actions?
  run qa_bonus_action_between_attacks = {
    // Attack action taken (first attack done), extra attack still pending — bonus action is available
    val creature = freshCreature(20)
    val t = FRESH_TURN
      .with("actionUsed", true)
      .with("attackActionUsed", true)
      .with("extraAttacksRemaining", 1)
      .with("bonusActionUsed", false)
    val t1 = pUseBonusAction(t, creature)
    assert(t1.bonusActionUsed and t1.extraAttacksRemaining == 1)
  }
  
  // Can an attack action be broken up for other actions? (reaction between attacks)
  run qa_reaction_between_attacks = {
    // Reaction (e.g. Shield, Opportunity Attack trigger) available while Attack action is in progress
    val t = FRESH_TURN
      .with("actionUsed", true)
      .with("attackActionUsed", true)
      .with("extraAttacksRemaining", 1)
      .with("reactionAvailable", true)
    val t1 = pUseReaction(t)
    // Reaction consumed; extra attack still intact
    assert(not(t1.reactionAvailable) and t1.extraAttacksRemaining == 1)
  }
  
  // Can an attack action be broken up for other actions? (TWF Light-weapon bonus action after Attack action)
  run qa_twf_bonus_action_eligible_after_attack = {
    // PHB: TWF off-hand attack is a bonus action; timing is player's choice, so usable between extra attacks
    val creature = freshCreature(20)
    val t = FRESH_TURN
      .with("actionUsed", true)
      .with("attackActionUsed", true)
      .with("extraAttacksRemaining", 1)
      .with("bonusActionUsed", false)
    // Eligible for TWF bonus attack (attacks taken, bonus not yet used, not incapacitated)
    assert(pCanTwoWeaponFighting(t, creature))
  }
  
  // Can an attack action be broken up for other actions? (incapacitated blocks bonus action mid-attack)
  run qa_incapacitated_no_bonus_action_between_attacks = {
    // Anything that deprives you of actions also prevents bonus actions (PHB Bonus Action rule)
    val creature = freshCreature(20)
      .with("stunned", true)
      .with("incapacitatedSources", Set(ISStunned))
    val t = FRESH_TURN
      .with("actionUsed", true)
      .with("attackActionUsed", true)
      .with("extraAttacksRemaining", 1)
      .with("bonusActionUsed", false)
    val t1 = pUseBonusAction(t, creature)
    assert(not(t1.bonusActionUsed) and not(pCanTwoWeaponFighting(t, creature)))
  }

}
