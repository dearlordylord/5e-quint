  // Source: https://rpg.stackexchange.com/q/205110
  
  // Can an army of bards with lyres of building make a castle wall invulnerable?
  run qa_lyre_immunity_blocks_matched_damage_type = {
    // One Lyre reaction grants immunity to Bludgeoning: catapult hits deal 0 damage.
    val wall = freshCreature(100)
    val afterCatapult = pTakeDamage(wall, 30, Bludgeoning, Set(), Set(), Set(Bludgeoning), false)
    assert(afterCatapult.hp == 100)
  }
  
  // Can an army of bards with lyres of building make a castle wall invulnerable?
  run qa_lyre_combining_game_effects_blocks_stacked_immunity = {
    // Combining Game Effects: only one Lyre immunity applies per target at a time.
    // Wall immune to Bludgeoning (catapults) is still fully vulnerable to Piercing (ballista).
    val wall = freshCreature(100)
    val afterBallista = pTakeDamage(wall, 25, Piercing, Set(), Set(), Set(Bludgeoning), false)
    assert(afterBallista.hp == 75)
  }
  
  // Can an army of bards with lyres of building make a castle wall invulnerable?
  run qa_lyre_diversified_siege_bypasses_single_immunity = {
    // Enemy diversifies: even with Bludgeoning immunity active, Thunder and Force punch through.
    // No single Lyre reaction can cover all damage types simultaneously.
    val wall = freshCreature(100)
    val lyreImmunity = Set(Bludgeoning)
    val afterThunder  = pTakeDamage(wall, 20, Thunder, Set(), Set(), lyreImmunity, false)
    val afterForce    = pTakeDamage(wall, 15, Force,   Set(), Set(), lyreImmunity, false)
    assert(
      afterThunder.hp == 80
      and afterForce.hp == 85
    )
  }

  // Source: https://rpg.stackexchange.com/q/166863
  
  // Can a caster interrupt another caster from casting Time Stop by readying a Time Stop?
  // Accepted: Ready action consumes the action but NOT the reaction; reaction fires AFTER the trigger, not during cast
  run qa_ready_action_preserves_reaction = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, creature, AReady)
    assert(t1.actionUsed and t1.readiedAction and t1.reactionAvailable)
  }
  
  // Readied action fires AFTER trigger: reaction is a separate resource consumed post-trigger
  run qa_readied_reaction_fires_after_not_during = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, creature, AReady)  // Alice readies Time Stop on her turn
    // Bob's cast resolves fully (cannot be interrupted by readied action)
    // Only then does Alice's reaction fire
    val t2 = pUseReaction(t1)
    assert(t1.reactionAvailable and not(t2.reactionAvailable))
  }
  
  // Once the reaction is spent firing the readied action, it cannot fire a second time this round
  run qa_reaction_cannot_fire_twice_same_round = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseAction(t0, creature, AReady)
    val t2 = pUseReaction(t1)   // readied action fires (after trigger)
    val t3 = pUseReaction(t2)   // attempt second use — no-op, already spent
    assert(not(t2.reactionAvailable) and not(t3.reactionAvailable))
  }
  
  // Reaction resets at the start of the creature's own turn — after readied action fired, fresh reaction next round
  run qa_reaction_resets_at_turn_start = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val t1 = pUseReaction(t0)  // reaction spent firing the readied action
    val t2 = pStartTurn(TEST_CONFIG, creature, Unarmored, false, 0, false, false)
    assert(not(t1.reactionAvailable) and t2.reactionAvailable)
  }

  // Source: https://rpg.stackexchange.com/q/123553
  
  // How many times per rest cycle can a cleric cast their domain spells? And at what level are they cast?
  run qa_domain_spell_uses_slot = {
    // Domain spells consume regular spell slots — not free like cantrips
    val slots = EMPTY_SLOTS.set(1, 2)
    val ss = FRESH_SPELL_SLOTS.with("slotsMax", slots).with("slotsCurrent", slots)
    val ss1 = pExpendSlot(ss, 1)
    assert(ss1.slotsCurrent.get(1) == 1)
  }
  
  // Domain spell upcast: using a higher-level slot consumes that slot, not the spell's base slot
  run qa_domain_spell_upcast_uses_higher_slot = {
    val slots = EMPTY_SLOTS.set(1, 2).set(4, 1)
    val ss = FRESH_SPELL_SLOTS.with("slotsMax", slots).with("slotsCurrent", slots)
    // PHB: "if you use a higher-level slot to cast it, it will consume a slot of the level you used"
    val canUpcast = pCanCastAtLevel(ss, 1, 4)
    val ss1 = pExpendSlot(ss, 4)
    assert(canUpcast and ss1.slotsCurrent.get(4) == 0 and ss1.slotsCurrent.get(1) == 2)
  }
  
  // Domain spell slots are NOT restored on short rest — only on long rest
  run qa_domain_spells_restore_on_long_rest_only = {
    val slots = EMPTY_SLOTS.set(1, 2)
    val ss = FRESH_SPELL_SLOTS.with("slotsMax", slots).with("slotsCurrent", slots)
    val ss1 = pExpendSlot(ss, 1)
    val ssAfterShortRest = pRestorePactSlots(ss1)
    val ssAfterLongRest  = pRestoreAllSlots(ss1)
    assert(
      ssAfterShortRest.slotsCurrent.get(1) == 1 and
      ssAfterLongRest.slotsCurrent.get(1)  == 2
    )
  }

  // Source: https://rpg.stackexchange.com/q/206914
  
  // Can mundane light penetrate magical darkness to illuminate regions outside the dark space?
  run qa_magical_darkness_is_heavily_obscured = {
    // Darkness spell creates Dark illumination; Dark -> HeavilyObscured blocks vision entirely (PHB p.183)
    assert(pIlluminationObscurement(Dark) == HeavilyObscured)
  }
  
  // Mundane light (torch) outside darkness is unobscured; inside the darkness boundary it becomes Dark regardless
  run qa_mundane_light_does_not_penetrate_darkness = {
    // Torch in normal air: Bright -> Unobscured (illuminates normally)
    // Same torch entering magical darkness: area is Dark -> HeavilyObscured (light cannot penetrate through)
    assert(
      pIlluminationObscurement(Bright) == Unobscured and
      pIlluminationObscurement(Dark)   == HeavilyObscured
    )
  }
  
  // A creature standing inside magical darkness is effectively blinded by the heavily obscured area
  run qa_darkness_blinds_creatures_inside = {
    // HeavilyObscured blocks vision entirely; pBlindedByObscurement returns true for it
    assert(pBlindedByObscurement(pIlluminationObscurement(Dark)) == true)
  }
  
  // Darkvision does not fully overcome magical darkness (still lightly obscured, not unobscured)
  run qa_darkvision_still_impaired_in_magical_darkness = {
    // Without darkvision: Dark -> HeavilyObscured (blinded)
    // With darkvision: Dark -> LightlyObscured (still perceives disadvantage, not full vision)
    // Either way, light from inside does not illuminate outside the darkness boundary
    assert(
      pEffectiveObscurement(Dark, false) == HeavilyObscured and
      pEffectiveObscurement(Dark, true)  == LightlyObscured
    )
  }

  // Source: https://rpg.stackexchange.com/q/79814
  
  // What happens when allies occupy the same space? - ally space is difficult terrain (cost multiplier 2)
  run qa_ally_space_is_difficult_terrain = {
    // PHB p.191: "another creature's space is difficult terrain for you"
    // pMovementCost with isDifficultTerrain=true must return 2 (costs 1 extra foot per foot)
    val cost = pMovementCost(true, false, false, false, false)
    assert(cost == 2)
  }
  
  // What happens when allies occupy the same space? - entering ally space consumes double movement budget
  run qa_moving_through_ally_space_costs_double = {
    // Moving 5 feet through difficult terrain (ally's space) spends 10 feet from a 30-foot budget
    val t = pUseMovement(FRESH_TURN, 5, 2)
    assert(t.movementRemaining == 20)
  }
  
  // What happens when allies occupy the same space? - grappled creature gets speed 0, forced to stay
  run qa_grapple_arrests_creature_in_space = {
    // A readied grapple (AWins) applies CGrappled; grappled creatures have speed 0 on their turn
    // This models unwillingly ending a move in another creature's space
    val target = freshCreature(20)
    val result = pGrapple(Medium, Medium, target, AWins, true)
    val t = pStartTurn(TEST_CONFIG, result.targetState, Unarmored, false, 0, false, false)
    assert(result.success and result.targetState.grappled and t.movementRemaining == 0)
  }
  
  // What happens when allies occupy the same space? - grapple on ally (size-eligible) succeeds on AWins
  run qa_ally_grapple_succeeds_same_size = {
    // "You can grapple your ally, providing they're unwilling, as grapple is a contest"
    // Same-size grapple with a free hand and AWins result applies CGrappled
    val ally = freshCreature(20)
    val result = pGrapple(Medium, Medium, ally, AWins, true)
    assert(result.success and result.targetState.grappled)
  }
  
  // What happens when allies occupy the same space? - difficult terrain stacks with other penalties (crawling)
  run qa_ally_space_plus_crawling_costs_triple = {
    // Crawling through difficult terrain (ally's space while prone): 1 + 1 (difficult) + 1 (crawl) = 3
    val cost = pMovementCost(true, true, false, false, false)
    assert(cost == 3)
  }

  // When readying an action to cast a spell from a magic item, do you have to maintain concentration as though you were readying the Cast a Spell action?
  run qa_ready_magic_item_no_forced_concentration = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    val ss0 = FRESH_SPELL_SLOTS
  
    // Take the Ready action, modelling readying a magic item activation (not Cast a Spell)
    val t1 = pUseAction(t0, creature, AReady)
  
    // Ruling: readying a magic item does NOT require concentration to hold the energy;
    // concentration requirement only applies when specifically readying the Cast a Spell action.
    // pUseAction(AReady) marks the readied action but never starts concentration.
    assert(
      t1.readiedAction == true
      and t1.actionUsed == true
      and ss0.concentrationSpellId == ""
      and not(isConcentrating(ss0))
    )
  }

  // Source: https://rpg.stackexchange.com/q/205363
  
  // Does the damage from Hexblade's Curse apply to attacks from summons?
  run qa_hexblade_curse_summon_no_profbonus = {
    // Accepted answer: "You gain a bonus to damage rolls" — the warlock's own rolls only.
    // Summoned creatures make their OWN damage rolls; the curse bonus does not transfer.
    val warlockLevel = 5
    val profBonus = proficiencyBonus(warlockLevel) // 3 at level 5
    val roll = 6
    val warlockMod = 3
    val summonMod = 2
    // Warlock attacks the cursed target: proficiency bonus (curse bonus) is included
    val warlockDmg = normalDamage(roll, warlockMod + profBonus)
    // Summoned creature attacks the cursed target: only its own modifier applies
    val summonDmg = normalDamage(roll, summonMod)
    assert(
      // Summoned creature's damage is exactly roll + its own mod — no curse bonus
      summonDmg == roll + summonMod
      // Warlock's own damage roll correctly includes the curse's proficiency bonus
      and warlockDmg == roll + warlockMod + profBonus
      // The curse bonus is NOT "passed through" to the summoned creature's roll
      and summonDmg != normalDamage(roll, summonMod + profBonus)
    )
  }

  // Source: https://rpg.stackexchange.com/q/56631
  
  // Would Shriekers prevent someone from hearing Harpies?
  run qa_shrieker_no_deafened_means_can_hear_harpy = {
    // Shriekers don't impose CDeafened; a creature not deafened has no auto-fail
    // on hearing-required checks, so Harpy Luring Song can still affect them.
    val creature = freshCreature(20)
    val mods = pCheckModifiers(creature, false, true, false)
    assert(not(mods.autoFail))
  }
  
  // Would Shriekers prevent someone from hearing Harpies? (contrast: deafened does block)
  run qa_deafened_condition_blocks_hearing_based_checks = {
    // Only CDeafened causes auto-fail on hearing-required checks — not loud noises alone.
    val creature = pApplyCondition(freshCreature(20), CDeafened)
    val mods = pCheckModifiers(creature, false, true, false)
    assert(mods.autoFail)
  }

  // Source: https://rpg.stackexchange.com/q/97230
  
  // Can a Wildshaped druid ride a mount?
  run qa_wildshaped_druid_can_ride_mount = {
    // Black Bear (Large, wildshaped druid) riding an Elephant (Huge):
    // mount must be at least one size category larger than the rider
    val riderSize = Large  // druid wildshaped as Black Bear
    val mountSize = Huge   // Elephant
    assert(sizeOrd(mountSize) >= sizeOrd(riderSize) + 1)
  }

  // Source: https://rpg.stackexchange.com/q/134751
  
  // Does radiant damage work in magical darkness?
  // Darkness spell grants no immunity/resistance to radiant; creature takes full damage
  run qa_radiant_damage_in_magical_darkness = {
    val creature = freshCreature(20)
    // Magical darkness provides no radiant immunity, resistance, or vulnerability
    val damaged = pTakeDamage(creature, 10, Radiant, Set(), Set(), Set(), false)
    assert(damaged.hp == 10)
  }
  
  // Does radiant damage work in magical darkness? — damage modifier layer
  // applyDamageModifiers with no darkness-derived sets leaves radiant damage unchanged
  run qa_radiant_no_darkness_modifier = {
    val result = applyDamageModifiers(12, Radiant, Set(), Set(), Set())
    assert(result == 12)
  }

  // Source: https://rpg.stackexchange.com/q/103539
  
  // What is the difference between an Arcane Focus and a Component Pouch?
  run qa_component_somatic_requires_free_hand = {
    val c = freshCreature(10)
    // PHB: "A spellcaster must have a hand free to access material components or to hold a focus"
    assert(
      pCanProvideComponents(c, false, true, false) == false
      and pCanProvideComponents(c, false, true, true) == true
    )
  }
  
  // What is the difference between an Arcane Focus and a Component Pouch?
  run qa_component_same_hand_for_somatic_and_material = {
    val c = freshCreature(10)
    // PHB: the hand for material/focus "can be the same hand used to perform somatic components"
    // One free hand satisfies both S and M simultaneously — no second hand needed
    assert(pCanProvideComponents(c, false, true, true) == true)
  }
  
  // What is the difference between an Arcane Focus and a Component Pouch?
  run qa_component_verbal_requires_speech = {
    val c = freshCreature(10)
    val paralyzed = pApplyCondition(c, CParalyzed)
    val petrified  = pApplyCondition(c, CPetrified)
    // Paralyzed/petrified creatures cannot speak, so cannot supply verbal components
    assert(
      pCanProvideComponents(paralyzed, true, false, true) == false
      and pCanProvideComponents(petrified, true, false, true) == false
      and pCanProvideComponents(c, true, false, true) == true
    )
  }
  
  // What is the difference between an Arcane Focus and a Component Pouch?
  run qa_component_unconscious_no_verbal = {
    val c = freshCreature(10)
    val unconscious = pApplyCondition(c, CUnconscious)
    // Unconscious creature cannot speak → verbal component impossible
    assert(pCanProvideComponents(unconscious, true, false, true) == false)
  }
  
  // What is the difference between an Arcane Focus and a Component Pouch?
  run qa_component_no_requirements_always_satisfiable = {
    val c = freshCreature(10)
    val paralyzed = pApplyCondition(c, CParalyzed)
    // If a spell has no V/S components (e.g. pure M only, caller-validated),
    // neither speech nor hand restrictions block casting at this layer
    assert(
      pCanProvideComponents(paralyzed, false, false, false) == true
      and pCanProvideComponents(c, false, false, false) == true
    )
  }

  // Source: https://rpg.stackexchange.com/q/129161
  
  // Do attacks from Bag of Tricks creatures count as magical?
  run qa_bag_of_tricks_attack_is_nonmagical = {
    // Giant Boar summoned by Bag of Tricks is not a magic item; its Tusk
    // (slashing) attack is nonmagical. Ghost's resistance to nonmagical
    // slashing therefore applies and halves the damage.
    val ghost = freshCreature(45)
    val rawDamage = 10  // pre-resolved 2d6+3 tusk damage
    // Nonmagical attack: Ghost's slashing resistance applies (Set(Slashing))
    val ghostAfter = pTakeDamage(ghost, rawDamage, Slashing, Set(Slashing), Set(), Set(), false)
    assert(ghostAfter.hp == 40)  // 45 - (10 / 2) = 40; resistance halves nonmagical slashing
  }

  // Source: https://rpg.stackexchange.com/q/193534
  
  // Are Arcane Grimoires destructible? — magic items have resistance to all damage (DMG p.141 Magic Item Resilience)
  run qa_magic_item_resistance_all_damage = {
    val creature = freshCreature(20)
    // Magic item resilience: resistance to ALL damage types
    val afterFire     = pTakeDamage(creature, 10, Fire,     ALL_DAMAGE_TYPES, Set(), Set(), false)
    val afterCold     = pTakeDamage(creature, 10, Cold,     ALL_DAMAGE_TYPES, Set(), Set(), false)
    val afterSlashing = pTakeDamage(creature, 10, Slashing, ALL_DAMAGE_TYPES, Set(), Set(), false)
    // Resistance halves: floor(10/2)=5 damage each → 20-5=15 HP
    assert(afterFire.hp == 15 and afterCold.hp == 15 and afterSlashing.hp == 15)
  }
  
  // Are Arcane Grimoires destructible? — magic item resistance does not grant immunity; sufficient damage destroys it
  run qa_magic_item_still_destructible = {
    val creature = freshCreature(10)
    // 30 fire damage with resistance → floor(30/2)=15 > 10 HP: item reaches 0
    val afterDamage = pTakeDamage(creature, 30, Fire, ALL_DAMAGE_TYPES, Set(), Set(), false)
    assert(afterDamage.hp == 0)
  }
  
  // Are Arcane Grimoires destructible? — without magic item resilience, a normal spellbook takes full damage
  run qa_nonmagic_spellbook_takes_full_damage = {
    val creature = freshCreature(20)
    // No resistance (non-magic item): 10 fire → full 10 damage
    val afterDamage = pTakeDamage(creature, 10, Fire, Set(), Set(), Set(), false)
    assert(afterDamage.hp == 10)
  }

  // Source: https://rpg.stackexchange.com/q/75736
  
  // Can a Half-Elf pass for a Full Human, or a Full Elf, using a disguise kit?
  // Easy disguise (similar race, e.g. half-elf → elf): deceiver gets advantage on Deception vs Perception contest
  run qa_disguise_easy_similar_race_deceiver_advantage = {
    val chaMod = abilityModifier(14)           // CHA 14 → +2
    val pb     = proficiencyBonus(3)           // level 3 → +2
    val adv    = resolveAdvantage({ hasAdvantage: true, hasDisadvantage: false })
    val d1 = 7
    val d2 = 14
    // Advantage: take higher of two pre-resolved d20s
    val deceiverRoll  = if (adv.hasAdvantage) intMax(d1, d2) else intMin(d1, d2) // 14
    val deceiverTotal = deceiverRoll + chaMod + pb             // 14+2+2 = 18
    // Inspector: active Perception, WIS 12 → +1, no proficiency
    val inspectorTotal = 12 + abilityModifier(12)              // 12+1 = 13
    assert(contestWinner(deceiverTotal, inspectorTotal) == AWins)
  }
  
  // Hard disguise (very different race, e.g. half-elf → tiefling with horns/tail): deceiver has disadvantage
  run qa_disguise_hard_different_race_deceiver_disadvantage = {
    val chaMod  = abilityModifier(14)
    val pb      = proficiencyBonus(3)
    val disadv  = resolveAdvantage({ hasAdvantage: false, hasDisadvantage: true })
    val d1 = 15
    val d2 = 6
    // Disadvantage: take lower of two pre-resolved d20s
    val deceiverRoll  = if (disadv.hasDisadvantage) intMin(d1, d2) else intMax(d1, d2) // 6
    val deceiverTotal = deceiverRoll + chaMod + pb             // 6+2+2 = 10
    // Inspector straight roll, same WIS
    val inspectorTotal = 11 + abilityModifier(12)              // 11+1 = 12
    assert(contestWinner(deceiverTotal, inspectorTotal) == BWins)
  }

  // Source: https://rpg.stackexchange.com/q/213420
  
  // Is Wild Shape affected by Moonbeam? (2024 rules: Wild Shape is shape-shifting; failed Con save deals Radiant damage)
  run qa_moonbeam_wild_shape_radiant_damage = {
    // Druid in Wild Shape treated as a creature subject to Moonbeam's Con save
    val druidInWildShape = freshCreature(30)
    // Pre-resolved 2d10 Radiant = 14
    val moonbeamDamage = 14
    // Druid caster level 5, Wis 16 (mod +3): DC = 8 + 3 + 3 = 14
    val moonbeamDC = 14
    // Wild Shape form has Con 12 (mod +1); d20 roll 7 → total 8 < 14 → fails
    val conMod = 1
    val d20roll = 7
    val saveFailed = not(saveSucceeds(d20roll, conMod, false, 0, 0, moonbeamDC))
    val s1 = pTakeDamage(druidInWildShape, moonbeamDamage, Radiant, Set(), Set(), Set(), false)
    assert(saveFailed and s1.hp == 30 - 14)
  }
  
  // Is Wild Shape affected by Moonbeam? — successful save means no damage taken
  run qa_moonbeam_wild_shape_save_succeeds_no_damage = {
    val druidInWildShape = freshCreature(30)
    val moonbeamDC = 14
    val conMod = 1
    // d20 roll 15 → total 16 >= 14 → save succeeds, no damage
    val d20roll = 15
    val saveSucceeded = saveSucceeds(d20roll, conMod, false, 0, 0, moonbeamDC)
    // On a successful save Moonbeam deals no damage; HP unchanged
    assert(saveSucceeded and druidInWildShape.hp == 30)
  }

  // Source: https://rpg.stackexchange.com/q/149531
  
  // Does a warship make a Constitution saving throw against Shatter, or does it automatically take the damage?
  run qa_shatter_object_auto_damage_no_save = {
    // Non-creature objects (ship components) automatically take full thunder damage - no save allowed
    val shatterDamage = 18 // 3d8 thunder, e.g. 6+6+6
    val objectDamage = applyDamageModifiers(shatterDamage, Thunder, Set(), Set(), Set())
    assert(objectDamage == shatterDamage)
  }
  
  // Does a warship make a Constitution saving throw against Shatter, or does it automatically take the damage?
  run qa_shatter_creature_fails_save_full_damage = {
    // Creature that fails CON save (DC 13) takes full 3d8 thunder damage
    val shatterDamage = 18
    val saveRoll = 4
    val conMod = 1
    val profBonus = 2
    val dc = 13
    val saved = saveSucceeds(saveRoll, conMod, false, profBonus, 0, dc)
    val damageDealt = if (saved) shatterDamage / 2 else shatterDamage
    assert(not(saved) and damageDealt == 18)
  }
  
  // Does a warship make a Constitution saving throw against Shatter, or does it automatically take the damage?
  run qa_shatter_creature_passes_save_half_damage = {
    // Creature that succeeds CON save (DC 13) takes half of 3d8 thunder damage
    val shatterDamage = 18
    val saveRoll = 15
    val conMod = 1
    val profBonus = 2
    val dc = 13
    val saved = saveSucceeds(saveRoll, conMod, false, profBonus, 0, dc)
    val damageDealt = if (saved) shatterDamage / 2 else shatterDamage
    assert(saved and damageDealt == 9)
  }
  
  // Does a warship make a Constitution saving throw against Shatter, or does it automatically take the damage?
  run qa_shatter_component_threshold_exceeded_takes_damage = {
    // Ship component with damage threshold 10: 3d8=15 thunder exceeds threshold -> full damage lands
    val shatterDamage = 15
    val threshold = 10
    // Threshold exceeded: component is NOT immune; damage applies normally
    val effectiveDamage = if (shatterDamage >= threshold)
      applyDamageModifiers(shatterDamage, Thunder, Set(), Set(), Set())
    else
      applyDamageModifiers(shatterDamage, Thunder, Set(Thunder), Set(), Set())
    assert(effectiveDamage == 15)
  }
  
  // Does a warship make a Constitution saving throw against Shatter, or does it automatically take the damage?
  run qa_shatter_component_threshold_not_exceeded_immune = {
    // Ship component with damage threshold 10: 3d8=7 thunder below threshold -> component is immune, 0 damage
    val shatterDamage = 7
    val threshold = 10
    val effectiveDamage = if (shatterDamage >= threshold)
      applyDamageModifiers(shatterDamage, Thunder, Set(), Set(), Set())
    else
      applyDamageModifiers(shatterDamage, Thunder, Set(Thunder), Set(), Set())
    assert(effectiveDamage == 0)
  }

  // Source: https://rpg.stackexchange.com/q/158304
  
  // Can you use a Tentacle Rod to make Opportunity Attacks?
  // OA is a reaction; using it does not consume an action, so action-requiring items (like the Rod) cannot be activated
  run qa_opportunity_attack_uses_reaction_not_action = {
    val t0 = FRESH_TURN
    val t1 = pUseReaction(t0)
    assert(
      // Reaction is spent — OA was taken
      t1.reactionAvailable == false
      // Action is NOT consumed — OA never grants an action
      and t1.actionUsed == false
      // Attack action not triggered either — no attackActionUsed-gated abilities become available
      and t1.attackActionUsed == false
    )
  }
  
  // Can you use a Tentacle Rod to make Opportunity Attacks? (grapple/shove analog from Sage Advice)
  // Grapple/shove require the Attack action; TWF shares the same attackActionUsed gate — both unavailable after OA (reaction-only)
  run qa_opp_attack_no_attack_action_grapple_analog = {
    val creature = freshCreature(20)
    val t0 = FRESH_TURN
    // Opportunity attack: spend reaction only
    val t_oa = pUseReaction(t0)
    // TWF requires attackActionUsed=true; after OA (reaction only), attackActionUsed is still false
    assert(pCanTwoWeaponFighting(t_oa, creature) == false)
  }

  // Source: https://rpg.stackexchange.com/q/125121
  
  // Can Locate Object find a specific instance of a common object?
  // Locate Object targets either a specific seen object OR nearest of a kind — spellcasting bonus/DC are unaffected by target specificity
  run qa_locate_object_spell_attack_bonus_unaffected_by_target_type = {
    // Locate Object is a spell — its casting mechanics (attack bonus, save DC)
    // depend only on the caster's spellcasting ability, level, and proficiency,
    // not on whether targeting a specific object vs. nearest of a kind.
    val config: CharConfig = {
      abilityScores: Map(Str -> 10, Dex -> 10, Con -> 10, Int_ -> 10, Wis -> 18, Cha -> 10),
      level: 5,
      size: Medium,
      speeds: Map(Walk -> 30, Fly -> 0, Swim -> 0, Climb -> 0, Burrow -> 0),
      saveProficiencies: Set(Wis),
      skillProficiencies: Set(),
      expertiseSkills: Set(),
      armorProficiencies: Set(),
      hitDieType: 8,
      spellcastingAbility: Wis,
      hasSpellcasting: true,
      canRitualCast: true,
      unarmoredDefense: NoUnarmoredDefense,
      features: Set(),
    }
    // WIS 18 => mod +4; profBonus at level 5 => (5-1)/4 + 2 = 3; spellcastingBonus = 4+3 = 7
    val expectedBonus = 7
    val expectedDC = 8 + expectedBonus // 15
    // Whether locating a specific gold coin (seen before) or nearest gold coin of a kind,
    // the spell attack bonus and save DC are identical — only caster stats matter.
    val bonusSpecificObject = spellAttackBonus(config)
    val bonusNearestOfKind  = spellAttackBonus(config)
    val dcSpecificObject    = spellSaveDC(config)
    val dcNearestOfKind     = spellSaveDC(config)
    assert(
      bonusSpecificObject == expectedBonus
      and bonusNearestOfKind == expectedBonus
      and bonusSpecificObject == bonusNearestOfKind
      and dcSpecificObject == expectedDC
      and dcNearestOfKind == expectedDC
      and dcSpecificObject == dcNearestOfKind
    )
  }

  // Source: https://rpg.stackexchange.com/q/111308
  
  // SKIP: Arcane Archer / Arcane Shot is XGtE content; the spec models PHB mechanics only and has no types or functions for archetype features, ammunition magic properties, or Arcane Shot eligibility checks.

  // Source: https://rpg.stackexchange.com/q/181050
  
  // Can there be portals in the Astral Plane that lead to the Elemental Planes?
  // SKIP: This Q&A concerns planar cosmology and travel routes (Astral/Ethereal/Elemental plane connectivity), which are narrative/setting rules with no mechanical encoding in the spec's combat, condition, HP, spell slot, or turn-structure functions.

  // Source: https://rpg.stackexchange.com/q/178243
  
  // Does the Psi Warrior's Psionic Strike ability prompt a second Concentration save?
  // Accepted answer: Psionic Strike is a separate damage source, requiring its own concentration check.
  run qa_psionic_strike_two_concentration_checks = {
    // Caster is concentrating on a spell
    val slots = FRESH_SPELL_SLOTS.with("concentrationSpellId", "bless")
  
    // First check: weapon attack damage — save passes (roll 15, CON mod +2, DC 10)
    val dc1 = pConcentrationDC(10) // max(10, 5) = 10
    val conSave1 = saveSucceeds(15, 2, false, 0, 0, dc1) // true
    val afterWeaponCheck = pConcentrationCheck(slots, conSave1)
  
    // Second check: psionic strike force damage (separate source) — save fails (roll 5, CON mod +2, DC 10)
    val dc2 = pConcentrationDC(8) // max(10, 4) = 10
    val conSave2 = saveSucceeds(5, 2, false, 0, 0, dc2) // false
    val afterPsionicCheck = pConcentrationCheck(afterWeaponCheck, conSave2)
  
    assert(
      // After passing first check, still concentrating
      isConcentrating(afterWeaponCheck)
      // After failing second (separate source) check, concentration is broken
      and not(isConcentrating(afterPsionicCheck))
    )
  }
  
  // Each damage source gets its own DC — not combined into one roll
  run qa_psionic_strike_independent_concentration_dc = {
    // Weapon deals 20 damage, psionic deals 8 damage
    val weaponDmg   = 20  // DC = max(10, 10) = 10
    val psionicDmg  = 8   // DC = max(10,  4) = 10
    val combinedDmg = weaponDmg + psionicDmg // DC = max(10, 14) = 14 (wrong single-source approach)
  
    val dcWeapon   = pConcentrationDC(weaponDmg)
    val dcPsionic  = pConcentrationDC(psionicDmg)
    val dcCombined = pConcentrationDC(combinedDmg)
  
    assert(
      // Two separate DCs at 10 each (two checks at the lower threshold)
      dcWeapon  == 10
      and dcPsionic  == 10
      // Single combined check would impose a harder DC — incorrect per accepted answer
      and dcCombined == 14
      and dcCombined > dcWeapon
      and dcCombined > dcPsionic
    )
  }

  // Source: https://rpg.stackexchange.com/q/162817
  
  // Does Healing Restore Blood? — HP is an abstraction (physical + mental + luck), not literal blood volume; healing restores the abstraction
  run qa_heal_restores_hp_agnostic_of_damage_cause = {
    // Psychic damage causes no blood loss yet still reduces HP; healing restores it identically
    val c = freshCreature(20)
    val afterPsychic = pTakeDamage(c, 12, Psychic, Set(), Set(), Set(), false)
    val afterHeal    = pHeal(afterPsychic, 12)
    assert(afterHeal.hp == 20)
  }
  
  // Does Healing Restore Blood? — accepted answer recommends exhaustion to model anemia; exhaustion 1 gives disadvantage on ability checks (weakness/fatigue)
  run qa_exhaustion_1_disadv_on_checks = {
    val c    = freshCreature(20).with("exhaustion", 1)
    val mods = pCheckModifiers(c, false, false, false)
    assert(mods.hasDisadvantage)
  }
  
  // Does Healing Restore Blood? — exhaustion 2 halves speed (shortness of breath / reduced exertion)
  run qa_exhaustion_2_halves_speed = {
    val c = freshCreature(20).with("exhaustion", 2)
    val t = pStartTurn(TEST_CONFIG, c, Unarmored, false, 0, false, false)
    assert(t.effectiveSpeed == 15)
  }
  
  // Does Healing Restore Blood? — exhaustion 4 halves hit point maximum (severe anemia / cardiac compensation)
  run qa_exhaustion_4_halves_max_hp = {
    val c = freshCreature(20).with("exhaustion", 4)
    assert(effectiveMaxHp(c) == 10)
  }

  // Source: https://rpg.stackexchange.com/q/96028
  
  // Beating invisibility: invisible attacker (target can't see them) gets advantage on attack rolls (PHB p.194-195)
  run qa_invisible_attacker_has_advantage = {
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
      attackerFrightened: false,
      attackerFrightSourceInLOS: false,
      attackerExhaustion: 0,
      targetBlinded: false,
      targetParalyzed: false,
      targetPetrified: false,
      targetStunned: false,
      targetUnconscious: false,
      targetRestrained: false,
      targetProne: false,
      attackerWithin5ft: true,
      targetDodging: false,
      targetCanSeeAttacker: false,  // target cannot see the invisible boss
      attackerCanSeeTarget: true,
      isRangedAttack: false,
      beyondNormalRange: false,
      hostileWithin5ft: false,
      isHeavyWeapon: false,
      wielderSizeSmallOrTiny: false,
      squeezing: false,
      underwater: false,
      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(mods.hasAdvantage and not(mods.hasDisadvantage))
  }
  
  // Beating invisibility: PC attacking invisible boss (can't see target) has disadvantage (PHB p.194-195)
  run qa_attacking_invisible_target_has_disadvantage = {
    val ctx: AttackContext = {
      attackerBlinded: false,
      attackerProne: false,
      attackerRestrained: false,
      attackerPoisoned: false,
