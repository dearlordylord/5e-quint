      attackerHasSwimSpeed: false,
      isUnderwaterMeleeException: false,
      isUnderwaterRangedException: false,
    }
    val mods = pAggregateAttackMods(ctx)
    assert(not(mods.hasAdvantage) and not(mods.hasDisadvantage))
  }

  // Source: https://rpg.stackexchange.com/q/114707
  
  // Does a wand lose a charge if it attempts to target an invalid target?
  // Accepted answer: the charge is expended — spending the resource and casting are the same action.
  // Modeled here via the spell slot analog: pExpendSlot consumes the slot regardless of target state.
  run qa_wand_charge_expended_on_invalid_target = {
    // Set up one first-level slot (proxy for one wand charge)
    val slots = FRESH_SPELL_SLOTS
      .with("slotsMax", EMPTY_SLOTS.set(1, 1))
      .with("slotsCurrent", EMPTY_SLOTS.set(1, 1))
    // The "invalid target" creature: state is entirely unaffected by the spell
    val creature = freshCreature(20)
    // Cast the spell (expend the charge/slot) — target validity does not gate resource expenditure
    val afterCast = pExpendSlot(slots, 1)
    // Charge is spent (slot count drops to 0) even though nothing happened to the creature
    assert(afterCast.slotsCurrent.get(1) == 0 and creature.hp == 20)
  }

  // Source: https://rpg.stackexchange.com/q/170259
  
  // Can someone use a Readied Help action between multiple attacks?
  run qa_ready_action_uses_action_keeps_reaction = {
    // Ready action costs action slot and sets readiedAction; reaction stays available for when trigger fires
    val helper = freshCreature(20)
    val t = FRESH_TURN
    val t1 = pUseAction(t, helper, AReady)
    assert(t1.actionUsed and t1.readiedAction and t1.reactionAvailable)
  }
  
  // Can someone use a Readied Help action between multiple attacks?
  run qa_ready_help_reaction_expended_when_triggered = {
    // When trigger fires (after ally's first attack), helper expends reaction to deliver Help
    val helper = freshCreature(20)
    val t = FRESH_TURN
    val t1 = pUseAction(t, helper, AReady)
    // trigger fires → reaction used
    val t2 = pUseReaction(t1)
    assert(t1.reactionAvailable and not(t2.reactionAvailable) and t2.readiedAction)
  }
  
  // Can someone use a Readied Help action between multiple attacks?
  run qa_extra_attack_slot_available_for_help_benefiting_second_attack = {
    // Ally with Extra Attack still has extra attack slot after first attack action;
    // the readied Help fires in between, granting advantage on this second attack
    val ally = freshCreature(20)
    val t = FRESH_TURN   // extraAttacksRemaining = 1 (FExtraAttack)
    val t1 = pUseAction(t, ally, AAttack)
    // first attack made; Help reaction fires here (modeled separately above)
    val t2 = pUseExtraAttack(t1)
    assert(t1.extraAttacksRemaining == 1 and t2.extraAttacksRemaining == 0)
  }
  
  // Can someone use a Readied Help action between multiple attacks?
  run qa_readied_help_full_sequence_ready_attack_react_extra_attack = {
    // Full sequence: helper readies, ally takes Attack action, help reaction fires,
    // ally still has extra attack slot for second swing with advantage
    val helper = freshCreature(20)
    val ally = freshCreature(20)
    // Helper's turn: ready Help
    val helperTurn = FRESH_TURN
    val helperT1 = pUseAction(helperTurn, helper, AReady)
    // Ally's turn: Attack action (first attack)
    val allyTurn = FRESH_TURN
    val allyT1 = pUseAction(allyTurn, ally, AAttack)
    // Trigger fires: helper's reaction expended to Help
    val helperT2 = pUseReaction(helperT1)
    // Ally makes second attack (benefiting from Help advantage)
    val allyT2 = pUseExtraAttack(allyT1)
    assert(
      helperT1.readiedAction
      and not(helperT2.reactionAvailable)
      and allyT1.extraAttacksRemaining == 1
      and allyT2.extraAttacksRemaining == 0
    )
  }

  // Source: https://rpg.stackexchange.com/q/207165
  
  // How can I learn wizard spells as a warlock without multiclassing?
  // Magic Initiate feat: grants one 1st-level spell use restored only on long rest
  run qa_magic_initiate_spell_restored_on_long_rest = {
    val ss = {
      slotsMax: EMPTY_SLOTS.set(1, 1),
      slotsCurrent: EMPTY_SLOTS.set(1, 1),
      pactSlotsMax: 0, pactSlotsCurrent: 0, pactSlotLevel: 0,
      concentrationSpellId: "",
    }
    val afterCast = pExpendSlot(ss, 1)
    val afterLongRest = pRestoreAllSlots(afterCast)
    assert(
      not(pCanCastAtLevel(afterCast, 1, 1))
      and pCanCastAtLevel(afterLongRest, 1, 1)
    )
  }
  
  // How can I learn wizard spells as a warlock without multiclassing?
  // Warlock pact slots (short rest) vs Magic Initiate regular slot (long rest only)
  run qa_warlock_pact_short_rest_magic_initiate_long_rest = {
    // Both exhausted: pact slot and the one regular level-1 slot from Magic Initiate
    val ss = {
      slotsMax: EMPTY_SLOTS.set(1, 1),
      slotsCurrent: EMPTY_SLOTS,
      pactSlotsMax: 1, pactSlotsCurrent: 0, pactSlotLevel: 1,
      concentrationSpellId: "",
    }
    val afterShortRest = pRestorePactSlots(ss)
    val afterLongRest  = pRestoreAllSlots(ss)
    assert(
      // Short rest restores pact slot but NOT Magic Initiate's regular slot
      afterShortRest.pactSlotsCurrent == 1
      and afterShortRest.slotsCurrent.get(1) == 0
      // Long rest restores both
      and afterLongRest.pactSlotsCurrent == 1
      and afterLongRest.slotsCurrent.get(1) == 1
    )
  }
  
  // How can I learn wizard spells as a warlock without multiclassing?
  // Book of Ancient Secrets: can inscribe ritual spells of level <= floor(warlock_level / 2)
  run qa_book_of_ancient_secrets_half_level_gate = {
    // Level-3 warlock: floor(3/2) = 1, so only 1st-level rituals are inscribable
    val warlockLevel3MaxRitual = 3 / 2  // = 1
    // Level-5 warlock: floor(5/2) = 2
    val warlockLevel5MaxRitual = 5 / 2  // = 2
    val floatingDiskLevel = 1  // Floating Disk is a 1st-level ritual
    val web2ndLevel = 2        // hypothetical 2nd-level ritual
    assert(
      // Floating Disk learnable at level 3
      floatingDiskLevel <= warlockLevel3MaxRitual
      // 2nd-level ritual NOT learnable at level 3, but IS at level 5
      and not(web2ndLevel <= warlockLevel3MaxRitual)
      and web2ndLevel <= warlockLevel5MaxRitual
    )
  }
  
  // How can I learn wizard spells as a warlock without multiclassing?
  // Ritual Caster feat / Pact of Tome + Book of Ancient Secrets sets canRitualCast = true
  run qa_ritual_caster_feat_enables_can_ritual_cast = {
    val configWithoutRitual = TEST_CONFIG.with("canRitualCast", false)
    val configWithRitual    = TEST_CONFIG.with("canRitualCast", true)
    assert(not(configWithoutRitual.canRitualCast) and configWithRitual.canRitualCast)
  }

