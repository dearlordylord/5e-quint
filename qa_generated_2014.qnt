  // Can a Druid take a short rest while in wildshape form?
  run qa_druid_short_rest_while_wildshaped = {
    // Rule: nothing prevents short-resting while wildshaped; beast-form Hit Dice
    // may be spent to regain HP exactly as normal short-rest mechanics dictate.
    val beastForm = freshCreature(20).with("hp", 8).with("hitDiceRemaining", 3)
    // CON mod +2; roll a 6 on the hit die — heals 6 + 2 = 8 HP
    val afterRest = pShortRest(beastForm, 2, [6])
    assert(
      afterRest.hp == 16               // 8 + 8 = 16, within maxHp 20
      and afterRest.hitDiceRemaining == 2  // one hit die spent
      and afterRest.hp <= afterRest.maxHp  // never exceeds max
    )
  }

  // Source: https://rpg.stackexchange.com/q/167382
  
  // Can goblin food of poor quality cause some sort of damage?
  // PHB p.158: poor lifestyle food is sufficient but unpleasant — no poison, damage, or disease mechanics;
  // only squalid/wretched quality triggers disease. Poor quality food counts as eating.
  run qa_poor_quality_food_no_mechanical_effect = {
    val c = freshCreature(20)
    // Poor quality food satisfies the daily food requirement (hasEaten = true).
    // It does NOT apply CPoisoned, deal damage, or cause exhaustion.
    val afterRest = pLongRest(c, 5, true)
    assert(
      afterRest.hp == 20         and  // full HP restored — food caused no damage
      not(afterRest.poisoned)    and  // no poison condition from eating poor quality food
      afterRest.exhaustion == 0  and  // no exhaustion (starvation threshold not crossed)
      not(afterRest.dead)
    )
  }
  
  // Poor quality food vs. no food: only skipping meals triggers starvation exhaustion
  run qa_poor_quality_food_vs_starvation = {
    val c = freshCreature(20)
    // Eating poor quality food: exhaustion unchanged
    val afterEating = pLongRest(c, 5, true)
    // NOT eating at all: starvation exhaustion applies after threshold (modeled as pApplyStarvation)
    val afterStarving = pApplyStarvation(c)
    assert(
      afterEating.exhaustion == 0   and  // poor quality food → no exhaustion
      afterStarving.exhaustion == 1      // skipping food → exhaustion level added
    )
  }

  // Source: https://rpg.stackexchange.com/q/67649
  
  // Do any fighting styles affect an unarmed strike?
  run qa_fighting_styles_no_benefit_to_unarmed = {
      // STR 14 -> modifier +2; unarmed = 1 + strMod with no Fighting Style bonus
      val strMod2 = abilityModifier(14)
      // STR 8 -> modifier -1; unarmed floors at 0 (intMax), still no style bonus
      val strModNeg = abilityModifier(8)
      assert(
          // Dueling, GWF, TWF, Archery: none apply — result is exactly 1 + strMod, no extra modifier
          unarmedDamage(strMod2) == 1 + strMod2
          and unarmedDamage(strMod2) == 3
          // Minimum is 0, not boosted by any style
          and unarmedDamage(strModNeg) == intMax(0, 1 + strModNeg)
          // No style inflates the result beyond the base formula
          and unarmedDamage(strMod2) == normalDamage(1, strMod2)
      )
  }

  // Source: https://rpg.stackexchange.com/q/90860
  
  // Are effects that activate "on a 20" by definition "critical effects"?
  // Accepted: No. "Roll a 20" effects (e.g. Sword of Sharpness +14) check d20Roll == 20;
  // critical hit effects (extra dice) check isCritical. Improved Critical makes roll 18
  // a critical hit (isCritical: true) but does NOT trigger "roll a 20" effects.
  run qa_nat20_vs_critical_hit_distinction = {
    // resolveAttackRoll: only d20Roll == 20 sets isCritical = true (base rules)
    val nat20Result    = resolveAttackRoll(20, 3, 15, 0)
    val roll18Result   = resolveAttackRoll(18, 3, 15, 0) // 18+3=21 >= 15, hits but not crit
  
    // Simulate Improved Critical: roll 18 counts as critical hit (isCritical: true),
    // but d20Roll is still 18. Spec only models base rules; construct manually.
    val improvedCritResult = { hits: true, isCritical: true }
    val improvedCritRoll   = 18
  
    // "Sword of Sharpness" / "Vorpal" effects: check d20Roll == 20, NOT isCritical
    val swordBonus_nat20      = if (20 == 20) 14 else 0            // 14 — triggers
    val swordBonus_hit18      = if (18 == 20) 14 else 0            // 0  — does not trigger
    val swordBonus_imprCrit18 = if (improvedCritRoll == 20) 14 else 0  // 0 — still does NOT trigger
  
    // Critical hit effects (extra dice, Brutal Critical, etc.) check isCritical
    val normalDmg = normalDamage(8, 3)           // 11
    val critDmg   = criticalDamage(8, 8, 3)      // 19 — extra dice on crit
  
    val critEffects_nat20     = nat20Result.isCritical       // true
    val critEffects_hit18     = roll18Result.isCritical      // false
    val critEffects_imprCrit  = improvedCritResult.isCritical // true — Improved Crit applies
  
    assert(
      // Nat 20: both "roll a 20" and critical hit effects apply
      nat20Result.hits
      and nat20Result.isCritical
      and swordBonus_nat20 == 14
      and critEffects_nat20
      // Plain roll-18 hit: neither effect applies
      and roll18Result.hits
      and not(roll18Result.isCritical)
      and swordBonus_hit18 == 0
      and not(critEffects_hit18)
      // Improved Critical on roll 18: critical effects apply, "roll a 20" effects do NOT
      and critEffects_imprCrit
      and swordBonus_imprCrit18 == 0
      // Critical damage (isCritical path) exceeds normal damage
      and critDmg > normalDmg
    )
  }

  // Source: https://rpg.stackexchange.com/q/81083
  
  // Is there a consistent method to introducing nonmagical items with mechanical implications?
  run qa_sneaking_cloak_adv_plus_disadv_cancel = {
    // Cloak grants advantage on Stealth; poisoned condition grants disadvantage → both cancel to straight roll
    val result = resolveAdvantage({ hasAdvantage: true, hasDisadvantage: true })
    assert(result.hasAdvantage == false and result.hasDisadvantage == false)
  }
  
  // Is there a consistent method to introducing nonmagical items with mechanical implications?
  run qa_sneaking_cloak_passive_check_advantage_is_plus5 = {
    // PHB p.175: advantage on a passive check = +5, not a flat item bonus
    // Dex mod +1, proficient in Stealth, profBonus 3 (level 5)
    val withAdv    = passiveCheck(1, Proficient, 3, true,  false)
    val withoutAdv = passiveCheck(1, Proficient, 3, false, false)
    assert(withAdv == withoutAdv + 5)
  }
  
  // Is there a consistent method to introducing nonmagical items with mechanical implications?
  run qa_sneaking_cloak_advantage_does_not_stack = {
    // Multiple circumstantial sources (cloak + darkness) both give advantage; result is still one advantage, not additive
    val oneSource  = resolveAdvantage({ hasAdvantage: true, hasDisadvantage: false })
    assert(oneSource.hasAdvantage == true and oneSource.hasDisadvantage == false)
  }
  
  // Is there a consistent method to introducing nonmagical items with mechanical implications?
  run qa_sneaking_cloak_advantage_can_flip_outcome = {
    // Dex mod +1, no prof, DC 14:
    // without advantage, lower die (7): 7+1=8 < 14 → fails
    // with advantage, higher die (14) passed by caller: 14+1=15 >= 14 → succeeds
    val failsNoAdv     = checkSucceeds(7,  1, NoneProf, 3, 0, 14)
    val succeedsWithAdv = checkSucceeds(14, 1, NoneProf, 3, 0, 14)
    assert(not(failsNoAdv) and succeedsWithAdv)
  }

  // Source: https://rpg.stackexchange.com/q/59865
  
  // Are there specific skills required to tame mounts? - Animal Handling maps to Wisdom
  run qa_animal_handling_uses_wisdom = {
    assert(skillAbility(AnimalHandling) == Wis)
  }
  
  // Are there specific skills required to tame mounts? - proficiency in Animal Handling beats taming DC
  run qa_animal_handling_proficiency_beats_dc = {
    // Wis 14 → mod +2; level 5 → prof +3; roll 11 → 11+2+3=16 >= DC 15
    val wisMod = abilityModifier(14)
    val prof = proficiencyBonus(5)
    assert(checkSucceeds(11, wisMod, Proficient, prof, 0, 15))
  }
  
  // Are there specific skills required to tame mounts? - without proficiency, same DC is harder
  run qa_animal_handling_no_proficiency_fails_dc = {
    // Wis 14 → mod +2; no prof; roll 11 → 11+2=13 < DC 15
    val wisMod = abilityModifier(14)
    val prof = proficiencyBonus(5)
    assert(not(checkSucceeds(11, wisMod, NoneProf, prof, 0, 15)))
  }
  
  // Are there specific skills required to tame mounts? - Animal Friendship: beast with low Wis fails save
  run qa_animal_friendship_beast_fails_wis_save = {
    // Level 3 caster, Wis 16 (mod +3), prof +2 → spell DC = 8+3+2 = 13
    val casterWisMod = abilityModifier(16)
    val casterProf   = proficiencyBonus(3)
    val spellDc      = 8 + casterWisMod + casterProf
    // Beast: Wis 8 (mod -1), not proficient; roll 10 → 10+(-1)=9 < 13 → fails
    val beastWisMod  = abilityModifier(8)
    assert(not(saveSucceeds(10, beastWisMod, false, 2, 0, spellDc)))
  }
  
  // Are there specific skills required to tame mounts? - Animal Friendship: beast with high Wis can resist
  run qa_animal_friendship_beast_high_wis_succeeds_save = {
    // Same caster DC = 13; beast Wis 18 (mod +4), not proficient; roll 10 → 10+4=14 >= 13 → succeeds
    val casterWisMod = abilityModifier(16)
    val casterProf   = proficiencyBonus(3)
    val spellDc      = 8 + casterWisMod + casterProf
    val beastWisMod  = abilityModifier(18)
    assert(saveSucceeds(10, beastWisMod, false, 2, 0, spellDc))
  }
  
  // Are there specific skills required to tame mounts? - passive Animal Handling with proficiency
  run qa_passive_animal_handling_proficient = {
    // Wis 13 (mod +1), level 5 prof +3, proficient, no adv/disadv → passive = 10+1+3 = 14
    val wisMod = abilityModifier(13)
    val prof   = proficiencyBonus(5)
    val passive = passiveCheck(wisMod, Proficient, prof, false, false)
    assert(passive == 14)
  }

  // Source: https://rpg.stackexchange.com/q/132812
  
  // Does Crossbow Expert override the light weapon requirement for Two Weapon Fighting?
  run qa_twf_longsword_handcrossbow_fails_light_check = {
    // Standard TWF rules: both weapons must be light melee. Longsword lacks Light_;
    // hand crossbow lacks both Light_ and isMelee — so pCanTWFWithWeapons rejects this combo.
    // Crossbow Expert bypasses this entirely (not modelled in spec).
    val longsword = {
      name: "longsword", damageDie: 8, versatileDie: 10, damageType: Slashing,
      properties: Set(Versatile), isMelee: true, normalRange: 0, longRange: 0
    }
    val handCrossbow = {
      name: "hand crossbow", damageDie: 6, versatileDie: 0, damageType: Piercing,
      properties: Set(Ammunition, Loading), isMelee: false, normalRange: 30, longRange: 120
    }
    val t = FRESH_TURN.with("attackActionUsed", true)
    val creature = freshCreature(10)
    assert(not(pCanTWFWithWeapons(longsword, handCrossbow, t, creature)))
  }
  
  // Does Crossbow Expert override the light weapon requirement for Two Weapon Fighting?
  run qa_twf_two_light_melee_succeeds = {
    // Control: two daggers (both Light_ and isMelee) pass the TWF check — confirming
    // the light+melee requirement is what blocks the longsword/crossbow combo above.
    val dagger = {
      name: "dagger", damageDie: 4, versatileDie: 0, damageType: Piercing,
      properties: Set(Finesse, Light_, Thrown), isMelee: true, normalRange: 20, longRange: 60
    }
    val t = FRESH_TURN.with("attackActionUsed", true)
    val creature = freshCreature(10)
    assert(pCanTWFWithWeapons(dagger, dagger, t, creature))
  }
  
  // Does Crossbow Expert override the light weapon requirement for Two Weapon Fighting?
  run qa_twf_offhand_no_positive_ability_mod_d0fc82c9 = {
    // TWF off-hand: positive ability modifier is NOT added (pTWFOffHandDamage).
    // Crossbow Expert is not TWF, so it adds full DEX — but that mechanic is outside the spec.
    // 4 dice result + 3 DEX mod = still 4 under TWF rules.
    assert(pTWFOffHandDamage(4, 3) == 4)
  }
  
  // Does Crossbow Expert override the light weapon requirement for Two Weapon Fighting?
  run qa_twf_offhand_negative_ability_mod_applies = {
    // TWF off-hand: negative ability modifier IS applied (penalty can't be avoided).
    // 4 dice result + (-1) mod = 3.
    assert(pTWFOffHandDamage(4, -1) == 3)
  }

  // Source: https://rpg.stackexchange.com/q/110209
  
  // Does the fire damage of a bow still work with lightning arrow?
  // Rule: Lightning Arrow replaces the weapon's normal damage including magical bonus damage
  // (e.g., Opal of the Ild Rune 1d6 fire) — fire rune is part of the bow's normal damage profile.
  run qa_lightning_arrow_replaces_bow_fire_rune_damage = {
    val creature = freshCreature(40)
  
    // Normal bow attack: 1d8 piercing (roll=6) + DEX mod 2 = 8, plus 1d6 fire from rune (roll=3) = 3
    val normalBowDmg = normalDamage(6, 2)   // 8 piercing
    val fireRuneDmg  = normalDamage(3, 0)   // 3 fire (Opal of the Ild Rune bonus)
  
    val afterPiercing  = pTakeDamage(creature, normalBowDmg, Piercing, Set(), Set(), Set(), false)
    val afterNormalBow = pTakeDamage(afterPiercing, fireRuneDmg, Fire, Set(), Set(), Set(), false)
  
    // Lightning Arrow replaces ALL weapon damage: only the spell's lightning damage applies.
    // Fire rune bonus is part of the bow's normal damage and is therefore replaced — not added on top.
    val lightningDmg = normalDamage(14, 0)  // 4d8 lightning on hit (roll=14)
    val afterLightningArrow = pTakeDamage(creature, lightningDmg, Lightning, Set(), Set(), Set(), false)
  
    assert(
      afterNormalBow.hp == 29                              // 40 - 8 - 3: both piercing and fire apply normally
      and afterLightningArrow.hp == 26                     // 40 - 14: only lightning, fire rune excluded
      and afterLightningArrow.hp != (40 - 14 - fireRuneDmg) // fire NOT wrongly stacked onto lightning (would be 23)
    )
  }

  // Source: https://rpg.stackexchange.com/q/169384
  
  // "When would someone in a Sculpt Spell's 'pocket of safety' take damage?"
  // Accepted answer: Sculpt Spell has two distinct protections: (1) auto-succeed the saving throw
  // (avoiding non-damage effects like being pushed/prone), AND (2) negate half-damage on that success.
  // If it only said "no damage", the pocket creature would still need to roll against the push.
  run qa_sculpt_spell_auto_success_avoids_non_damage_effects = {
    // Thunderwave-like spell:
    //   Failed save  → 16 thunder damage + prone (pushed)
    //   Natural success → 8 thunder damage (half), not prone
    //   Sculpt pocket  → 0 damage, not prone (auto-success + half-damage negation)
  
    val creature = freshCreature(20)
    val fullDamage = 16   // 2d8 = 16
    val halfDamage = 8    // half of 16, what a normal successful save gives
  
    // Without Sculpt: nat-1 vs DC 13 fails the save
    val withoutSculpt_saveFails = not(saveSucceeds(1, 0, false, 2, 0, 13))
  
    // Failed save: full damage + prone (thunderwave pushes to the ground)
    val afterFailedSave =
      pTakeDamage(
        pApplyCondition(creature, CProne),
        fullDamage, Thunder, Set(), Set(), Set(), false
      )
  
    // Natural success (roll 20): passes save, no prone, but STILL takes half damage
    val withoutSculpt_saveSucceeds = saveSucceeds(20, 0, false, 2, 0, 13)
    val afterNaturalSuccess =
      pTakeDamage(creature, halfDamage, Thunder, Set(), Set(), Set(), false)
  
    // Sculpt Spell pocket: auto-succeed = no save roll needed → no prone, AND 0 damage
    val afterSculptPocket = creature  // untouched: no condition, no damage
  
    assert(
      // Nat-1 fails DC 13
      withoutSculpt_saveFails
      // Failed save → prone + full damage (20 − 16 = 4 HP)
      and afterFailedSave.prone
      and afterFailedSave.hp == 4
      // Nat-20 passes save → not prone, but still half damage (20 − 8 = 12 HP)
      and withoutSculpt_saveSucceeds
      and not(afterNaturalSuccess.prone)
      and afterNaturalSuccess.hp == 12
      // Sculpt pocket: auto-success avoids prone, AND negates the residual half-damage
      and not(afterSculptPocket.prone)
      and afterSculptPocket.hp == 20
      // Key: natural success still deals 8 damage; sculpt gives strictly better (0 damage)
      and afterNaturalSuccess.hp < afterSculptPocket.hp
    )
  }

  // Source: https://rpg.stackexchange.com/q/181230
  
  // Does wearing magic items with armor affect AC negatively?
  // Accepted answer: No — rules have no armor-component granularity; plate is plate.
  run qa_magic_item_gauntlets_do_not_reduce_plate_ac = {
    // "Swapping gauntlets for Gauntlets of Ogre Power" is not represented in the spec
    // at all — armor is a single unit. Both before and after the swap the character is
    // WearingArmor(PLATE). Calculate AC both ways and assert they are identical and == 18.
    val dexMod = 4  // high DEX: irrelevant for heavy armor, but shows it doesn't sneak in
    val acNormal     = calculateAC(WearingArmor(PLATE), dexMod, false, NoUnarmoredDefense, 0, 0)
    val acMagicGaunt = calculateAC(WearingArmor(PLATE), dexMod, false, NoUnarmoredDefense, 0, 0)
    assert(acNormal == 18 and acMagicGaunt == 18 and acNormal == acMagicGaunt)
  }

